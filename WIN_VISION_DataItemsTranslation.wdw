     code : |1+
      // Summary: Opens the Vision window of DataItemsTranslation
      // Syntax:
      //WIN_Vision_DataItemsTranslation ()
      //
      // Parameters:
      //	None
      // Return value:
      // 	None
      //
      // Example:
      // Open(WIN_Vision_DataItemsTranslation)
      //
      // Automatic process of errors: display the error, then exit or restart the application
      //
      
      PROCEDURE WIN_VISION_DataItemsTranslation()
   -
     code : |1+
      // Position on the current record
      TableDisplay(TABLE_DataItemsTranslation,taCurrentFirst)
      
      // Default return value
      MyWindow..ReturnedValue = False
