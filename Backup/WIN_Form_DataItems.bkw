 menu :
  name : _Menu
  identifier : 0x292573e513b5f221
  internal_properties : BQAAAAUAAACu1EK9cHAkN5Twz1hVIc+FtYSepVp6OILXiORFbjytXgAsGUCSpN5mrorWH2CVHOYlY4+rF2Sy1IZzzzxvCJu7QBcSAqhQMDzKvfh1V8yfoi9Ves1JlhY+e0Nq/6GomTv4eTtMQ7vvkK0GoiSdR7jgQApfITz+5hiKin3aCatyfk/kFdeczXBQLezuL9mZURtGcsavGmlthynIFkFxO7gBxRRk4KRGASHZ9xjbrRmis6S414nZEmdjqrU5WTQjWQ==
  options : []
 languages :
  - en-GB
  - de-DE
 popup_menus : []
 message_bar :
  internal_properties : BQAAAAUAAABqPQh6HC8RxAVkp2SqPYLuZrfVhd+1KX4lx22hIT8uqEpE6yP7Sbc2rmVqdmL816EWzXOkEe9ijOtYwchZKAfpy3B1cNqhpJgsnbUs
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      // Open the Form window
      // In:CallMode=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      //				- "LinkedBrowse"	Browse the file in relation with the parent window
      //							(with deletion and creation)
      
      PROCEDURE RADForm(OpeningMode="Browse")
      
      GLOBAL
      	gnRecNum is int = 0					// current file record
      	gsWindowMode is string					// Window Mode
      	gsModifiedWindow is boolean = False		// Was a record modified? 
      	gsCallMode is string = OpeningMode	//  Call mode of the window
      
      // Management of database access errors
      // Error messages returned by the database are displayed
      // Database error reviews can be processed here
      WHEN EXCEPTION
      	Error(<§$0007§>,ExceptionInfo(errMessage))
      	// Re-enable the exceptions
      	ExceptionEnable()
      	// Resume the process
      	ReturnToCapture()
      END
   -
     code : |1+
      	
      
      // If the form is opened in 'Browse' mode
      // but the file is empty
      // automatically switch to 'Creation' mode
      IF (OpeningMode="Browse" OR OpeningMode~="LinkedBrowse") AND HNbRec(DataItems)=0 THEN
      	// opens a dialog box to inform the user
      	Info("No record found in file.","The form will switch to 'Creation' mode.")
      	// change the opening mode
      	OpeningMode="Creation"
      END
      
      // enable the controls according to the window mode
      ModifyWindowMode(OpeningMode)
     type : 34
   -
     code : |1-
      
      // check the form modifications
      CheckModification()
      Close("",gsModifiedWindow)
      	
     type : 2
   -
     type : 230
     enabled : false
   -
     code : |1+
      
      
     type : 11
   -
     code : |1+
      
      
     type : 12
   -
     code : |1-
      // If a control was modified, activate the group for modification validation
      IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Active
      	
      	
     type : 17
   -
     code : |1+
      
      
     type : 13
  procedures :
   -
     name : RADFindControl
     procedure_id : 1153301772485786429
     type_code : 14
     code : |1+
      PROCEDURE RADFindControl(sItemName)
      
      WHEN EXCEPTION
      	RESULT ""
      END
      
      // Name of the control corresponding to the specified item
      sControlName is string
      nSubscript is int
      
      
      // Browse the window controls
      nSubscript = 1
      sControlName = EnumControl(WinInput(),nSubscript)
      WHILE NOT sControlName~="" 
      	// Is this control linked to the item specified in parameter
      	IF {sControlName,indControl}..FileLink<>"" THEN
      		IF {{sControlName,indControl}..FileLink}..InitialItem~=sItemName THEN
      			// Return the name of the control linked to the specified item		
      			RESULT sControlName
      		END
      	END
      	
      	// Continue to browse the window controls
      	nSubscript++
      	sControlName = EnumControl(WinInput(),nSubscript)
      END
      
      
      // Return an empty string if no control is linked to this item
      RESULT ""
     type : 458752
   -
     name : RADDisplay
     procedure_id : 1153301772485851965
     type_code : 14
     code : |1-
      
      PROCEDURE RADDisplay()
      
      local
      	n is int
      	sLanguage is string
      	bGenerateThisTemplatePage is boolean
      	
      // Called when displaying the form or when going to to the next form
      FileToScreen()
      
      IF WinStatus(WIN_Main)<>NotFound THEN
      	gnProjectID=WIN_Main.COMBO_Project
      ELSE
      	gnProjectID=1
      END
      
      hreadseek(Project,ProjectID,gnProjectID,hIdentical)
      if not hfound(Project) then
      	info(<§$0000§>)
      	close()
      END
      
      HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,gnProjectID,Project.LastVersionNo),hIdentical)
      IF NOT HFound(Version) THEN
      	info("Version "+Project.LastVersionNo+<§$0001§>)
      	close()
      else
      	IF gsWindowMode<>"Creation" THEN
      		hreadseek(DataFile,DataFileID,DataItems.DataFileID,hIdentical)
      		if hfound(DataFile) then
      			if DataFile.VersionID<>version.VersionID then
      				hreadseek(Version,VersionID,DataFile.VersionID,hIdentical)
      				if not hfound(Version) then
      					info(<§$0012§>+DataFile.VersionID+<§$0002§>)
      					close()
      				END
      			END
      		else
      			info(<§$0004§>+DataItems.DataFileID+<§$0003§>)
      			close()
      		end
      	end
      end
      
      HReadFirst(Language,LanguageID)
      WHILE NOT HOut(Language)
      	if Language.LanguageGenerate then
      		sLanguage=sLanguage+Language.Description+CRLF
      	end
      	HReadNext(Language,LanguageID)
      END
      sLanguage=Left(sLanguage,Length(sLanguage)-2)
      
      TableDeleteAll(TABLE_TemplatePages)
      
      IF gsWindowMode<>"Creation" THEN
      	
      	TABLE_TemplatePages..State=Active
      	
      	HFilter(ProjectTemplates,ProjectID,gnProjectID,gnProjectID)
      	HReadFirst(ProjectTemplates,ProjectID)
      	WHILE NOT HOut(ProjectTemplates)
      		HFilter(TemplatePage,TemplatePageKeyID,HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMaxVal))
      		HReadFirst(TemplatePage,TemplatePageKeyID)
      		WHILE NOT HOut(TemplatePage)
      			if TemplatePage.GenerationType>2 then
      				
      				HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TemplatePage.TemplateID),hIdentical)
      				IF HFound(DataFileTypeDetails) THEN
      					bGenerateThisTemplatePage=DataFileTypeDetails.FileGenerate
      				ELSE
      					DataFileTypeDetails.DataFileID=DataFile.DataFileID
      					DataFileTypeDetails.TemplatePageID=TemplatePage.TemplatePageID
      					DataFileTypeDetails.FileGenerate=True
      					HAdd(DataFileTypeDetails)
      					bGenerateThisTemplatePage=True
      				END
      				
      				if bGenerateThisTemplatePage then
      					n=TableAddLine(TABLE_TemplatePages)
      					TABLE_TemplatePages[n].COL_TemplatePageID=TemplatePage.TemplatePageID
      					TABLE_TemplatePages[n].COL_TemplatePageID..BrushColor=RGB(68, 94, 181)
      					TABLE_TemplatePages[n].COL_TemplatePageID..Color=White
      					TABLE_TemplatePages[n].COL_TemplatePageID..State=DisplayOnly
      			
      					//DataItemsID+TemplatePageID
      					HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,TemplatePage.TemplatePageID),hIdentical)
      					IF HFound(DataItemsTypeDetails) THEN
      						TABLE_TemplatePages[n].COL_State..Content="Active"+CRLF+"Inactive"+CRLF+"Invisible"
      						TABLE_TemplatePages[n].COL_nSortIndex=DataItemsTypeDetails.SortIndex
      						TABLE_TemplatePages[n].COL_X=DataItemsTypeDetails.X
      						TABLE_TemplatePages[n].COL_Y=DataItemsTypeDetails.Y
      						TABLE_TemplatePages[n].COL_State=DataItemsTypeDetails.ItemState
      						TABLE_TemplatePages[n].COL_Visible=DataItemsTypeDetails.ItemVisible
      						TABLE_TemplatePages[n].COL_Generate=DataItemsTypeDetails.ItemGenerate
      					ELSE
      						TABLE_TemplatePages[n].COL_State..Content="Active"+CRLF+"Inactive"+CRLF+"Invisible"
      					END
      					TABLE_TemplatePages[n].COL_LanguageID..Content=sLanguage
      					TABLE_TemplatePages[n].COL_LanguageID=1
      					
      					HReadFirst(Language,LanguageID)
      					WHILE NOT Language.LanguageGenerate
      						HReadNext(Language,LanguageID)
      					END
      					
      					TABLE_TemplatePages[n].COL_LanguageID=Language.LanguageID
      					
      					//DataItemsID+TemplatePageID+LanguageID
      					HReadSeek(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,TemplatePage.TemplatePageID,Language.LanguageID),hIdentical)
      					IF not HFound(DataItemsTranslation) THEN
      						DataItemsTranslation.LanguageID=Language.LanguageID
      						DataItemsTranslation.VersionID=version.VersionID
      						DataItemsTranslation.DataItemsID=DataItems.DataItemsID
      						DataItemsTranslation.TemplatePageID=TemplatePage.TemplatePageID
      						DataItemsTranslation.Caption=DataItems.ItemName
      						hadd(DataItemsTranslation)
      					end
      					
      					TABLE_TemplatePages[n].COL_Caption=DataItemsTranslation.Caption
      					TABLE_TemplatePages[n].COL_Combobox_Content=DataItemsTranslation.ComboBoxContent
      					
      				END
      			end
      			HReadNext(TemplatePage,TemplatePageKeyID)
      		END
      		HReadNext(ProjectTemplates,ProjectID)
      	END
      	
      	HDeactivateFilter(Template)
      	HDeactivateFilter(TemplatePage)
      	HDeactivateFilter(Project)
      	HDeactivateFilter(ProjectTemplates)
      	HDeactivateFilter(DataFileTypeDetails)
      	
      else
      	TABLE_TemplatePages..State=Grayed
      end
     type : 458752
   -
     name : RADClear
     procedure_id : 1153301772485917501
     type_code : 14
     code : |1-
      PROCEDURE RADClear()
      // Called by the 'New' button or in form creation
      Reset
      
      	
      	
     type : 458752
   -
     name : RADSave
     procedure_id : 1153301772485983037
     type_code : 14
     code : |1-
      PROCEDURE RADSave()
      // Function called when clicking the 'OK' button
      // Returns 'True' if the record is validated, 'False' otherwise
      // Transfer controls to file buffer
      ScreenToFile()
      
      // The record is valid
      RESULT True
      	
      	
     type : 458752
   -
     name : CheckModification
     procedure_id : 1153301772486048620
     type_code : 14
     code : |1-
      // check the form modifications
      // If the form was modified, ask the user
      // for confirmation
      // Modifies the record if user confirmation
      PROCEDURE CheckModification()
      
      // if a control was modified in the form
      IF MyWindow..Modified THEN
      
      	IF YesNo(<§$0005§>) THEN
      		// Setup the record and save
      		IF RADSave() THEN
      
      			// Modify the record
      			HModify(DataItems)
      			IF ErrorOccurred THEN
      				Info(<§$0006§>+CR+HErrorInfo())
      				RETURN
      			END
      
      			// Indicate that a record was modified (data refresh required)
      			gsModifiedWindow = True
      
      			// indicates that the form is no longer modified
      			MyWindow..Modified=False
      
      
      			// Gray the controls for modification validation
      			IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Grayed
      		END
      	ELSE
      		// Modifications must not be taken into account
      		MyWindow..Modified = False
      
      		// Gray the controls for modification validation
      		IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Grayed
      		
      	END
      END
     type : 458752
   -
     name : ModifyWindowMode
     procedure_id : 1153301772486114187
     type_code : 14
     code : |1+
      // Modify the window mode
      // In:	ModeAppliedWindow=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      PROCEDURE ModifyWindowMode(sModeAppliedWindow)
      
      // local variables
      sRelationKey is string
      sNameLinkedKey is string
      sValRelationKey is string
      
      // Saves the window mode
      gsWindowMode=sModeAppliedWindow
      
      // Link buttons (if any) are accessible by default
      IF ControlExist("GP_LINK") THEN {"GP_LINK",indControl}..State=Active
      
      // Buttons for modification validation (if any) are invisible and grayed by default
      IF ControlExist("GP_APPLY") THEN 
      	GP_APPLY..Visible = False		
      	GP_APPLY..State = Grayed
      END
      
      // switch to 'Browse' mode
      IF sModeAppliedWindow="Browse" OR sModeAppliedWindow~="LinkedBrowse" THEN
      	// buttons of 'browse' mode are visible
      	GP_BROWSE..Visible=True
      	// Invisible mode modification buttons
      	GP_MODIF..Visible=False
      		// buttons for modification validation are visible
      	IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=True		
      
      		// In 'LinkedBrowse' mode, the current record is retained
      		IF gsWindowMode~="LinkedBrowse" THEN
      		gnRecNum = HRecNum(DataItems)
      	END
      
      	// point to the current record
      	IF gnRecNum<>0 THEN
      		HRead(DataItems,gnRecNum)
      		gnRecNum = 0
      	// or go to first record
      	ELSE
      		HReadFirst(DataItems,DataItemsID)
      	END
      
      	// transfer the file buffer to window controls
      	RADDisplay()
      
      // otherwise, switch to 'Creation' or 'Modif' mode
      ELSE
      	// Buttons of 'Browse' mode are invisible
      	GP_BROWSE..Visible=False
      	// buttons of 'modif' mode are visible
      	GP_MODIF..Visible=True
      	
      	// Management of parameter passing for relation links
      	sRelationKey = ExtractString(gsWindowMode,2,"=")
      	sNameLinkedKey = ExtractString(gsWindowMode,2,".")
      	IF NOT sNameLinkedKey~="" AND NOT sNameLinkedKey~=EOT THEN
      		// Store the value of the relation parameter
      		WHEN EXCEPTION IN
      			sValRelationKey = {sRelationKey}
      		DO
      			sValRelationKey = ""
      		END
      	END
      
      	// If switch to 'Creation' mode
      	IF Left(sModeAppliedWindow,8)~="Creation" THEN
      		IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=False	// buttons for modification validation are invisible
      			// clear the controls
      			HReset(DataItems)
      			RADClear()
      			// In 'Creation' mode, link buttons (if any) are inaccessible
      			IF ControlExist("GP_LINK") THEN GP_LINK..State=Grayed
      		ELSE
      			// buttons for modification validation are visible
      			IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=True	
      			// stores the current record number
      				gnRecNum = HRecNum(DataItems)
      		
      		END
      	// transfer the file buffer to window controls
      	RADDisplay()
      
      	// Check whether this is a link for forms on relation file 
      	// (parameter such as Creation=XXX or Modif=XXX)		
      	IF NOT sNameLinkedKey~~"" THEN
      		sControlName is string = RADFindControl(sNameLinkedKey)
      		IF NOT sControlName~="" THEN
      			{sControlName,indControl}..State = Grayed
      			// In 'Creation' mode, use the current value of the linked file
      			IF Left(sModeAppliedWindow,8)~="Creation" THEN {sControlName,indControl} = sValRelationKey
      	
      			// Is a Vision control associated with this control
      			IF ControlExist("Vision_"+sControlName) THEN
      				{"Vision_"+sControlName,indControl}..State = Grayed
      			END			
      		END	
      	END
      
      END
