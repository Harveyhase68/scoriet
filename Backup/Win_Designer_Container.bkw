  procedures :
   -
     name : MOUSE_DOWN
     procedure_id : 1958459796546857382
     type_code : 14
     code : |1-
      // Syntax:
      //MOUSE_DOWN ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      
      PROCEDURE MOUSE_DOWN()
      
      LOCAL
      	CtlName is string=_EVE.name
      	pnt is POINTAPI
      	nX is real
      	nY is real
      	nW is real
      	nH is real
      
      CallDLL32("user32","GetCursorPos",&pnt) //Holen der X/Y Maus-Zeiger Werte
      CallDLL32("user32", "ScreenToClient" , Handle(CtlName), &pnt) //Jetzt haben wir auch den richtigen Offset ohne Rechnen!
      
      OffsetX=pnt:x+1 //+GetScrollValueH(WIN_Designer_Container)
      OffsetY=pnt:y+1 //+GetScrollValueV(Win_Designer_Container)
      
      SWITCH CtlName
      	CASE "Resize1"
      		IF ResizePossible THEN
       			ResizeAcive=True
       			ResizeRichtung=1
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	CASE "Resize2"
      		IF ResizePossible THEN
       			ResizeAcive=True
       			ResizeRichtung=2
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	CASE "Resize3"
      		IF ResizePossible THEN
       			ResizeAcive=True
       			ResizeRichtung=3
      		END
      	CASE "Resize4"
      		IF ResizePossible THEN
       			ResizeAcive=True
       			ResizeRichtung=4
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	CASE "Resize5"
      		IF ResizePossible THEN
      			ResizeAcive=True
      			ResizeRichtung=5
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	CASE "Resize6"
      		IF ResizePossible THEN
      			ResizeAcive=True
      			ResizeRichtung=6
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	CASE "Resize7"
      		IF ResizePossible THEN
      			ResizeAcive=True
      			ResizeRichtung=7
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	CASE "Resize8"
      		IF ResizePossible THEN
      			ResizeAcive=True
      			ResizeRichtung=8
      
      		END
      		gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      	OTHER CASE
      		IF Upper(Left(CtlName,6))="OBJEKT" THEN
      
      				
      			gsTargetControl=CtlName
      			
      			CalcObject(gsTargetControl,nX,nY,nW,nH)
      			
      			Message("("+nX+","+nY+") B:"+nW+" H:"+nH)
      			
      			{gsTargetControl,indControl}..MouseCursor=curHand //Hand anzeigen
      			{gsTargetControl,indControl}..ZOrder=9999 //Z-Order bestimmen
      			
      			MoveActive=True
      
      			ResizeHandleEinstellen()
      			AnzeigenControl(gsTargetControl)
      			gnMouseMove=Event("MOUSE_MOVE", ".*", WM_MOUSEMOVE)
      			
      		ELSE
      			SWITCH CtlName
      				CASE "RIBBON_Designer","BTN_Bold","BTN_Italic","BTN_Underline","BTN_Strikethrough","Combo_TextColor","BTN_TextColorSelect","Combo_BackgroundColor","BTN_BackgroundColorSelect","COMBO_Schriftarten","EDT_FONTSIZE","SPIN_FONTSIZE","BTN_LEFT","BTN_CENTER","BTN_RIGHT","BTN_TOP","BTN_CENTERV","BTN_BOTTOM","COMBO_ANGEL","SPIN_ANGEL","BTN_Delete","CBOX_Ruler","CBOX_Grid","RIBGRP_Font","RIBGRP_Orientation","RIBGRP_Display","RIBGRP_Actions","RIBGRP_FixedValues","RIBGRP_DatabaseFields","RIBGRP_PageLayout","BTN_Change","BTN_Werte","BTN_BACK","BTN_FORWARD","BTN_INSERT","BTN_COPY","BTN_MARKALL","BTN_MARKNONE","BTN_COPY1","BTN_INSERT1","BTN_DELETE1","BTN_Change1"
      					return
      				OTHER CASE
      					WIN_Designer.COMBO_Schriftarten=""
      					WIN_Designer.EDT_FontSize=""
      					WIN_Designer.BTN_Bold..Pushed=false
      					WIN_Designer.BTN_Italic..Pushed=false
      					WIN_Designer.BTN_Underline..Pushed=false
      					WIN_Designer.Combo_TextColor=""
      					WIN_Designer.Combo_BackgroundColor=""
      					gsTargetControl=""
      					MoveActive=False
      					ResizeRichtung=False
      					if gnMouseMove<>0 then
      						EndEvent(gnMouseMove)
      					end
      					WHEN EXCEPTION IN
      						Resize1..Visible=False
      						Resize2..Visible=False
      						Resize3..Visible=False
      						Resize4..Visible=False
      						Resize5..Visible=False
      						Resize6..Visible=False
      						Resize7..Visible=False
      						Resize8..Visible=False
      					DO
      					END
      					Message("")
      			END
      		end
      END
     type : 458752
   -
     name : MOUSE_MOVE
     procedure_id : 1958459800841890355
     type_code : 14
     code : |1+
      // Syntax:
      //MOUSE_MOVE ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      
      Procedure MOUSE_MOVE()
      
      LOCAL
      	pnt is POINTAPI
      	i is int
      	sCtlName is string=_EVE.name
      	nMess is int=_EVE.wMessage
      	nX is real on 8 bytes
      	nY is real on 8 bytes
      	nW is real on 8 bytes
      	nH is real on 8 bytes
      	x is int on 8 bytes
      	y is int on 8 bytes
      	nOffx is int
      	nOffy is int
      	
      CallDLL32("user32","GetCursorPos",&pnt) //Holen der X/Y Maus-Zeiger Werte
      //Trace(pnt.x+" - "+pnt.y)
      CallDLL32("user32", "ScreenToClient" , Handle(Mywindow), &pnt) //Jetzt haben wir auch den richtigen Offset!
      
      nOffx=GetScrollValueH("WIN_Designer.IW_InternalWindow1")
      nOffy=GetScrollValueV("WIN_Designer.IW_InternalWindow1")
      
      if gsTargetControl="" then
      	MoveActive=false
      	ResizeAcive=false
      	resize1..Visible=False
      	resize2..Visible=False
      	resize3..Visible=False
      	resize4..Visible=False
      	resize5..Visible=False
      	resize6..Visible=False
      	resize7..Visible=False
      	resize8..Visible=False
      	return
      END
      
      if MoveActive then
      	
      	x=pnt:x-OffsetX-Win_Designer_Container..X+nOffx
      	y=pnt:y-OffsetY-Win_Designer_Container..Y+nOffy
      		
      	resize1..Visible=false
      	resize2..Visible=False
      	resize3..Visible=False
      	resize4..Visible=False
      	resize5..Visible=False
      	resize6..Visible=False
      	resize7..Visible=False
      	resize8..Visible=False
      	{gsTargetControl,indControl}..X=pnt:x-OffsetX
      	{gsTargetControl,indControl}..Y=pnt:y-OffsetY
      	
      	CalcObject(gsTargetControl,nX,nY,nW,nH)
      	
      	Message("("+nX+","+nY+") B:"+nW+" H:"+nH)
      	
      	AnzeigenControl(gsTargetControl,2)
      	MultitaskRedraw()
      
      	return
      END
      
      if ResizeAcive and ResizePossible then
      	
      	FOR i=1 TO 8
      		if i<>ResizeRichtung then
      			{"Resize"+NumToString(i,"d"),indControl}..Visible=false	
      		END
      	END
      	
      	x=pnt:x-OffsetX-Win_Designer_Container..X+nOffx
      	y=pnt:y-OffsetY-Win_Designer_Container..Y+nOffy
      	
      	SWITCH ResizeRichtung
      		case 1
      			//Links oben
      			{gsTargetControl,indControl}..Width={gsTargetControl,indControl}..Width+({gsTargetControl,indControl}..X-(pnt:x-OffsetX))
      			{gsTargetControl,indControl}..X=(pnt:x-OffsetX)
      			{gsTargetControl,indControl}..Height={gsTargetControl,indControl}..Height+({gsTargetControl,indControl}..Y-(pnt:y-OffsetY))
      			{gsTargetControl,indControl}..Y=(pnt:y-OffsetY)
      			Resize1..X={gsTargetControl,indControl}..X-4
      			Resize1..Y={gsTargetControl,indControl}..Y-4
      		CASE 2
      			//Oben
      			IF pnt:Y-OffsetY-4<({gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height)-5 THEN
      				{gsTargetControl,indControl}..Height={gsTargetControl,indControl}..Height+({gsTargetControl,indControl}..Y-(pnt:y-OffsetY))
      				{gsTargetControl,indControl}..Y=(pnt:y-OffsetY)
      				Resize2..X={gsTargetControl,indControl}..X+IntegerPart({gsTargetControl,indControl}..Width/2)-3
      				Resize2..Y={gsTargetControl,indControl}..Y-4
      			end
      		CASE 3
      			//Rechts oben
      			{gsTargetControl,indControl}..Width=(pnt:x-OffsetX)-{gsTargetControl,indControl}..X
      			{gsTargetControl,indControl}..Height={gsTargetControl,indControl}..Height+({gsTargetControl,indControl}..Y-(pnt:y-OffsetY))
      			{gsTargetControl,indControl}..Y=(pnt:y-OffsetY)
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..Y={gsTargetControl,indControl}..Y-4
      		CASE 4
      			//rechts
      			{gsTargetControl,indControl}..Width=(pnt:x-OffsetX)-{gsTargetControl,indControl}..X
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..Y={gsTargetControl,indControl}..Y+IntegerPart({gsTargetControl,indControl}..Height/2)-3
      		CASE 5
      			//rechts unten
      			{gsTargetControl,indControl}..Width=(pnt:x-OffsetX)-{gsTargetControl,indControl}..X
      			{gsTargetControl,indControl}..Height=(pnt:y-Offsety)-{gsTargetControl,indControl}..Y
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..X=pnt:x-OffsetX
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..Y=pnt:y-OffsetY
      		CASE 6
      			//Unten
      			{gsTargetControl,indControl}..Height=(pnt:y-OffsetY)-{gsTargetControl,indControl}..Y
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..Y=pnt:y-OffsetY
      		CASE 7
      			//Nach links unten
      			{gsTargetControl,indControl}..Width={gsTargetControl,indControl}..Width+({gsTargetControl,indControl}..X-(pnt:x-OffsetX))
      			{gsTargetControl,indControl}..X=(pnt:x-OffsetX)
      			{gsTargetControl,indControl}..Height=(pnt:y-Offsety)-{gsTargetControl,indControl}..Y
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..X=pnt:x-OffsetX-4
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..Y=pnt:y-OffsetY
      		CASE 8
      			//Links
      			{gsTargetControl,indControl}..Width={gsTargetControl,indControl}..Width+({gsTargetControl,indControl}..X-(pnt:x-OffsetX))
      			{gsTargetControl,indControl}..X=(pnt:x-OffsetX)
      			{"Resize"+NumToString(ResizeRichtung,"d"),indControl}..X=pnt:x-OffsetX-4
      	END
      	
      	Resize1..X={gsTargetControl,indControl}..X-4
      	Resize1..Y={gsTargetControl,indControl}..Y-4
      	Resize2..X={gsTargetControl,indControl}..X+IntegerPart({gsTargetControl,indControl}..Width/2)-3
      	Resize2..Y={gsTargetControl,indControl}..Y-4
      	Resize3..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      	Resize3..Y={gsTargetControl,indControl}..Y-4
      	Resize4..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      	Resize4..Y={gsTargetControl,indControl}..Y+IntegerPart({gsTargetControl,indControl}..Height/2)-3
      	Resize5..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      	Resize5..Y={gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height-1
      	Resize6..X={gsTargetControl,indControl}..X+IntegerPart({gsTargetControl,indControl}..Width/2)-3
      	Resize6..Y={gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height-1
      	Resize7..X={gsTargetControl,indControl}..X-4
      	Resize7..Y={gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height-1
      	Resize8..X={gsTargetControl,indControl}..X-4
      	Resize8..Y={gsTargetControl,indControl}..Y+IntegerPart({gsTargetControl,indControl}..Height/2)-3
      	
      	AnzeigenControl(gsTargetControl,2)
      	
      	CalcObject(gsTargetControl,nX,nY,nW,nH)
      	
      	Message("("+nX+","+nY+") B:"+nW+" H:"+nH)
      
      END
     type : 458752
   -
     name : MOUSE_UP
     procedure_id : 1958459800841956000
     type_code : 14
     code : |1+
      // Syntax:
      //MOUSE_UP ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      
      PROCEDURE MOUSE_UP()
      
      LOCAL
      	pnt is POINTAPI
      	x is real on 8 bytes
      	y is real on 8 bytes
      	wd is real on 8 bytes
      	hg is real on 8 bytes
      	nOffx is int, useful
      	nOffy is int, useful
      		
      CallDLL32("user32","GetCursorPos",&pnt) //Holen der X/Y Maus-Zeiger Werte
      CallDLL32("user32", "ScreenToClient" , Handle(WIN_Designer_Container), &pnt) //Jetzt haben wir auch den richtigen Offset!
      
      if gnMouseMove<>0 then
      	EndEvent(gnMouseMove)
      END
      
      IF MoveActive THEN
      	{gsTargetControl,indControl}..MouseCursor=curArrow
      	MoveActive=False
      	HReadSeek(DataFile,DataFileID,Val({gsTargetControl,indControl}..Note),hIdentical)
      	IF HFound(DataFile) THEN
      		x=(((({gsTargetControl,indControl}..X)-IMG_Blatt..X)/gnZoom)*100)
      		y=(((({gsTargetControl,indControl}..Y)-IMG_Blatt..Y)/gnZoom)*100)
      		if DataFile.VD_X<>x or DataFile.VD_Y<>y then
      			gaaHistoryNachher["DataFileID"]=DataFile.DataFileID
      			gaaHistoryNachher["VD_X"]=x
      			gaaHistoryNachher["VD_Y"]=y
      			HistoryAdd(2)
      		end
      		WIN_Designer.CalcAnalyseWidthHeight()
      		WIN_Designer.ResizeBlatt()
      		AnzeigenControl(gsTargetControl,false)
      		ResizeHandleEinstellen()
      	END
      END
      
      IF ResizeAcive THEN
      	ResizeAcive=False
      	IF ResizePossible THEN
      		ResizeHandleEinstellen()
      	END
      	HReadSeek(DataFile,DataFileID,Val({gsTargetControl,indControl}..Note),hIdentical)
      	IF HFound(DataFile) THEN
      		wd=(({gsTargetControl,indControl}..Width/gnZoom)*100)
      		hg=(({gsTargetControl,indControl}..Height/gnZoom)*100)
      		x=((({gsTargetControl,indControl}..X-gnPageOffsetleft+GetScrollValueH(Win_Designer_Container))/gnZoom)*100)
      		y=((({gsTargetControl,indControl}..Y-gnPageOffsetTop+GetScrollValueV(Win_Designer_Container))/gnZoom)*100)
      		if DataFile.VD_W<>wd or DataFile.VD_H<>hg or DataFile.VD_X<>x or DataFile.VD_Y<>y then
      			gaaHistoryNachher["DataFileID"]=DataFile.DataFileID
      			gaaHistoryNachher["VD_X"]=x
      			gaaHistoryNachher["VD_Y"]=y
      			gaaHistoryNachher["VD_W"]=wd
      			gaaHistoryNachher["VD_H"]=hg
      			HistoryAdd(2)
      		end
      		AnzeigenControl(gsTargetControl,False)
      	END
      END
      
     type : 458752
   -
     name : ResizeHandleEinstellen
     procedure_id : 1958459800842021629
     type_code : 14
     code : |1-
      // Syntax:
      //ResizeHandleEinstellen ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      
      Procedure ResizeHandleEinstellen()
      
      local
      	i is int
      	
      if ResizePossible and gsTargetControl<>"" then
      	i=1
      
      	resize1..X={gsTargetControl,indControl}..X-4
      	resize1..Y={gsTargetControl,indControl}..Y-4
      	resize2..X={gsTargetControl,indControl}..X+IntegerPart({gsTargetControl,indControl}..Width/2)-3
      	resize2..Y={gsTargetControl,indControl}..Y-4
      	resize3..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      	resize3..Y={gsTargetControl,indControl}..Y-4
      	resize4..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      	resize4..Y={gsTargetControl,indControl}..Y+IntegerPart({gsTargetControl,indControl}..Height/2)-3
      	resize5..X={gsTargetControl,indControl}..X+{gsTargetControl,indControl}..Width-1
      	resize5..Y={gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height-1
      	resize6..X={gsTargetControl,indControl}..X+IntegerPart({gsTargetControl,indControl}..Width/2)-3
      	resize6..Y={gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height-1
      	resize7..X={gsTargetControl,indControl}..X-4
      	resize7..Y={gsTargetControl,indControl}..Y+{gsTargetControl,indControl}..Height-1
      	resize8..X={gsTargetControl,indControl}..X-4
      	resize8..Y={gsTargetControl,indControl}..Y+IntegerPart({gsTargetControl,indControl}..Height/2)-3
      	
      	Resize1..ZOrder=9999
      	Resize2..ZOrder=9999
      	Resize3..ZOrder=9999
      	Resize4..ZOrder=9999
      	Resize5..ZOrder=9999
      	Resize6..ZOrder=9999
      	Resize7..ZOrder=9999
      	Resize8..ZOrder=9999
      
      	resize1..Visible=True
      	resize2..Visible=True
      	resize3..Visible=True
      	resize4..Visible=True
      	resize5..Visible=True
      	resize6..Visible=True
      	resize7..Visible=True
      	resize8..Visible=True
      else
      	Resize1..Visible=false
      	Resize2..Visible=false
      	Resize3..Visible=false
      	Resize4..Visible=false
      	Resize5..Visible=false
      	Resize6..Visible=false
      	Resize7..Visible=false
      	Resize8..Visible=false	
      end
     type : 458752
   -
     name : AnzeigenControl
     procedure_id : 1958463412910555112
     type_code : 14
     code : |1+
      // Syntax:
      //AnzeigenControl (<CtlName> [, <bFinal>])
      //
      // Parameters:
      //	CtlName: <specify the role of CtlName>
      // 	bFinal (default value=0): 0,1,2 0=none, 1=final, 2=controlvalue
      // Return Value:
      // 	None
      
      PROCEDURE AnzeigenControl(CtlName, bFinal=0)
      
      LOCAL
      	s is string
      	x is int
      	y is int
      	wd is int
      	hg is int
      	nHdc is system int
      	bFound is boolean
      
      WIN_Designer.BTN_BACK..State=Grayed
      WIN_Designer.BTN_FORWARD..State=Grayed
      IF gnAktuelleHistoryNr>0 THEN
      	WIN_Designer.BTN_BACK..State=Active
      END
      IF Dimension(garrHistory)>gnAktuelleHistoryNr THEN
      	WIN_Designer.BTN_FORWARD..State=Active
      END
      
      if CtlName<>"" then
      	
      	HReadSeek(DataFile,DataFileID,Val({CtlName,indControl}..Note),hIdentical)
      	IF HFound(DataFile) THEN
      		s="OBJEKT"+DataFile.DataFileID
      	ELSE
      		s=CtlName
      	END
      	
      	WIN_Designer.BTN_BACK..State=Grayed
      	WIN_Designer.BTN_FORWARD..State=Grayed
      	
      	if Dimension(garrHistory)>0 then
      		WIN_Designer.BTN_BACK..State=Active
      	END
      	
      	if Dimension(garrHistory)>gnAktuelleHistoryNr then
      		WIN_Designer.BTN_FORWARD..State=Active
      	END
      	
      	WIN_Designer.BTN_Bold..Pushed=val(ExtractString(DataFile.VD_FontProperties,1,";"))
      	WIN_Designer.BTN_Italic..Pushed=Val(ExtractString(DataFile.VD_FontProperties,2,";"))
      	WIN_Designer.BTN_Underline..Pushed=Val(ExtractString(DataFile.VD_FontProperties,3,";"))
      	WIN_Designer.BTN_Strikethrough..Pushed=Val(ExtractString(DataFile.VD_FontProperties,4,";"))
      	
      	bFound=False
      	FOR i=1 to ListCount(WIN_Designer.Combo_TextColor)
      		IF WIN_Designer.Combo_TextColor.Column2[i]=DataFile.VD_FontColor THEN
      			ListSelectPlus(WIN_Designer.Combo_TextColor,i)
      			bFound=True
      			BREAK
      		END
      	END
      	
      	IF NOT bFound THEN
      		ListDeleteAll(WIN_Designer.Combo_TextColor)
      		FOR i=1 TO Dimension(iFarbe)
      			ListAdd(WIN_Designer.Combo_TextColor,gBackground(iFarbe[i])+Left(sFarbeName[i]+RepeatString(" ",96),96)+TAB+NumToString(iFarbe[i],"06X"))
      		END
      		ListAdd(WIN_Designer.Combo_TextColor,gBackground(Val(DataFile.VD_FontColor,"x"))+Left(<§$0001§>+RepeatString(" ",96),96)+TAB+DataFile.VD_FontColor)
      		ListSelectPlus(WIN_Designer.Combo_TextColor,ListCount(WIN_Designer.Combo_TextColor))
      	END
      	
      	bFound=False
      	IF DataFile.VD_BackgroundColor="-1" THEN
      		ListSelectPlus(WIN_Designer.Combo_BackgroundColor,1)
      		bFound=True
      	ELSE
      		FOR i=1 TO ListCount(WIN_Designer.Combo_BackgroundColor)
      			IF NumToString(WIN_Designer.Combo_BackgroundColor.Column2[i],"06X")=DataFile.VD_BackgroundColor THEN
      				ListSelectPlus(WIN_Designer.Combo_BackgroundColor,i)
      				bFound=True
      				BREAK
      			END
      		END
      	END
      	
      	IF NOT bFound THEN
      		ListDeleteAll(WIN_Designer.Combo_BackgroundColor)
      		ListAdd(WIN_Designer.Combo_BackgroundColor,Left("Transparent"+RepeatString(" ",96),96)+TAB+"-1")
      		FOR i=1 TO Dimension(iFarbe)
      			ListAdd(WIN_Designer.Combo_BackgroundColor,gBackground(iFarbe[i])+Left(sFarbeName[i]+RepeatString(" ",96),96)+TAB+NumToString(iFarbe[i],"06X"))
      		END
      		ListAdd(WIN_Designer.Combo_BackgroundColor,gBackground(Val(DataFile.VD_BackgroundColor,"x"))+Left(<§$0002§>+RepeatString(" ",96),96)+TAB+DataFile.VD_BackgroundColor)
      		ListSelectPlus(WIN_Designer.Combo_BackgroundColor,ListCount(WIN_Designer.Combo_BackgroundColor))
      	END
      	
      	WIN_Designer.COMBO_Schriftarten=DataFile.VD_Font
      	WIN_Designer.EDT_FONTSIZE=DataFile.VD_FontSize
      	
      END
      
      
      if bFinal=1 then
      	x=((DataFile.VD_X/100)*gnZoom)+gnPageOffsetleft-GetScrollValueH(Win_Designer.IW_InternalWindow1)
      	y=((DataFile.VD_Y/100)*gnZoom)+gnPageOffsetTop-GetScrollValueV(Win_Designer.IW_InternalWindow1)
      	
      	wd=(DataFile.VD_W/100)*gnZoom
      	hg=(DataFile.VD_H/100)*gnZoom
      	
      	{CtlName,indControl}..x=x
      	{CtlName,indControl}..Y=y
      	{CtlName,indControl}..Width=wd
      	{CtlName,indControl}..Height=hg
      end
      
      {"OBJEKT"+DataFile.DataFileID,indControl}..ZOrder=9999
      
      nHdc=dStartDrawing({"OBJEKT"+DataFile.DataFileID,indControl},dErase)
      {"OBJEKT"+DataFile.DataFileID,indControl}..ZOrder=9999
      dRectangle(1,1,{"OBJEKT"+DataFile.DataFileID,indControl}..Width-1,{"OBJEKT"+DataFile.DataFileID,indControl}..Height-1,White,Black)
      dRectangle(1,1,{"OBJEKT"+DataFile.DataFileID,indControl}..Width-1,22,DarkRed,DarkRed)
      MaleText(nHdc,DataFile.FileName,IntegerPart(1),IntegerPart(1),IntegerPart({"OBJEKT"+DataFile.DataFileID,indControl}..Width),IntegerPart(22),0,DataFile.VD_Font,IntegerPart(DataFile.VD_FontSize),"FFFFFF",Val(ExtractString(DataFile.VD_FontProperties,1,";")),Val(ExtractString(DataFile.VD_FontProperties,2,";")),Val(ExtractString(DataFile.VD_FontProperties,3,";")),Val(ExtractString(DataFile.VD_FontProperties,4,";")),2,2,0,gnZoom)
      
     type : 458752
   -
     name : CalcObject
     procedure_id : 1403341346628896171
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Description of in/out parameters for 'CalcObject' :
      //
      // Syntax:
      //[ <Result> = ] CalcObject (<sTargetControl> is string, <nX> is real, <nY> is real, <nW> is real, <nH> is real)
      //
      // Parameters:
      //	sTargetControl (ANSI string): <specify the role of sTargetControl>
      //	nX (real): <specify the role of nX>
      //	nY (real): <specify the role of nY>
      //	nW (real): <specify the role of nW>
      //	nH (real): <specify the role of nH>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CalcObject(sTargetControl is string, nX is real, nY is real, nW is real, nH is real)
      
      //rBreite=(((Formular.Breite*72)/25.4)/100)*gnZoom
      if sTargetControl<>"" then
      	nX=round(((((({sTargetControl,indControl}..X-WIN_Designer.IW_InternalWindow1.IMG_Blatt..X)/gnZoom)*100)*25.4)/72),2)
      	nY=round(((((({sTargetControl,indControl}..Y-WIN_Designer.IW_InternalWindow1.IMG_Blatt..Y)/gnZoom)*100)*25.4)/72),2)
      	nW=round((((({sTargetControl,indControl}..Width/gnZoom)*100)*25.4)/72),2)
      	nH=round((((({sTargetControl,indControl}..Height/gnZoom)*100)*25.4)/72),2)
      end
      
      result true
     type : 458752
   -
