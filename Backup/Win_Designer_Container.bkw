      		IF gsTargetControl<>"" THEN
      			ExecuteProcess(WIN_Designer.BTN_Delete,trtClick)
      		END
      	OTHER CASE
      		//Trace(LoWord(_EVE.wParam)+" / "+HiWord(_EVE.wParam)+ " - "+LoWord(_EVE.lParam)+" / "+HiWord(_EVE.lParam))
      END
     type : 458752
   -
     name : PaintResizeMore
     procedure_id : 1493908192549601875
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //PaintResizeMore (<sControlName> [, <bErase>])
      //
      // Parameters:
      //	sControlName: <specify the role of sControlName>
      // 	bErase (default value=0): <specify the role of bErase>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE PaintResizeMore(sControlName, bErase=false)
      
      if not bErase then
      	dRectangle(0,0,4,4,Black,Black)
      	dRectangle({sControlName,indControl}..Width-6,0,{sControlName,indControl}..Width-2,4,black,Black)
      	dRectangle(0,{sControlName,indControl}..Height-2,4,{sControlName,indControl}..Height-7,black,Black)
      	dRectangle({sControlName,indControl}..Width-6,{sControlName,indControl}..Height-2,{sControlName,indControl}..Width-2,{sControlName,indControl}..Height-7,black,Black)
      else
      	dRectangle(0,0,4,4,White,White)
      	dRectangle({sControlName,indControl}..Width-6,0,{sControlName,indControl}..Width-1,4,White,White)
      	dRectangle(0,{sControlName,indControl}..Height-2,4,{sControlName,indControl}..Height-7,White,White)
      	dRectangle({sControlName,indControl}..Width-6,{sControlName,indControl}..Height-2,{sControlName,indControl}..Width-2,{sControlName,indControl}..Height-7,White,White)
      end
     type : 458752
