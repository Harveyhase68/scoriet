      PROCEDURE KEY_UP()
      
      //trace(LoWord(_EVE.lParam)+"/"+HiWord(_EVE.lParam)+" - "+LoWord(_EVE.wParam)+"/"+HiWord(_EVE.wParam))
      
      switch LoWord(_EVE.wParam)
