               local
               	arrKeys is dynamic array of 0 string
               	n is int
               
               IF ListSelect(COMBO_DataFileMasterDetail)>0 THEN
               	ListDeleteAll(COMBO_DetailKey)
               	ArrayDeleteAll(arrKeys)
               	HFilter(DataKeys,DataKeysKey,HBuildKeyValue(DataKeys,DataKeysKey,COMBO_DataFileMasterDetail,hMinVal,hMinVal),HBuildKeyValue(DataKeys,DataKeysKey,COMBO_DataFileMasterDetail,hMaxVal,hMaxVal))
               	HReadFirst(DataKeys,DataKeysKey)
               	WHILE NOT HOut(DataKeys)
               		IF DataKeys.KeyType=4 OR DataKeys.KeyType=3 THEN
               			n=ArraySeek(arrKeys,asLinear,DataKeys.KeyName)
               			IF n=-1 THEN
               				Dimension(arrKeys,Dimension(arrKeys)+1)
               				arrKeys[Dimension(arrKeys)]=DataKeys.KeyName
               			END
               		END
               		HReadNext(DataKeys,DataKeysKey)
               	END
               	HDeactivateFilter(DataKeys)
               	
               	FOR i=1 to Dimension(arrKeys)
               		ListAdd(COMBO_DetailKey,arrKeys[i])
               		IF DataFile.DetailKeyName=arrKeys[i] THEN
               			ListSelectPlus(COMBO_DetailKey,i)
               		END
               	END
               END
              type : 33
