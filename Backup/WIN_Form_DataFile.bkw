    name : BTN_TableLink_WIN_Table_DataItems
    identifier : 0x200159e0d23e1091
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         
         // open the window "WIN_Table_DataItems"
         sAliasName is string = "Link_DataFileID_"+DataFile.DataFileID
         sWindowTitle is string = "File Link DataFileID: "+DataFile.DataFileID
         IF WinStatus(sAliasName)<>NotFound THEN
         	WinStatus(sAliasName,TopActive)
         ELSE
         	MDIOpen(WIN_Table_DataItems,sAliasName ,sWindowTitle ,"DataFileID="+DataFile.DataFileID)
         END
        type : 18
