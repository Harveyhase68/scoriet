        -
          name : FileName
          identifier : 0x200159ded20409ce
          internal_properties : 
          type : 2
          code_elements :
           type_code : 3
           p_codes :
            -
              code : |1-
               
               LOCAL
               	arrKeys is array of 0 string
               	n is int
               	STlanguage is Structure
               		id is int
               		description is string
               	END
               	
               IF WinStatus(WIN_Main)<>NotFound THEN
               	gnProjectID=WIN_Main.COMBO_Project
               ELSE
               	gnProjectID=1
               END
               
               IF gsWindowMode="Creation" THEN
               	ListDeleteAll(COMBO_Keys)
               	ArrayDeleteAll(arrKeys)
               	hreadseek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,gnProjectID,FileName),hIdentical)
               	if hfound(DataFile) then
               		HFilter(DataKeys,DataKeysKey,HBuildKeyValue(DataKeys,DataKeysKey,gnProjectID,DataFile.DataFileID,hMinVal,hMinVal),HBuildKeyValue(DataKeys,DataKeysKey,gnProjectID,DataFile.DataFileID,hMaxVal,hMaxVal))
               		HReadFirst(DataKeys,DataKeysKey)
               		WHILE NOT HOut(DataKeys)
               			IF DataKeys.KeyType=4 or DataKeys.KeyType=3 THEN
               				n=ArraySeek(arrKeys,asLinear,DataKeys.Field)
               				IF n=-1 THEN
               					Dimension(arrKeys,Dimension(arrKeys)+1)
               					arrKeys[Dimension(arrKeys)]=DataKeys.Field
               				END
               			END
               			HReadNext(DataKeys,DataKeysKey)
               		END
               		HDeactivateFilter(DataKeys)
               		FOR i=1 to Dimension(arrKeys)
               			ListAdd(COMBO_Keys,arrKeys[i])
               			IF DataFile.KeyName=arrKeys[i] THEN
               				ListSelectPlus(COMBO_Keys,i)
               			END
               		END
               		ListSelectPlus(COMBO_Keys,1)
               	end
               end
