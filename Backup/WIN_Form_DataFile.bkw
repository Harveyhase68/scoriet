  -
    name : BTN_NewLine
    identifier : 0x200159dfd22a0e12
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // switch to 'Creation' mode
         ModifyWindowMode("Creation")
         		
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLine
    identifier : 0x200159dfd22e0e12
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(No,<§$0006§>) THEN
         	// deletion
         	HDelete(DataFile)
         	IF ErrorOccurred THEN
         		Error(<§$0005§>+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// Indicate that a record was modified (data refresh required)
         	gsModifiedWindow = True
         	
         	// reading the next record
         	HReadNext(DataFile,DataFileID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(DataFile,DataFileID)
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			RADClear()
         			// tell the user that the file is empty
         			Info(<§$0007§>)
         			// done
         			RETURN
         		END
         	END
         	
         	// transfer the file buffer to controls
         	RADDisplay()
         END
         	
         	
        type : 18
      -
        type : 161
        enabled : false
