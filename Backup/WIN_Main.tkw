   -
     name : OPT_Screenshots
     identifier : 0x255c6c9900ee7f04
     internal_properties : 
     code_elements :
      type_code : 26
      p_codes :
       -
         code : |1+
          
          
          LOCAL
          	i is int
          	s is string
          	h is string
          	k is int
          	o is int
          	n is int
          	f is int
          	
          	AnzahlParameter is int
          	Param1 is string
          	Param2 is string
          	Param3 is string
          	Param4 is string
          	Param5 is string
          	Param6 is string
          	NoOpen is boolean
          	RES is int
          	DesktopHwnd is int
          	DesktopHdc is int
          	hdc is system int
          	nFensterID is int
          	desktop is RECT
          	
          	zz is int
          	
          	WindowName is string
          	sWindowCaption is string
          	nFile is int
          	
          	nWahl is int
          	sWindowList is dynamic array of 0 string
          	
          	sDirectory is string
          	sBildName is string
          	
          	nFileID is int
          	sKopf is string
          	sMitte is string
          	sFuss is string
          	//sMenu is dynamic array of 0 mm
          	sText is string
          	sBuffer is string
          	sBlock is string
          	sFett is string
          	sNormal is string
          	sTopicText is string
          	sList is string
          	sControl is string
          	sControl2 is string
          	t is int
          	u is int
          
          sText=sText+"<!DOCTYPE HTML PUBLIC ""-//W3C//DTD HTML 4.01 Transitional//EN"">"+CRLF
          sText=sText+"<html>"+CRLF
          sText=sText+"<head>"+CRLF
          sText=sText+"<title>%1</title>"+CRLF
          sText=sText+"<meta name=""generator"" content=""Help &amp; Manual"" />"+CRLF
          sText=sText+"<meta name=""keywords"" content="""" />"+CRLF
          sText=sText+"<meta http-equiv=""Content-Type"" content=""text/html; charset=UTF-8"" />"+CRLF
          sText=sText+"<meta http-equiv=""Content-Style-Type"" content=""text/css"" />"+CRLF
          sText=sText+"<link type=""text/css"" href=""default.css"" rel=""stylesheet"" />"+CRLF
          sText=sText+"</head>"+CRLF
          sText=sText+"<body style=""margin: 0px 0px 0px 0px; background: #FFFFFF;"">"+CRLF
          sText=sText+"<p class=""p_Heading1""><span class=""f_Heading1"">%2</span></p>"+CRLF
          sText=sText+"<br />%3"+CRLF
          sText=sText+"</body>"+CRLF
          sText=sText+"</html>"+CRLF
          
          sFett="<span style=""font-weight: bold;"">%1</span>"
          sNormal="<p>%1</p>"
          
          sKopf=""
          nFileID = fOpen(CompleteDir(fExeDir())+"kopf.txt", foRead)
          IF nFileID <> -1 THEN
          	s = fReadLine(nFileID)
          	WHILE s <> EOT
          		sKopf=sKopf+s+CRLF
          		s = fReadLine(nFileID)
          	END
          	fClose(nFileID)
          ELSE
          	Error()
          END
          
          sFuss=""
          nFileID = fOpen(CompleteDir(fExeDir())+"fuss.txt", foRead)
          IF nFileID <> -1 THEN
          	s = fReadLine(nFileID)
          	WHILE s <> EOT
          		sFuss=sFuss+s+CRLF
          		s = fReadLine(nFileID)
          	END
          	fClose(nFileID)
          ELSE
          	Error()
          END
          
          sDirectory=CompleteDir(CompleteDir(fExeDir())+"Dokumentation_Bilder")
          IF NOT fDirectoryExist(sDirectory) THEN
          	fMakeDir(sDirectory)
          END
          
          WindowName = EnumElement(enumWindow)
          WHILE WindowName <> ""
          	Dimension(sWindowList,Dimension(sWindowList)+1)
          	sWindowList[Dimension(sWindowList)]=WindowName
          	WindowName = EnumElement()
          END
          
          IF Open(Testprogramme_MenuScreenShot,nWahl) THEN
          	
          	OpenChild(Testprogramme_MacheScreenShots)
          	
          	IF nWahl=1 OR nWahl=3 THEN
          		
          		nFile = fOpen(sDirectory+"WindowStructure.txt", foReadWrite + foCreate)
          		
          		n=Dimension(sWindowList)
          		FOR nFensterID=1 TO n
          			
          			WindowName=sWindowList[nFensterID]	
          			//if WindowName="WIN_Datum" then stop
          			//if WindowName="Dienstprogramme_Daten_Update" then stop
          			Multitask(-1)
          			
          			zz++
          			Param1=""
          			NoOpen=False
          			s=""
          			AnzahlParameter=0
          			sBildName=sDirectory+WindowName
          			
          			SWITCH WindowName
          				CASE "WIN_Main","WIN_Datachanged","WIN_Lock","WIN_Duplicate","WIN_Integrity","WIN_Modif","WIN_MandatoryInput","WIN_Password","WIN_Reindexing","Testprogramme_MacheScreenShot","WIN_EingabeEAN128"
          					NoOpen=True
          				CASE "WIN_Designer","WIN_Datum","WIN_Property","WIN_EingabeNumerisch","WIN_EingabeRTF","WIN_EingabeText","WIN_EingabeDatum","WIN_EingabeEAN","WIN_Property_GDA","WIN_Werte","WIN_GDAWerte","WIN_Neues_Etikett","WIN_Etikett_Kopieren","WIN_Standard_Etikett_Kopieren","WIN_Property_Standard","WIN_Neues_Standard_Etikett","WIN_Werte2","WIN_Property_Standard_GDA","WIN_Neues_GDA_Etikett","WIN_GDA_Kopieren","WIN_Property_GDA_Table"
          					Param1="1"
          					AnzahlParameter=1
          				OTHER CASE
          			END
          			
          			IF Left(WindowName,5)="Form_" THEN
          				Param1="Creation"
          				Param1="Modif"
          				Param1="Browse"
          				AnzahlParameter=1
          				sBildName=sBildName+"_"+Param1
          			END
          			
          			IF NOT NoOpen AND AnzahlParameter=0 THEN
          				WHEN EXCEPTION IN
          					IF WinStatus(WindowName)=NotFound THEN
          						OpenChild(WindowName)
          						Multitask(-1)
          					END
          				DO
          					s=WindowName+" - "+ErrorInfo(errFullDetails)
          					h=ExceptionInfo(errFullDetails)
          					IF Position(h,"Error code: 1002")>0 THEN
          						k=Position(h,"window: ")
          						o=Position(h," parameters",k+1)
          						AnzahlParameter=Val(Middle(h,k+8,o-(k+8)))
          					END
          				END
          				WHEN EXCEPTION IN
          					Restore(WindowName)
          				DO
          				END
          			END
          			
          			IF NOT NoOpen AND AnzahlParameter<>0 THEN
          				WHEN EXCEPTION IN
          					SWITCH AnzahlParameter
          						CASE 1
          							IF Param1<>"" THEN
          								OpenChild(WindowName,Param1)
          							ELSE
          								OpenChild(WindowName,1)
          							END
          						CASE 2
          							IF Param2<>"" THEN
          								OpenChild(WindowName,Param1,Param2)
          							ELSE
          								OpenChild(WindowName,1,2)
          							END
          						CASE 3
          							IF Param3<>"" THEN
          								OpenChild(WindowName,Param1,Param2,Param3)
          							ELSE
          								OpenChild(WindowName,1,2,3)
          							END
          						CASE 4
          							IF Param4<>"" THEN
          								OpenChild(WindowName,Param1,Param2,Param3,Param4)
          							ELSE
          								OpenChild(WindowName,1,2,3,4)
          							END
          						CASE 5
          							IF Param5<>"" THEN
          								OpenChild(WindowName,Param1,Param2,Param3,Param4,Param5)
          							ELSE
          								OpenChild(WindowName,1,2,3,4,5)
          							END
          						CASE 6
          							IF Param6<>"" THEN
          								OpenChild(WindowName,Param1,Param2,Param3,Param4,Param5,Param6)
          							ELSE
          								OpenChild(WindowName,1,2,3,4,5,6)
          							END
          						OTHER CASE
          					END
          				DO
          				END	
          				
          				WHEN EXCEPTION IN
          					Restore(WindowName)
          				DO
          				END
          				
          			END
          			
          			Multitask(-1)
          			
          			IF NOT NoOpen THEN
          				WHEN EXCEPTION IN
          					sWindowCaption=GetCleanFileName({WindowName,indWindow}..Caption)
          					fWrite(nFile,"zz++;Dimension(arrFensterNamen,zz)"+CRLF)
          					fWrite(nFile,"arrFensterNamen[zz].fenstername="""+WindowName+""";arrFensterNamen[zz].bezeichnung="""+{WindowName,indWindow}..Caption+""""+CRLF)
          					Multitask(-1)
          					DesktopHwnd = CallDLL32("user32","GetDesktopWindow")
          					DesktopHdc = CallDLL32("user32","GetDC",DesktopHwnd)
          					IF {WindowName,indWindow}..Type=typInternalWindow OR {WindowName,indWindow}..Type=40001 THEN
          					ELSE
          						IF CheckIsMDI(WindowName) THEN
          							{WindowName,indWindow}..X=0
          							{WindowName,indWindow}..Y=0
          							desktop.nLeft=WIN_Main..X+Win_main..MDILeft+10
          							desktop.nTop=WIN_Main..Y+WIN_Main..MDITop+57
          							desktop.nRight={WindowName,indWindow}..Width+desktop.nLeft
          							desktop.nBottom={WindowName,indWindow}..Height+desktop.nTop
          						ELSE
          							desktop.nLeft={WindowName,indWindow}..X
          							desktop.nTop={WindowName,indWindow}..Y
          							desktop.nRight={WindowName,indWindow}..Width+desktop.nLeft
          							desktop.nBottom={WindowName,indWindow}..Height+desktop.nTop
          						END
          						
          						Testprogramme_MacheScreenShots.Image1..Width=desktop.nRight-desktop.nLeft
          						Testprogramme_MacheScreenShots.Image1..Height=desktop.nBottom-desktop.nTop
          						
          						sTopicText=""
          						sControl=""
          						sControl2=""
          						sList=""
          						i=1; sControl = EnumControl(WindowName, i ,byTabOrder)
          						WHILE sControl<>""
          							SWITCH {WindowName+"."+sControl,indControl}..Type
          								CASE typButton,typActiveX,typCube,typHTML,typMenuOption,typScrollbar,typSpin, typStatusBarBox, typWebCam,typTable, typSplitter, 30001, typForme, typInternalWindow, typOrganizer,typCalendar,typToolbar, typToolbox, typGauge
          								CASE 20004, typComboWE,typComboNE,typDate,typDuration,typTime,typCurrency,typText, typList, typImage, typCheckBox, typInputDate, typInputDuration, typInputNum, typInputNumericPrecise, typInputText, typInputTime, typSelect
          									sList=sList+sControl+";"
          								CASE 40
          									t=1; sControl2 = EnumControl(WindowName+"."+sControl, t ,byTabOrder)
          									WHILE sControl2<>""
          										SWITCH {WindowName+"."+sControl2,indControl}..Type
          											CASE 20004, typComboWE,typComboNE,typDate,typDuration,typTime,typCurrency,typText, typList, typImage, typCheckBox, typInputDate, typInputDuration, typInputNum, typInputNumericPrecise, typInputText, typInputTime, typSelect
          												sList=sList+sControl+"."+sControl2+";"
          										END
          										t++; sControl2 = EnumControl(WindowName, t ,byTabOrder)
          									END
          								CASE typTab
          									FOR u=1 TO {WindowName+"."+sControl,indControl}..Occurrence
          										sList=sList+"TAB:"+{WindowName+"."+sControl+"["+NumToString(u,"d")+"]"}..Caption+";"
          										t=1; sControl2 = EnumControl({WindowName+"."+sControl+"["+NumToString(u,"d")+"]"}, t ,byTabOrder)
          										WHILE sControl2<>""
          											SWITCH {WindowName+"."+sControl+"["+NumToString(u,"d")+"]."+sControl2}..Type
          												CASE 20004, typComboWE,typComboNE,typDate,typDuration,typTime,typCurrency,typText, typList, typImage, typCheckBox, typInputDate, typInputDuration, typInputNum, typInputNumericPrecise, typInputText, typInputTime, typSelect
          													sList=sList+sControl+"["+NumToString(u,"d")+"]"+"."+sControl2+";"
          												OTHER CASE
          											END
          											t++; sControl2 = EnumControl({WindowName+"."+sControl+"["+NumToString(u,"d")+"]"}, t ,byTabOrder)
          										END
          									END
          									//								OTHER CASE
          									//									info("Unbekanntes Control: "+WindowName+"."+sControl)
          							END
          							i++; sControl = EnumControl(WindowName, i ,byTabOrder)
          						END
          						
          						FOR i=1 TO StringCount(sList,";")
          							sControl=ExtractString(sList,i,";")
          							IF Left(sControl,4)="TAB:" THEN
          								sTopicText=sTopicText+StringToUTF8(StringBuild(sNormal,StringBuild(sFett,Replace(Middle(sControl,5),"&","")))+CRLF+"<br />"+CRLF)
          							ELSE
          								IF sControl<>"" THEN
          									SWITCH {WindowName+"."+sControl}..Type
          										CASE typCheckBox
          											IF Upper({WindowName+"."+sControl}[1]..Caption)="JA" THEN
          												sTopicText=sTopicText+StringToUTF8(StringBuild(sNormal,StringBuild(sFett,Replace({WindowName+"."+sControl}..Caption,"&","")+":")+"&nbsp;")+CRLF+"<br />"+CRLF)
          											ELSE
          												sTopicText=sTopicText+StringToUTF8(StringBuild(sNormal,StringBuild(sFett,Replace({WindowName+"."+sControl}[1]..Caption,"&","")+":")+"&nbsp;")+CRLF+"<br />"+CRLF)
          											END	
          										CASE typSelect
          											sTopicText=sTopicText+StringToUTF8(StringBuild(sNormal,StringBuild(sFett,Replace({WindowName+"."+sControl}..Caption,"&","")+":")+":&nbsp;")+CRLF+"<br />"+CRLF)
          											FOR f=1 TO {WindowName+"."+sControl}..Occurrence
          												sTopicText=sTopicText+StringToUTF8(StringBuild(sNormal,StringBuild(sFett,Replace({WindowName+"."+sControl+"["+f+"]"}..Caption,"&","")+":")+"&nbsp;")+CRLF+"<br />"+CRLF)
          											END
          										OTHER CASE
          											IF {WindowName+"."+sControl}..Caption<>"" THEN
          												sTopicText=sTopicText+StringToUTF8(StringBuild(sNormal,StringBuild(sFett,Replace({WindowName+"."+sControl}..Caption,"&","")+":")+"&nbsp;")+CRLF+"<br />"+CRLF)
          											END
          									END
          								END
          							END
          						END						
          						
          						sMitte=StringBuild(sText,{WindowName,indWindow}..Caption,StringToUTF8({WindowName,indWindow}..Caption),sTopicText)
          						
          						SWITCH WindowName
          //							CASE "WIN_Form_Stammdaten"
          //								FOR i=1 TO 3
          //									WIN_Form_Stammdaten.TAB_Stammdaten=i
          //									Multitask(-1)
          //									hdc=dStartDrawing(Testprogramme_MacheScreenShots.Image1,dNoErase)
          //									RES = CallDLL32("gdi32","StretchBlt",hdc, 0, 0, desktop.nRight, desktop.nBottom, DesktopHdc , desktop.nLeft, desktop.nTop, desktop.nRight, desktop.nBottom, SRCCOPY)
          //									dSaveImagePNG(Testprogramme_MacheScreenShots.Image1,sBildName+"_"+NumToString(i,"d")+".png")
          //									dEndDrawing(Testprogramme_MacheScreenShots.Image1)
          //								END
          							OTHER CASE
          								hdc=dStartDrawing(Testprogramme_MacheScreenShots.Image1,dNoErase)
          								RES = CallDLL32("gdi32","StretchBlt",hdc, 0, 0, desktop.nRight, desktop.nBottom, DesktopHdc , desktop.nLeft, desktop.nTop, desktop.nRight, desktop.nBottom, SRCCOPY)
          								dSaveImagePNG(Testprogramme_MacheScreenShots.Image1,sBildName+".png")
          								dEndDrawing(Testprogramme_MacheScreenShots.Image1)
          						END
          						RES = CallDLL32("user32","ReleaseDC",DesktopHwnd, DesktopHdc)
          					END
          					
          					IF WindowName<>"WIN_Main" THEN
          						IF sWindowCaption<>"" THEN
          							nFileID = fOpen("D:\Eigene Dateien\My HelpAndManual Projects\Etiketten Solo\HTML\"+sWindowCaption+".htm", foWrite+foCreate)
          							IF nFileID <> -1 THEN
          								sBuffer=sMitte
          								FOR i = 1 _TO_ Length(sBuffer) NOT 1024
          									sBlock = sBuffer[[i on 1024]]
          									fWrite(nFileID, &sBlock, Length(sBlock))
          								END
          								
          								// Fermeture du fichier
          								fClose(nFileID)
          							ELSE
          								Error()
          							END
          						END
          						FillMenuName(WindowName)
          						IF Left(WindowName,5)="Form_" OR WindowName="Formular_und_Tabelle_Device_DeviceCodes" THEN
          							{WindowName,indWindow}..Modified=False
          						END
          						Close(WindowName)
          						Multitask(-1)
          					END
          				DO
          					h=ExceptionInfo(errFullDetails)
          					Info(h)
          				END
          			ELSE
          				fWrite(nFile,"zz++;Dimension(arrFensterNamen,zz)"+CRLF)
          				WHEN EXCEPTION IN
          					s={WindowName,indWindow}..Caption	
          				DO
          					fWrite(nFile,"arrFensterNamen[zz].fenstername="""+WindowName+""";arrFensterNamen[zz].bezeichnung="""""+CRLF)	
          				ELSE
          					fWrite(nFile,"arrFensterNamen[zz].fenstername="""+WindowName+""";arrFensterNamen[zz].bezeichnung="""+{WindowName,indWindow}..Caption+""""+CRLF)
          				END
          			END
          			Multitask(-1)
          			
          		END
          		
          		FillSubMenuName(WindowName)
          		
          		fClose(nFile)
          		
          	END
          	
          	Multitask(-1)
          	
          	IF nWahl=1 THEN
          		FillMenuName("WIN_Main")
          	ELSE IF nWahl=2 THEN
          		FillMenuName("WIN_Main")
          	END
          	
          	if WinStatus(Testprogramme_MacheScreenShots)<>NotFound then
          		Close(Testprogramme_MacheScreenShots)
          	end
          	
          	Info("Fertig!")
          	
          END
          
          
          
