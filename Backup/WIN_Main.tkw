     code : |1+
      	
      if ontestmode() then
      	OPT_Screenshots..Visible=true
      END
      
      if LoadParameter("wizardshow")<>"NOSHOW" and gbOpenWizzard then
      	Menu_Open("WIN_Welcome")
      	gbOpenWizzard=false
      END
      
      IF ListSelect(COMBO_Project)=-1 THEN
      	ListSelectPlus(COMBO_Project,1)
      END
      
      IF gnLanguage=1 THEN
      	Deutsch..Visible=False
      	English..Visible=True
      	Nation(gnLanguage)
      ELSE
      	Deutsch..Visible=True
      	English..Visible=False
      	Nation(gnLanguage)
      END
      
      if Dimension(garrWindowOpen)>0 then
      	for i=1 to Dimension(garrWindowOpen)
      		Menu_Open(garrWindowOpen[i])
      	end
      	ArrayDeleteAll(garrWindowOpen)
      END
      
      hreadfirst(Project,ProjectID)
      while not hout(Project)
      	CheckProjectTemplates(Project.ProjectID)
      	hreadnext(Project,ProjectID)
      END
      
      //FillEventConstant()
      //Event("EventTest2", "COMBO_Project", null)
      
      Message(<§$000e§>+gsUserName)
