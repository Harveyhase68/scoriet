      for i=1 to Dimension(arrFensterNamen)
      	if Position(arrFensterNamen[i].fenstername,"Kassa_Dialog")>0 then
      		ArrayDelete(arrFensterNamen,i)
      	END
      END
      ArraySort(arrFensterNamen,asMember,"+bezeichnung")
     type : 458752
   -
     name : FillMenuName
     procedure_id : 1539226071695150044
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //FillMenuName (<sWindowName>)
      //
      // Parameters:
      //	sWindowName: <specify the role of sWindowName>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	sMenu: <specify the role of sMenu>
      PROCEDURE FillMenuName(sWindowName)
      
      local
      	sMenu is dynamic array of string
      	i is int
      	n is int
      	
      FillArrMenuName(sWindowName,sMenu)	
      
      WHEN EXCEPTION IN
      	n=Dimension(sMenu)
      	FOR i=1 TO n
      		Gauge(i,Dimension(sMenu),NumToString(i,"d")+" - "+sMenu[i])
      		MakeMenuScreenShot(sWindowName,sMenu[i],i)
      	END
      DO
      END
     type : 458752
   -
     name : FillSubMenuName
     procedure_id : 1539226071695215721
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //FillSubMenuName (<sWindowName>)
      //
      // Parameters:
      //	sWindowName: <specify the role of sWindowName>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FillSubMenuName(sWindowName)
      
      local
      	ControlName is string
      
      // Enumerate the controls found in a window of a project
      ControlName= EnumSubElement (sWindowName,enumFirst+enumContextualMenu)
      // Browse all the controls
      WHILE ControlName <> ""
      	FillMenuName(sWindowName+"."+ControlName)
      	// Go to the next control
      	ControlName = EnumSubElement(sWindowName)
      END
     type : 458752
