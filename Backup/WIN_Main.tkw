   -
     name : FillArrMenu
     procedure_id : 1539226067399985126
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] FillArrMenu (<sWindowName>, <sMenu>)
      //
      // Parameters:
      //	sWindowName: <specify the role of sWindowName>
      //	sMenu: <specify the role of sMenu>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	sMenu: <specify the role of sMenu>
      PROCEDURE FillArrMenu(sWindowName,sMenu)
      
      local
      	sNameSubMenu1 is string
      	sNameSubMenu2 is string
      	sNameSubMenu3 is string
      	sNameSubMenu4 is string
      	sNameSubMenu5 is string
      	sNameSubMenu6 is string
      	
      	i is int
      	zz is int
      	j is int
      	n is int
      	t is int
      	u is int
      	v is int
      	h is string
      
      when exception IN
      	sNameSubMenu1 = EnumMenu(sWindowName, 1) // read the 1st menu of the window
      	i=1
      	zz=0
      	WHILE sNameSubMenu1 <> ""
      		zz++
      		Dimension(sMenu,zz)
      		sMenu[zz]:sCaption=GetCleanFileName({sWindowName+"."+sNameSubMenu1,indControl}..Caption)
      		sMenu[zz]:sPath=sWindowName+"."+sNameSubMenu1
      		j=1
      		sNameSubMenu2 = EnumMenu(sWindowName+"."+sNameSubMenu1, j) // read the 1st menu option
      		WHILE sNameSubMenu2 <> ""
      			IF {sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2,indControl}..Caption<> "-" THEN
      				zz++
      				Dimension(sMenu,zz)
      				sMenu[zz]:sCaption=GetCleanFileName({sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2,indControl}..Caption)
      				sMenu[zz]:sPath=sWindowName+"."+sNameSubMenu1+";"+sNameSubMenu2
      			END
      			n=1
      			sNameSubMenu3 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2, n) // read the 1st menu option
      			WHILE sNameSubMenu3 <> ""
      				IF {sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3,indControl}..Caption<> "-" THEN
      					zz++
      					Dimension(sMenu,zz)
      					sMenu[zz]:sCaption=GetCleanFileName({sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3,indControl}..Caption)
      					sMenu[zz]:sPath=sWindowName+"."+sNameSubMenu1+";"+sNameSubMenu2+"."+sNameSubMenu3
      				END
      				t=1
      				sNameSubMenu4 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3, t) // read the 1st menu option
      				WHILE sNameSubMenu4 <> ""
      					IF {sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4,indControl}..Caption<> "-" THEN
      						zz++
      						Dimension(sMenu,zz)
      						sMenu[zz]:sCaption=GetCleanFileName({sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu4,indControl}..Caption)
      						sMenu[zz]:sPath=sWindowName+"."+sNameSubMenu1+";"+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4
      					END
      					u=1
      					sNameSubMenu5 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4, u) // read the 1st menu option
      					WHILE sNameSubMenu5 <> ""
      						IF {sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4+"."+sNameSubMenu5,indControl}..Caption<>"-" THEN
      							zz++
      							Dimension(sMenu,zz)
      							sMenu[zz]:sCaption=GetCleanFileName({sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu5,indControl}..Caption)
      							sMenu[zz]:sPath=sWindowName+"."+sNameSubMenu1+";"+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4+"."+sNameSubMenu5
      						END
      						v=1
      						sNameSubMenu6 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4+"."+sNameSubMenu5, v) // read the 1st menu option
      						WHILE sNameSubMenu6 <> ""
      							IF {sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4+"."+sNameSubMenu5+"."+sNameSubMenu6,indControl}..Caption<> "-" THEN
      								zz++
      								Dimension(sMenu,zz)
      								sMenu[zz]:sCaption=GetCleanFileName({sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu6,indControl}..Caption)
      								sMenu[zz]:sPath=sWindowName+"."+sNameSubMenu1+";"+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4+"."+sNameSubMenu5+"."+sNameSubMenu6
      							END
      							v++ // next option
      							sNameSubMenu6 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4+"."+sNameSubMenu5, v)
      						END
      						u++ // next option
      						sNameSubMenu5 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3+"."+sNameSubMenu4, u)
      					END
      					t++ // next option
      					sNameSubMenu4 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2+"."+sNameSubMenu3, t)
      				END
      				n++ // next option
      				sNameSubMenu3 = EnumMenu(sWindowName+"."+sNameSubMenu1+"."+sNameSubMenu2, n)
      			END
      			j++ // next option
      			sNameSubMenu2 = EnumMenu(sWindowName+"."+sNameSubMenu1, j)
      		END
      		i++ // next menu
      		sNameSubMenu1 = EnumMenu(sWindowName,i)
      	END
      do
      	h=ExceptionInfo(errFullDetails)
      	Info(h)
      	result false
      end
      
      RESULT true
     type : 458752
   -
     name : FillArrMenuName
     procedure_id : 1539226067400050787
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] FillArrMenuName (<sWindowName>, <sMenu>)
      //
      // Parameters:
      //	sWindowName: <specify the role of sWindowName>
      //	sMenu: <specify the role of sMenu>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	sMenu: <specify the role of sMenu>
      PROCEDURE FillArrMenuName(sWindowName,sMenu)
      
      local
      	NameSubMenu1 is string
      	NameSubMenu2 is string
      	NameSubMenu3 is string
      	NameSubMenu4 is string
      	NameSubMenu5 is string
      	NameSubMenu6 is string
      	i is int
      	zz is int
      	j is int
      	n is int
      	t is int
      	u is int
      	v is int
      	
      	h is string
      	
      //If sWindowName="Kassa" then
      //	stop
      //END
      
      when exception IN
      	NameSubMenu1 = EnumMenu(sWindowName, 1) // read the 1st menu of the window
      	i=1
      	zz=0
      	WHILE NameSubMenu1 <> ""
      		zz++
      		Dimension(sMenu,zz)
      		sMenu[zz]=GetReplace({sWindowName+"."+NameSubMenu1,indControl}..Caption)
      		j=1
      		NameSubMenu2 = EnumMenu(sWindowName+"."+NameSubMenu1, j) // read the 1st menu option
      		WHILE NameSubMenu2 <> ""
      			IF {sWindowName+"."+NameSubMenu1+"."+NameSubMenu2,indControl}..Caption<> "-" THEN
      				zz++
      				Dimension(sMenu,zz)
      				sMenu[zz]=GetReplace({sWindowName+"."+NameSubMenu1,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2,indControl}..Caption)
      			END
      			n=1
      			NameSubMenu3 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2, n) // read the 1st menu option
      			WHILE NameSubMenu3 <> ""
      				IF {sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3,indControl}..Caption<> "-" THEN
      					zz++
      					Dimension(sMenu,zz)
      					sMenu[zz]=GetReplace({sWindowName+"."+NameSubMenu1,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3,indControl}..Caption)
      				END
      				t=1
      				NameSubMenu4 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3, t) // read the 1st menu option
      				WHILE NameSubMenu4 <> ""
      					IF {sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4,indControl}..Caption<> "-" THEN
      						zz++
      						Dimension(sMenu,zz)
      						sMenu[zz]=GetReplace({sWindowName+"."+NameSubMenu1,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4,indControl}..Caption)
      					END
      					u=1
      					NameSubMenu5 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4, u) // read the 1st menu option
      					WHILE NameSubMenu5 <> ""
      						IF {sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5,indControl}..Caption<>"-" THEN
      							zz++
      							Dimension(sMenu,zz)
      							sMenu[zz]=GetReplace({sWindowName+"."+NameSubMenu1,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5,indControl}..Caption)
      						END
      						v=1
      						NameSubMenu6 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5, v) // read the 1st menu option
      						WHILE NameSubMenu6 <> ""
      							IF {sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5+"."+NameSubMenu6,indControl}..Caption<> "-" THEN
      								zz++
      								Dimension(sMenu,zz)
      								sMenu[zz]=GetReplace({sWindowName+"."+NameSubMenu1,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4,indControl}..Caption)+"."+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5,indControl}..Caption)+";"+GetReplace({sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5+"."+NameSubMenu6,indControl}..Caption)
      							END
      							v++ // next option
      							NameSubMenu6 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4+"."+NameSubMenu5, v)
      						END
      						u++ // next option
      						NameSubMenu5 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3+"."+NameSubMenu4, u)
      					END
      					t++ // next option
      					NameSubMenu4 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2+"."+NameSubMenu3, t)
      				END
      				n++ // next option
      				NameSubMenu3 = EnumMenu(sWindowName+"."+NameSubMenu1+"."+NameSubMenu2, n)
      			END
      			j++ // next option
      			NameSubMenu2 = EnumMenu(sWindowName+"."+NameSubMenu1, j)
      		END
      		i++ // next menu
      		NameSubMenu1 = EnumMenu(sWindowName,i)
      	END
      do
      	h=ExceptionInfo(errFullDetails)
      	Info(h)
      	result false
      end
      
