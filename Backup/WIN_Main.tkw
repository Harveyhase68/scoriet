      zz++;Dimension(arrFensterNamen,zz)
      arrFensterNamen[zz].fenstername="Kassa_Dialog_Gutschein_nicht_gefunden";arrFensterNamen[zz].bezeichnung="Dieser Gutschein wurde nicht gefunden!"
      zz++;Dimension(arrFensterNamen,zz)
      arrFensterNamen[zz].fenstername="Kassa_Dialog_Gutschein_nicht_boniert";arrFensterNamen[zz].bezeichnung="Dieser Gutschein konnte nicht boniert werden!"
      zz++;Dimension(arrFensterNamen,zz)
      arrFensterNamen[zz].fenstername="Kassa_Dialog_Gutschein_bereits_am_Bon";arrFensterNamen[zz].bezeichnung="Gutscheine dürfen nur 1x am Bon eingelöst werden"
      zz++;Dimension(arrFensterNamen,zz)
      arrFensterNamen[zz].fenstername="Kassa_Dialog_Bon_Barauszahlung_mit_Gutschein";arrFensterNamen[zz].bezeichnung="Barauszahlung mit Gutschein nicht erlaubt!"
      zz++;Dimension(arrFensterNamen,zz)
      arrFensterNamen[zz].fenstername="Kassa_Dialog_Gutschein_Prozent_Kann_Nicht_Verkauft";arrFensterNamen[zz].bezeichnung="Dieser Prozent Gutschein kann nicht verkauft werden!"
      zz++;Dimension(arrFensterNamen,zz)
      arrFensterNamen[zz].fenstername="Formular_und_Tabelle_Gutschein_Kopf_Gutschein_Erzeugen";arrFensterNamen[zz].bezeichnung="Gutscheine und Gutschein Erzeugungstabelle"
