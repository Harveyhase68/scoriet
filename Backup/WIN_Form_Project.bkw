#To edit and compare internal_properties, use WINDEV integrated tools.
#Internal properties refer to the properties of controls in windows, reports, etc.
info :
 name : WIN_Form_Project
 major_version : 25
 minor_version : 0
 type : 2
 description : ""
 subtype : 0
window :
 name : WIN_Form_Project
 identifier : 0x200159e3d3941f31
 internal_properties : 
 controls :
  -
    name : BTN_OK
    identifier : 0x200159e4d3ee1fcd
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // According to the window mode
         SWITCH Left(ExtractString(gsWindowMode,1,"="),8)
         	// 'Creation' mode
         	CASE "Creation"
         		// Setup the record and save
         		IF RADSave() THEN
         			// Add the record
         			HAdd(Project)
         			IF ErrorOccurred THEN
         				Info("Unable to add record"+CR+HErrorInfo())
         				RETURN
         			END
         
         			// Indicates that the form is no longer modified
         			gsModifiedWindow = gsModifiedWindow OR MyWindow..Modified
         			MyWindow..Modified=False
         
         		END
         	// 'Modif' mode
         	CASE "Modif"
         		// Setup the record and save
         		IF RADSave() THEN
         			// modify the record
         			HModify(Project)
         			IF ErrorOccurred THEN
         				Info("Unable to modify record"+CR+HErrorInfo())
         				RETURN
         			END
         
         			// Indicates that the form is no longer modified
         			gsModifiedWindow = gsModifiedWindow OR MyWindow..Modified
         			MyWindow..Modified=False
         
         		END
         END
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" OR OpeningMode~="LinkedBrowse" OR gsCallMode~="Browse" THEN
         	// the new record becomes the current record
         	gnRecNum = HRecNum(Project)
         
         	// Was the window opening mode changed?
         	IF gsCallMode ~= "Browse" THEN
         		// Go to the record in order to reinitialize the browse
         		IF gnRecNum<>0 THEN
         			HReadFirst(Project)
         		ELSE
         			HReadFirst(Project,ProjectID)
         		END
         
         		// Restore the expected opening mode
         		OpeningMode = gsCallMode
         	END
         
         	// back to source mode
         	ModifyWindowMode(OpeningMode)
         	// in other cases
         ELSE
         	// close the window
         	Close("",gsModifiedWindow)
         END
         
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Cancel
    identifier : 0x200159e4d3f22124
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // indicates that the form is no longer modified
         MyWindow..Modified=False
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" OR OpeningMode~="LinkedBrowse" THEN
         	
         	// back to 'Browse' or 'LinkedBrowse' mode
         	ModifyWindowMode(OpeningMode)
         	
         	// if there was a current record
         	IF gnRecNum<>0 THEN
         		// point to the modified record
         		HRead(Project,gnRecNum)
         
         		// and display items in controls
         		RADDisplay()
         	END
         	// otherwise, close the window
         ELSE
         	Close("",gsModifiedWindow)
         END
         	
         	
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_First
    identifier : 0x200159e4d3f6225c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // read the first record
         HReadFirst(Project,ProjectID)
         
         // no record
         IF HOut() THEN
         	Info("The file is empty")
         	// otherwise, transfer the file buffer to controls
         ELSE
         	RADDisplay()
         END	
         	
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Previous
    identifier : 0x200159e4d3fa226c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // read the previous record
         HReadPrevious(Project,ProjectID)
         
         // no record
         IF HOut() THEN
         	Info("Start of file reached")
         	// otherwise, transfer the file buffer to controls
         ELSE
         	RADDisplay()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Next
    identifier : 0x200159e4d3fe227c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // reading the next record
         HReadNext(Project,ProjectID)
         
         // no record
         IF HOut() THEN
         	Info("End of file reached")
         ELSE
         	// Otherwise, transfer the file buffer to controls
         	RADDisplay()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Last
    identifier : 0x200159e4d402229b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // read the last record
         HReadLast(Project,ProjectID)
         
         // no record
         IF HOut() THEN
         	Info("The file is empty")
         	// otherwise, transfer the file buffer to controls
         ELSE
         	RADDisplay()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLine
    identifier : 0x200159e4d40a22aa
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(No,"Do you want to delete the record?") THEN
         	// deletion
         	HDelete(Project)
         	IF ErrorOccurred THEN
         		Error("Unable TO delete record."+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// Indicate that a record was modified (data refresh required)
         	gsModifiedWindow = True
         	
         	// reading the next record
         	HReadNext(Project,ProjectID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(Project,ProjectID)
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			RADClear()
         			// tell the user that the file is empty
         			Info("The file is empty")
         			// done
         			RETURN
         		END
         	END
         	
         	// transfer the file buffer to controls
         	RADDisplay()
         END
         	
         	
        type : 18
      -
        type : 161
        enabled : false
