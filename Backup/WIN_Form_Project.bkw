           type_code : 4
           p_codes :
            -
              code : |1+
               
               LOCAL
               	sFileName is string
               	sDir is string
               	
               IF fFileExist(WinDevAnalyse) THEN
               	sFileName=fExtractPath(WinDevAnalyse,fFileName+fExtension)
               	sDir=fExtractPath(WinDevAnalyse,fDrive+fDirectory)
               END
               
               sFileName=fSelect(sDir, sFileName, "Select a file...", "Analysis .wdd"+TAB+"*.wdd", "wdd", fselOpen)
               
               IF sFileName<>"" THEN
               	WinDevAnalyse=sFileName
               END
