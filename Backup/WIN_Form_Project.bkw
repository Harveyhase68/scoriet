          name : BTN_DeleteProjectTemplate
          identifier : 0x253c95762d07dc6a
          internal_properties : 
          type : 4
          code_elements :
           type_code : 4
           p_codes :
            -
              code : |1+
               
               // no action if no record is selected in the table
               IF TableSelect(TABLE_ProjectTemplates)=-1 THEN RETURN
               
               // The input/selection row cannot be deleted
               IF TableSelect(TABLE_ProjectTemplates)>TableCount(TABLE_ProjectTemplates) THEN 
               	Info(<§$0000§>,"This row cannot be deleted")
               	RETURN
               END
               
               // if the deletion is confirmed, delete the table row and
               // the matching record from DataItems file
               IF YesNo(<§$0002§>) THEN 
               	// Delete the record from the table
               	TableDelete(TABLE_ProjectTemplates)
               	
               	// Check integrity
               	IF HErrorIntegrity() THEN
               		Error(<§$0003§>,HErrorInfo())		
               	END
               END
              type : 18
            -
              type : 161
              enabled : false
        -
          name : BTN_ModifyProjectTemplate
          identifier : 0x253c959c2dad6e9b
          internal_properties : 
          type : 4
          code_elements :
           type_code : 4
           p_codes :
            -
              code : |1+
               
               IF TableSelect(TABLE_ProjectTemplates)=-1 THEN RETURN
               
               // The input/selection row cannot be deleted
               IF TableSelect(TABLE_ProjectTemplates)>TableCount(TABLE_ProjectTemplates) THEN 
               	Info(<§$0005§>,<§$0004§>)
               	RETURN
               END
               
               IF Open("WIN_Form_ProjectTemplates","Modif") THEN
               	TableDisplay(TABLE_ProjectTemplates,taCurrentFirst)
               END
               
              type : 18
            -
              type : 161
              enabled : false
