 message_bar :
  internal_properties : BQAAAAUAAABqPQh6HC8RxAVkp2SqPYLuZrfVhd+1KX4lx22hIT8uqEpE6yP7Sbc2rmVqdmL816EWzXOkEe9ijOtYwchZKAfpy3B1cNqhpJgsnbUs
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      // Open the Table window
      PROCEDURE RADTable(FilterValue="")
      GLOBAL
      	gbLocalQuery is boolean = False				// Has the query been run?
      	gnTimerNum is int					// Number of the refresh timer
      	gnNoRef is int = 1500				// Time between 2 refresh operations (100th/sec)
      	gbManageAutoRef is boolean = False				// Management of refresh 
      	gnFileVersionNum is int = HVersion(DataItems)	// File version (for refresh)
      
      // Management of database access errors
      // Error messages returned by the database are displayed
      // Database error reviews can be processed here
      WHEN EXCEPTION
      	Error("An error occured in the window",ExceptionInfo(errMessage))
      	// Re-enable the exceptions
      	ExceptionEnable()
      	// Resume the process
      	ReturnToCapture()
      END
      
      
      // Specify the default initial filter
      InitialFilter(FilterValue)
      
      // Start the automatic refresh
      ManageRefresh(True)
   -
     code : |1-
      
     type : 34
   -
     code : |1-
      // Stop the automatic window refresh
      ManageRefresh(False)									
     type : 2
   -
     type : 230
     enabled : false
   -
     code : |1-
      // Refresh table data?
      Refresh()	
     type : 11
   -
     code : |1+
      
      
     type : 12
   -
     code : |1+
      
      
     type : 17
   -
     code : |1+
      
      
     type : 13
  procedures :
   -
     name : ManageRefresh
     procedure_id : 1153301781076443805
     type_code : 14
     code : |1-
      // Automatic refresh management
      PROCEDURE ManageRefresh(sAutoRefresh=False)
      
      // Store whether refresh must be managed or not 
      gbManageAutoRef = sAutoRefresh
      
      // Is a timer enabled?
      IF gnTimerNum > 0 THEN
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	ELSE		
      		// Stops the timer
      		EndTimerSys(gnTimerNum)
      		gnTimerNum= 0
      	END
      ELSE
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	END
      END
     type : 458752
   -
     name : SuspendRefresh
     procedure_id : 1153301781076509356
     type_code : 14
     code : |1-
      // Automatic refresh management
      PROCEDURE SuspendRefresh(sSuspend=True)
      
      // Suspend the refresh if this one is managed or restart it
      IF sSuspend = True THEN
      	IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer		
      	gnTimerNum = 0
      ELSE
      	// Reenable the timer (if managed)
      	IF gbManageAutoRef=True THEN
      		IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)		
      	END
      END
     type : 458752
   -
     name : Refresh
     procedure_id : 1153301781076574924
     type_code : 14
     code : |1-
      // Method called by the refresh timer
      PROCEDURE Refresh()
      // Stops the timer
      EndTimerSys(gnTimerNum)
      
      // If the user is not currently in edit
      IF TableInputInProgress(TABLE)=False THEN		
      	// If no modification was made by the user
      	// Was the file modified?
      	IF gnFileVersionNum < HVersion(DataItems) OR (DataItems..Type<>hFileNormal AND DataItems..Type<>hFileHF5) THEN
      		// Store the file version number
      		gnFileVersionNum = HVersion(DataItems)
      
      		// Refresh the table display
      		TableDisplay(TABLE,taCurrentSelection)
      		
      		// Other linked controls?
      		WHEN EXCEPTION IN 
      			ExecuteProcess("RADDisplay",trtProcedure)
      		DO
      			// Exception corresponding to an unknown procedure?
      			IF ExceptionInfo(errCode)<> 1027 THEN EXCEPTION
      		END
      	END
      END
      
      // Restart the timer
      IF gbManageAutoRef=True THEN
      	gnTimerNum = TimerSys("Refresh",gnNoRef)
      END
     type : 458752
   -
     name : InitialFilter
     procedure_id : 1153301781076640475
     type_code : 14
     code : |1+
      // Implement a filter on the table
      PROCEDURE InitialFilter(FilterVal)
      
      // Search for first "=" character (this character can be found in the filter value)
      nSeparatorPosition is int = Position(FilterVal,"=")
      
      // Is a filter required?
      IF NOT FilterVal~="" THEN
      	// Change the search key
      	Table..BrowsedItem = FilterVal[[1 TO (nSeparatorPosition-1)]]
      
      	// Filter the table content
      	Table..Filter = FilterVal[[(nSeparatorPosition+1) TO Length(FilterVal)]]
      	
      	// Store the specified search key (in case of empty file)
      	WHEN EXCEPTION IN
      		{Table..BrowsedFile+"."+Table..BrowsedItem}=FilterVal[[(nSeparatorPosition+1) TO Length(FilterVal)]]
      	DO
      		// May occur according to user preferences
      	END	
      END
     type : 458752
  procedure_templates : []
  property_templates : []
