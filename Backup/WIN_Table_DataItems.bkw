  -
    name : BTN_TableLink_WIN_Table_ForeignKey
    identifier : 0x200159dcd0e50194
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         // Stop the automatic window refresh
         SuspendRefresh(True)
         // open the window "WIN_Table_ForeignKey"
         nAliasName is string = "Link_DataItemsID_"+DataItems.DataItemsID
         nWindowTitle is string = "File Link {NOQUOTE_RAD_LINKKEY_SOURCE}: "+DataItems.DataItemsID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	IF TableSelect(TABLE)>=1 THEN	
         		MDIOpen(WIN_Table_ForeignKey ,nAliasName,nWindowTitle,"DataItemsID="+DataItems.DataItemsID)
         	END
         END
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
