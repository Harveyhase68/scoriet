window :
 name : WIN_JSON2PHP
 identifier : 0x2f7eef0b0188b277
 internal_properties : 
 controls :
  -
    name : SPLIT_NoName1
    identifier : 0x2f7eef6402a11004
    internal_properties : 
    type : 28
    code_elements :
     type_code : 61
     p_codes : []
  -
    name : EDT_JSON
    identifier : 0x2f7eef7d02d46e21
    internal_properties : 
    type : 2
    code_elements :
     type_code : 3
     p_codes :
      -
        type : 276
        enabled : false
      -
        type : 277
        enabled : false
      -
        type : 278
        enabled : false
      -
        code : |1-
         
         local
         	vContent is variant
         	sResult is string
         	
         WHEN EXCEPTION in
         	vContent=JSONToVariant(EDT_JSON)
         do
         	EDT_PHP="//error"
         	return
         END
         
         sResult="$data = [];"+crlf
         sResult+=MakePHPAssociativeArray((vContent)) //, arrEmpty)
         EDT_PHP=sResult
         
         internal procedure MakePHPAssociativeArray(vData is variantMember, arrIdent is array of string=null)
         
         private
         	sBuffer is string
         	vSub is variantmember
         	zz is int
         	if arrIdent=null then
         		arrIdent = new dynamic array of 0 string
         	END
         	zz=0
         	for EACH vSub OF vData..Member
         		zz++
         		if vSub..Name="status" then stop
         		switch vSub..Type
         			case wlVariantArray //142
         				//array
         				sBuffer+="$data"
         				for i=1 to Dimension(arrIdent)
         					sBuffer+="["""+arrIdent[i]+"""]"
         				END
         				sBuffer+=" += ["""+vSub..Name+"""=>[]];"+CRLF
         				ArrayAddLine(arrIdent,vSub..Name)
         				for i=1 to vSub..Occurrence
         					ArrayAddLine(arrIdent,NumToString(i-1,"d"))
         					sBuffer+="$data"
         					FOR t=1 TO Dimension(arrIdent)
         						sBuffer+="["""+arrIdent[t]+"""]"
         					END
         					sBuffer+=" = [];"+CRLF
         					sBuffer+=MakePHPAssociativeArray((vSub[i]),arrIdent)
         					ArrayDelete(arrIdent,Dimension(arrIdent))
         				END
         				ArrayDelete(arrIdent,Dimension(arrIdent))
         			case wlVariantObject //143
         				//Object
         				sBuffer+="$data"
         				FOR i=1 TO Dimension(arrIdent)
         					sBuffer+="["""+arrIdent[i]+"""]"
         				END
         				IF bNoPlusSign AND zz=1 THEN
         					sBuffer+=" = ["""+vSub..Name+"""=>[]];"+CRLF
         				else
         					sBuffer+=" += ["""+vSub..Name+"""=>[]];"+CRLF
         				END
         				ArrayAddLine(arrIdent,vSub..Name)
         				sBuffer+=MakePHPAssociativeArray((vSub),arrIdent)
         				ArrayDelete(arrIdent,Dimension(arrIdent))
         			case wlBoolean
         				//Simple type, boolean
         				sBuffer+="$data"
         				FOR i=1 TO Dimension(arrIdent)
         					sBuffer+="["""+arrIdent[i]+"""]"
         				END
         				IF bNoPlusSign AND zz=1 THEN
         					if vSub..Value then
         						sBuffer+=" = ["""+vSub..Name+"""=>true];"+CRLF
         					else
         						sBuffer+=" = ["""+vSub..Name+"""=>false];"+CRLF
         					end
         				ELSE
         					IF vSub..Value THEN
         						sBuffer+=" += ["""+vSub..Name+"""=>true];"+CRLF
         					else
         						sBuffer+=" += ["""+vSub..Name+"""=>false];"+CRLF
         					end
         				END
         			CASE wlInt,wlInt_1,wlInt_2,wlInt_4,wlInt_8,wlReal,wlCurrency,wlNumeric //Integer
         				//Simple type, numeric
         				sBuffer+="$data"
         				FOR i=1 TO Dimension(arrIdent)
         					sBuffer+="["""+arrIdent[i]+"""]"
         				END
         				IF bNoPlusSign AND zz=1 THEN
         					sBuffer+=" = ["""+vSub..Name+"""=>"+vSub..Value+"];"+CRLF
         				else
         					sBuffer+=" += ["""+vSub..Name+"""=>"+vSub..Value+"];"+CRLF
         				end
         			case 16,19,wlCharacter,wlDate,wlDateTime,wlTime,wlSQLQuery,wlUUID,wlUUID_128,wlUUID_256 //String = wlString but be careful!!
         				//Simple type, char, string
         				sBuffer+="$data"
         				FOR i=1 TO Dimension(arrIdent)
         					sBuffer+="["""+arrIdent[i]+"""]"
         				END
         				if bNoPlusSign and zz=1 then
         					sBuffer+=" = ["""+vSub..Name+"""=>"""+vSub..Value+"""];"+CRLF
         				else
         					sBuffer+=" += ["""+vSub..Name+"""=>"""+vSub..Value+"""];"+CRLF
         				END
         			case wlEmpty
         				sBuffer+="$data"
         				FOR i=1 TO Dimension(arrIdent)
         					sBuffer+="["""+arrIdent[i]+"""]"
         				END
         				IF bNoPlusSign AND zz=1 THEN
         					sBuffer+=" = ["""+vSub..Name+"""=>NULL];"+CRLF
         				ELSE
         					sBuffer+=" += ["""+vSub..Name+"""=>NULL];"+CRLF
         				END
         			OTHER CASE
         				info("ERROR ")
         		end
         	end
         
         	result sBuffer
         end
        type : 17
