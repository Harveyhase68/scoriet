  -
    name : BTN_NoName2
    identifier : 0x225150f11722bc87
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sBitmapInfo is string
         	w is int
         	h is int
         	rw is int
         	rh is int
         	nh is int
         	nw is int
         	sFileName is string="C:\Users\Alex\Pictures\eBay\Philips Walkman\2013-08-30 11.58.01.jpg"	
         
         sBitmapInfo=BitmapInfo(sFileName)
         w=Val(ExtractString(sBitmapInfo, 2))
         h=Val(ExtractString(sBitmapInfo, 3))
         IF GetRatio(w,h,rw,rh) THEN
         	nw=w/100*80
         	nh=(nw/rw)*rh
         END
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_NoName3
    identifier : 0x2254545b00f979a2
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sResult is string
         	sHeader is string
         
         if HTTPRequest("http://localhost/naboo/login.php","Mozilla/5.0 (compatible; MSIE 10.0; Windows NT 6.1; WOW64; Trident/6.0)","","user=harvey&pw=prcode") then
         	sResult=HTTPGetResult(httpResult)
         	sHeader=HTTPGetResult(httpHeader)
         	Info(sResult)
         ELSE
         	Info("Fehler beim Kontakten der angegebenen Webseite!")
         END
         
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_NoName4
    identifier : 0x22ee1ae101ea9c0b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sSource is string
         	
         sSource="WHEN EXCEPTION IN"+crlf
         sSource+="For i=1 to 2"+crlf
         sSource+="info({ABC})"+crlf
         sSource+="END"+crlf
         sSource+="DO"+crlf
         sSource+="ExceptionPropagate(""Fehler"")"+crlf
         sSource+="END"+crlf
         
         WHEN EXCEPTION IN
         	ExecuteCode(sSource)	
         DO
         	info(ExceptionInfo(errFullDetails))
         END
         
         
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_NoName5
    identifier : 0x233bab8d0119d3f4
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         j is int
         dt is Date = DateSys()
         sDT is string
         
         grParameter(myChart,grOptimizedMarksY)
         grParameter(myChart,grOptimizedMarksX)
         
         sData is string = "1;2;3;Null;5;6;7;8;9;Null;11;12"		// null data is entered as a space or "" or Null
         sUL is string = "7;7;7;7;7;7;7;7;7;7;7;7"
         sLL is string = "3;3;3;3;3;3;3;3;3;3;3;3"
         
         grSourceSeries(myChart,1,grProgramming,sData)
         grSourceSeries(myChart,2,grProgramming,sUL)
         grSourceSeries(myChart,3,grProgramming,sLL)
         
         grSeriesLabel(myChart,1,"Temp")
         grSeriesLabel(myChart,2,"Upper Limit")
         grSeriesLabel(myChart,3,"Lower Limit")
         
         FOR j =1 TO 11
         	
         	sDT = DateToString(dt,"M/D/YY")
         	//TableAddLine(myChart, sDT , 5 )
         	
         	grCategoryLabel(myChart, j, sDT)
         
         	dt..Day += 1	
         	
         END
         
         grOrigin(myChart,0,15,grYCoordinate)
         
         grDraw(myChart)
        type : 18
      -
        type : 161
        enabled : false
