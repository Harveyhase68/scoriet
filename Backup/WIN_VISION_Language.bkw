     code : |1+
      // Summary: Opens the Vision window of Language
      // Syntax:
      //WIN_Vision_Language ()
      //
      // Parameters:
      //	None
      // Return value:
      // 	None
      //
      // Example:
      // Open(WIN_Vision_Language)
      //
      // Automatic process of errors: display the error, then exit or restart the application
      //
      
      PROCEDURE WIN_VISION_Language()
   -
     code : |1+
      // Position on the current record
      TableDisplay(TABLE_Language,taCurrentFirst)
      
      // Default return value
      MyWindow..ReturnedValue = False
