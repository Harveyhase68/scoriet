      secure[228]="94"
      secure[229]="N2"
      secure[230]="N1"
      secure[231]="U4"
      secure[232]="R1"
      secure[233]="2Y"
      secure[234]="5H"
      secure[235]="WP"
      secure[236]="2X"
      secure[237]="FA"
      secure[238]="2U"
      secure[239]="RV"
      secure[240]="M6"
      secure[241]="RT"
      secure[242]="FD"
      secure[243]="DR"
      secure[244]="1J"
      secure[245]="WW"
      secure[246]="9V"
      secure[247]="T6"
      secure[248]="4A"
      secure[249]="VU"
      secure[250]="17"
      secure[251]="UY"
      secure[252]="K3"
      secure[253]="AA"
      secure[254]="VE"
      secure[255]="HE"
      secure[256]="EJ"
      
      FOR i=1 TO Length(pScrambledPassword) STEP 2
      	test=FindItembyChr(secure,pScrambledPassword[[i on 2]])
      	anzahl=anzahl+1
      	if test>0 then
      		t[anzahl]=test-1
      	end
      END
      
      pPassword=""
      FOR i= anzahl TO 1 STEP -1
      	IF i=1 THEN
      		test=BinaryXOR(t[i],99)
      	ELSE
      		test=BinaryXOR(t[i],t[i-1])
      	END
      	pPassword=charact(BinaryXOR(test,i*2))+pPassword
      END
      
      RESULT pPassword
     type : 458752
   -
     name : FindItemByChr
     procedure_id : 1545699772819035887
     type_code : 15
     code : |1+
      PROCEDURE FindItemByChr(pArray,pChar)
      
      LOCAL
      	i is int
      
      FOR i=1 TO Dimension(pArray)
      	IF pArray[i]=pChar THEN
      		RESULT i
      	END
      END
      
      RESULT 0
     type : 458752
