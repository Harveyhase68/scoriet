   -
     name : AddProjectList
     procedure_id : 1571126430347665262
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //AddProjectList ( [<sNewProjectName> is string])
      //
      // Parameters:
      //	sNewProjectName (ANSI string - default value=""): <specify the role of sNewProjectName>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE AddProjectList(sNewProjectName is string="")
      
      local
      	stProjects is structure
      		sProjectName is string
      		dtDateTime is datetime
      	END
      	arrProjects is dynamic array of 0 stprojects
      	s is string
      	zz is int
      	n is int
      	v is int
      	
      v=HSavePosition(Project)	
      
      for i=1 to 10
      	s=INIRead("Scoriet","LastProjectName"+NumToString(i,"d"),"",gsIniFile)
      	if s<>"" then
      		zz++
      		Dimension(arrProjects,zz)
      		arrProjects[zz].sProjectName=s
      		arrProjects[zz].dtDateTime=INIRead("Scoriet","LastProjectDate"+NumToString(i,"d"),"",gsIniFile)
      	END
      END
      
      if sNewProjectName<>"" then
      	n=arrayseek(arrProjects,asLinear,"sProjectName",sNewProjectName)
      	if n<>-1 then
      		arrProjects[n].dtDateTime=datesys()+timesys()
      	else
      		Dimension(arrProjects,Dimension(arrProjects)+1)
      		arrProjects[Dimension(arrProjects)].sProjectName=sNewProjectName
      		arrProjects[Dimension(arrProjects)].dtDateTime=DateSys()+TimeSys()
      	END
      end
      
      zz=0
      loop
      	zz++
      	if zz>Dimension(arrProjects) then break
      	hreadseek(Project,ProjectName,arrProjects[zz].sProjectName,hIdentical)
      	if not hfound(Project) then
      		ArrayDelete(arrProjects,zz)
      		zz=0
      	END
      end
      
      if Dimension(arrProjects)>0 then
      	ArraySort(arrProjects,asMember,"-dtDateTime")
      END
      
      for i=1 to 10
      	if Dimension(arrProjects)>=i then
      		INIWrite("Scoriet","LastProjectName"+NumToString(i,"d"),arrProjects[i].sProjectName,gsIniFile)
      		iNIWrite("Scoriet","LastProjectDate"+NumToString(i,"d"),arrProjects[i].dtDateTime,gsIniFile)
      	else
      		INIWrite("Scoriet","LastProjectName"+NumToString(i,"d"),"",gsIniFile)
      		INIWrite("Scoriet","LastProjectDate"+NumToString(i,"d"),"",gsIniFile)
      	end
      END
      
      HRestorePosition(v)
     type : 458752
   -
     name : CheckProject
     procedure_id : 1573089505123728355
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] CheckProject ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CheckProject()
      
      if WinStatus(WIN_Main)<>NotFound then
      	IF WIN_Main.COMBO_Project=0 THEN
      		Info("Bitte wählen Sie ein Projekt aus!")
      		SendMessage(Handle(WIN_Main.COMBO_Project),513,0,0)
      		result false
      	else
      		hreadseek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
      		if hfound(Project) then
      			gnProjectID=Project.ProjectID
      			result true
      		END
      	end
      	RESULT True
      else
      	if ontestmode() then
      		gnProjectID=gnTestProjectID
      		result true
      	else
      		result false
      	END
      end
     type : 458752
   -
     name : CheckProjectTemplates
     procedure_id : 1582429469857594959
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //CheckProjectTemplates (<nProjectID>)
      //
      // Parameters:
      // 	nProjectID: <specify the role of nProjectID>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CheckProjectTemplates(nProjectID)
      
      hreadseek(Project,ProjectID,nProjectID,hIdentical)
      if hfound(Project) then
      	//ProjectID+VersionNo
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	IF HFound(Version) THEN
      		HFilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
      		HReadFirst(ProjectTemplates,ProjectTemplateKey)
      		WHILE NOT HOut(ProjectTemplates)
      			HReadSeek(Template,TemplateID,ProjectTemplates.TemplateID,hIdentical)
      			//VersionID+FileName
      			if hfound(Template) then
      				HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMinVal))
      				if not hout(DataFile) then
      					IF DataFile.VersionID=Version.VersionID THEN
      						//TemplateID+TemplatePageID
      						HFilter(TemplatePage,TemplatePageKey,HBuildKeyValue(TemplatePage,TemplatePageKey,Template.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKey,Template.TemplateID,hMaxVal))
      						HReadFirst(TemplatePage,TemplatePageKey)
      						WHILE NOT HOut(TemplatePage)
      							//DataFileTypeDetails
      							//DataFileTypeDetailsKey
      							//DataFileID+TemplatePageID
      							HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TemplatePage.TemplatePageID),hIdentical)
      							IF NOT HFound(DataFileTypeDetails) THEN
      								UpdateAll()
      								return
      							END
      							HReadNext(TemplatePage,TemplatePageKey)
      						END
      						HDeactivateFilter(TemplatePage)
      					END
      				end
      			end
      			HReadNext(ProjectTemplates,ProjectTemplateKey)
      		END
      		HDeactivateFilter(ProjectTemplates)
      	END
      end
     type : 458752
   -
     name : Win32_UUID
     procedure_id : 1699167355272338016
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] Win32_UUID ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE Win32_UUID()
      
      LOCAL	
      	s is string
      	r1 is string
      	r2 is string
      	m is string
      	
      WMIClasse, WMIClasseProperties, VBSFieldList are strings
      WMIClasse="Win32_ComputerSystemProduct"
      WMIClasseProperties = "" + ...
      "string Uuid;"+...
      ""
      
      WMIClasseProperties = NoSpace(WMIClasseProperties)
      IF Right(WMIClasseProperties,1) = ";" THEN WMIClasseProperties = WMIClasseProperties[[ 1 TO Length(WMIClasseProperties)-1]]
      VBSFieldList = _CreateVbsLoop(WMIClasseProperties)
      s=_ExecuteVbs(NetMachineName(), WMIClasse,  VBSFieldList, WMIClasseProperties)
      
      r1=ExtractString(s,1,CRLF)
      r2=ExtractString(s,2,CRLF)
      
      m=ExtractString(r2,1,TAB)
      
      RESULT m
     type : 458752
   -
     name : HistoryAdd
     procedure_id : 1802141167632350215
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] HistoryAdd (<nType> is int [, <bVorherNicht> is boolean])
      //
      // Parameters:
      //	nType (int):<specify the role of sTypeOfChange>
      //	bVorherNicht (boolean - default value=0):<specify the role of bVorherNicht>
      // Return Value:
      // 	Unspecified Type: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	arrNachher: <specify the role of arrNachher>
      PROCEDURE HistoryAdd(nType is int, bVorherNicht is boolean=false)
      
      local
      	xmlRecord is string
      	sXMLDoc is string="XML"
      	bufBufferVorher is buffer
      	bufBufferNachher is buffer
      	bArrayDone is boolean
      	
      if nType=2 or nType=3 and not bVorherNicht then
      	HReadSeek(DataFile,DataFileID,gaaHistoryNachher["DataFileID"],hIdentical)
      	IF HFound(DataFile) THEN
      		WHEN EXCEPTION IN
      			xmlRecord=HRecordToXML(DataFile,"",charsetAnsi)
      			xmlRecord=StringToUTF8(xmlRecord)
      			XMLDocument("XMLDoc", xmlRecord)
      			XMLFirst("XMLDoc")
      			XMLChild("XMLDoc")
      			XMLFirst("XMLDoc")
      			WHILE NOT XMLOut("XMLDoc")
      				gaaHistoryVorher[XMLElementName("XMLDoc")]=XMLData("XMLDoc")
      				XMLNext("XMLDoc")
      			END
      			XMLClose("XMLDoc")
      		do
      		end
      	end
      end
      
      switch nType
      	case 1
      		//Add
      		FOR EACH ELEMENT vSValue,sKey,nCounter OF gaaHistoryNachher
      			IF NOT bArrayDone THEN
      				gnAktuelleHistoryNr++
      				Dimension(garrHistory,gnAktuelleHistoryNr)
      				ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsVorher)
      				ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsNachher)
      				garrHistory[gnAktuelleHistoryNr].nType=nType
      				bArrayDone=True
      			END
      			garrHistory[gnAktuelleHistoryNr].aaControlsNachher[sKey]=gaaHistoryNachher[sKey]
      			{"DataFile." + sKey,indItem}=gaaHistoryNachher[sKey]
      		END
      		hadd(DataFile)
      		gbEtiketteChanged=True
      		garrHistory[gnAktuelleHistoryNr].DataFileID=DataFile.DataFileID
      		HModify(DataFile)
      	case 2
      		//Change
      		FOR EACH ELEMENT sValue,sKey,nCounter OF gaaHistoryVorher
      			IF gaaHistoryNachher[sKey]..Exist THEN
      				switch sKey
      					case "Bild"
      						WHEN EXCEPTION IN
      							if gaaHistoryVorher["Bild"]<>"" then
      								bufBufferVorher=gaaHistoryVorher["Bild"]
      							end
      							if gaaHistoryNachher["Bild"]<>"" then
      								bufBufferNachher=gaaHistoryNachher["Bild"]
      							end
      							IF bufBufferVorher<>bufBufferNachher THEN		
      								IF NOT bArrayDone THEN
      									gnAktuelleHistoryNr++
      									Dimension(garrHistory,gnAktuelleHistoryNr)
      									ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsVorher)
      									ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsNachher)
      									garrHistory[gnAktuelleHistoryNr].DataFileID=gaaHistoryNachher["DataFileID"]
      									garrHistory[gnAktuelleHistoryNr].nType=nType
      									bArrayDone=true
      								END
      								garrHistory[gnAktuelleHistoryNr].aaControlsVorher[skey]=gaaHistoryVorher["Bild"]
      								garrHistory[gnAktuelleHistoryNr].aaControlsNachher[skey]=gaaHistoryNachher["Bild"]
      								{"DataFile." + sKey,indItem}=gaaHistoryNachher[sKey]
      								gbEtiketteChanged=True
      							END
      						do
      						end
      					OTHER CASE
      						IF gaaHistoryNachher[sKey]<>sValue THEN
      							IF NOT bArrayDone THEN
      								gnAktuelleHistoryNr++
      								Dimension(garrHistory,gnAktuelleHistoryNr)
      								ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsVorher)
      								ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsNachher)
      								garrHistory[gnAktuelleHistoryNr].DataFileID=gaaHistoryNachher["DataFileID"]
      								garrHistory[gnAktuelleHistoryNr].nType=nType
      								bArrayDone=True
      							END
      							garrHistory[gnAktuelleHistoryNr].aaControlsVorher[sKey]=gaaHistoryVorher[sKey]
      							garrHistory[gnAktuelleHistoryNr].aaControlsNachher[sKey]=gaaHistoryNachher[sKey]
      							{"DataFile." + sKey,indItem}=UTF8ToAnsi(gaaHistoryNachher[sKey])
      							gbEtiketteChanged=True
      						END
      				END
      			END
      		END
      		HModify(DataFile)
      	case 3
      		//Delete
      		FOR EACH ELEMENT vSValue,sKey,nCounter OF gaaHistoryVorher
      			IF NOT bArrayDone THEN
      				gnAktuelleHistoryNr++
      				Dimension(garrHistory,gnAktuelleHistoryNr)
      				ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsVorher)
      				ArrayDeleteAll(garrHistory[gnAktuelleHistoryNr].aaControlsNachher)
      				garrHistory[gnAktuelleHistoryNr].DataFileID=gaaHistoryNachher["DataFileID"]
      				garrHistory[gnAktuelleHistoryNr].nType=nType
      				bArrayDone=True
      			END
      			garrHistory[gnAktuelleHistoryNr].aaControlsVorher[sKey]=UTF8ToAnsi(gaaHistoryVorher[sKey])
      		END
      		hdelete(DataFile)
      		gbEtiketteChanged=True
      		gsTargetControl=""
      end
      
      ArrayDeleteAll(gaaHistoryNachher)
      ArrayDeleteAll(gaaHistoryVorher)
      
      WIN_Designer.BTN_BACK..State=Grayed
      WIN_Designer.BTN_FORWARD..State=Grayed
      IF Dimension(garrHistory)>0 THEN
      	WIN_Designer.BTN_BACK..State=Active
      END
      IF Dimension(garrHistory)>gnAktuelleHistoryNr THEN
      	WIN_Designer.BTN_FORWARD..State=Active
      END
      
      RESULT DataFile.DataFileID
     type : 458752
   -
     name : HistoryTakeBack
     procedure_id : 1802141171927383594
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //HistoryTakeBack ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	arrNachher: <specify the role of arrNachher>
      //	nType (int): <specify the role of sTypeOfChange>
      PROCEDURE HistoryTakeBack()
      
      switch garrHistory[gnAktuelleHistoryNr].nType
      	case 1
      		//Add, bestehendes Feld löschen...
      		hreadseek(DataFile,DataFileID,garrHistory[gnAktuelleHistoryNr].DataFileID,hIdentical)
      		if hfound(DataFile) THEN
      			hdelete(DataFile)
      		END
      		gnAktuelleHistoryNr--
      		gsTargetControl=""
      		WIN_Designer.DisplayObjects()
      	case 2
      		//Change, Änderungen rückgängig machen...
      		hreadseek(DataFile,DataFileID,garrHistory[gnAktuelleHistoryNr].DataFileID,hIdentical)
      		if hfound(DataFile) then
      			FOR EACH ELEMENT vSValue,sKey,nCounter OF garrHistory[gnAktuelleHistoryNr].aaControlsVorher
      				switch sKey
      					case "Bild"
      						{"DataFile." + sKey,indItem}=garrHistory[gnAktuelleHistoryNr].aaControlsVorher[sKey]
      					OTHER CASE
      						{"DataFile." + sKey,indItem}=UTF8ToAnsi(garrHistory[gnAktuelleHistoryNr].aaControlsVorher[sKey])
      				END
      			end
      			HModify(DataFile)
      		end
      		gnAktuelleHistoryNr--
      		WIN_Designer.Display(DataFile.DataFileID)
      		WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
      		WIN_Designer.IW_InternalWindow1.AnzeigenControl("OBJEKT"+DataFile.DataFileID)
      	case 3
      		//Delete, schon gelöschtes Feld wiederherstellen...
      		FOR EACH ELEMENT vSValue,sKey,nCounter OF garrHistory[gnAktuelleHistoryNr].aaControlsVorher
      			{"DataFile." + sKey,indItem}=garrHistory[gnAktuelleHistoryNr].aaControlsVorher[sKey]
      		END
      		hadd(DataFile)
      		garrHistory[gnAktuelleHistoryNr].DataFileID=DataFile.DataFileID
      		garrHistory[gnAktuelleHistoryNr].aaControlsVorher["DataFileID"]=DataFile.DataFileID
      		garrHistory[gnAktuelleHistoryNr].aaControlsVorher["DataFileID"]="OBKJEKT"+NumToString(DataFile.DataFileID,"d")
      		HModify(DataFile)
      		gnAktuelleHistoryNr--
      		gsTargetControl=""
      		WIN_Designer.DisplayObjects()
      		WIN_Designer.Display(DataFile.DataFileID)
      		WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
      		WIN_Designer.IW_InternalWindow1.AnzeigenControl("OBJEKT"+DataFile.DataFileID)
      end
      
      WIN_Designer.BTN_BACK..State=Grayed
      WIN_Designer.BTN_FORWARD..State=Grayed
      IF gnAktuelleHistoryNr>0 THEN
      	WIN_Designer.BTN_BACK..State=Active
      END
      IF Dimension(garrHistory)>gnAktuelleHistoryNr THEN
      	WIN_Designer.BTN_FORWARD..State=Active
      END
     type : 458752
   -
     name : HistoryTakeForward
     procedure_id : 1802141171927449474
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //HistoryTakeForward ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	arrNachher: <specify the role of arrNachher>
      //	nType (int): <specify the role of sTypeOfChange>
      PROCEDURE HistoryTakeForward()
      
      gnAktuelleHistoryNr++
      switch garrHistory[gnAktuelleHistoryNr].nType
      	case 1
      		//Add
      		FOR EACH ELEMENT vSValue,sKey,nCounter OF garrHistory[gnAktuelleHistoryNr].aaControlsNachher
      			{"DataFile." + sKey,indItem}=garrHistory[gnAktuelleHistoryNr].aaControlsNachher[sKey]
      		END
      		HAdd(DataFile)
      		garrHistory[gnAktuelleHistoryNr].DataFileID=DataFile.DataFileID
      		garrHistory[gnAktuelleHistoryNr].aaControlsVorher["DataFileID"]=DataFile.DataFileID
      		garrHistory[gnAktuelleHistoryNr].aaControlsVorher["DataFileID"]="OBKJEKT"+NumToString(DataFile.DataFileID,"d")
      		garrHistory[gnAktuelleHistoryNr].aaControlsNachher["DataFileID"]=DataFile.DataFileID
      		garrHistory[gnAktuelleHistoryNr].aaControlsNachher["DataFileID"]="OBKJEKT"+NumToString(DataFile.DataFileID,"d")
      		HModify(DataFile)
      		gsTargetControl=""
      		WIN_Designer.DisplayObjects()
      		WIN_Designer.Display(DataFile.DataFileID)
      		WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
      		WIN_Designer.IW_InternalWindow1.AnzeigenControl("OBJEKT"+DataFile.DataFileID)
      	case 2
      		//Change
      		hreadseek(DataFile,DataFileID,garrHistory[gnAktuelleHistoryNr].DataFileID,hIdentical)
      		if hfound(DataFile) then
      			FOR EACH ELEMENT vSValue,sKey,nCounter OF garrHistory[gnAktuelleHistoryNr].aaControlsNachher
      				switch sKey
      					case "Bild"
      						{"DataFile." + sKey,indItem}=garrHistory[gnAktuelleHistoryNr].aaControlsNachher[sKey]
      					OTHER CASE
      						{"DataFile." + sKey,indItem}=UTF8ToAnsi(garrHistory[gnAktuelleHistoryNr].aaControlsNachher[sKey])
      				END
      			end
      			HModify(DataFile)
      		end
      		WIN_Designer.Display(DataFile.DataFileID)
      		WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
      		WIN_Designer.IW_InternalWindow1.AnzeigenControl(DataFile.DataFileID)
      	case 3
      		//Delete
      		HReadSeek(DataFile,DataFileID,garrHistory[gnAktuelleHistoryNr].DataFileID,hIdentical)
      		IF HFound(DataFile) THEN
      			HDelete(DataFile)
      		END
      		gsTargetControl=""
      		WIN_Designer.DisplayObjects()
      end
      
      WIN_Designer.BTN_BACK..State=Grayed
      WIN_Designer.BTN_FORWARD..State=Grayed
      IF gnAktuelleHistoryNr>0 THEN
      	WIN_Designer.BTN_BACK..State=Active
      END
      IF Dimension(garrHistory)>gnAktuelleHistoryNr THEN
      	WIN_Designer.BTN_FORWARD..State=Active
      END
     type : 458752
   -
     name : SetScrollValueH
     procedure_id : 1802426791555513804
     type_code : 15
     code : |1-
