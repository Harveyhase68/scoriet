   -
     name : LizenzCheck
     procedure_id : 1545703938937430351
     type_code : 15
     code : |1+
      
      PROCEDURE LizenzCheck(sNr, sName)
      
      LOCAL
      	lizcalc is string
      	i is int
      	t is int
      	quer is 8-byte int
      	Rest is int
      	A1 is int
      	A2 is int
      	A3 is int
      	A4 is int
      	calcn1 is int
      	calcn2 is int
      	ok is boolean
      	n is int
      
      IF Length(sNr)<>9 THEN
      	RESULT False
      END
      
      IF sName="" THEN
      	RESULT False
      END
      
      //Hole die Optionen und auch die Lizenz
      lizcalc=ScorietUnScramble(Middle(sNr,1,4)+Middle(sNr,6,4))
      
      n=Length(NoSpace(sName))
      FOR i=1 TO n
      	quer=quer+Asc(Middle(sName,i,1))
      END
      
      A1=Asc(Middle(lizcalc,2,1))
      A2=Asc(Middle(lizcalc,3,1))
      
      IF quer<0 THEN
      	//Minus korrigieren...
      	quer=quer+4294967296
      END
      
      A4=IntegerPart(quer/16777216)
      Rest=quer-(A4*16777216)
      A3=IntegerPart(Rest/65536)
      Rest=Rest-(A3*65536)
      A2=IntegerPart(Rest/256)
      Rest=Rest-(A2*256)
      A1=Rest
      
      t=modulo(A1+A2,255) //Checksum..
      i=modulo(A3+A4,255) //Checksum..
      
      calcn1=Asc(Middle(lizcalc,2,1))
      calcn2=Asc(Middle(lizcalc,3,1))
      
      IF t<>calcn1 OR i<>calcn2 THEN
      	ok=False
      ELSE
      	ok=True
      END
      
      RESULT ok
     type : 458752
   -
     name : LizenzCheck_Local
     procedure_id : 1545703938937495981
     type_code : 15
     code : |1+
      Procedure LizenzCheck_Local(bCheckLicense=true)
      	
      if bCheckLicense then
      	if not LizenzCheck(gsLicenseNo,gsEmail) then
      		result false
      	end
      end
      
      RESULT True
