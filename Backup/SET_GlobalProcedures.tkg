      	case "{nmaxitemsmasterdetail}"
      		RESULT "vProjektVars.nMaxItemsMasterDetail"
      	CASE "{nmaxitemsmasterdetailnokeys}"
      		RESULT "vProjektVars.nMaxItemsMasterDetailNoKey"
      	case "{nmaxkeyssegment}"
      		RESULT "dimension(arrKeys[nCountKeys].arrFields)"
      		
      	CASE "{projectname}"
      	    RESULT "vProject.sProjectName"
      	CASE "{projectdataversioin}"
      		RESULT "vProject.nVersionNo"
      	CASE "{projectdirectory}"
      	    RESULT "vProject.sDirectory"
      	CASE "{projecturl}"
