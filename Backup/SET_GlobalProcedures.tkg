     name : GetPixelWidth
     procedure_id : 1539229554959068025
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetPixelWidth (<hdc> is int, <sText> is string, <sFontName> is string, <cSize> is real, <bBold> is boolean, <bUnterline> is boolean, <bItalic> is boolean)
      //
      // Parameters:
      //	hdc (int): <specify the role of sControlName>
