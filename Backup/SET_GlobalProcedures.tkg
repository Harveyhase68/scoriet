      // Summary: <specify the procedure action>
      // Syntax:
      //Hilfe ( [<nContext> is int])
      //
      // Parameters:
      //	nContext (int - default value=173): <specify the role of nContext>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE Hilfe(nContext is int=110)
      
      LOCAL
      	nHH_DISPLAY_TOPIC is int = 0x0
      	nHH_SET_WIN_TYPE is int = 0x4
      	nHH_GET_WIN_TYPE is int = 0x5
      	nHH_GET_WIN_HANDLE is int = 0x6
      	nHH_DISPLAY_TEXT_POPUP is int = 0xE //Display string resource ID or text in a pop-up window.
      	nHH_DISPLAY_INDEX is int = 0x2
      	HH_HELP_CONTEXT is int = 0xF //Display mapped numeric value in dwData.
      	nHH_TP_HELP_CONTEXTMENU is int = 0x10 //Text pop-up help, similar to WinHelp's HELP_CONTEXTMENU.
      	nHH_TP_HELP_WM_HELP is int = 0x11 //text pop-up help, similar to WinHelp's HELP_WM_HELP.
      	nHH_CLOSE_ALL is int = 0x12
      	sHelpFile is string
      	
      switch gnLanguage
      	case 1
      		//German
      		sHelpFile=CompleteDir(fExeDir())+"Scoriet_DE.chm"
      	case 3
      		//English
      		sHelpFile=CompleteDir(fExeDir())+"Scoriet_EN.chm"
      	OTHER CASE
      END
      
      if nContext=0 then
      	CallDLL32("hhctrl.ocx","HtmlHelpA",0, sHelpFile, nHH_DISPLAY_TOPIC, 110)
      else
      	CallDLL32("hhctrl.ocx","HtmlHelpA",0, sHelpFile, HH_HELP_CONTEXT, nContext)
      END
      
      
     type : 458752
   -
     name : Database_Classic
     procedure_id : 1487629757684911527
     type_code : 15
     code : |1-
      // Syntax:
      //[ <Result> = ] Database_Classic (<sVerzeichnis>)
      //
      // Parameters:
      //	sVerzeichnis: <specify the role of sVerzeichnis>
      // Return Value:
      // 	boolean: // 	None
      
      //	bFortschritt (default value=1): <specify the role of bFortschritt>
      PROCEDURE Database_Classic(sVerzeichnis)
      
      LOCAL
      	err is boolean
      	s is string
      	u is string
      	i is int
      	zz is int
      	n is int
      
      err=False
      s=HListFile(hLstAll+hLstSorted)
      
      n=StringCount(s,CR)+1
      FOR i=1 TO n
      	zz++
      
      	u=ExtractString(s,i,CR)
      	
      	when exception in
      		{u,indFile}..Connection=""
      	do
      		if val(herror(hErrCurrent))=72136 then
      			Database_Classic_Upgrade()
      		END
      	end
      	
      	hchangedir(u,sVerzeichnis)
      	
      	IF NOT fFileExist(CompleteDir(sVerzeichnis)+u+".FIC") THEN
      		WHEN EXCEPTION IN
      			IF NOT HCreationIfNotFound(u,gsDBPassword) THEN
      				Info(<§@1fb8c9cd011e86710000§>+u,HErrorInfo())
      				result false
      			end
      			HPass(u,gsDBPassword)
      			//HChangePassword(u,"")
      		DO
      			IF Val(HError(hErrCurrent))=70016 THEN
      				Database_Classic_Upgrade()
      			END
      			IF Val(HError(hErrCurrent))=70052 OR Val(HError(hErrCurrent))=70302 OR Val(HError(hErrCurrent))=70303 THEN
      				HIndex(u,hNdxCompact+hNdxDelete+hCheckMemo)
      			END
      			IF Val(HError(hErrCurrent))=70720 THEN
      				//Index in Progress
      				result false
      			END
      			IF NOT HCreationIfNotFound(u,gsDBPassword) THEN 
      				Info(<§@1fb8c9cd011e86710001§>+u,HErrorInfo())	
      				result false
      			END
      		END
      	END
      	
      	IF NOT fFileExist(CompleteDir(sVerzeichnis)+u+".NDX") THEN
      		HIndex(u,hNdxCompact+hNdxDelete+hCheckMemo)
      	END
      	
      	WHEN EXCEPTION IN
      		HDeactivateFilter(u)
      	DO
      		IF Val(HError(hErrCurrent))=70016 THEN
      			Database_Classic_Upgrade()
      		END		
      	END
      
      end
      
      result true
     type : 458752
   -
     name : Database_Classic_Upgrade
     procedure_id : 1487629757684977172
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //Database_Classic_Upgrade ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      Procedure Database_Classic_Upgrade()
      
      local
      	exestring is string
      
      IF YesNo(<§@1fb8c9cd011e86710002§>+CRLF+CRLF+<§@1fb8c9cd011e86710003§>+crlf+crlf+<§@1fb8c9cd011e86710004§>)=Yes THEN
      	//ShellExecute(CompleteDir(fexedir())+"WDModFic.EXE")
      	exestring=StringBuild("""WDModFic.EXE"" -error -report -subdir -backup -nowizard -noprogress /WDD=""%1"" /DIR=""%2""",gsExePath+"TotalSourceMaker.wdd",gsDataPath)
      	ExeRun(exestring, exeInactive, True)
      ELSE
      	EndProgram()
      END
     type : 458752
   -
     name : Up
     procedure_id : 1527570522708744737
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] Up (<sText>)
      //
      // Parameters:
      //	sText: <specify the role of sText>
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE Up(sText)
      
      local
      	sOut is string
      	n is int
      	
      sOut=Upper(middle(sText,1,1))+Middle(sText,2)
      n=Length(sOut)
      for i=1 to n
      	if middle(sOut,i,1)="_" then
      		if i<Length(sOut) then
      			sOut=middle(sOut,1,i)+Upper(Middle(sOut,i+1,1))+Middle(sOut,i+2)
      		END
      	END
      END
      sOut=replace(sOut,"_","")
      
      result sOut
     type : 458752
