      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetIntend (<arrIntend>)
      //
      // Parameters:
      //	arrIntend: <specify the role of arrIntend>
      // Return Value:
      // 	Unspecified Type: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetIntend(arrIntend)
      
      if Dimension(arrIntend)>0 then
      	result arrIntend[Dimension(arrIntend)]
      else
      	result 0
      END
