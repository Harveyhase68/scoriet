      PROCEDURE ScorietUnScramble(pScrambledPassword)
      
      LOCAL
      	pPassword is string
      	i is int
      	test is int
      	secure is array of 300 string
      	t is array of 128 int
      	anzahl is int
      
      IF Length(pScrambledPassword)<2 THEN
      	RESULT ""
      END
      
      IF Length(pScrambledPassword)>127 THEN
      	Error("Verschlüsselungsdaten drüfen nur max 127 Zeichen lang sein")
      	RESULT ""
      END
      
