      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetPixelWidth(hdc is int, sText is string, sFontName is string, cSize is real, bBold is boolean, bUnterline is boolean, bItalic is boolean)
      
      LOCAL
      	srect is RECT
      	bold is int
      	Italic is boolean
      	Underline is boolean
      	Size is int
      	Font is int
      	Fontmem is int
      	s is string
      	align is int
      	f is int
      	res is int
      	nHeight is int
      	
      align=0x100+ 0x40000
      
      srect:nLeft = 0
      srect:nTop = 0
      srect:nRight =  1280
      srect:nBottom = 1024
      
      IF bBold THEN
      	bold=700
      ELSE
      	bold=0
      END
      
      Size=cSize
      
      Italic=bItalic
      
      Underline=bUnterline
      
      nHeight = -((Size*CallDLL32("gdi32","GetDeviceCaps",hdc, 90))/72)
      
      Font = CallDLL32("gdi32","CreateFontA", nHeight, 0, 0, 0, bold, Italic, Underline, 0, 1, 4, 0x10, 2, 4, &sFontName)
      
      Fontmem = CallDLL32("gdi32","SelectObject",hdc, Font)
      
      CallDLL32("gdi32","SetBkMode",hdc, 1)
      
      s=sText
      
      f=CallDLL32("user32","DrawTextA", hdc, &s, (Length(s)), &srect, BinaryOR(DT_CALCRECT, align))
      
      res = CallDLL32("gdi32","SelectObject",hdc, Fontmem)
      res = CallDLL32("gdi32","DeleteObject",Font)
      
      RESULT srect.nRight
     type : 458752
   -
     name : Win32_SystemEnclosure
     procedure_id : 1539567255383409557
     type_code : 15
     code : |1-
      // see : http://msdn2.microsoft.com/en-us/library/aa394474.aspx
      Procedure Win32_SystemEnclosure(pComputerName=NetMachineName())
      WMIClasse, WMIClasseProperties, VBSFieldList are strings
      WMIClasse   = "Win32_SystemEnclosure"	
      WMIClasseProperties = "" + ...
      "boolean AudibleAlarm;" +...
      "string BreachDescription;" +...
      "string CableManagementStrategy;" +...
      "string Caption;" +...
      "uint16 ChassisTypes[];" +...
      "string CreationClassName;" +...
      "sint16 CurrentRequiredOrProduced;" +...
      "real32 Depth;" +...
      "string Description;" +...
      "uint16 HeatGeneration;" +...
      "real32 Height;" +...
      "boolean HotSwappable;" +...
      "datetime InstallDate;" +...
      "boolean LockPresent;" +...
      "string Manufacturer;" +...
      "string Model;" +...
      "string Name;" +...
      "uint16 NumberOfPowerCords;" +...
      "string OtherIdentifyingInfo;" +...
      "string PartNumber;" +...
      "boolean PoweredOn;" +...
      "boolean Removable;" +...
      "boolean Replaceable;" +...
      "uint16 SecurityBreach;" +...
      "uint16 SecurityStatus;" +...
      "string SerialNumber;" +...
      "string ServiceDescriptions[];" +...
      "uint16 ServicePhilosophy[];" +...
      "string SKU;" +...
      "string SMBIOSAssetTag;" +...
      "string Status;" +...
      "string Tag;" +...
      "string TypeDescriptions[];" +...
      "string Version;" +...
      "boolean VisibleAlarm;" +...
      "real32 Weight;" +...
      "real32 Width;" +...
      ""
      WMIClasseProperties = NoSpace(WMIClasseProperties)
      IF Right(WMIClasseProperties,1) = ";" THEN WMIClasseProperties = WMIClasseProperties[[ 1 TO Length(WMIClasseProperties)-1]]
      VBSFieldList = _CreateVbsLoop(WMIClasseProperties)
      RESULT _ExecuteVbs(pComputerName, WMIClasse,  VBSFieldList, WMIClasseProperties)
     type : 458752
   -
     name : Win32_ComputerSystem
     procedure_id : 1539576730191998565
     type_code : 15
     code : |1-
      Procedure Win32_ComputerSystem(pComputerName=NetMachineName())
      
      local	
      	s is string
      	r1 is string
      	r2 is string
      	m is string
      	n is int
      	WMIClasse is string
      	WMIClasseProperties is string
      	VBSFieldList is strings
      
      WMIClasse   = "Win32_ComputerSystem"
      
      WMIClasseProperties = "" + ...
      					  "string Description;" +...
      					  "string Manufacturer;" +...
      					  "string Model;" +...
      					  "string Name;" +...
      					  "uint16 PCSystemType;" +...
      					  "boolean PowerManagementSupported;" +...
      					  "uint16 PowerOnPasswordStatus;" +...
      					  "uint16 PowerState;" +...
      					  "uint16 PowerSupplyState;" +...
      					  "string PrimaryOwnerName;" +...
      					  "string uuid;"
      
      WMIClasseProperties = NoSpace(WMIClasseProperties)
      IF Right(WMIClasseProperties,1) = ";" THEN WMIClasseProperties = WMIClasseProperties[[ 1 TO Length(WMIClasseProperties)-1]]
      VBSFieldList = _CreateVbsLoop(WMIClasseProperties)
      s=_ExecuteVbs(pComputerName, WMIClasse,  VBSFieldList, WMIClasseProperties)
      
      r1=ExtractString(s,1,crlf)
      r2=ExtractString(s,2,crlf)
      
      n=StringCount(r1,tab)+1
      for i=1 to n
      	m+=ExtractString(r1,i,tab)+": "+ExtractString(r2,i,tab)+crlf
      end
      
      result m
