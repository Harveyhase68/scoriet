     name : GetArrayName
     procedure_id : 1351113131260459593
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetArrayName (<n>, <sForLoopVariable>)
      //
      // Parameters:
      //	n: <specify the role of n>
      //	sForLoopVariable: <specify the role of sForLoopVariable>
      // Return Value:
      // 	Unspecified Type: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetArrayName(n, sForLoopVariable)
      
      switch n
      	case 1
      		result "arrItems[nCountItems]"
      	CASE 2
      		RESULT "arrItemsNoKey[nCountItemsNoKey]"
      	CASE 3
      		RESULT "arrForeignKeys[nCountForeignCount]"
      	CASE 4
      		RESULT "arrForeignKeys[nCountForeignCount].arrForeignItems[nCountForeignItems]"
      	case 5
      		result "arrItemsMasterDetail[nCountItemDetails]"
      	CASE 6
      		RESULT "arrItemsMasterDetailNoKey[nCountItemDetailsNoKey]"
      	CASE 7
      		RESULT "arrFiles[nCountFileItems]"
      	CASE 8
      		RESULT "arrKeys[nCountKeys]"
      	CASE 9
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment]"
      	CASE 10
      		RESULT "arrLanguages[nCountLanguages]"
      	case 11
      		RESULT "arrItems["+sForLoopVariable+"]"
      	CASE 12
      		RESULT "arrItemsNoKeyAll[nCountItemsNoKeyAll]"
      	other case
      		result "/*ERROR: wrong scope!*/"
      END
     type : 458752
   -
     name : GetArrayType2
     procedure_id : 1351113131260525223
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetArrayType2 (<n>, <nCountType>, <sForLoopVariable>)
      //
      // Parameters:
      //	n: <specify the role of nType>
      //	nCountType: <specify the role of nCountType>
      //	sForLoopVariable: <specify the role of vProjektVars>
      // Return Value:
      // 	Unspecified Type: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	sForLoopVariable: <specify the role of sForLoopVariable>
      PROCEDURE GetArrayType2(n, nCountType, sForLoopVariable)
      
      SWITCH arrKeyWord[n].sKeyWord
      	CASE "{item.filename}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sFileName"
      	CASE "{item.name}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sItemName"
      	CASE "{item.typecast}"
      		result GetArrayName(nCountType,sForLoopVariable)+".sTypeCast"
      	CASE "{item.datatype}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".Data_Type"
      	CASE "{item.dbdatatype}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".DB_Data_Type"
      	CASE "{item.windevtypeplain}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sWinDevTypePlain"
      	CASE "{item.default}"
      		result GetArrayName(nCountType,sForLoopVariable)+".sDefault"
      	CASE "{item.type}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nType"
      	CASE "{item.keytype}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nKeyType"
      	CASE "{item.controltype}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nControlType"
      	CASE "{item.id}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nDataItemsId"
      	CASE "{item.sort}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nSortIndex"
      	CASE "{item.caption}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sCaption"
      	CASE "{item.editmask}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sEditMask"
      	CASE "{item.size}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sSize"
      	CASE "{item.notnull}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".bNotNull"
      	CASE "{item.autoincrement}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".bAutoIncrement"
      	CASE "{item.unsigned}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".bUnsigned"
      	CASE "{item.visible}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".bItemVisible"
      	CASE "{item.x}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nX"
      	CASE "{item.y}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nY"
      	CASE "{item.state}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nState"
      	
      	CASE "{item.foreigntable}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sForeignTable"
      	CASE "{item.foreigntableid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nForeignTableID"
      	CASE "{item.foreignitem}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sForeignTableItem"
      	CASE "{item.foreignitemid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nForeignTableItemID"
      	CASE "{item.foreigndisplayitem}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sForeignTableDisplayItem"
      	CASE "{item.foreigndisplayitemid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nForeignTableDisplayItemID"
      	CASE "{item.foreignsortitem}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sForeignTableSortItem"
      	CASE "{item.foreignsortitemid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nForeignTableSortItemID"
      	CASE "{item.foreignarrayid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nForeignArrayID"
      		
      	CASE "{keys.name}"
      		RESULT "arrKeys[nCountKeys].sKeyName"
      	CASE "{keys.id}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].nID"
      	CASE "{keys.type}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].nType"
      	CASE "{keys.segment}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].nSegment"
      	case "{keys.fieldname}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].sFieldName"
      	CASE "{keys.typecast}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].sTypeCast"
      	CASE "{keys.datatype}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].Data_Type"
      	CASE "{keys.dbdatatype}"
      		RESULT "arrKeys[nCountKeys].arrFields[nCountSegment].DB_Data_Type"
      		
      	case "{foreign.sourcetableitem}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sSourceTablePlusItem"
      	CASE "{foreign.tablename}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sTableName"
      	CASE "{foreign.itemname}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sItemName"
      	CASE "{foreign.displayname}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sItemDisplay"
      	CASE "{foreign.displayid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nItemDisplayId"
      	CASE "{foreign.sortname}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sItemSort"
      	CASE "{foreign.sortid}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nItemSortId"
      		
      	CASE "{file.name}"
      	    RESULT GetArrayName(nCountType,sForLoopVariable)+".sFileName"
      	CASE "{file.nameshort}"
      	    RESULT GetArrayName(nCountType,sForLoopVariable)+".sFileNameShort"
      	case "{file.description}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sDescription"
      	CASE "{file.id}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nFileId"
      	CASE "{file.keyname}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sKeyName"
      	CASE "{file.primarykey}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sPrimaryKey"
      	CASE "{file.generatemasterdetail}"
      	    RESULT GetArrayName(nCountType,sForLoopVariable)+".bGenerateMasterDetail"
      	CASE "{file.detailfileid}"
      	    RESULT GetArrayName(nCountType,sForLoopVariable)+".sDetailFileID"
      	CASE "{file.detailfilename}"
      	    RESULT GetArrayName(nCountType,sForLoopVariable)+".sDetailFileName"
      	CASE "{file.detailkey}"
      	    RESULT GetArrayName(nCountType,sForLoopVariable)+".sDetailFileKey"
      
      	case "{language.id}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".nLanguageID"
      	CASE "{language.token}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sToken"
      	CASE "{language.sourcetoken}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sSourceToken"
      	CASE "{language.description}"
      		RESULT GetArrayName(nCountType,sForLoopVariable)+".sDescription"
      
      	CASE "{nmaxfiles}"
      		RESULT "vProjektVars.nMaxFiles"
      	CASE "{nmaxkeys}"
      		RESULT "vProjektVars.nMaxKeys"
      	CASE "{nmaxitems}"
      		RESULT "vProjektVars.nMaxItems"
      	CASE "{nmaxitemsnokey}"
      		RESULT "vProjektVars.nMaxItemsNoKey"
      	CASE "{nmaxitemsnokeyall}"
