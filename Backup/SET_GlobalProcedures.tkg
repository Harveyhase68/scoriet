      HReadSeek(Project,ProjectID,nProjectID,hIdentical)
      IF NOT HFound(Project) THEN
      	result false
      END
      
      hreadseek(Template,TemplateID,nTemplateID,hIdentical)
      if hfound(Template) then
      	
      	sDirTemplate=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)
      	sXMLFileName=sDirTemplate+"template.xml"
      	
      	if fFileExist(sXMLFileName) then
      		xml=XMLOpen(sXMLFileName,fromFile)
      		
      		sTemplateName=xml.Template.Name
      		sTemplateFolder=xml.Template.Folder
      		sTemplateCommentChar=xml.Template.CommentChar
      		
      		if sTemplateName<>template.TemplateName then
      			result false
      		END
      		
      		if sTemplateFolder<>template.TemplateFolder then
      			result false
      		END
      		
      		if sTemplateCommentChar<>template.TemplateCommentChar then
      			result false
      		END
      		
      		FOR EACH ARootNode of xml.Template
      			SWITCH ARootNode..Name
      				CASE "TemplatePage"
      					HReadSeek(TemplatePage,TemplatePageKey,HBuildKeyValue(TemplatePage,TemplatePageKey,Template.TemplateID,ARootNode.Name),hIdentical)
      					IF not HFound(TemplatePage) THEN
      						nError++
      					END
      					
      					if TemplatePage.GenerationType<>ARootNode.GenerationID then nError++
      					if TemplatePage.PersistentFile<>ARootNode.Persistent then  nError++
      					if TemplatePage.TemplateExecuteProgramAfter<>ARootNode.Execute then nError++
      					if TemplatePage.TemplateID<>Template.TemplateID then nError++
      					if TemplatePage.TemplatePageConstruct<>ARootNode.Construct then nError++
      					if TemplatePage.TemplatePageFilename<>ARootNode.FileName then nError++
      					if TemplatePage.TemplatePageFolder<>ARootNode.Folder then nError++
      					if TemplatePage.TemplatePageGenerate<>ARootNode.Generate then nError++
      					if TemplatePage.TemplatePageName<>ARootNode.Name then nError++
      											
      					SWITCH ARootNode.GenerationID
      						CASE 2
      							//We have a directory...
      							FOR EACH aDirectory of ARootNode on TemplatePageFileName
      								//info(aDirectory.FileNameFull)
      								sFileName=sDirTemplate+aDirectory.FileNameFull
      								if fFileExist(sFileName) then
      									sBuffer=fLoadText(sFileName,foAnsi)
      									nCRC=sComputeCrc32(sBuffer)
      									IF aDirectory.CRC<>nCRC THEN
      										nError++
      									END
      								else
      									nError++
      								end
      							END
      						OTHER CASE
      							sFileName=sDirTemplate+ARootNode.FileName
      							if fFileExist(sFileName) then
      								sBuffer=fLoadText(sFileName,foAnsi)
      								nCRC=sComputeCrc32(sBuffer)
      								IF ARootNode.CRC<>nCRC THEN
      									nError++
      								END
      							else
      								nError++
      							end
      					END
      				CASE "TemplateVars"
      					//TemplateID+VarName
      					HReadSeek(TemplateVars,TemplateVarsKey,HBuildKeyValue(TemplateVars,TemplateVarsKey,Template.TemplateID,ARootNode.VarName),hIdentical)
      					IF not HFound(TemplateVars) THEN
      						nError++
      					END
      				other case
      			END
      		END
      		
      		IF nError<>0 THEN
      			result nError
      		ELSE
      			result 0
      		END
      	else
      		result 1
      	END
      else
      	result 1
      END
     type : 458752
   -
     name : ExportTemplate
     procedure_id : 1551545060102881810
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //ExportTemplate (<nProjectID>, <nTemplateID>, <sZIPName>)
      //
      // Parameters:
      //	nProjectID: <specify the role of sZIPName>
      //	nTemplateID: <specify the role of sZIPName>
      // 	sZIPName: <specify the role of sZIPName>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE ExportTemplate(nProjectID, nTemplateID, sZIPName)
      
      LOCAL
      	sMyXMLDoc is string = "XML"
      	sXMLInfo is string
      	nMax is int
      	nCount is int
      	nCountDirs is int
      	sFiles is string
      	sBuffer is string
      	sTemplateFile is string
      	nCRC is int on 8 bytes
      	sSingleFile is string
      	sFileName is string
      	sStripedFileName is string
      	sStripedPath is string
      	zz is int
      	gnMaxFiles is int
      	
      HReadSeek(Project,ProjectID,nProjectID,hIdentical)
      IF NOT HFound(Project) THEN
      	Info(<§@1fb8c9cd011e8671000e§>)
      	RETURN
      END
      
      XMLDocument(sMyXMLDoc, "",xdHTML)
      
      HReadSeek(Template,TemplateID,nTemplateID,hIdentical)
      IF HFound(Template) THEN
      	
      	XMLAddChild(sMyXMLDoc,"Template","",True)
      	XMLAddAttribute(sMyXMLDoc,"ID",Template.TemplateID)
      	XMLAddChild(sMyXMLDoc,"ID",Template.TemplateID)
      	XMLAddChild(sMyXMLDoc,"Name",Template.TemplateName)
      	XMLAddChild(sMyXMLDoc,"Folder",Template.TemplateFolder)
      	XMLAddChild(sMyXMLDoc,"CommentChar",Template.TemplateCommentChar)
      
      	IF gsUserName="" THEN
      		XMLAddChild(sMyXMLDoc,"UserName","*unregistered user*")
      	ELSE
      		XMLAddChild(sMyXMLDoc,"UserName",gsUserName)
      	END
      	
      	
      	HFilter(TemplatePage,TemplatePageKey,HBuildKeyValue(TemplatePage,TemplatePageKeyID,Template.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,Template.TemplateID,hMaxVal))
      	HReadFirst(TemplatePage,TemplatePageKeyID)
      	WHILE NOT HOut(TemplatePage)
      		nMax++
      		HReadNext(TemplatePage,TemplatePageKeyID)
      	END
      	
      	HReadFirst(TemplatePage,TemplatePageKeyID)
      	WHILE NOT HOut(TemplatePage)
      		nCountDirs=0
      		nCount=0
      		SWITCH TemplatePage.GenerationType
      			CASE 2
      				//Folder...
      				XMLAddChild(sMyXMLDoc,"TemplatePage","",True)
      				XMLAddAttribute(sMyXMLDoc,"ID",TemplatePage.TemplatePageID)
      				XMLAddChild(sMyXMLDoc,"Name",TextToXML(TemplatePage.TemplatePageName))
      				XMLAddChild(sMyXMLDoc,"FileName",TextToXML(TemplatePage.TemplatePageFilename))
      				XMLAddChild(sMyXMLDoc,"Folder",TextToXML(TemplatePage.TemplatePageFolder))
      				XMLAddChild(sMyXMLDoc,"Construct",TextToXML(TemplatePage.TemplatePageConstruct))
      				XMLAddChild(sMyXMLDoc,"Persistent",TemplatePage.PersistentFile)
      				XMLAddChild(sMyXMLDoc,"Generate",TemplatePage.TemplatePageGenerate)
      				XMLAddChild(sMyXMLDoc,"Execute",TextToXML(TemplatePage.TemplateExecuteProgramAfter))
      				XMLAddChild(sMyXMLDoc,"GenerationID",TemplatePage.GenerationType)
      				sTemplateFile=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
      				IF fDirectoryExist(sTemplateFile) THEN
      					sFiles=fListFile(CompleteDir(sTemplateFile)+"*.*",fdFullInformation+frRecursive)
      					zz=0
      					FOR EACH STRING sSingleFile OF sFiles SEPARATED BY CR
      						sFileName=ExtractString(sSingleFile,1,TAB)
      						IF fFileExist(sFileName) THEN
      							zz++
      							XMLAddChild(sMyXMLDoc,"TemplatePageFileName","",True)
      							XMLAddAttribute(sMyXMLDoc,"ID",NumToString(zz,"d"))
      							sBuffer=fLoadText(sFileName,foAnsi)
      							nCRC=sComputeCrc32(sBuffer)
      							sStripedFileName=Replace(sFileName,CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder),"")
      							sStripedPath=Replace(fExtractPath(sFileName,fDrive+fDirectory),CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder),"")
      							XMLAddChild(sMyXMLDoc,"FileNameFull",TextToXML(sStripedFileName))
      							XMLAddChild(sMyXMLDoc,"FileName",TextToXML(fExtractPath(sFileName,fExtension+fFileName)))
      							XMLAddChild(sMyXMLDoc,"FileFolder",TextToXML(sStripedPath))
      							XMLAddChild(sMyXMLDoc,"CRC",NumToString(nCRC,"d"))
      							XMLParent(sMyXMLDoc)
      						END
      					END
      				END
      				XMLParent(sMyXMLDoc)
      			OTHER CASE
      				sTemplateFile=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
      				IF fFileExist(sTemplateFile) THEN
      					nCount++
      					Gauge(nCount,nMax,"Export Template XML")
      					Multitask(-1)
      					XMLAddChild(sMyXMLDoc,"TemplatePage","",True)
      					XMLAddAttribute(sMyXMLDoc,"ID",TemplatePage.TemplatePageID)
      					XMLAddChild(sMyXMLDoc,"Name",TextToXML(TemplatePage.TemplatePageName))
      					XMLAddChild(sMyXMLDoc,"FileName",TextToXML(TemplatePage.TemplatePageFilename))
      					XMLAddChild(sMyXMLDoc,"Folder",TextToXML(TemplatePage.TemplatePageFolder))
      					XMLAddChild(sMyXMLDoc,"Construct",TextToXML(TemplatePage.TemplatePageConstruct))
      					XMLAddChild(sMyXMLDoc,"Persistent",TemplatePage.PersistentFile)
      					XMLAddChild(sMyXMLDoc,"Generate",TemplatePage.TemplatePageGenerate)
      					XMLAddChild(sMyXMLDoc,"Execute",TextToXML(TemplatePage.TemplateExecuteProgramAfter))
      					XMLAddChild(sMyXMLDoc,"GenerationID",TemplatePage.GenerationType)
      					IF fFileExist(sTemplateFile) THEN
      						sBuffer=fLoadText(sTemplateFile,foAnsi)
      						nCRC=sComputeCrc32(sBuffer)
      						XMLAddChild(sMyXMLDoc,"CRC",NumToString(nCRC,"d"))
      					END
      					XMLParent(sMyXMLDoc)
      				END
      		END
      		HReadNext(TemplatePage,TemplatePageKeyID)
      	END
      	HDeactivateFilter(TemplatePage)
      	
      	HFilter(TemplateVars,TemplateID,Template.TemplateID,Template.TemplateID)
      	HReadFirst(TemplateVars,TemplateID)
      	WHILE NOT HOut(TemplateVars)
      		XMLAddChild(sMyXMLDoc,"TemplateVars","",True)
      		XMLAddAttribute(sMyXMLDoc,"ID",TemplateVars.TemplateVarsID)
      		XMLAddChild(sMyXMLDoc,"Name",TextToXML(TemplateVars.Caption))
      		XMLAddChild(sMyXMLDoc,"VarName",TextToXML(TemplateVars.VarName))
      		XMLParent(sMyXMLDoc)
      		HReadNext(TemplateVars,TemplateID)
      	END
      	HDeactivateFilter(TemplateVars)
      	
      	sXMLInfo = XMLBuildString(sMyXMLDoc,XMLDocumentDefault,XMLEncodingUTF8)
      	XMLClose(sMyXMLDoc)
      	
      	fSaveText(CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+"template.xml", sXMLInfo)
      	IF fFileExist(sZIPName) THEN
      		fDelete(sZIPName)
      	END
      	
      	zipCreate(ZIP_ARCHIVE,sZIPName)
      	sFiles=fListFile(CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+"\*.*",frRecursive)
      	gnMaxFiles=StringCount(sFiles,CR)
      	zipAddDirectory(ZIP_ARCHIVE,CompleteDir(gsTemplatePath)+Template.TemplateFolder,True,zipRelative)
      	//zipAddFile(ZIP_ARCHIVE,CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+"template.xml",zipNone)
      	zipClose(ZIP_ARCHIVE)
      	
      END
     type : 458752
   -
     name : UploadTemplate
     procedure_id : 1551561638708946849
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //UploadTemplate (<nProjectID>, <nTemplateID>)
      //
      // Parameters:
      // 	nProjectID: <specify the role of nProjectID>
      // 	nTemplateID: <specify the role of nTemplateID>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE UploadTemplate(nProjectID, nTemplateID)
      
      local
      	sZipFileName is string
      	nFTP is int
      
      HReadSeek(Project,ProjectID,nProjectID,hIdentical)
      IF NOT HFound(Project) THEN
      	Info(<§@1fb8c9cd011e8671000e§>)
      	Close()
      END
      
      HReadSeek(Template,TemplateID,nTemplateID,hIdentical)
      if not hfound(Template) then
      	info(<§@1fb8c9cd011e8671000f§>)
      	close()
      END
      
      //Wieder zurück auf 0, user will uploaden!
      IF gsUserName="" THEN
      	gsUserName="anonymous"
      END
      sZipFileName=CompleteDir(gsTemplatePath)+Template.TemplateName+"_"+gsUserName+"_"+DateToString(DateSys(),"DD_MM_YYYY")+"_"+TimeToString(TimeSys(),"HH_MM")+".zip"
      ExportTemplate(Project.ProjectID,Template.TemplateID,sZipFileName)
      nFTP=FTPConnect("scoriet.com","ftp_scoriet_com","newcommunity",21,True)
      IF nFTP<>-1 THEN
      	IF FTPSend(nFTP,sZipFileName,"/upload") THEN
      		Info(<§@0000000000000000000a§>)
      	ELSE
      		Error(<§@0000000000000000000b§>)
      	END
      ELSE
      	Error(<§@0000000000000000000c§>)
      END
      fDelete(sZipFileName)
     type : 458752
   -
     name : FTPProgressBar
     procedure_id : 1560083042771699891
     type_code : 15
     code : |1+
      // Description of input/output parameters of 'ProgressBarAFileThread13':
      //
      // Syntax // PROCEDURE THAT WILL BE INTERNALLY USED BY THE SET OF PROCEDURES
      //procedure automatically called by FTPGet or FTPSend with the information about the progress of the send operation
      //
      // Syntax:
      //[ <Result> = ] FTPProgressBar (<nParamTotalSize>, <nParamTransferredSize>)
      //
      // Parameters:
      //	nParamTotalSize: integer with the total size to transfer
      //	nParamTransferredSize: integer with the size already transferred
      // Notes:
      //This procedure is used to recall the "ProgressBarAFile" procedure with an additional parameter that allows 
      //"ProgressBarAFile" to define the file for which the sizes are passed in parameter
      //
      // Return value:
      // 	boolean:    True to continue the transfer, False to stop it
      Procedure PRIVATE FTPProgressBar(nParamTotalSize,nParamTransferredSize)
      
      //bounce on "ProgressBarAFile", we return the returned value
      gauge(nParamTransferredSize,nParamTotalSize,"FTP upload: "+gsActualFile)
      
      result true
      
     type : 458752
   -
     name : EventTest
     procedure_id : 1560687817181574155
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //EventTest ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      Procedure EventTest()
      
      switch _EVE.wMessage
      	case 32,512,160,132,133,1735,2035,2036,2037,15
      	
      	OTHER CASE
      		if _EVE.name<>"IW_InternalWindow1" THEN //_EVE.lParam<>0 or _EVE.wParam<>0 then
      			Trace(_EVE.wMessage+", "+_EVE.name+", "+_EVE.hWnd+", "+_EVE.lParam+"("+LoWord(_EVE.lParam)+"/"+HiWord(_EVE.lParam)+"), "+_EVE.wParam+"("+LoWord(_EVE.wParam)+"/"+HiWord(_EVE.wParam)+")")
      		end
      END
     type : 458752
   -
     name : EventTest2
     procedure_id : 1560687817181639878
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //EventTest2 ()
      //
      // Parameters:
      //	None
      
      // Return value:
      // 	boolean: // 	None
      // For instance:
      PROCEDURE EventTest2()
      
      LOCAL
      	Text is string
      	found is boolean
      	sControl is string
      	
      sControl=_EVE.name
      
      IF left(sControl,4)="WIRE" then //gsTargetControl THEN
      //	IF WIN_Designer.gbFirstLoad THEN
      //		return
      //	END
      	//IF _EVE.name="IW_InternalWindow1" THEN
      	SWITCH _EVE.wMessage
      		case 2036,2037,133,20,15,132,32,512
      		//CASE 133,20, 2037,2036,132,512,32,15//32, 512, 132, 2036, 2037, 135, 160 ,133, 20 ,15 ,1735,5,33
      		OTHER CASE
      			Text=""
      			found=False
      			FOR i=1 TO 178
      				IF wm_buf[i]:wm_value=_EVE.wMessage THEN
      					Text=Text+wm_buf[i]:wm_pars+":"+wm_buf[i]:wm_value
      					found=True
      					BREAK
      				END
      			END
      			
      			IF NOT found THEN
      				Text=Text+"Unbekannt"+":"+_EVE.wMessage
      			END
      			
      			Text=Text+" Control:  "+_EVE.name+" wParam: "+_EVE.wParam+" ("+LoWord(_EVE.wParam)+"/"+HiWord(_EVE.wParam)+")"+" lParam: "+_EVE.lParam+" ("+LoWord(_EVE.lParam)+"/"+HiWord(_EVE.lParam)+")"+CRLF
      			
      			Trace(Text)
      
      	END
      end
      
     type : 458752
