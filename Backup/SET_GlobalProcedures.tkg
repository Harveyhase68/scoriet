     name : AddKeyWord
     procedure_id : 1351113131260262345
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] AddKeyWord (<arrKeyWords>, <sKeyWord>, <sCodeWord>, <nType> [, <VaterId> [, <bFinal> [, <bNoCrlf>]]])
      //
      // Parameters:
      //	arrKeyWords: <specify the role of sKeyWord>
      //	sKeyWord: <specify the role of sKeyWord>
      //	sCodeWord: <specify the role of nType>
      //	nType: <specify the role of nType>
      //	VaterId (default value=0): <specify the role of nVaterId>
      //	bFinal (default value=1): <specify the role of bFinal>
      // 	bNoCrlf (default value=0): <specify the role of bNoCrlf>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE AddKeyWord(arrKeyWords, sKeyWord, sCodeWord, nType, VaterId=0, bFinal=true, bNoCrlf=true)
      
      local
      	s is STKeyWord
      	
      s.nType=nType
      s.sKeyWord=sKeyWord
      s.sCodeWord=sCodeWord
      s.nVaterId=VaterId
      s.bFinal=bFinal
      s.bNoCrLf=bNoCrlf
      
      ArrayAdd(arrKeyWords, s)
      
      result true
     type : 458752
   -
     name : FindKeyWord
     procedure_id : 1351113131260393823
     type_code : 15
     code : |1+
      PROCEDURE FindKeyWord(nStart, sSourceString, nIndex, nEndPos)
      
      local
      	n is int
      	i is int
      	l is int
      	t is int
      	sTempKeyWord is string
      	sTempKeyEndWord is string
      	sTempKeyWordLast is string
      	bFound is boolean
      	cc is int
      	v is int
      	
      for i=1 to Dimension(arrkeyword)
      	
      	n=Position(arrKeyWord[i].sKeyWord,"%")
      	if n>0 then
      		//Wir müssen Teile ignorieren
      		sTempKeyWord=middle(arrKeyWord[i].sKeyWord,1,n-1)
      		sTempKeyEndWord=middle(arrKeyWord[i].sKeyWord,n+1)
      	else
      		sTempKeyWord=arrKeyWord[i].sKeyWord
      		sTempKeyEndWord=""
      	END
      
      	IF Middle(sSourceString,nStart,Length(sTempKeyWord))=sTempKeyWord THEN
      		
      		if arrKeyWord[i].nType=1 THEN
      			//Wir haben ein KeyWord gefunden!
      			nIndex=i
      			l=Position(arrKeyWord[i].sKeyWord,"%")
      			IF l>0 THEN
      				sTempKeyWordLast=Middle(arrKeyWord[i].sKeyWord,l+1)
      				l=0
      				cc=0
      				v=Length(sSourceString)
      				for t=nStart+1 to v
      					IF cc=0 AND upper(Middle(sSourceString,t,Length(sTempKeyEndWord)))=upper(sTempKeyEndWord) THEN
      						l=t
      						BREAK
      					END
      					//Verschachtelte Strukturen erkennen!
      					if middle(sSourceString,t,1)="{" then
      						cc++
      					END
      					IF Middle(sSourceString,t,1)="}" THEN
      						cc--
      					END
      				END
      				IF l=0 THEN
      					//Nicht gefunden? Eigentlich ein Fehler...
      					Error("Falscher Template Code: "+middle(sSourceString,nStart,100)+" Ende des Keywords nicht gefunden!")
      					EndProgram()
      				ELSE
      					nEndPos=(l-nStart)+Length(sTempKeyWordLast)
      					IF Middle(sSourceString,nStart+nEndPos,2)=CRLF THEN
      						nEndPos=nEndPos+2
      					end
      				END
      			ELSE
      				//Kein % = keine Variablen im Keyword
      				nEndPos=Length(sTempKeyWord)
      				IF Middle(sSourceString,nStart+nEndPos,2)=CRLF THEN
      					nEndPos=nEndPos+2
      				END
      			END
      			bFound=True
      			BREAK
      		else
      			//Wir haben das KeyWord gefunden!
      			nIndex=i
      			l=Position(arrKeyWord[i].sKeyWord,"%")
      			IF l>0 THEN
      				l=Position(sSourceString,sTempKeyEndWord,nStart+1,IgnoreCase)
      				if l>0 then
      					nEndPos=(l-nStart)+Length(sTempKeyEndWord)
      				END
      			else
      				nEndPos=Length(sTempKeyWord)
      			end
      			bFound=True
      			BREAK
      		end
      	END
      	if bFound then break
      end
      
      if bFound then
      	result true
      else
      	result False
      end
      
     type : 458752
