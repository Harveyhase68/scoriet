      // Summary: <specify the procedure action>
      // Syntax:
      //Menu_Open (<sWindowName> is string [, ...])
      //
      // Parameters:
      //	sWindowName (ANSI string): <specify the role of sWindowName>
      // 	<*>: <specify the role of <*>>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      //	Option1 (string - default value=""): <specify the role of Option>
      // 	Option2 (string - default value=""): <specify the role of Option2>
      // 	<*>: <specify the role of <*>>
      PROCEDURE Menu_Open(sWindowName is string, *)
      
      sAliasName is string = sWindowName
      
      IF WinStatus(sAliasName)<>NotFound THEN
      	WinStatus(sAliasName,TopActive)
      ELSE
      	WHEN EXCEPTION IN
      		MDIOpen(sWindowName,sAliasName,"",MyParameters[2 TO ])
      	DO
      		Open(sWindowName,MyParameters[2 TO ])
      	END
      END
      
      
     type : 458752
   -
     name : Win32_Process2
     procedure_id : 1531780552672302875
     type_code : 15
     code : |1-
      // see : http://msdn2.microsoft.com/en-us/library/aa394372.aspx
      FUNCTION Win32_Process2(pComputerName=NetMachineName(), sProcess is string="httpd.exe")
      
      local
      	WMIClasse is string
      	WMIClasseProperties is string
      	VBSFieldList is strings
      	sListProcesses is string
      	n is int
      	
      WMIClasse   = "Win32_Process"	
      WMIClasseProperties = "" + ...
      "string Caption;" +...
      "string Description;" +...
      "string ExecutablePath;" +...
      "uint32 ProcessId"
      
      WMIClasseProperties = NoSpace(WMIClasseProperties)
      
      IF Right(WMIClasseProperties,1) = ";" THEN WMIClasseProperties = WMIClasseProperties[[ 1 TO Length(WMIClasseProperties)-1]]
      
      VBSFieldList = _CreateVbsLoop(WMIClasseProperties)
      
      sListProcesses=_ExecuteVbs(pComputerName, WMIClasse,  VBSFieldList, WMIClasseProperties)
      
      n=StringCount(sListProcesses,crlf)+1
      for i=1 to n
      	if upper(left(ExtractString(sListProcesses,i,crlf),Length(sProcess)))=upper(sProcess) then
      		result NoSpace(ExtractString(ExtractString(sListProcesses,i,crlf),3,tab))
      	END
      END
      
      result ""
     type : 458752
   -
     name : _BASE
     procedure_id : 1531984194226716903
     type_code : 15
     code : |1-
      // 1° Copier cette fonction
      // 2° Renommer la ( perso je la renomme avec le nom de la classe WMI)
      // 3° Mettre le nom de la classe WMI dans la variable WMIClasse
      // 4° Faire un copier-coller de la page microsoft des propriétés de la classe
      //    entre WMIClasseProperties = "" + ... et ""
      // 5° Ajouter devant chaque ligne " et aprés chaque ligne " + ... 
      //    perso j'ai un p'tit prog qui fait ca et qui me le renvoie dans le presse papier
      
      // see : 
      Procedure _BASE(pComputerName=NetMachineName())
      WMIClasse, WMIClasseProperties, VBSFieldList are strings
      WMIClasse   = ""	
      WMIClasseProperties = "" + ...
      
      ""
      WMIClasseProperties = NoSpace(WMIClasseProperties)
      IF Right(WMIClasseProperties,1) = ";" THEN WMIClasseProperties = WMIClasseProperties[[ 1 TO Length(WMIClasseProperties)-1]]
      VBSFieldList = _CreateVbsLoop(WMIClasseProperties)
      RESULT _ExecuteVbs(pComputerName, WMIClasse,  VBSFieldList, WMIClasseProperties)
     type : 458752
   -
     name : _CreateVbsLoop
     procedure_id : 1531984194226782564
     type_code : 15
     code : |1+
      FUNCTION _CreateVbsLoop(FieldList)
      VbsResult, FieldDefinition, FieldType, FieldName, vbsFieldName, InitialLastBlock, NewLastBlock are strings
      VbsResult =  ""
      
      FieldDefinition = ExtractString(FieldList,firstRank,";")
      WHILE FieldDefinition <> EOT
      	FieldDefinition = NoSpace(FieldDefinition)
      	WHILE Position(FieldDefinition,"  ") > 0
      		FieldDefinition = Replace(FieldDefinition,"  "," ")
      	END
      	FieldType = Upper(NoSpace(ExtractString(FieldDefinition,1," ")))
      	FieldName = ExtractString(FieldDefinition,2," ")
      	
      	SWITCH FieldType
      	
      		CASE "STRING", "STRING.", "BOOLEAN"
      			vbsFieldName = "objItem." + NoSpace(Replace(FieldName,"[]",""))
      			VbsResult += "if IsNull(" + vbsFieldName + ") then" + CRLF
      			VbsResult += "strResult =  strResult & ||  & chr(9)" + CRLF
      			VbsResult += "else" + CRLF
      			VbsResult += "strResult =  strResult & " + vbsFieldName + " & chr(9)" + CRLF
      			VbsResult += "end If" + CRLF
      						
      		CASE "SINT16", "SINT32", "SINT64", "UINT8", "UINT16", "UINT32", "UINT64", "REAL16", "REAL32", "REAL64", "DATETIME"
      			vbsFieldName = "objItem." + NoSpace(Replace(FieldName,"[]",""))
      			VbsResult += "if IsNull(" + vbsFieldName + ") then" + CRLF
      			VbsResult += "strResult =  strResult & ||  & chr(9)" + CRLF
      			VbsResult += "else" + CRLF
      			VbsResult += "strResult =  strResult & CStr(" + vbsFieldName + ") & chr(9)" + CRLF
      			VbsResult += "end If" + CRLF
      			
      		OTHER CASE
      			IF InTestMode() THEN Trace("type non référencé : " + FieldType)
      END
      	
      	FieldDefinition = ExtractString(FieldList,nextRank,";")
      END
      InitialLastBlock = ExtractString(VbsResult,lastRank,"if")
      NewLastBlock = Replace(InitialLastBlock,"chr(9)","chr(13) & chr(10)")
      VbsResult = Replace(VbsResult,InitialLastBlock,NewLastBlock)
      RESULT VbsResult
     type : 458752
   -
     name : _ExecuteVbs
     procedure_id : 1531984198521815505
     type_code : 15
     code : |1+
      FUNCTION _ExecuteVbs(pComputerName, pWmiClasse, pFieldList, pFieldnameList)
      
      objWMIService is object Automation "MSScriptControl.ScriptControl"
      VBSFunction, ProgrammeVbs, ResultatVbs, Entête, Temp are strings
      
      VBSFunction = "WindevWMI"
      
      // Dans le programme VBS je remplace les " par des | et à la fin je les remplaces en global
      ProgrammeVbs = StringBuild("Function %1(ComputerName)", VBSFunction) + CRLF
      ProgrammeVbs += "On Error Resume Next" + CRLF
      ProgrammeVbs += "strComputer = ComputerName" + CRLF
      ProgrammeVbs += "strResult = ||" + CRLF
      ProgrammeVbs += "Set objWMIService = GetObject(|winmgmts:\\| & strComputer & |\root\cimv2|)" + CRLF
      ProgrammeVbs += StringBuild("Set colItems = objWMIService.ExecQuery(|Select * from %1|,,48)", pWmiClasse) + CRLF
      ProgrammeVbs += "For Each objItem in colItems" + CRLF
      ProgrammeVbs += pFieldList + CRLF
      ProgrammeVbs += "Next" + CRLF
      ProgrammeVbs += VBSFunction + "= strResult" + CRLF
      ProgrammeVbs += "End Function"
      ProgrammeVbs = Replace(ProgrammeVbs,"|", Charact(34))
      
      objWMIService>>Language("VBScript")
      objWMIService>>Reset()
      
      WHEN EXCEPTION IN
      	objWMIService>>AddCode(ProgrammeVbs)
      DO
      	Error("Erreur dans le programme vbs...")
      	RESULT ""
      END
      
      ResultatVbs = ""
      
      WHEN EXCEPTION IN
      	ResultatVbs = objWMIService>>Eval(VBSFunction+"("+Charact(34)+pComputerName+Charact(34)+")")
      DO
      	Error("Erreur d'execution du programme vbs")
      	RESULT ""
      END
      
      IF ResultatVbs <> "" THEN ResultatVbs = ResultatVbs[[1 on Length(ResultatVbs)-2]]
      
      Entête = ""
      IF pFieldnameList <> "" THEN
      	FOR ALL string Temp of pFieldnameList separee by ";"
      		IF Entête <> "" THEN Entête += TAB
      		Entête += ExtractString(Temp, 2, " ")
          END
      END
      
      RESULT (Entête = "" ? ResultatVbs ELSE Entête + CR + ResultatVbs)
     type : 458752
   -
     name : ImportTable
     procedure_id : 1532532073143951890
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] ImportTable (<nVersionID>, <nDBConnectionID>, <sDBName>, <sTableName>, <nSortIndex> [, <nTableLenght>])
      //
      // Parameters:
      //	nVersionID: <specify the role of nDBConnectionID>
      //	nDBConnectionID: <specify the role of sDBName>
      //	sDBName: <specify the role of sTableName>
      //	sTableName: <specify the role of sDBName>
      //	nSortIndex: <specify the role of nSortIndex>
      //	nTableLenght (default value=2): 
      
      PROCEDURE ImportTable(nVersionID, nDBConnectionID, sDBName, sTableName, nSortIndex, nTableLenght=2)
      
      LOCAL
      	dsData is Data Source
      	dsData3 is Data Source
      	sSQL is string
      	sKeySQL is string
      	s is string
      	sItemName is string
      	sType is string
      	sRawType is string
      	sDefault is string
      	zz is int
      	sShort is string
      	mm is int
      	sFileTranslationText is string
      	bFound is boolean
      	sUniqueKeyName is string
      	sKeyName is string
      	nOldVersionID is int on 8 bytes
      	sItemTranslationText is string
      	nSaveID is int
      	nSaveItemID is int
      	sIntegerPart is string
      	sDecimalPart is string
      	nNewItemId is int on 8 bytes
      	bDataItemsTypeDetailsAdded is boolean
      	clConnect is connection
      	sError is string
      
      //Trace("hItemInvalid: "+hItemInvalid)  //Invalid = 0
      //Trace("hItemIdAuto: "+hItemIdAuto)  //Automatic identifier (8 bytes) = 1
      //Trace("hItemText: "+hItemText)  //Text = 2
      //Trace("hItemInteger2: "+hItemInteger2)  //2-byte integer = 3
      //Trace("hItemIInteger1: "+hItemIInteger1)  //1-byte integer = 4
      //Trace("hItemInteger4: "+hItemInteger4)  //4-byte integer = 5
      //Trace("hItemReal4: "+hItemReal4)  //4-byte real = 6
      //Trace("hItemReal8: "+hItemReal8)  //8-byte real = 7
      //Trace("hItemNumRec: "+hItemNumRec)  //Record number = 8
      //Trace("hItemUnsignedInteger2 : "+hItemUnsignedInteger2)  //Unsigned 2-byte integer = 9
      //Trace("hItemDate6: "+hItemDate6)  //Date in YYMMDD format = 10
      //Trace("hItemHour: "+hItemHour)  //Time = 11
      //Trace("hItemUnsignedInteger1 : "+hItemUnsignedInteger1)  //Unsigned 1-byte integer = 12
      //Trace("hItemRealTurbo: "+hItemRealTurbo)  //Turbo real = 13
      //Trace("hItemDate8: "+hItemDate8)  //Date in YYYYMMDD format = 14
      //Trace("hItemTextMemo: "+hItemTextMemo)  //Text memo = 15
      //Trace("hItemBinaryMemo4: "+hItemBinaryMemo4)  //Binary memo (4 bytes) = 16
      //Trace("hItemCurrency: "+hItemCurrency)  //Currency = 17
      //Trace("hItemBinaryMemo: "+hItemBinaryMemo)  //Binary memo = 18
      //Trace("hItemInteger8: "+hItemInteger8)  //8-byte integer = 19
      //Trace("hItemUnsignedInteger8 : "+hItemUnsignedInteger8)  //Unsigned 8-byte integer = 20
      //Trace("hItemPicture: "+hItemPicture)  //Image = 21
      //Trace("hItemUnsignedInteger4 : "+hItemUnsignedInteger4)  //Unsigned 4-byte integer = 22
      //Trace("hItemBinary: "+hItemBinary)  //Binary = 23
      //Trace("hItemDateTime: "+hItemDateTime)  //Date/Time = 24
      //Trace("hItemTimeLength: "+hItemTimeLength)  //Duration = 25
      //Trace("hItemCharacter: "+hItemCharacter)  //Character = 26
      //Trace("hItemBoolean: "+hItemBoolean)  //Boolean = 27
      //Trace("hItemIdAuto4 : "+hItemIdAuto4)  //Automatic identifier (4 bytes) = 28
      //Trace("hItemUnicodeText: "+hItemUnicodeText)  //Unicode text = 29
      //Trace("hItemUnicodeMemo: "+hItemUnicodeMemo)  //Unicode text memo = 30
      //Trace("hItemNumeric: "+hItemNumeric)  //Numeric = 31
      
      HDeactivateFilter(Project)
      HReadSeek(Project,ProjectID,gnProjectID)
      IF NOT HFound(Project) THEN
      	Error("Projekt nicht gefunden!")
      	result false
      END
      
      HReadSeek(DBConnection,DBConnectionID,nDBConnectionID,hIdentical)
      
      InitRandom(-Timer)
      
      IF DBConnect(clConnect,sError,DBConnection.Type,DBConnection.Server,DBConnection.Username,DBConnection.Password,sDBName) THEN
      	
      	Message("Lese Dateiinformationen "+sTableName)
      	
      	Multitask(-1)
      
      	sShort=GetTableNameShort(nVersionID, sTableName, nTableLenght)
      	
      	DataFile.ProjectID=project.ProjectID
      	DataFile.FileName=sTableName
      	DataFile.FileNameShort=sShort
      	DataFile.DataFileGenerate=True
      	DataFile.DataFileSort=zz
      	DataFile.KeyName=""
      	DataFile.VersionID=nVersionID
      	DataFile.DataFileSort=nSortIndex
      	HAdd(DataFile)
      	
      	HFilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
      	HReadFirst(ProjectTemplates,ProjectTemplateKey)
      	WHILE NOT HOut(ProjectTemplates)
      		HFilter(TemplatePage,TemplatePageKeyID,HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMaxVal))
      		HReadFirst(TemplatePage,TemplatePageKeyID)
      		WHILE NOT HOut(TemplatePage)
      			//DataFileID+TemplatePageID
      			HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TemplatePage.TemplatePageID),hIdentical)
      			IF NOT HFound(DataFileTypeDetails) THEN
      				DataFileTypeDetails.DataFileID=DataFile.DataFileID
      				DataFileTypeDetails.TemplatePageID=TemplatePage.TemplatePageID
      				DataFileTypeDetails.FileGenerate=True
      				HAdd(DataFileTypeDetails)
      			END
      			HReadNext(TemplatePage,TemplatePageKeyID)
      		END
      		HReadNext(ProjectTemplates,ProjectTemplateKey)
      	END
      	HDeactivateFilter(ProjectTemplates)
      	HDeactivateFilter(TemplatePage)
      	
      	HFilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
      	HReadFirst(ProjectTemplates,ProjectTemplateKey)
      	WHILE NOT HOut(ProjectTemplates)
      		HFilter(TemplatePage,TemplatePageKeyID,HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMaxVal))
      		HReadFirst(TemplatePage,TemplatePageKeyID)
      		WHILE NOT HOut(TemplatePage)
      			HReadFirst(Language,LanguageID)
      			WHILE NOT HOut(Language)
      				IF nOldVersionID>0 THEN
      					nSaveID=HSavePosition(DataFile)
      					HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nOldVersionID,sTableName),hIdentical)
      					IF HFound(DataFile) THEN
      						HReadSeek(DataFileTranslation,DataFileVersionKey,HBuildKeyValue(DataFileTranslation,DataFileVersionKey,Version.VersionID,DataFile.DataFileID),hIdentical)
      						IF HFound(DataFileTranslation) THEN
      							sFileTranslationText=DataFileTranslation.Description
      						ELSE
      							sFileTranslationText=FormatCaption(DataFile.FileName)
      						END
      					ELSE
      						sFileTranslationText=FormatCaption(DataFile.FileName)
      					END
      					HRestorePosition(nSaveID)
      				ELSE
      					sFileTranslationText=FormatCaption(DataFile.FileName)
      				END
      				HReset(DataFileTranslation)
      				DataFileTranslation.Description=sFileTranslationText
      				DataFileTranslation.DataFileID=DataFile.DataFileID
      				DataFileTranslation.LanguageID=Language.LanguageID
      				DataFileTranslation.VersionID=Version.VersionID
      				DataFileTranslation.TemplatePageID=TemplatePage.TemplatePageID
      				HAdd(DataFileTranslation)
      				HReadNext(Language,LanguageID)
      			END
      			HReadNext(TemplatePage,TemplatePageKeyID)
      		END
      		HReadNext(ProjectTemplates,ProjectTemplateKey)
      	END
      	HDeactivateFilter(ProjectTemplates)
      	HDeactivateFilter(TemplatePage)
      	
      	SWITCH DBConnection.Type
      		CASE 1
      			//MySQL
      			sSQL="SHOW FULL COLUMNS FROM " + sTableName + ";"
      			s=""
      			IF NOT HExecuteSQLQuery(dsData,clConnect,hQueryWithoutCorrection+hNoBind,sSQL) THEN
      				Error(ErrorInfo(errFullDetails)+CRLF+CRLF+ErrorInfo(errFullDetails))
      				RESULT False
      			END
      		CASE 2
      			sSQL="sp_columns @table_name = '"+sTableName+"';"
      			s=""
      			IF NOT HExecuteSQLQuery(dsData,clConnect,hQueryWithoutCorrection+hNoBind,sSQL) THEN
      				Error(ErrorInfo(errFullDetails)+CRLF+CRLF+ErrorInfo(errFullDetails))
      				RESULT False
      			END
      		OTHER CASE
      	END
      	
      	mm=0
      	HReadFirst(dsData)
      	WHILE NOT HOut(dsData)
      		mm++
      		
      		SWITCH DBConnection.Type
      			CASE 1
      				//MySQL
      				sItemName={"dsDATA.Field",indItem}
      			CASE 2
      				//MSSQL
      				sItemName={"dsDATA.COLUMN_NAME",indItem}
      			OTHER CASE
      		END
      		
      		DataItems.ItemName=sItemName
      		DataItems.DataFileID=DataFile.DataFileID
      		DataItems.VersionID=nVersionID
      		
      		SWITCH DBConnection.Type
      			CASE 1
      				//MySQL
      				sRawType={"dsDATA.Type",indItem}
      				
      				IF Position(sRawType,"(")>0 THEN
      					sType=Upper(NoSpace(Left(sRawType,Position(sRawType,"(")-1)))
      				ELSE
      					sType=Upper(NoSpace(sRawType))
      				END
      				
      				// 1 - Text edit field
      				// 2 - Numeric integer edit field
      				// 3 - Numeric real edit field
      				// 4 - Date edit field
      				// 5 - Time edit field
      				// 6 - Date-Time edit field
      				// 7 - Checkbox
      				// 8 - Radio Button
      				// 9 - Listbox
      				// 10 - Combobox
      				// 11 - Static display field
      				// 12 - Image display
      				// 13 - Image edit and display
      				// 14 - Upload image (.png, .jpg, .gif)
      				// 15 - Upload document (.doc, docx, .odt, .pdf)
      				// 16 - Upload any file (*.*)
      				
      				SWITCH sType
      					CASE "TINYINT"
      						DataItems.Type=1
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="tinyInteger"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "SMALLINT"
      						DataItems.Type=2
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="smallInteger"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "MEDIUMINT"
      						DataItems.Type=3
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="mediumInteger"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "INT"
      						DataItems.Type=4
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="integer"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "BIGINT"
      						DataItems.Type=5
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="bigInteger"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "DECIMAL"
      						DataItems.Type=6
      						DataItems.TypeCast="(float)"
      						DataItems.Data_Type="decimal"
      						DataItems.ControlType=7
      						DataItems.WinDevTypePlain="currency"
      					CASE "FLOAT"
      						DataItems.Type=7
      						DataItems.TypeCast="(float)"
      						DataItems.Data_Type="float"
      						DataItems.ControlType=7
      						DataItems.WinDevTypePlain="real"
      					CASE "DOUBLE"
      						DataItems.Type=8
      						DataItems.TypeCast="(float)"
      						DataItems.Data_Type="double"
      						DataItems.ControlType=7
      						DataItems.WinDevTypePlain="real on 8 bytes"
      					CASE "REAL"
      						DataItems.Type=9
      						DataItems.TypeCast="(float)"
      						DataItems.Data_Type="float"
      						DataItems.ControlType=7
      						DataItems.WinDevTypePlain="real on 8 bytes"
      					CASE "BIT"
      						DataItems.Type=10
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=14
      						DataItems.WinDevTypePlain="boolean"
      					CASE "BOOLEAN"
      						DataItems.Type=11
      						DataItems.TypeCast="(bool)"
      						DataItems.Data_Type="boolean"
      						DataItems.ControlType=14
      						DataItems.WinDevTypePlain="boolean"
      					CASE "SERIAL"
      						DataItems.Type=12
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="int"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="string"
      					CASE "DATE"
      						DataItems.Type=13
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="date"
      						DataItems.ControlType=8
      						DataItems.WinDevTypePlain="date"
      					CASE "DATETIME"
      						DataItems.Type=14
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="datetime"
      						DataItems.ControlType=10
      						DataItems.WinDevTypePlain="DateTime"
      					CASE "TIMESTAMP"
      						DataItems.Type=15
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="timestamp"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "TIME"
      						DataItems.Type=16
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="time"
      						DataItems.ControlType=9
      						DataItems.WinDevTypePlain="time"
      					CASE "YEAR"
      						DataItems.Type=17
      						DataItems.TypeCast="(int)"
      						DataItems.Data_Type="integer"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="int"
      					CASE "CHAR"
      						DataItems.Type=18
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=1
      						DataItems.WinDevTypePlain="string"
      					CASE "VARCHAR"
      						DataItems.Type=19
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=1
      						DataItems.WinDevTypePlain="string"
      					CASE "TINYTEXT"
      						DataItems.Type=20
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="text"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "TEXT"
      						DataItems.Type=21
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="text"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "MEDIUMTEXT"
      						DataItems.Type=22
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="mediumtext"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "LONGTEXT"
      						DataItems.Type=23
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="longtext"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "BINARY"
      						DataItems.Type=24
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=27
      						DataItems.WinDevTypePlain="string"
      					CASE "VARBINARY"
      						DataItems.Type=25
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=27
      						DataItems.WinDevTypePlain="string"
      					CASE "TINYBLOB"
      						DataItems.Type=26
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=27
      						DataItems.WinDevTypePlain="image"
      					CASE "MEDIUMBLOB"
      						DataItems.Type=27
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=27
      						DataItems.WinDevTypePlain="image"
      					CASE "BLOB"
      						DataItems.Type=28
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=27
      						DataItems.WinDevTypePlain="image"
      					CASE "LONGBLOB"
      						DataItems.Type=29
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="binary"
      						DataItems.ControlType=27
      						DataItems.WinDevTypePlain="image"
      					CASE "ENUM"
      						DataItems.Type=30
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="enum"
      						DataItems.ControlType=6
      						DataItems.WinDevTypePlain="string"
      					CASE "SET"
      						DataItems.Type=31
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "GEOMETRY"
      						DataItems.Type=32
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "POINT"
      						DataItems.Type=33
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "LINESTRING"
      						DataItems.Type=34
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "POLYGON"
      						DataItems.Type=35
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "MULTIPOINT"
      						DataItems.Type=36
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "MULTILINESTRING"
      						DataItems.Type=37
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "MULTIPOLIGON"
      						DataItems.Type=38
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					CASE "GEOMETRYCOLLECTION"
      						DataItems.Type=39
      						DataItems.TypeCast="(string)"
      						DataItems.Data_Type="string"
      						DataItems.ControlType=2
      						DataItems.WinDevTypePlain="string"
      					OTHER CASE
      						Info(sType + " MySQL type not assigned")
      				END
      				SWITCH DataItems.Type
      					CASE 6
      						sIntegerPart=IntegerPart(Val(Replace(GetText(sRawType,"(",")"),",",".")))
      						sDecimalPart=DecimalPart(Val(Replace(GetText(sRawType,"(",")"),",",".")))*10
      						DataItems.Size=sIntegerPart+","+sDecimalPart
      					OTHER CASE
      						DataItems.Size=NumToString(Val(Replace(GetText(sRawType,"(",")"),",",".")),"d")
      				END
      				IF DataItems.Type=1 AND DataItems.Size=1 THEN
      					DataItems.Data_Type="boolean"
      				END
      				IF Position(sRawType,"unsigned")>0 THEN
      					DataItems.bUnsigned=True
      				ELSE
      					DataItems.bUnsigned=False
      				END
      				IF Position({"dsDATA.Extra",indItem},"auto_increment")>0 THEN
      					DataItems.AutoIncrement=True
      				ELSE
      					DataItems.AutoIncrement=False
      				END
      				SWITCH {"dsDATA.Key",indItem}
      					CASE "MUL"
      						DataItems.KeyType=2
      					CASE "UNI"
      						DataItems.KeyType=3
      					CASE "PRI"
      						DataItems.KeyType=4
      					OTHER CASE
      						DataItems.KeyType=1
      				END
      				
      				sDefault={"dsDATA.Default",indItem}
      				DataItems.sDefault=sDefault
      				DataItems.DB_Data_Type=sRawType
      				
      				IF {"dsDATA.Null",indItem}="YES" THEN
      					DataItems.bNotNull=True
      				ELSE
      					DataItems.bNotNull=False
      				END
      				
      				HAdd(DataItems)
      				
      			CASE 2
      				//PostgreSQL
      				sRawType={"dsDATA.TYPE_NAME",indItem}
      				IF Position(sRawType,"(")>0 THEN
      					sType=Upper(NoSpace(Left(sRawType,Position(sRawType,"(")-1)))
      				ELSE
      					sType=Upper(NoSpace(sRawType))
      				END
      				
      				// 1 - Text edit field
      				// 2 - Numeric integer edit field
      				// 3 - Numeric real edit field
      				// 4 - Date edit field
      				// 5- Time edit field
      				// 6 - Date-Time edit field
      				// 7 - Checkbox
      				// 8 - Radio Button
      				// 9 - Listbox
      				// 10 - Combobox
      				// 11 - Static display field
      				// 12 - Image display
      				// 13 - Image edit and display
      				// 14 - Upload image (.png, .jpg, .gif)
      				// 15 - Upload document (.doc, docx, .odt, .pdf)
      				// 16 - Upload any file (*.*)
      				
      				SWITCH sType
      					CASE "TINYINT"
      						DataItems.Type=1
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "SMALLINT"
      						DataItems.Type=2
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "MEDIUMINT"
      						DataItems.Type=3
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "INT"
      						DataItems.Type=4
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "BIGINT"
      						DataItems.Type=5
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "DECIMAL"
      						DataItems.Type=6
      						DataItems.TypeCast="(float)"
      						DataItems.ControlType=3
      					CASE "FLOAT"
      						DataItems.Type=7
      						DataItems.TypeCast="(float)"
      						DataItems.ControlType=3
      					CASE "DOUBLE"
      						DataItems.Type=8
      						DataItems.TypeCast="(float)" 
      						DataItems.ControlType=3
      					CASE "REAL"
      						DataItems.Type=9
      						DataItems.TypeCast="(float)"
      						DataItems.ControlType=3
      					CASE "BIT"
      						DataItems.Type=10
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "BOOLEAN"
      						DataItems.Type=11
      						DataItems.TypeCast="(bool)"
      						DataItems.ControlType=2
      					CASE "SERIAL"
      						DataItems.Type=12
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "DATE"
      						DataItems.Type=13
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=4
      					CASE "DATETIME"
      						DataItems.Type=14
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=6
      					CASE "TIMESTAMP"
      						DataItems.Type=15
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "TIME"
      						DataItems.Type=16
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=5
      					CASE "YEAR"
      						DataItems.Type=17
      						DataItems.TypeCast="(int)"
      						DataItems.ControlType=2
      					CASE "VARCHAR"
      						DataItems.Type=18
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "TINYTEXT"
      						DataItems.Type=19
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "TEXT"
      						DataItems.Type=20
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "MEDIUMTEXT"
      						DataItems.Type=21
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "LONGTEXT"
      						DataItems.Type=22
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "BINARY"
      						DataItems.Type=23
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=15
      					CASE "VARBINARY"
      						DataItems.Type=24
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=15
      					CASE "TINYBLOB"
      						DataItems.Type=25
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=15
      					CASE "MEDIUMBLOB"
      						DataItems.Type=26
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=15
      					CASE "BLOB"
      						DataItems.Type=27
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=15
      					CASE "LONGBLOB"
      						DataItems.Type=28
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=15
      					CASE "ENUM"
      						DataItems.Type=29
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "SET"
      						DataItems.Type=30
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "GEOMETRY"
      						DataItems.Type=31
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "POINT"
      						DataItems.Type=32
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "LINESTRING"
      						DataItems.Type=33
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "POLYGON"
      						DataItems.Type=34
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "MULTIPOINT"
      						DataItems.Type=35
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "MULTILINESTRING"
      						DataItems.Type=36
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "MULTIPOLIGON"
      						DataItems.Type=37
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					CASE "GEOMETRYCOLLECTION"
      						DataItems.Type=38
      						DataItems.TypeCast="(string)"
      						DataItems.ControlType=1
      					OTHER CASE
      						Info(sType + " PostgreSQL type not assigned")
      				END
      				
      				DataItems.Size=Val(Replace(GetText(sRawType,"(",")"),",","."))
      				DataItems.bUnsigned=False
      				
      				//						IF Position({"dsDATA.Extra"},"auto_increment")>0 THEN
      				//							DataItems.AutoIncrement=True
      				//						ELSE
      				DataItems.AutoIncrement=False
      				//						END
      				
      				//						SWITCH {"dsDATA.Key"}
      				//							CASE "MUL"
      				//								DataItems.KeyType=2
      				//							CASE "UNI"
      				//								DataItems.KeyType=3
      				//							CASE "PRI"
      				//								DataItems.KeyType=4
      				//							OTHER CASE
      				//								DataItems.KeyType=1
      				//						END
      				
      				sDefault={"dsDATA.COLUMN_DEF",indItem}
      				DataItems.sDefault=Replace(Replace(sDefault,"(",""),")","")
      				
      				IF {"dsDATA.NULLABLE",indItem}="1" THEN
      					DataItems.bNotNull=True
      				ELSE
      					DataItems.bNotNull=False
      				END
      				
      				DataItems.DB_Data_Type=sRawType
      				
      				HAdd(DataItems)
      				
      			OTHER CASE
      		END
      		
      		nNewItemId=DataItems.DataItemsID
      		
      		HFilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
      		HReadFirst(ProjectTemplates,ProjectTemplateKey)
      		WHILE NOT HOut(ProjectTemplates)
      			HFilter(TemplatePage,TemplatePageKeyID,HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMaxVal))
      			HReadFirst(TemplatePage,TemplatePageKeyID)
      			WHILE NOT HOut(TemplatePage)
      				HReadFirst(Language,LanguageID)
      				WHILE NOT HOut(Language)
      					IF nOldVersionID>0 THEN
      						nSaveID=HSavePosition(DataFile)
      						HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nOldVersionID,sTableName),hIdentical)
      						IF HFound(DataFile) THEN
      							nSaveItemID=HSavePosition(DataItems)
      							HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,DataFile.DataFileID,sItemName),hIdentical)
      							IF HFound(DataItems) THEN
      								//DataItemsID+TemplatePageID+LanguageID
      								HReadSeek(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,TemplatePage.TemplatePageID,Language.LanguageID),hIdentical)
      								IF HFound(DataItemsTranslation) THEN
      									sItemTranslationText=DataItemsTranslation.Caption
      								ELSE
      									sItemTranslationText=FormatCaption(sItemName)
      								END
      							ELSE
      								sItemTranslationText=FormatCaption(sItemName)
      							END
      							HRestorePosition(nSaveItemID)
      						ELSE
      							sItemTranslationText=FormatCaption(sItemName)
      						END
      						HRestorePosition(nSaveID)
      					ELSE
      						sItemTranslationText=FormatCaption(sItemName)
      					END
      					
      					HReset(DataItemsTranslation)
      					DataItemsTranslation.DataItemsID=DataItems.DataItemsID
      					DataItemsTranslation.LanguageID=Language.LanguageID
      					DataItemsTranslation.TemplatePageID=TemplatePage.TemplatePageID
      					DataItemsTranslation.Caption=sItemTranslationText
      					DataItemsTranslation.VersionID=Version.VersionID
      					HAdd(DataItemsTranslation)
      					
      					HReadNext(Language,LanguageID)
      				END
      				
      				bDataItemsTypeDetailsAdded=False
      				nSaveID=HSavePosition(DataFile)
      				HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nOldVersionID,sTableName),hIdentical)
      				IF HFound(DataFile) THEN
      					nSaveItemID=HSavePosition(DataItems)
      					HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,DataFile.DataFileID,sItemName),hIdentical)
      					IF HFound(DataItems) THEN
      						HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,TemplatePage.TemplatePageID),hIdentical)
      						IF HFound(DataItemsTypeDetails) THEN
      							DataItemsTypeDetails.DataItemsID=nNewItemId
      							HAdd(DataItemsTypeDetails)
      							bDataItemsTypeDetailsAdded=True
      						END
      					END
      					HRestorePosition(nSaveItemID)
      				END
      				HRestorePosition(nSaveID)
      				
      				//Defaults adding
      				IF NOT bDataItemsTypeDetailsAdded THEN
      					DataItemsTypeDetails.DataItemsID=nNewItemId
      					DataItemsTypeDetails.TemplatePageID=TemplatePage.TemplatePageID
      					DataItemsTypeDetails.SortIndex=mm
      					DataItemsTypeDetails.ItemVisible=True
      					DataItemsTypeDetails.ItemState=1 //Visible
      					DataItemsTypeDetails.ItemGenerate=True
      					DataItemsTypeDetails.VersionID=Version.VersionID
      					DataItemsTypeDetails.X=1
      					DataItemsTypeDetails.Y=1
      					DataItemsTypeDetails.DataFileID=DataFile.DataFileID
      					HAdd(DataItemsTypeDetails)
      				END
      				
      				HReadNext(TemplatePage,TemplatePageKeyID)
      			END
      			HReadNext(ProjectTemplates,ProjectTemplateKey)
      		END
      		HDeactivateFilter(ProjectTemplates)
      		HDeactivateFilter(TemplatePage)
      		
      		s=s+sItemName+","
      		s=s+{"dsDATA.TYPE",indItem} //+","
      		s=s+{"dsDATA.Collation",indItem}+","
      		s=s+{"dsDATA.Null",indItem}+"," //YES, NO
      		s=s+{"dsDATA.Key",indItem}+"," //PRI = Primary, 	MUL = Multiple key (Index), UNI=unique key
      		s=s+{"dsDATA.Default",indItem}+","
      		s=s+{"dsDATA.Extra",indItem}+CRLF+CRLF
      		
      		HReadNext(dsData)
      	END
      	HFreeQuery(dsData)
      	
      	//Key's read
      	sKeySQL="SHOW INDEX FROM " + sTableName + " FROM "+sDBName+";"
      	IF NOT HExecuteSQLQuery(dsData3,clConnect,hQueryWithoutCorrection+hNoBind,sKeySQL) THEN
      		Error(ErrorInfo(errFullDetails)+CRLF+CRLF+ErrorInfo(errFullDetails))
      		RESULT False
      	END
      	sUniqueKeyName=""
      	HReadFirst(dsData3)
      	WHILE NOT HOut(dsData3)
      		//Insert
      		DataKeys.DataFileID=DataFile.DataFileID
      		DataKeys.KeyName={"dsDATA3.Key_name",indItem}
      		DataKeys.Field={"dsDATA3.Column_name",indItem}
      		DataKeys.Segment={"dsDATA3.Seq_in_index",indItem}
      		DataKeys.VersionID=Version.VersionID
      		IF {"dsDATA3.Non_unique",indItem}=0 AND {"dsDATA3.Key_name",indItem}="PRIMARY" THEN
      			DataKeys.KeyType=4
      		ELSE IF {"dsDATA3.Non_unique",indItem}=0  AND {"dsDATA3.Key_name",indItem}<>"PRIMARY" THEN
      			DataKeys.KeyType=3
      		ELSE
      			DataKeys.KeyType=2
      		END
      		HAdd(DataKeys)
      		HReadNext(dsData3)
      	END
      	
      	IF DataFile.KeyName="" THEN
      		bFound=False
      		sKeyName=""
      		HFilter(DataKeys,DataKeysKey,HBuildKeyValue(DataKeys,DataKeysKey,DataFile.DataFileID,hMinVal,hMinVal),HBuildKeyValue(DataKeys,DataKeysKey,DataFile.DataFileID,hMaxVal,hMaxVal))
      		HReadFirst(DataKeys,DataKeysKey)
      		WHILE NOT HOut(DataKeys)
      			IF DataKeys.KeyType=4 AND DataKeys.Segment=1 THEN
      				sKeyName=DataKeys.KeyName
      				HReadNext(DataKeys,DataKeysKey)
      				IF DataKeys.KeyName=sKeyName AND DataKeys.Segment=2 THEN
      					//Segmented Key found, not needed!
      					sKeyName=DataKeys.KeyName
      				ELSE
      					DataFile.KeyName=sKeyName
      					HModify(DataFile)
      					bFound=True
      					BREAK
      				END
      			END
      			HReadNext(DataKeys,DataKeysKey)
      		END
      		HDeactivateFilter(DataKeys)
      		IF NOT bFound AND sKeyName<>"" THEN
      			DataFile.KeyName=sKeyName
      			HModify(DataFile)	
      		END
      	END
      	HCloseConnection(clConnect)
      else
      	info(sError)
      	result false
      end
      
      RESULT True
      
     type : 458752
   -
     name : ImportForeignKey
     procedure_id : 1532543248649098820
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] ImportForeignKey (<nVersionID>, <nDBConnectionID>, <sDBName>, <sTableName>)
      //
      // Parameters:
      //	nVersionID: <specify the role of sTableName>
      //	nDBConnectionID: <specify the role of sTableName>
      //	sDBName: <specify the role of nDBConnectionID>
      //	sTableName: <specify the role of sDBName>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      //	sTableName: <specify the role of sTableName>
      PROCEDURE ImportForeignKey(nVersionID, nDBConnectionID, sDBName, sTableName)
      
      local
      	sSQLForeign is string
      	bUpdate is boolean
      	dsData2 is Data Source
      	sError is string
      	nForeignZZ is int
      	sSourceDatabase is string
      	sForeignTableName is string
      	sItemName is string
      	sDestinationDatabase is string
      	stForeignData is Structure
      		DataItemsID is int on 8 bytes
      		DataItemsID_Relation is int on 8 bytes
      		Parent_Schema is string
      		Child_Schema is string
      		Parent_Table is string
      		Parent_Item is string
      		Child_Table is string
      		Child_Item is string
      		Constraint_Name is string
      		RuleDelete is string
      		RuleUpdate is string
      		ProjectID is int
      	END
      	arrForeignData is dynamic array of 0 stForeignData
      	clConnect is connection
      	n is int
      	i is int
      	
      Message(<§@1fb8c9cd011e86710011§>+sTableName)
      Multitask(-1)
      
      hreadseek(DBConnection,DBConnectionID,nDBConnectionID,hIdentical)
      if hfound(DBConnection) then
      	IF DBConnect(clConnect,sError,DBConnection.Type,DBConnection.Server,DBConnection.Username,DBConnection.Password,sDBName) THEN
      		
      		sSQLForeign="SELECT c.table_schema as 'Parent Schema',u.referenced_table_name as 'Parent Table',u.referenced_column_name as 'Parent Column',u.table_schema as 'Child Schema',u.table_name as 'Child Table',u.column_name as 'Child Column', u.CONSTRAINT_NAME as 'Constraint Name', rs.UPDATE_RULE as 'Update Rule', rs.DELETE_RULE AS 'Delete Rule' "
      		sSQLForeign=sSQLForeign+"FROM information_schema.table_constraints AS c "
      		sSQLForeign=sSQLForeign+"JOIN information_schema.key_column_usage AS u USING(constraint_schema,constraint_name) "
      		sSQLForeign=sSQLForeign+"JOIN information_schema.referential_constraints AS rs USING(constraint_schema,constraint_name) "
      		sSQLForeign=sSQLForeign+"WHERE c.constraint_type = 'FOREIGN KEY' AND u.referenced_table_schema = '" + sDBName + "'  AND u.referenced_table_name = '" + sTableName +"' "
      		sSQLForeign=sSQLForeign+"ORDER BY c.table_schema, u.referenced_table_name, u.referenced_column_name,u.table_schema, u.table_name, u.column_name"
      		
      		IF NOT HExecuteSQLQuery(dsData2,clConnect,hQueryWithoutCorrection+hNoBind,sSQLForeign) THEN
      			Error(ErrorInfo(errFullDetails)+CRLF+CRLF+ErrorInfo(errFullDetails))
      			RESULT False
      		END
      		
      		HReadFirst(dsData2)
      		WHILE NOT HOut(dsData2)
      			nForeignZZ++
      			Dimension(arrForeignData,nForeignZZ)
      			arrForeignData[nForeignZZ].Parent_Schema={"dsDATA2.Parent Schema",indItem}
      			arrForeignData[nForeignZZ].Child_Schema={"dsDATA2.Child Schema",indItem}
      			arrForeignData[nForeignZZ].Parent_Table={"dsDATA2.Parent Table",indItem}
      			arrForeignData[nForeignZZ].Parent_Item={"dsDATA2.Parent Column",indItem}
      			arrForeignData[nForeignZZ].Child_Table={"dsDATA2.Child Table",indItem}
      			arrForeignData[nForeignZZ].Child_Item={"dsDATA2.Child Column",indItem}
      			arrForeignData[nForeignZZ].Constraint_Name={"dsDATA2.Constraint Name",indItem}
      			arrForeignData[nForeignZZ].RuleDelete={"dsDATA2.Delete Rule",indItem}
      			arrForeignData[nForeignZZ].RuleUpdate={"dsDATA2.Update Rule",indItem}
      			arrForeignData[nForeignZZ].ProjectID=gnProjectID
      			HReadNext(dsData2)
      		END
      		HFreeQuery(dsData2)
      		
      		n=Dimension(arrForeignData)
      		FOR i=1 TO n
      			sSourceDatabase=arrForeignData[i].Parent_Schema
      			sForeignTableName=arrForeignData[i].Parent_Table
      			HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,sForeignTableName),hIdentical)
      			IF HFound(DataFile) THEN
      				sItemName=arrForeignData[i].Parent_Item
      				HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,DataFile.DataFileID,sItemName),hIdentical)
      				IF HFound(DataItems) THEN
      					arrForeignData[i].DataItemsID=DataItems.DataItemsID
      				ELSE
      					Error(sForeignTableName+ "."+sItemName+<§@1fb8c9cd011e86710012§>)
      				END
      			ELSE
      				Info(<§@1fb8c9cd011e86710014§>+sForeignTableName+<§@1fb8c9cd011e86710013§>)
      			END
      			
      			sDestinationDatabase=arrForeignData[i].Child_Schema
      			sForeignTableName=arrForeignData[i].Child_Table
      			HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,sForeignTableName),hIdentical)
      			IF HFound(DataFile) THEN
      				sItemName=arrForeignData[i].Child_Item
      				HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,DataFile.DataFileID,sItemName),hIdentical)
      				IF HFound(DataItems) THEN
      					arrForeignData[i].DataItemsID_Relation=DataItems.DataItemsID
      				ELSE
      					Error(sForeignTableName+ "."+sItemName+<§@1fb8c9cd011e86710015§>)
      				END
      			ELSE
      				Info(<§@1fb8c9cd011e86710017§>+sForeignTableName+<§@1fb8c9cd011e86710016§>)
      			END
      			
      			HReadSeek(ForeignKey,ForeignIDKey,HBuildKeyValue(ForeignKey,ForeignIDKey,arrForeignData[i].DataItemsID,arrForeignData[i].DataItemsID_Relation))
      			IF HFound(ForeignKey) THEN
      				bUpdate=True
      			ELSE
      				bUpdate=False
      			END
      			
      			IF arrForeignData[i].DataItemsID>0 AND arrForeignData[i].DataItemsID_Relation>0 THEN
      				
      				ForeignKey.DataItemsID=arrForeignData[i].DataItemsID
      				ForeignKey.DataItemsID_Relation=arrForeignData[i].DataItemsID_Relation
      				ForeignKey.Parent_Table=arrForeignData[i].Parent_Table
      				ForeignKey.Parent_Item=arrForeignData[i].Parent_Item
      				ForeignKey.Child_Table=arrForeignData[i].Child_Table
      				ForeignKey.Child_Item=arrForeignData[i].Child_Item
      				ForeignKey.Constraint_Name=arrForeignData[i].Constraint_Name
      				ForeignKey.RuleDelete=arrForeignData[i].RuleDelete
      				ForeignKey.RuleUpdate=arrForeignData[i].RuleUpdate
      				ForeignKey.VersionID=nVersionID
      				
      				IF bUpdate THEN
      					HModify(ForeignKey)
      				ELSE
      					HAdd(ForeignKey)	
      				END
      				
      				hreadseek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nVersionID,arrForeignData[i].Child_Table),hIdentical)
      				if HFound(DataFile) then
      					hreadseek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,DataFile.DataFileID,arrForeignData[i].Child_Item),hIdentical)
      					if hfound(DataItems) then
      						//Combobox assign
      						DataItems.ControlType=17
      						HModify(DataItems)
      					END
      				end
      			END
      		END
      	else
      		error(sError)	
      	END
      	
      	HCloseConnection(clConnect)
      else
      	info(<§@1fb8c9cd011e86710018§>)
      	result false
      end	
      
      result true
     type : 458752
   -
     name : DBConnect
     procedure_id : 1532544103347658413
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] DBConnect (<ctConnect> is HFSQL connection, <sError>, <nType>, <sServer>, <sUsername>, <sPassword>, <sDatabase>)
      //
      // Parameters:
      //	ctConnect (HFSQL connection): <specify the role of clConnect>
      //	sError: <specify the role of nType>
      //	nType: <specify the role of sServer>
      //	sServer: <specify the role of sUsername>
      //	sUsername: <specify the role of sPassword>
      //	sPassword: <specify the role of sDatabase>
      // 	sDatabase: <specify the role of sDatabase>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE DBConnect(ctConnect is connection, sError, nType, sServer, sUsername, sPassword, sDatabase)
      
      local
      	bRes is boolean
      
      SWITCH nType
      	CASE 1
      		//MySQL
      		ctConnect..Server=sServer
      		ctConnect..User=sUsername
      		ctConnect..Password=sPassword
      		ctConnect..Database=sDatabase
      		ctConnect..Provider = hNativeAccessMySQL
      		ctConnect..CursorOptions = hClientCursor
      		ctConnect..Access=hOReadWrite
      	CASE 2
      		//MsSQL
      		ctConnect..Server=sServer
      		ctConnect..User=sUsername
      		ctConnect..Password=sPassword
      		ctConnect..Database=sDatabase
      		ctConnect..Provider = hOledbSQLServer
      		ctConnect..CursorOptions = hClientCursor
      		ctConnect..Access=hOReadWrite
      END
      
      bRes=HOpenConnection(ctConnect)
      IF bRes THEN
      	result true
      else
      	sError=HErrorInfo(hErrFullDetails)
      	result false
      end
     type : 458752
   -
     name : GetTimeStamp
     procedure_id : 1534731482906279799
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetTimeStamp (<dDatum> is date, <tZeit> is time)
      //
      // Parameters:
      //	dDatum (date): <specify the role of dDatum>
      //	tZeit (time): <specify the role of tZeit>
      // Return Value:
      // 	int: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetTimeStamp(dDatum is date, tZeit is time)
      
      local
      	sDatum is string
      	sDatumUTC is string
      	sTimeStamp is string
      	sDifferenz is string
      	duFraktion is duration	
      	nTimeStampResult is int
      	
      sDatum = dDatum + Left(tZeit, 6)
      sDatumUTC = Left(DateTimeLocalToUTC(sDatum), 14)
      sTimeStamp = "19700101000000"
      sDifferenz = DateTimeDifference(sTimeStamp, sDatumUTC)
      duFraktion = StringToDuration(sDifferenz,durationCenti)
      nTimeStampResult = duFraktion..Day * 86400 + duFraktion..Hour * 3600 + duFraktion..Minute * 60 + duFraktion..Second
      
      result nTimeStampResult
     type : 458752
   -
     name : UpdateAll
     procedure_id : 1535698138388361976
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //UpdateAll ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE UpdateAll()
      
      local
      	zz is int
      
      HReadFirst(Project,ProjectID)
      while not hout(Project)
      	
      	hreadfirst(Language,LanguageID)
      	while not hout(Language)
      		hreadseek(ProjectTranslation,DataFileTranslationKey,HBuildKeyValue(ProjectTranslation,DataFileTranslationKey,Project.ProjectID,Language.LanguageID),hIdentical)
      		if not hfound(ProjectTranslation) then
      			ProjectTranslation.ProjectID=Project.ProjectID
      			ProjectTranslation.LanguageID=Language.LanguageID
      			ProjectTranslation.Description=project.ProjectName
      			hadd(ProjectTranslation)
      		END
      		hreadnexT(Language,LanguageID)
      	END
      	
      	
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	if hfound(Version) then
      		
      		hfilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
      		HReadFirst(ProjectTemplates,ProjectTemplateKey)
      		while not hout(ProjectTemplates)
      			
      			hreadseek(Template,TemplateID,ProjectTemplates.TemplateID,hIdentical)
      			if hfound(Template) then
      				
      				hfilter(TemplateVars,TemplateID,template.TemplateID,Template.TemplateID)
      				hreadfirst(TemplateVars,TemplateID)
      				while not hout(TemplateVars)
      					//ProjectID+TemplateVarsID+LanguageID
      					HReadFirst(Language,LanguageID)
      					while not hout(Language)
      						hreadseek(ProjectVars,ProjectVarsKey,HBuildKeyValue(ProjectVars,ProjectVarsKey,Project.ProjectID,TemplateVars.TemplateVarsID,Language.LanguageID),hIdentical)
      						if not hfound(ProjectVars) then
      							ProjectVars.LanguageID=Language.LanguageID
      							ProjectVars.ProjectID=Project.ProjectID
      							ProjectVars.TemplateVarsID=TemplateVars.TemplateVarsID
      							ProjectVars.Text=TemplateVars.DefaultValue
      							hadd(ProjectVars)
      						END
      						hreadnext(Language,LanguageID)
      					end
      					hreadnext(TemplateVars,TemplateID)
      				END
      				HDeactivateFilter(TemplateVars)
      				
      				hfilter(TemplatePage,TemplatePageKeyID,HBuildKeyValue(TemplatePage,TemplatePageKeyID,Template.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,Template.TemplateID,hMaxVal))
      				HReadFirst(TemplatePage,TemplatePageKeyID)
      				while not hout(TemplatePage)
      					
      					message("Refresh "+TemplatePage.TemplatePageName)
      					Multitask(-1)
      					
      					HReadFirst(Language,LanguageID)
      					while not hout(Language)
      						if Language.LanguageGenerate then
      							
      							hreadseek(ProjectTranslation,DataFileTranslationKey,HBuildKeyValue(ProjectTranslation,DataFileTranslationKey,Project.ProjectID,Language.LanguageID),hIdentical)
      							if not hfound(ProjectTranslation) then
      								ProjectTranslation.ProjectID=project.ProjectID
      								ProjectTranslation.LanguageID=Language.LanguageID
      								ProjectTranslation.Description=Project.ProjectName
      								hadd(ProjectTranslation)
      							END
      							
      							hfilter(DataFile,VersionID,version.VersionID,version.VersionID)
      							HReadFirst(DataFile,VersionID)
      							while not hout(DataFile)
      								if DataFile.DataFileGenerate then
      									//DataFileID+TemplatePageID+LanguageID
      									hreadseek(DataFileTranslation,DataFileTranslationKey,HBuildKeyValue(DataFileTranslation,DataFileTranslationKey,DataFile.DataFileID,TemplatePage.TemplatePageID,Language.LanguageID),hIdentical)
      									if not hfound(DataFileTranslation) THEN
      										DataFileTranslation.DataFileID=DataFile.DataFileID
      										DataFileTranslation.Description=FormatCaption(DataFile.FileName)
      										DataFileTranslation.LanguageID=Language.LanguageID
      										DataFileTranslation.TemplatePageID=TemplatePage.TemplatePageID
      										DataFileTranslation.VersionID=version.VersionID
      										hadd(DataFileTranslation)
      									END
      									
      									//DataFileID+TemplatePageID
      									hreadseek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TemplatePage.TemplatePageID),hIdentical)
      									if not hfound(DataFileTypeDetails) THEN
      										DataFileTypeDetails.DataFileID=DataFile.DataFileID
      										DataFileTypeDetails.FileGenerate=true
      										DataFileTypeDetails.TemplatePageID=TemplatePage.TemplatePageID
      										hadd(DataFileTypeDetails)
      									END
      									
      									zz=0
      									//DataFileID+DataItemsID
      									hfilter(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,DataFile.DataFileID,hMinVal),HBuildKeyValue(DataItems,DataItemsKey,DataFile.DataFileID,hMaxVal))
      									HReadFirst(DataItems,DataItemsKey)
      									while not hout(DataItems)
      										zz++
      										//DataItemsID+TemplatePageID+LanguageID
      										hreadseek(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,TemplatePage.TemplatePageID,Language.LanguageID),hIdentical)
      										if not hfound(DataItemsTranslation) then
      											DataItemsTranslation.Caption=FormatCaption(DataItems.ItemName)
      											DataItemsTranslation.ComboBoxContent=""
      											DataItemsTranslation.DataItemsID=DataItems.DataItemsID
      											DataItemsTranslation.LanguageID=Language.LanguageID
      											DataItemsTranslation.TemplatePageID=TemplatePage.TemplatePageID
      											DataItemsTranslation.VersionID=version.VersionID
      											hadd(DataItemsTranslation)
      										END
      										
      										//DataItemsID+TemplatePageID
      										hreadseek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,TemplatePage.TemplatePageID),hIdentical)
      										if not hfound(DataItemsTypeDetails) then
      											DataItemsTypeDetails.DataItemsID=DataItems.DataItemsID
      											DataItemsTypeDetails.EditMask=""
      											DataItemsTypeDetails.ItemGenerate=True
      											DataItemsTypeDetails.ItemState=1
      											DataItemsTypeDetails.ItemVisible=true
      											DataItemsTypeDetails.SortIndex=zz
      											DataItemsTypeDetails.TemplatePageID=TemplatePage.TemplatePageID
      											DataItemsTypeDetails.VersionID=version.VersionID
      											DataItemsTypeDetails.X=1
      											DataItemsTypeDetails.Y=1
      											hadd(DataItemsTypeDetails)
      										END
      										
      										hreadnext(DataItems,DataItemsKey)
      									END
      								END
      								hreadnext(DataFile,VersionID)													
      							END
      						END
      						hreadnexT(Language,LanguageID)
      					END
      					hreadnext(TemplatePage,TemplatePageKeyID)
      				END
      			END
      			hreadnext(ProjectTemplates,ProjectTemplateKey)
      		END
      	END
      	hreadnext(Project,ProjectID)
      END
      
      HDeactivateFilter(ProjectTemplates)
      HDeactivateFilter(TemplatePage)
      HDeactivateFilter(DataFile)
      HDeactivateFilter(DataItems)
     type : 458752
   -
     name : GetCleanFileName
     procedure_id : 1539225552002479124
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetCleanFileName (<sFileName>)
      //
      // Parameters:
      //	sFileName: <specify the role of sFileName>
      // Return Value:
      // 	Unspecified Type: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetCleanFileName(sFileName)
      
      sFileName=Replace(sFileName,">","")
      sFileName=Replace(sFileName,"<","")
      sFileName=Replace(sFileName,Charact(34),"")
      sFileName=Replace(sFileName,"?","")
      sFileName=Replace(sFileName,"/","")
      sFileName=Replace(sFileName,"\","")
      sFileName=Replace(sFileName,"*","")
      sFileName=Replace(sFileName,"&","")
      sFileName=Replace(sFileName,"%","")
      
      result sFileName
     type : 458752
   -
     name : CheckIsMDI
     procedure_id : 1539225633607532343
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] CheckIsMDI (<sWindow> is string)
      //
      // Parameters:
      //	sWindow (ANSI string): <specify the role of sWindow>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CheckIsMDI(sWindow is string)
      
      local
      	AliasName is string
      	i is int = 1
      
      AliasName = MDIEnumChild(i)
      
      WHILE AliasName <> ""
      	if sWindow=AliasName then
      		result true
      	END
      	i++
      	AliasName = MDIEnumChild(i)
      END
      
      //Nichts gefunden...
      result false
     type : 458752
   -
     name : GetReplace
     procedure_id : 1539227489035474660
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetReplace (<s> is string [, <b> is string [, <c> is string]])
      //
      // Parameters:
      //	s (ANSI string): <specify the role of s>
      //	b (ANSI string - default value="&"): <specify the role of b>
      //	c (ANSI string - default value=""): <specify the role of c>
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetReplace(s is string, b is string="&", c is string="")
      
      local
      	sRes is string
      	i is int
      	
      sRes=s
      
      for i=1 to Length(b)
      	sRes=replace(sRes,middle(b,i,1),middle(c,i,1))
      END
      
      result sRes
     type : 458752
   -
     name : MakeMenuScreenShot
     procedure_id : 1539228330855158416
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //MakeMenuScreenShot (<sWindowName>, <sMenuName>, <zz>)
      //
      // Parameters:
      //	sWindowName: <specify the role of sMenuName>
      //	sMenuName: <specify the role of zz>
      //	zz: <specify the role of zz>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE MakeMenuScreenShot(sWindowName, sMenuName, zz)
      
      LOCAL
      	n1 is string
      	n2 is string
      	n3 is string
      	n4 is string
      	n5 is string
      	n6 is string
      	t is int
      	u is int
      	ResSave is boolean
      	hdc is int
      	x1 is int
      	x2 is int
      	x3 is int
      	x4 is int
      	x5 is int
      	y1 is int
      	maxbreite is int
      	maxhoehe is int
      	sLastText is string
      	
      WHEN EXCEPTION IN
      	IF WinStatus(Testprogramme_MacheScreenShots)=NotFound THEN
      		OpenChild(Testprogramme_MacheScreenShots)
      	END
      DO
      	
      END
      
      Testprogramme_MacheScreenShots.Image1..Width=1024
      Testprogramme_MacheScreenShots.Image1..Height=600
      
      n1=Replace(NoSpace(ExtractString(sMenuName,1,";")),TAB," ")
      n2=Replace(NoSpace(ExtractString(sMenuName,2,";")),TAB," ")
      n3=Replace(NoSpace(ExtractString(sMenuName,3,";")),TAB," ")
      n4=Replace(NoSpace(ExtractString(sMenuName,4,";")),TAB," ")
      n5=Replace(NoSpace(ExtractString(sMenuName,5,";")),TAB," ")
      n6=Replace(NoSpace(ExtractString(sMenuName,6,";")),TAB," ")
      
      hdc=dStartDrawing(Testprogramme_MacheScreenShots.Image1,dNoErase)
      
      dRectangle(0, 0, 1024, 600, RGB(255,255,255), RGB(255,255,255))
      
      dFont("MS Shell Dlg", 8, iNormal)
      
      IF n1<>"" AND NOT n1=EOT THEN
      	sLastText=n1
      	t=GetPixelWidth(hdc,n1,"MS Shell Dlg",8,False,False,False)
      	u=GetPixelHeight(hdc,n1,"MS Shell Dlg",8,False,False,False)
      	y1=u+4
      	dRectangle(0, 0, t+26, u+3, RGB(177,216,255), RGB(51,153,255))
      	maxbreite=t+26+1
      	maxhoehe=u+3+1
      	x1=t+26
      	dText(13,1,n1,RGB(0, 0, 0),False)
      END
      
      IF n2<>"" AND NOT n2=EOT THEN
      	sLastText=n1+"_"+n2
      	t=GetPixelWidth(hdc,n2,"MS Shell Dlg",8,False,False,False)
      	u=GetPixelHeight(hdc,n2,"MS Shell Dlg",8,False,False,False)
      	dRectangle(0, 17, t+62, u+2+22, RGB(254,254,254),RGB(120,120,120))
      	maxbreite=t+62+1
      	maxhoehe=u+2+22+1	
      	dLine(1,y1,x1,y1,RGB(241,241,241),1)
      	dRectangle(2, 19, t+60, u+2+20, RGB(177,216,255), RGB(51,153,255))
      	x2=t+60+4
      	IF n3<>"" AND NOT n3=EOT THEN
      		dLine((t+60)-10,24,(t+60)-10,24+7,RGB(0,0,0),1)
      		dLine((t+60)-9,25,(t+60)-9,25+5,RGB(0,0,0),1)
      		dLine((t+60)-8,26,(t+60)-8,26+3,RGB(0,0,0),1)
      		dPoint((t+60)-7,27,RGB(0,0,0))
      	END
      	dText(28,20,n2,RGB(0, 0, 0),False)
      END
      
      
      IF n3<>"" AND NOT n3=EOT THEN
      	sLastText=n2+"_"+n3
      	t=GetPixelWidth(hdc,n3,"MS Shell Dlg",8,False,False,False)
      	u=GetPixelHeight(hdc,n3,"MS Shell Dlg",8,False,False,False)
      	dRectangle(x2-2, 19, x2+t+62, u+2+24, RGB(254,254,254), RGB(120,120,120))
      	maxbreite=x2+t+62+1
      	maxhoehe=u+2+24+1
      	dRectangle(x2, 21, x2+t+60, u+2+22, RGB(177,216,255), RGB(51,153,255))
      	x3=x2+t+60+4
      	IF n4<>"" AND NOT n4=EOT THEN
      		dLine((x2+t+60)-10,24+2,(x2+t+60)-10,24+7+2,RGB(0,0,0),1)
      		dLine((x2+t+60)-9,25+2,(x2+t+60)-9,25+5+2,RGB(0,0,0),1)
      		dLine((x2+t+60)-8,26+2,(x2+t+60)-8,26+3+2,RGB(0,0,0),1)
      		dPoint((x2+t+60)-7,27+2,RGB(0,0,0))
      	END
      	dText(x2+26,22,n3,RGB(0, 0, 0),False)
      END
      
      IF n4<>"" AND NOT n4=EOT THEN
      	sLastText=n2+"_"+n4
      	t=GetPixelWidth(hdc,n4,"MS Shell Dlg",8,False,False,False)
      	u=GetPixelHeight(hdc,n4,"MS Shell Dlg",8,False,False,False)
      	dRectangle(x3-2, 21, x3+t+62, u+2+26, RGB(254,254,254),RGB(120,120,120))
      	maxbreite=x3+t+62+1
      	maxhoehe=u+2+26+1
      	x4=x3+t+60+4
      	dRectangle(x3, 23, x3+t+60, u+2+24, RGB(177,216,255), RGB(51,153,255))
      	IF n5<>"" AND NOT n5=EOT THEN
      		dLine((x3+t+60)-10,24+4,(x3+t+60)-10,24+7+4,RGB(0,0,0),1)
      		dLine((x3+t+60)-9,25+4,(x3+t+60)-9,25+5+4,RGB(0,0,0),1)
      		dLine((x3+t+60)-8,26+4,(x3+t+60)-8,26+3+4,RGB(0,0,0),1)
      		dPoint((x3+t+60)-7,27+4,RGB(0,0,0))
      	END
      	dText(x3+26,24,n4,RGB(0, 0, 0),False)
      END
      
      IF n5<>"" AND NOT n5=EOT THEN
      	sLastText=n2+"_"+n5
      	t=GetPixelWidth(hdc,n5,"MS Shell Dlg",8,False,False,False)
      	u=GetPixelHeight(hdc,n5,"MS Shell Dlg",8,False,False,False)
      	dRectangle(x4-2, 23, x4+t+62, u+2+28, RGB(254,254,254),RGB(120,120,120))
      	maxbreite=x4+t+62+1
      	maxhoehe=u+2+28+1
      	x5=x4+t+60+4
      	dRectangle(x4, 25, x4+t+60, u+2+26, RGB(177,216,255), RGB(51,153,255))
      	IF n6<>"" AND NOT n6=EOT THEN
      		dLine((x4+t+60)-10,24+6,(x4+t+60)-10,24+7+6,RGB(0,0,0),1)
      		dLine((x4+t+60)-9,25+6,(x4+t+60)-9,25+5+6,RGB(0,0,0),1)
      		dLine((x4+t+60)-8,26+6,(x4+t+60)-8,26+3+6,RGB(0,0,0),1)
      		dPoint((x4+t+60)-7,27+6,RGB(0,0,0))
      	END
      	dText(x4+26,27,n5,RGB(0, 0, 0),False)
      END
      
      IF n6<>"" AND NOT n6=EOT THEN
      	sLastText=n2+"_"+n6
      	t=GetPixelWidth(hdc,n6,"MS Shell Dlg",8,False,False,False)
      	u=GetPixelHeight(hdc,n6,"MS Shell Dlg",8,False,False,False)
      	dRectangle(x5-2, 23, x5+t+62, u+2+28, RGB(254,254,254),RGB(120,120,120))
      	maxbreite=x5+t+62+1
      	maxhoehe=u+2+28+1
      	dRectangle(x5, 25, x5+t+60, u+2+26, RGB(177,216,255), RGB(51,153,255))
      	dText(x5+26,27,n6,RGB(0, 0, 0),False)
      END
      
      Testprogramme_MacheScreenShots.Image1..Width=maxbreite
      Testprogramme_MacheScreenShots.Image1..Height=maxhoehe
      
      Multitask(-1)
      
      ResSave = dSaveImagePNG(Testprogramme_MacheScreenShots.Image1, CompleteDir(fExeDir())+"Dokumentation_Bilder\"+NumToString(zz,"d")+"_"+GetCleanFileName(sLastText)+".PNG")
      if not ResSave then
      	trace(GetCleanFileName(sWindowName))
      END
      
      Multitask(-1)
     type : 458752
   -
     name : GetPixelHeight
     procedure_id : 1539229550663969267
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetPixelHeight (<hdc> is int, <sText> is string, <sFontName> is string, <cSize> is real, <bBold> is boolean, <bUnterline> is boolean, <bItalic> is boolean)
      //
      // Parameters:
      //	hdc (int): <specify the role of hdc>
      //	sText (ANSI string): <specify the role of sText>
      //	sFontName (ANSI string): <specify the role of sFontName>
      //	cSize (real): <specify the role of cSize>
      //	bBold (boolean): <specify the role of bBold>
      //	bUnterline (boolean): <specify the role of bUnterline>
      //	bItalic (boolean): <specify the role of bItalic>
      // Return Value:
      // 	int: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetPixelHeight(hdc is int, sText is string, sFontName is string, cSize is real, bBold is boolean, bUnterline is boolean, bItalic is boolean)
      
      LOCAL
      	srect is RECT
      	bold is int
      	Italic is boolean
      	Underline is boolean
      	Size is int
      	Font is int
      	Fontmem is int
      	s is string
      	align is int
      	f is int
      	res is int
      	nHeight is int
      	
      align=0x100+ 0x40000
      
      srect:nLeft = 0
      srect:nTop = 0
      srect:nRight =  1280
      srect:nBottom = 1024
      
      IF bBold THEN
      	bold=700
      ELSE
      	bold=0
      END
      
      Size=cSize
      
      Italic=bItalic
      
      Underline=bUnterline
      
      nHeight = -((Size*CallDLL32("gdi32","GetDeviceCaps",hdc, 90))/72)
      
      Font = CallDLL32("gdi32","CreateFontA", nHeight, 0, 0, 0, bold, Italic, Underline, 0, 1, 4, 0x10, 2, 4, &sFontName)
      
      Fontmem = CallDLL32("gdi32","SelectObject",hdc, Font)
      
      CallDLL32("gdi32","SetBkMode",hdc, 1)
      
      s=sText
      
      f=CallDLL32("user32","DrawTextA", hdc, &s, (Length(s)), &srect, BinaryOR(DT_CALCRECT, align))
      
      res = CallDLL32("gdi32","SelectObject",hdc, Fontmem)
      res = CallDLL32("gdi32","DeleteObject",Font)
      
      RESULT srect.nBottom
     type : 458752
   -
     name : GetPixelTwips
     procedure_id : 1539229550664035006
