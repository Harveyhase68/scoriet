      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetScrollValueV(sControlName)
      
      local
      	n is real on 8 bytes
      	//lpScrollInfo is STScrollInfo
      	
      //CallDLL32("user32","GetScrollInfo",Handle(sControlName), SB_VERT, &lpScrollInfo)
      
      //n=lpScrollInfo.nPos
      
      n=API("user32", "GetScrollPos" , Handle(sControlName), 1)
      
      n=((gnInternalWindowHeight-WIN_Designer.IW_InternalWindow1..Height)/100)*n
      
      result n
     type : 458752
   -
     name : GetNameShort
     procedure_id : 2265772587840694083
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetNameShort (<sFileName> [, <nLength>])
      //
      // Parameters:
      //	sFileName: 
      //	nLength (default value=2): <specify the role of nLength>
      
      procedure GetNameShort(sFileName, nLength=2)
      
      local
      	arrVowels is array of 5 string
      	sResult is string
      	n is int
      	
      arrVowels[1]="A"
      arrVowels[2]="E"
      arrVowels[3]="I"
      arrVowels[4]="O"
      arrVowels[5]="U"
      
      //Always 1. letter is exception
      sResult=upper(left(sFileName,1))
      for i=2 to Length(sFileName)
      	n=ArraySeek(arrVowels,asLinear,upper(middle(sFileName,i,1)))
      	if n=-1 then
      		sResult+=upper(Middle(sFileName,i,1))
      		if Length(sResult)>=nLength THEN
      			break
      		END
      	END
      END
      
      //We have or not reached the max length, in any case return the result
      RESULT sResult
     type : 458752
   -
     name : GetTableNameShort
     procedure_id : 2265777209225859839
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetTableNameShort (<nVersionID>, <sTableName>, <nShortLength>)
      //
      // Parameters:
      // 	nVersionID: <specify the role of nVersionID>
      //	sTableName: 
      //	nShortLength: <specify the role of nShortLength>
      
      procedure GetTableNameShort(nVersionID, sTableName, nShortLength)
      
      local
      	sShort is string
      	sSuchString is string
      	bFound is boolean
      	arrChar is dynamic array of 0 string
      	i is int
      	t is int
      	
      FOR i=65 TO 90
      	Dimension(arrChar,Dimension(arrChar)+1)
      	arrChar[Dimension(arrChar)]=Charact(i)
      END
      
      FOR i=48 TO 57
      	Dimension(arrChar,Dimension(arrChar)+1)
      	arrChar[Dimension(arrChar)]=Charact(i)
      END
      
      sShort=GetNameShort(sTableName,nShortLength)
      HReadSeek(DataFile,DataFileShortKey,HBuildKeyValue(DataFile,DataFileShortKey, nVersionID, sShort),hIdentical)
      IF HFound(DataFile) THEN
      	//We need to do magic stuff, beacuse the filename is occupied
      	FOR i=Length(sShort) TO 1 STEP -1
      		FOR t=1 TO Dimension(arrChar)
      			sSuchString=Left(sShort,i)+arrChar[t]+Middle(sShort,i+1)
      			HReadSeek(DataFile,DataFileShortKey,HBuildKeyValue(DataFile, DataFileShortKey, nVersionID,sSuchString),hIdentical)
      			IF NOT HFound(DataFile) THEN
      				sShort=sSuchString
      				bFound=true
      				BREAK(2)
      			END
      		END
      	END
      ELSE
      	bFound	= True
      END
      
      if not bFound then
      	error("Wir konnten keinen gültigen Dateinamen für "+sTableName+" finden, erhöhen Sie die Anzahl der Buchstaben von "+nShortLength+" auf "+(nShortLength+1))
      	result ""
      else
      	RESULT sShort	
      END
      
      
     type : 458752
