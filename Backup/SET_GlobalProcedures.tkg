     name : GetRatio
     procedure_id : 1319922421671067238
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetRatio (<w>, <h>, <rw>, <rh>)
      //
      // Parameters:
      //	w: <specify the role of w>
      //	h: <specify the role of h>
      //	rw: <specify the role of rw>
      //	rh: <specify the role of rh>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetRatio(w,h,rw,rh)
      
      LOCAL
      	n1 is int
      	n2 is int
      	tmp is int
      	
      if w=0 or h=0 then result false
      
      n1=w
      n2=h
      
      LOOP
      	IF n1 < n2 THEN
      		tmp = n1
      		n1 = n2
      		n2 = tmp
      	END
      	n1 = modulo(n1,n2)
      	IF NOT n1 THEN BREAK
      END 
      
      rw=w/n2
      rh=h/n2
      
      result true
      
      
