     type : 458752
   -
     name : MaleText
     procedure_id : 1802500793846409297
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //MaleText (<nHdc> is system integer, <sText>, <x> is int, <y> is int, <W> is int, <H> is int [, <Align> is int [, <sFontName> is string [, <nSize> is int [, <sFontFarbe> is string [, <bBold> is boolean [, <bItalic> is boolean [, <bUnderline> is boolean [, <bStrikethrough> is boolean [, <nOrientierungH> is int [, <nOrientierungV> is int [, <nAngel> is int [, <nZoom>]]]]]]]]]]]])
      //
      // Parameters:
      //	nHdc (system integer):<specify the role of nHdc>
      //	sText:<specify the role of X>
      //	x (int):<specify the role of Y>
      //	y (int):<specify the role of W>
      //	W (int):<specify the role of H>
      //	H (int):<specify the role of sText>
      //	Align (int - default value=0):<specify the role of align>
      //	sFontName (ANSI string - default value="Arial"):<specify the role of sFontName>
      //	nSize (int - default value=8):<specify the role of nSize>
      //	sFontFarbe (ANSI string - default value="000000"):<specify the role of sFontFarbe>
      //	bBold (boolean - default value=0):<specify the role of bBold>
      //	bItalic (boolean - default value=0):<specify the role of bItalic>
      //	bUnderline (boolean - default value=0):<specify the role of bUnderline>
      //	bStrikethrough (boolean - default value=0):<specify the role of strikethrough>
      //	nOrientierungH (int - default value=0):<specify the role of nOrientierungH>
      //	nOrientierungV (int - default value=0):<specify the role of nOrientierungV>
      //	nAngel (int - default value=0):<specify the role of nAngel>
      //	nZoom (default value=100):<specify the role of nZoom>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE MaleText(nHdc is system int, sText, x is int, y is int, W is int, H is int, Align is int=0, sFontName is string="Arial", nSize is int=8, sFontFarbe is string="000000", bBold is boolean=false, bItalic is boolean=false, bUnderline is boolean=false, bStrikethrough is boolean=false, nOrientierungH is int=0, nOrientierungV is int=0, nAngel is int=0, nZoom=100)
      
      LOCAL
      	s is string
      	CMZeilen is RECT
      	newfont is system int
      	oldfont is system int
      	ret is system int
      	nBold is int
      	nX is int
      	nY is int
      	nW is int
      	nH is int
      	
      s=sText
      nW=W
      nH=H
      nX=x
      nY=y
      
      CMZeilen.nLeft = nX
      CMZeilen.nTop = nY
      CMZeilen.nRight =  nX+nW
      CMZeilen.nBottom = nY+nH
      
      if bBold then
      	nBold=700
      else
      	nBold=400
      END
      
      IF nSize=0 THEN
      	nSize=12/100*nZoom
      else
      	nSize=nSize/100*nZoom
      END
      
      if sFontName="" then
      	sFontName="Arial"
      END
      
      newfont = CallDLL32("gdi32","CreateFontA", -nSize, 0, nAngel*10, 0, nBold, bItalic, bUnderline, bStrikethrough, DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, CLIP_DEFAULT_PRECIS, PROOF_QUALITY, DEFAULT_PITCH, sFontName)
      oldfont = CallDLL32("gdi32","SelectObject",nHdc, newfont)
      
      CallDLL32("gdi32","SetBkMode",nHdc, 1)
      CallDLL32("gdi32","SetTextColor",nHdc,RGB(val(middle(sFontFarbe,5,2),"x"),val(Middle(sFontFarbe,3,2),"X"),val(Middle(sFontFarbe,1,2),"X")))
      
      ret=CallDLL32("user32","DrawTextA", nHdc, s, (Length(s)), &CMZeilen, BinaryOR(BinaryOR(DT_CALCRECT, Align),DT_SINGLELINE))
      
      switch nAngel
      	case 0
      		switch nOrientierungH
      			case 2 //Zentriert
      				nX=nX+(nW-(CMZeilen.nRight-CMZeilen.nLeft))/2 //Zentrieren X
      			case 3 //Rechts
      				nX=nX+(nW-(CMZeilen.nRight-CMZeilen.nLeft))
      			OTHER CASE //Links
      				nX=nX
      		END
      		switch nOrientierungV
      			case 2 //Zentriert
      				nY=nY+(nH-(CMZeilen.nBottom-CMZeilen.nTop))/2
      			case 3 //Rechts
      				nY=nY+(nH-(CMZeilen.nBottom-CMZeilen.nTop))
      			OTHER CASE //Links
      				nY=nY
      		END
      	case 90
      		switch nOrientierungH
      			case 2 //Zentriert
      				nX=nX+(nW-(CMZeilen.nBottom-CMZeilen.nTop))/2
      			case 3 //Rechts
      				nX=nX+(nW-(CMZeilen.nBottom-CMZeilen.nTop))
      			OTHER CASE //Links
      				nX=nX
      		END
      		switch nOrientierungV
      			case 2
      				nY=nY-((nH-(CMZeilen.nRight-CMZeilen.nLeft))/2)+nH
      			case 3
      				nY=nY-(nH-(CMZeilen.nRight-CMZeilen.nLeft))+nH
      			OTHER CASE
      				nY=nY+nH-3
      		END
      	case 180
      		switch nOrientierungH
      			case 2
      				nX=nX-((nW-(CMZeilen.nRight-CMZeilen.nLeft))/2)+nW
      			case 3
      				nX=nX-(nW-(CMZeilen.nRight-CMZeilen.nLeft))+nW
      			OTHER CASE
      				nX=nX+nW
      		END
      		switch nOrientierungV
      			case 2
      				nY=nY-((nH-(CMZeilen.nBottom-CMZeilen.nTop))/2)+nH
      			case 3
      				nY=nY-(nH-(CMZeilen.nBottom-CMZeilen.nTop))+nH
      			OTHER CASE
      				nY=nY+nH
      		END
      	case 270
      		switch nOrientierungH
      			case 2
      				nX=nX-((nW-(CMZeilen.nBottom-CMZeilen.nTop))/2)+nW
      			case 3
      				nX=nX-(nW-(CMZeilen.nBottom-CMZeilen.nTop))+nW
      			OTHER CASE
      				nX=nX+nW
      		END
      		switch nOrientierungV
      			case 2
      				nY=nY+(nH-(CMZeilen.nRight-CMZeilen.nLeft))/2
      			case 3
      				nY=nY+(nH-(CMZeilen.nRight-CMZeilen.nLeft))
      			OTHER CASE
      				nY=nY
      		END		
      END
      
      ret = CallDLL32("gdi32","TextOutA",nHdc, nX, nY, s, Length(s))
      
      newfont = CallDLL32("gdi32","SelectObject",nHdc, oldfont)
      CallDLL32("gdi32","DeleteObject",newfont)
     type : 458752
   -
     name : GetScrollValueH
     procedure_id : 1802508907274566223
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetScrollValueH (<sControlName>)
      //
      // Parameters:
      //	sControlName:<specify the role of sControlName>
      // Return Value:
      // 	real: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetScrollValueH(sControlName)
      
      LOCAL
      	n is real on 8 bytes
      	//lpScrollInfo is STScrollInfo
      	
      //CallDLL32("user32","GetScrollInfo",Handle(sControlName), SB_HORZ, &lpScrollInfo)
      
      //n=lpScrollInfo.nPos
      
      n=API("user32", "GetScrollPos" , Handle(sControlName), 0)
      
      n=((gnInternalWindowWidth-WIN_Designer.IW_InternalWindow1..Width)/100)*n
      
      RESULT n
     type : 458752
   -
     name : GetScrollValueV
     procedure_id : 1802508907274632118
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetScrollValueV (<sControlName>)
      //
      // Parameters:
      //	sControlName:<specify the role of sControlName>
      // Return Value:
