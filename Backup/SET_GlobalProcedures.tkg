     name : GetText
     procedure_id : 2285798706099818841
     type_code : 15
     code : |1+
      PROCEDURE GetText(sBuffer is string, sStartText is string, sEndText is string, nBegin is int=1)
      
      LOCAL
      	l is int
      	r is int
      	s is string
      	
      l=Position(sBuffer,sStartText, nBegin)
      IF l>0 THEN
      	l=l+Length(sStartText)
      	r=Position(sBuffer,sEndText,l)
      	s=Middle(sBuffer,l,r-l)
      END
      
      RESULT s
     type : 458752
   -
     name : CheckTables
     internal_properties : 
     procedure_id : 1154055058147085483
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] CheckTables ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	gnProjectId: <specify the role of gnProjectId>
      PROCEDURE CheckTables()
      
      
      LOCAL
      	clConnect is Connector
      	sSQL is string
      	s is string
      	sFileName is string
      	zz is int
      	arrTables is array of string
      	
      hreadseek(Project,ProjectID,gnprojectid,hIdentical)
      HReadSeek(DBConnection,DBConnectionID,Project.DBConnectionID,hIdentical)
      if not hfound(DBConnection) then
      	info("Datenbank Verbindung im Projekt nicht gefunden!")
      	result false
      END
      
      IF clConnect.Connect(DBConnection.Server,DBConnection.Username,DBConnection.Password, Project.Database) THEN
      	
      	sSQL="show full tables from " + Project.Database + ";"
      	HExecuteSQLQuery(clConnect.dsDATA,clConnect.ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
      	HReadFirst(clConnect.dsDATA)
      	zz=0
      	WHILE NOT HOut(clConnect.dsDATA)
      		IF {"clConnect.dsDATA.Table_type"}="BASE TABLE" THEN
      			zz++
      			Dimension(arrTables,zz)
      			arrTables[zz]={"clConnect.dsDATA.tables_in_"+Project.Database}
      		END
      		HReadNext(clConnect.dsDATA)
      	END
      	HCloseConnection(clConnect.ctCdn)
      	HFreeQuery(clConnect.dsDATA)
      	
      	FOR i=1 TO Dimension(arrTables)
      		Gauge(i,Dimension(arrTables))
      		HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,gnProjectId,arrTables[i]),hIdentical)
      		if not hfound(DataFile) then
      			//Error
      			result false
      		else
      			sFileName=arrTables[i]
      			sSQL="SHOW FULL COLUMNS FROM " + sFileName + ";"
      			s=""
      			IF NOT HExecuteSQLQuery(clConnect.dsDATA,clConnect.ctCdn,hQueryWithoutCorrection+hNoBind,sSQL) THEN
      				Error(ErrorInfo(errFullDetails)+CRLF+CRLF+ErrorInfo(errFullDetails))
      				RESULT False
      			END
      			HReadFirst(clConnect.dsDATA)
      			WHILE NOT HOut(clConnect.dsDATA)
      				//DataFileID+DataItemsID
      				HReadSeek(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,DataFile.DataFileID,{"clConnect.dsDATA.Field"}))
      				IF not HFound(DataItems) THEN
      					//Error
      					result false
      				END
      				HReadNext(clConnect.dsDATA)
      			END
      			HFreeQuery(clConnect.dsDATA)
      		END
      	END
      else
      	Info(clConnect.p_s_sError)
      	result false
      END
      
      RESULT True
      
      
