   -
     name : GetTokenCount
     procedure_id : 1351113135555689704
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetTokenCount (<s>)
      //
      // Parameters:
      //	s: <specify the role of s>
      // Return Value:
      // 	int: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE GetTokenCount(s)
      
      local
      	i is int
      	zz is int
      	n is int
      	v is int
      	t is int
      	sTempKeyWord is string
      	sTempKeyEndWord is string
      	bOk is boolean
      
      t=Dimension(arrKeyWord)
      for i=1 to t
      	if arrKeyWord[i].nType=1 then
      		n=Position(arrKeyWord[i].sKeyWord,"%",1,IgnoreCase)
      		IF n>0 THEN
      			//Wir müssen Teile ignorieren
      			sTempKeyWord=Middle(arrKeyWord[i].sKeyWord,1,n-1)
      			sTempKeyEndWord=Middle(arrKeyWord[i].sKeyWord,n+1)
      		ELSE
      			sTempKeyWord=arrKeyWord[i].sKeyWord
      			sTempKeyEndWord=""
      		END
      	
      		n=Position(s,sTempKeyWord,1)
      		if n>0 then
      			bOk=true
      			t=n-1
      			for v=1 to t
      				if not (middle(s,v,1)=Charact(32) or middle(s,v,1)=Charact(9)) then
      					bOk=false
      				END
      			END
      			if bOk then
      				zz++
      			end
      		END
      	end
      END
      
      result zz
     type : 458752
   -
     name : AddSource
     procedure_id : 1361596918802802355
     type_code : 15
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] AddSource (<s> [, <noCrLf>])
      //
      // Parameters:
      //	s: <specify the role of s>
      //	noCrLf (default value=0): <specify the role of noCrLf>
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE AddSource(s, noCrLf=false)
      
      local
      	sOutput is string
      	sFinal is string
      	i is int
      	n is int
      	
      sOutput=s
      
      if not noCrLf then
      	n=Length(sOutput)
      	for i=1 to n
      		if middle(sOutput,i,2)=crlf then
      			sFinal=sFinal+Charact(34)+"+CRLF+"+Charact(34)
      			i++
      		else
      			IF Asc(Middle(sOutput,i,1))<32 THEN
      				if Asc(Middle(sOutput,i,1))=9 then
      					sFinal=sFinal+Charact(34)+"+TAB+"+Charact(34)
      				else
      					sFinal=sFinal+Charact(34)+"+Charact("+Asc(Middle(sOutput,i,1))+")+"+Charact(34)
      				END
      			ELSE if Asc(Middle(sOutput,i,1))=34 then
      				sFinal=sFinal+Charact(34)+"+Charact(34)+"+Charact(34)
      			else
      				sFinal=sFinal+Middle(sOutput,i,1)
      			END
      		END
      	END
      else
      	sFinal=sOutput
      end
      
      result sFinal
     type : 458752
   -
     name : FormatCaption
     procedure_id : 1372548230703488672
     type_code : 15
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] FormatCaption (<s>)
      //
      // Parameters:
      //	s: <specify the role of s>
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FormatCaption(s)
      
      local
      	sResult is string
      	n is int
      	
      if Length(s)>1 then
      	if not (asc(middle(s,1,1))>=97 and asc(middle(s,1,1))<=122 and asc(middle(s,2,1))>=65 and asc(middle(s,2,1))<=90) then
      		sResult=upper(middle(s,1,1))
      	END
      END
      
      n=Length(s)
      for i=2 to n
      	switch asc(middle(s,i,1))
      		case 45,46,95
      			sResult=sResult+" "
      		case 65 to 90 //Uppercase letters
      			if sResult<>"" then
      				sResult=sResult+" "+upper(middle(s,i,1))
      			else
      				sResult=sResult+upper(Middle(s,i,1))
      			end
      		OTHER CASE
      			if right(sResult,1)=" " then
      				sResult=sResult+upper(Middle(s,i,1))
      			else
      				sResult=sResult+middle(s,i,1)
      			end
      	END
      END
      
      
      result sResult
     type : 458752
