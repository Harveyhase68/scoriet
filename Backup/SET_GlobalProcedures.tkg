      	CASE "{filegeneratemasterdetail}"
      	    RESULT "vProjektVars.bGenerateMasterDetail"
      	CASE "{filedetailfileid}"
      	    RESULT "vProjektVars.sDetailFileID"
      	CASE "{filedetailfilename}"
      	    RESULT "vProjektVars.sDetailFileName"
      	CASE "{filedetailkey}"
      	    RESULT "vProjektVars.sDetailFileKey"
      	case "{fileprimarykey}"
      		RESULT "vProjektVars.sAktPrimaryKey"
      
      	case "{languageid}"
      		RESULT "vProjektVars.nAktLanguageID"
      	case "{languagetoken}"
      		RESULT "vProjektVars.sAktLanguageToken"
      	case "{languagesourcetoken}"
      		RESULT "vProjektVars.sAktLanguageSourceToken"
      	case "{languagedescription}"
      		RESULT "vProjektVars.sAktLanguageDescription"
      END
      
      result ""
