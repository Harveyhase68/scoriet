  -
    name : BTN_Cancel
    identifier : 0x200159ddd1b20674
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         
         
         // The window return value is set to 'False'
         MyWindow..ReturnedValue=False
         
         // if a record was selected during window opening
         // the window, go to this record
         IF gnRecNum<>-1 THEN
         	HRead(DataItems,gnRecNum)
         	// The context was freed
         	gnRecNum=0
         END
         
         // close the window
         Close()
         	
         	
        type : 18
      -
        type : 161
        enabled : false
