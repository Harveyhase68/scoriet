  procedures :
   -
     name : RADDisplay
     procedure_id : 1530497018847321599
     type_code : 14
     code : |1-
      
      Procedure RADDisplay()
      // Called when displaying the form or when going to to the next form
      FileToScreen()
     type : 458752
   -
     name : RADClear
     procedure_id : 1530497018847387135
     type_code : 14
     code : |1-
      
      Procedure RADClear()
      // Called by the 'New' button or in form creation
      Reset
     type : 458752
   -
     name : RADSave
     procedure_id : 1530497018847452671
     type_code : 14
     code : |1-
      
      Procedure RADSave()
      // Function called when clicking the 'OK' button
      // Returns 'True' if the record is validated, 'False' otherwise
      // Transfer controls to file buffer
      ScreenToFile()
      
      // The record is valid
      RESULT True
     type : 458752
   -
     name : ModifyWindowMode
     procedure_id : 1530497018847518207
     type_code : 14
     code : |1-
      // Modify the window mode
      // In:	ModeAppliedWindow=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      Procedure ModifyWindowMode(nModeAppliedWindow)
      
      // saves the window mode
      gsWindowMode=nModeAppliedWindow
      
      // switch to 'Browse' mode
      IF nModeAppliedWindow="Browse" THEN
      	// buttons of 'browse' mode are visible
      	GP_BROWSE..Visible=True
      	// Invisible mode modification buttons
      	GP_MODIF..Visible=False
      	// Activate buttons associated with the relation table
      	GP_BUTTON..State=Active
      
        	// enables the relation table
      	LINKEDTABLE..State=Active	
      	// Activate buttons associated with the relation table
      	GP_BUTTON..State=Active
      
      	// point to the current record
      	IF gnRecNum<>0 THEN
      		HRead(Template,gnRecNum)
      
      	// or go to first record
      	ELSE
      		HReadFirst(Template,TemplateID)
      	END
      	
      // otherwise, switch to 'Creation' or 'Modif' mode
      ELSE
      	// buttons of 'browse' mode are invisible
      	GP_BROWSE..Visible=False
      	// buttons of 'Modif' mode are visible
      	GP_MODIF..Visible=True
      
      	// In 'Creation' mode, the relation table is grayed (the form has no identifier)
      	IF nModeAppliedWindow="Creation" THEN
      	  	// gray the relation table
      		LINKEDTABLE..State=Grayed
      
      		// Buttons associated with the relation table are grayed
      		GP_BUTTON..State=Grayed
      
      	ELSE
      		// The relation table is enabled
      		LINKEDTABLE..State=Active
      
      		// Activate buttons associated with the relation table
      		GP_BUTTON..State=Active
      	END
      
      	// If switch to 'Creation' mode
      	IF nModeAppliedWindow="Creation" THEN
      		// clear the controls
      		HReset(Template)
      
      	ELSE
      		// stores the current record number		
      		gnRecNum = HRecNum(Template)
      
      	END
      END
      
      // refresh the controls
      Refresh()
     type : 458752
   -
     name : CheckModification
     procedure_id : 1530497018847583743
     type_code : 14
     code : |1-
      // check the form modifications
      // If the form was modified, ask the user
      // for confirmation
      // Modifies the record if user confirmation
      Procedure CheckModification()
      
      // if a control was modified in the form
      IF MyWindow..Modified THEN
      	// indicates that the form is no longer modified
      	MyWindow..Modified=False
      
      	IF YesNo("Form Template modified. Do you want to save these modifications?") THEN
      		// Setup the record and save
      		ScreenToFile()
      
      		HModify(Template)
      		IF ErrorOccurred THEN
      			Info("Unable to modify record"+CR+HErrorInfo())
      			RETURN
      		END
      	END
      END
     type : 458752
   -
     name : Refresh
     procedure_id : 1530497018847649279
     type_code : 14
     code : |1-
      // Refresh the window
      // The form part is filled with the file buffer
      // and the table part is refreshed according to
      // the current record in the main file
      Procedure Refresh()
      
      // transfer the file buffer to controls
      FileToScreen()
      
      // Define the search item used in the table
      LINKEDTABLE..BrowsedItem = "TemplateID"
      
      // Set a filter on the linked table
      LINKEDTABLE..Filter=Template.TemplateID
     type : 458752
