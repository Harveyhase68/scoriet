    name : BTN_First
    identifier : 0x253d6aee1dcf5dd0
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // read the first record
         HReadFirst(Template,TemplateID)
         
         // no record
         IF HOut() THEN
         	Info("The file is empty")
         ELSE
         	// otherwise, transfer the file buffer to controls
         	// and refresh the table	
         	Refresh()
         END	
         	
         	
        type : 18
