  -
    name : BTN_DeleteLine
    identifier : 0x253d6aee1dd95dd0
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo("Do you want to delete the record?") THEN
         	// delete the record	
         	HDelete(Template)
         	IF ErrorOccurred THEN
         		Error("Unable to delete record."+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// reading the next record
         	HReadNext(Template,TemplateID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(Template,TemplateID)
         		
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			Reset
         			// tell the user that the file is empty
         			Info("The file is empty")
         			// done
         			RETURN
         		END
         	END
         	
         	// refresh the form and the linked table
         	Refresh()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
