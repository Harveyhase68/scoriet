  -
    name : BTN_ModifyTab
    identifier : 0x253d6aee1de75def
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // empty table
         IF TableSelect(LINKEDTABLE)=-1 THEN RETURN
         
         // refresh the table before modification
         // in case modifications were made on another computer
         TableDisplay(LINKEDTABLE,taCurrentSelection)
         
         // Open the form of TemplateVars file in 'Modif' mode
         nAliasName is string = "Modification_TemplateVars_"+TemplateVars.TemplateID
         nWindowName is string = "Modify the file TemplateVars: "+TemplateVars.TemplateID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_TemplateVars",nAliasName ,nWindowName ,"Modif")
         END
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLineTab
    identifier : 0x253d6aee1deb5def
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // empty table
         IF TableSelect(LINKEDTABLE)=-1 THEN RETURN
         
         // if the deletion is confirmed
         IF YesNo(No,"Do you want to delete the row?") THEN
         	// delete the table row and
         	// the matching record from TemplateVars file
         	TableDelete(LINKEDTABLE)
         	
         	// display an error if deletion failed
         	IF HError()<>0 THEN Info("Deletion failed",HErrorInfo())
         END	
        type : 18
      -
        type : 161
        enabled : false
