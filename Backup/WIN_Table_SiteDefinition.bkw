  -
    name : BTN_NewLine
    identifier : 0x25a3dd2305d5cdf5
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         // Open the form of SiteDefinition file in 'Creation' mode
         nAliasName is string = "New_SiteDefinition"
         nWindowTitle is string = "New record: SiteDefinition"
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_SiteDefinition",nAliasName,nWindowTitle ,"Creation")
         END	
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Modify
    identifier : 0x25a3dd2305d7cdf5
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         	
         IF TableSelect(TABLE)=-1 THEN RETURN
         
         // The input/selection row cannot be deleted
         IF TableSelect(TABLE)>TableCount(TABLE) THEN 
         	Info("The selected row is used for direct input in the table","This row cannot be modified")
         	RETURN
         END
         
         // refresh the table before modification
         // in case modifications were made on another computer
         TableDisplay(TABLE,taCurrentSelection)
         
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         // open the form of SiteDefinition file in 'Modif' mode
         nAliasName is string = "Modification_SiteDefinition_"+SiteDefinition.SiteDefinitionID
         nWindowTitle is string = "Modification of SiteDefinition file: "+SiteDefinition.SiteDefinitionID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_SiteDefinition",nAliasName ,nWindowTitle , "Modif")
         END
         
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLine
    identifier : 0x25a3dd2305dbcdf5
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // no action if no record is selected in the table
         IF TableSelect(TABLE)=-1 THEN RETURN
         
         // The input/selection row cannot be deleted
         IF TableSelect(TABLE)>TableCount(TABLE) THEN 
         	Info("The selected row is used for direct input in the table","This row cannot be deleted")
         	RETURN
         END
         	
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         
         // if the deletion is confirmed, delete the table row and
         // the matching record from SiteDefinition file
         IF YesNo("Do you want to delete the row?") THEN 
         	// Delete the record from the table
         	TableDelete(TABLE)
         	
         	// Check integrity
         	IF HErrorIntegrity() THEN
         		Error("The selected row has not been deleted: ",HErrorInfo())		
         	END
         END
         
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Close
    identifier : 0x25a3dd2305dfce05
    internal_properties : 
    type : 4
    code_elements :
