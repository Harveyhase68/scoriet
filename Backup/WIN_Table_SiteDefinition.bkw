  procedures :
   -
     name : DeleteRow
     procedure_id : 1559333038403603973
     type_code : 14
     code : |1-
      Procedure DeleteRow()
     type : 458752
   -
     name : ManageRefresh
     procedure_id : 1559333038403669509
     type_code : 14
     code : |1-
      // Automatic refresh management
      Procedure ManageRefresh(sAutoRefresh=False)
      
      // Store whether refresh must be managed or not 
      gbManageAutoRef = sAutoRefresh
      
      // Is a timer enabled?
      IF gnTimerNum > 0 THEN
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	ELSE		
      		// Stops the timer
      		EndTimerSys(gnTimerNum)
      		gnTimerNum= 0
      	END
      ELSE
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	END
      END
     type : 458752
   -
     name : SuspendRefresh
     procedure_id : 1559333038403735045
     type_code : 14
     code : |1-
      // Automatic refresh management
      PROCEDURE SuspendRefresh(sSuspend=True)
      
      // Suspend the refresh if this one is managed or restart it
      IF sSuspend = True THEN
      	IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer		
      	gnTimerNum = 0
      ELSE
      	// Reenable the timer (if managed)
      	IF gbManageAutoRef=True THEN
      		IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)		
      	END
      END
     type : 458752
   -
     name : Refresh
     procedure_id : 1559333038403800581
     type_code : 14
     code : |1-
      // Method called by the refresh timer
      Procedure Refresh()
      // Stops the timer
      EndTimerSys(gnTimerNum)
      
      // If the user is not currently in edit
      IF TableInputInProgress(TABLE)=False THEN		
      	// If no modification was made by the user
      	// Was the file modified?
      	IF gnFileVersionNum < HVersion(SiteDefinition) OR (SiteDefinition..Type<>hFileNormal AND SiteDefinition..Type<>hFileHF5) THEN
      		// Store the file version number
      		gnFileVersionNum = HVersion(SiteDefinition)
      
      		// Refresh the table display
      		TableDisplay(TABLE,taCurrentSelection)
      		
      		// Other linked controls?
      		WHEN EXCEPTION IN 
      			ExecuteProcess("RADDisplay",trtProcedure)
      		DO
      			// Exception corresponding to an unknown procedure?
      			IF ExceptionInfo(errCode)<> 1027 THEN EXCEPTION
      		END
      	END
      END
      
      // Restart the timer
      IF gbManageAutoRef=True THEN
      	gnTimerNum = TimerSys("Refresh",gnNoRef)
      END
     type : 458752
   -
     name : InitialFilter
     procedure_id : 1559333038403866117
     type_code : 14
     code : |1+
      // Implement a filter on the table
      Procedure InitialFilter(FilterVal)
      
      // Search for first "=" character (this character can be found in the filter value)
      nSeparatorPosition is int = Position(FilterVal,"=")
      
      // Is a filter required?
      IF NOT FilterVal~="" THEN
      	// Change the search key
      	Table..BrowsedItem = FilterVal[[1 TO (nSeparatorPosition-1)]]
      
      	// Filter the table content
      	Table..Filter = FilterVal[[(nSeparatorPosition+1) TO Length(FilterVal)]]
      	
      	// Store the specified search key (in case of empty file)
      	WHEN EXCEPTION IN
      		{Table..BrowsedFile+"."+Table..BrowsedItem}=FilterVal[[(nSeparatorPosition+1) TO Length(FilterVal)]]
      	DO
      		// May occur according to user preferences
      	END	
      END
     type : 458752
