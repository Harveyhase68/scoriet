  -
    name : BTN_Ready
    identifier : 0x25b139ed3d89c129
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	s is string
         	u is string
         	i is int
         	zz is int
         	n is int
         
         if EDT_DatabasePath<>gsDataPath then
         	if YesNo(<§$000f§>+crlf+crlf+<§$0010§>+gsDataPath+<§$0011§>)=yes then
         		hclose("*")
         		if not fDirectoryExist(EDT_DatabasePath) then
         			fMakeDir(EDT_DatabasePath)
         		END
         		
         		s=HListFile(hLstAll+hLstSorted)
         		
         		n=StringCount(s,CR)+1
         		FOR i=1 TO n
         			zz++
         			
         			u=ExtractString(s,i,CR)
         			
         			if not fFileExist(CompleteDir(EDT_DatabasePath)+u+".dat") then
         				fCopyFile(CompleteDir(gsDataPath)+u+".*",EDT_DatabasePath)
         			end
         						
         		end	
         	end
         	
         	gsDataPath=EDT_DatabasePath
         	Database_Classic(gsDataPath)
         	
         	INIWrite("Scoriet","DatabasePath",gsDataPath,gsIniFile)
         END
         
         gsTemplatePath=EDT_TemplateRoot
         INIWrite("Scoriet","TemplateRootPath",gsTemplatePath,gsIniFile)
         
         gsWampVerzeichnis=EDT_WWW
         INIWrite("Scoriet","wwwroot",gsWampVerzeichnis,gsIniFile)
         
         if nation()<>LanguageID then
         	SaveParameter("Language",NumToString(LanguageID,"d"))
         	gnLanguage=LanguageID
         	Nation(languageid)
         	Use(MyWindow)
         else
         	close()
         END
        type : 18
      -
        type : 161
        enabled : false
