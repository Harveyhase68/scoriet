  -
    name : BTN_Choose_ZIP
    identifier : 0x2312d93f01d35d7a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sFile is string
         	sTemplateFile is string
         
         IF ListSelect(WIN_Main.COMBO_Project)>0 THEN
         	HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
         ELSE
         	Info(<§$0001§>)
         	RETURN
         END
         
         IF EDT_ZIP="" THEN
         	sTemplateFile=EDT_ZIP
         else
         	sTemplateFile=CompleteDir(gsTemplatePath)+COMBO_Template.COL_TemplateName+".zip"
         end
         
         sFile = fSelect(fExtractPath(sTemplateFile,fDirectory+fDrive), sTemplateFile, "Select a file...", "*.zip" + TAB + "*.zip", "*.zip", fselCreate)
         if sFile<>"" then
         	EDT_ZIP=sFile
         end
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Export
    identifier : 0x2312db1c0260a40b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         local
         	sMyXMLDoc is string = "XML"
         	sXMLInfo is string
         	nMax is int
         	nCount is int
         	nCountDirs is int
         	sFiles is string
         	sBuffer is string
         	sTemplateFile is string
         	nCRC is int on 8 bytes
         	sSingleFile is string
         	sFileName is string
         	sStripedFileName is string
         	sStripedPath is string
         	zz is int
         	
         HReadSeek(Project,ProjectID,gnProjectID,hIdentical)
         IF NOT HFound(Project) THEN
         	Info(<§$0003§>)
         	RETURN
         END
         
         gnFileCount=0
         
         XMLDocument(sMyXMLDoc, "",xdHTML)
         
         hreadseek(Template,TemplateID,COMBO_Template,hIdentical)
         if hfound(Template) then
         	
         	XMLAddChild(sMyXMLDoc,"Template","",True)
         	XMLAddAttribute(sMyXMLDoc,"ID",Template.TemplateID)
         	XMLAddChild(sMyXMLDoc,"ID",Template.TemplateID)
         	XMLAddChild(sMyXMLDoc,"Name",Template.TemplateName)
         	XMLAddChild(sMyXMLDoc,"Folder",Template.TemplateFolder)
         	XMLAddChild(sMyXMLDoc,"CommentChar",Template.TemplateCommentChar)
         	if gsUserName="" then
         		XMLAddChild(sMyXMLDoc,"UserName","*unregistered user*")
         	else
         		XMLAddChild(sMyXMLDoc,"UserName",gsUserName)
         	END
         	
         	
         	hfilter(TemplatePage,TemplatePageKey,HBuildKeyValue(TemplatePage,TemplatePageKeyID,Template.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,Template.TemplateID,hMaxVal))
         	HReadFirst(TemplatePage,TemplatePageKeyID)
         	WHILE NOT HOut(TemplatePage)
         		nMax++
         		HReadNext(TemplatePage,TemplatePageKeyID)
         	END
         	
         	HReadFirst(TemplatePage,TemplatePageKeyID)
         	while not hout(TemplatePage)
         		nCountDirs=0
         		nCount=0
         		switch TemplatePage.GenerationType
         			case 2
         				//Folder...
         				XMLAddChild(sMyXMLDoc,"TemplatePage","",True)
         				XMLAddAttribute(sMyXMLDoc,"ID",TemplatePage.TemplatePageID)
         				XMLAddChild(sMyXMLDoc,"Name",TextToXML(TemplatePage.TemplatePageName))
         				XMLAddChild(sMyXMLDoc,"FileName",TextToXML(TemplatePage.TemplatePageFilename))
         				XMLAddChild(sMyXMLDoc,"Folder",TextToXML(TemplatePage.TemplatePageFolder))
         				XMLAddChild(sMyXMLDoc,"Construct",TextToXML(TemplatePage.TemplatePageConstruct))
         				XMLAddChild(sMyXMLDoc,"Persistent",TemplatePage.PersistentFile)
         				XMLAddChild(sMyXMLDoc,"Generate",TemplatePage.TemplatePageGenerate)
         				XMLAddChild(sMyXMLDoc,"Execute",TextToXML(TemplatePage.TemplateExecuteProgramAfter))
         				XMLAddChild(sMyXMLDoc,"GenerationID",TemplatePage.GenerationType)
         				sTemplateFile=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         				IF fDirectoryExist(sTemplateFile) THEN
         					sFiles=fListFile(CompleteDir(sTemplateFile)+"*.*",fdFullInformation+frRecursive)
         					zz=0
         					FOR EACH STRING sSingleFile OF sFiles SEPARATED BY CR
         						sFileName=ExtractString(sSingleFile,1,tab)
         						IF fFileExist(sFileName) THEN
         							zz++
         							XMLAddChild(sMyXMLDoc,"TemplatePageFileName","",True)
         							XMLAddAttribute(sMyXMLDoc,"ID",NumToString(zz,"d"))
         							sBuffer=fLoadText(sFileName,foAnsi)
         							nCRC=sComputeCrc32(sBuffer)
         							sStripedFileName=replace(sFileName,CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder),"")
         							sStripedPath=Replace(fExtractPath(sFileName,fDrive+fDirectory),CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder),"")
         							XMLAddChild(sMyXMLDoc,"FileNameFull",TextToXML(sStripedFileName))
         							XMLAddChild(sMyXMLDoc,"FileName",TextToXML(fExtractPath(sFileName,fExtension+fFileName)))
         							XMLAddChild(sMyXMLDoc,"FileFolder",TextToXML(sStripedPath))
         							XMLAddChild(sMyXMLDoc,"CRC",NumToString(nCRC,"d"))
         							XMLParent(sMyXMLDoc)
         						END
         					end
         				END
         				XMLParent(sMyXMLDoc)
         			OTHER CASE
         				sTemplateFile=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         				IF fFileExist(sTemplateFile) THEN
         					nCount++
         					Gauge(nCount,nMax,"Export Template XML")
         					Multitask(-1)
         					XMLAddChild(sMyXMLDoc,"TemplatePage","",True)
         					XMLAddAttribute(sMyXMLDoc,"ID",TemplatePage.TemplatePageID)
         					XMLAddChild(sMyXMLDoc,"Name",TextToXML(TemplatePage.TemplatePageName))
         					XMLAddChild(sMyXMLDoc,"FileName",TextToXML(TemplatePage.TemplatePageFilename))
         					XMLAddChild(sMyXMLDoc,"Folder",TextToXML(TemplatePage.TemplatePageFolder))
         					XMLAddChild(sMyXMLDoc,"Construct",TextToXML(TemplatePage.TemplatePageConstruct))
         					XMLAddChild(sMyXMLDoc,"Persistent",TemplatePage.PersistentFile)
         					XMLAddChild(sMyXMLDoc,"Generate",TemplatePage.TemplatePageGenerate)
         					XMLAddChild(sMyXMLDoc,"Execute",TextToXML(TemplatePage.TemplateExecuteProgramAfter))
         					XMLAddChild(sMyXMLDoc,"GenerationID",TemplatePage.GenerationType)
         					IF fFileExist(sTemplateFile) THEN
         						sBuffer=fLoadText(sTemplateFile,foAnsi)
         						nCRC=sComputeCrc32(sBuffer)
         						XMLAddChild(sMyXMLDoc,"CRC",NumToString(nCRC,"d"))
         					END
         					XMLParent(sMyXMLDoc)
         				END
         		END
         		hreadnext(TemplatePage,TemplatePageKeyID)
         	END
         	HDeactivateFilter(TemplatePage)
         	
         	hfilter(TemplateVars,TemplateID,template.TemplateID,Template.TemplateID)
         	HReadFirst(TemplateVars,TemplateID)
         	WHILE NOT HOut(TemplateVars)
         		XMLAddChild(sMyXMLDoc,"TemplateVars","",True)
         		XMLAddAttribute(sMyXMLDoc,"ID",TemplateVars.TemplateVarsID)
         		XMLAddChild(sMyXMLDoc,"Name",TextToXML(TemplateVars.Caption))
         		XMLAddChild(sMyXMLDoc,"VarName",TextToXML(TemplateVars.VarName))
         		XMLParent(sMyXMLDoc)
         		HReadNext(TemplateVars,TemplateID)
         	END
         	HDeactivateFilter(TemplateVars)
         
         	XMLParent(sMyXMLDoc)
         	sXMLInfo = XMLBuildString(sMyXMLDoc,XMLDocumentDefault,XMLEncodingUTF8)
         	XMLClose(sMyXMLDoc)
         	
         	fSaveText(CompleteDir(CompleteDir(gsTemplatePath)+template.TemplateFolder)+"template.xml", sXMLInfo)
         	if fFileExist(EDT_ZIP) then
         		fDelete(EDT_ZIP)
         	END
         	
         	zipCreate(ZIP_ARCHIVE,EDT_ZIP)
         	sFiles=fListFile(CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+"\*.*",frRecursive)
         	gnMaxFiles=StringCount(sFiles,cr)
         	zipAddDirectory(ZIP_ARCHIVE,CompleteDir(gsTemplatePath)+Template.TemplateFolder,true,zipRelative,"ZIP_ADD")
         	zipAddFile(ZIP_ARCHIVE,CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+"template.xml",zipNone)
         	zipClose(ZIP_ARCHIVE)
         	
         	//fDelete(CompleteDir(gsTemplatePath)+"template.xml")
         	ShellExecute(fExtractPath(EDT_ZIP,fDirectory+fDrive))
         	
         	info(<§$0000§>)
         END
        type : 18
      -
        type : 161
        enabled : false
  -
