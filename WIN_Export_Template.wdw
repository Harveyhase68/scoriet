  procedures :
   -
     name : ZIP_ADD
     procedure_id : 1374451468215273202
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //ZIP_ADD (<sFileName>)
      //
      // Parameters:
      // 	sFileName: <specify the role of sFileName>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE ZIP_ADD(sFileName)
      
      gnFileCount++
      Gauge(gnFileCount,gnMaxFiles,"Copy file: "+fExtractPath(sFileName,fExtension+fFileName))
     type : 458752
