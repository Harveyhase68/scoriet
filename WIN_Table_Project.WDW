    name : BTN_NewLine
    identifier : 0x200159e6d4ca29cc
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         SuspendRefresh(True)
         // Create a new record
         HReset(Project)
         
         // Open the form of Language file in creation mode
         IF Open(WIN_Form_Project,"Creation") THEN
         
         	// Refresh the table
         	TableDisplay(Table,taCurrentFirst)
         	
         END
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Modify
    identifier : 0x200159e7d4ce2b61
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         	
         IF TableSelect(TABLE)=-1 THEN RETURN
         
         // The input/selection row cannot be deleted
         IF TableSelect(TABLE)>TableCount(TABLE) THEN 
         	Info("The selected row is used for direct input in the table","This row cannot be modified")
         	RETURN
         END
         
         if Open("WIN_Form_Project","Modif") then
         	TableDisplay(Table,taCurrentFirst)
         END
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLine
    identifier : 0x200159e7d4d22cb8
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // no action if no record is selected in the table
         IF TableSelect(TABLE)=-1 THEN RETURN
         
         // The input/selection row cannot be deleted
         IF TableSelect(TABLE)>TableCount(TABLE) THEN 
         	Info("The selected row is used for direct input in the table","This row cannot be deleted")
         	RETURN
         END
         	
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         
         // if the deletion is confirmed, delete the table row and
         // the matching record from Project file
         IF YesNo("Do you want to delete the row?") THEN 
         	// Delete the record from the table
         	TableDelete(TABLE)
         	
         	// Check integrity
         	IF HErrorIntegrity() THEN
         		Error("The selected row has not been deleted: ",HErrorInfo())		
         	END
         END
         
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
