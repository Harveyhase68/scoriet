  -
    name : BTN_TableLink_WIN_Table_DataFile
    identifier : 0x200159e7d4de2d26
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         // Stop the automatic window refresh
         SuspendRefresh(True)
         // open the window "WIN_Table_DataFile"
         nAliasName is string = "Link_ProjectID_"+Project.ProjectID
         nWindowTitle is string = "File Link {NOQUOTE_RAD_LINKKEY_SOURCE}: "+Project.ProjectID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	IF TableSelect(TABLE)>=1 THEN	
         		MDIOpen(WIN_Table_DataFile ,nAliasName,nWindowTitle,"ProjectID="+Project.ProjectID)
         	END
         END
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
