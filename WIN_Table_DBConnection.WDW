  -
    name : BTN_TableLink_WIN_Table_Project
    identifier : 0x200159cfcb3ccf8c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         // Stop the automatic window refresh
         SuspendRefresh(True)
         // open the window "WIN_Table_Project"
         nAliasName is string = "Link_DBConnectionID_"+DBConnection.DBConnectionID
         nWindowTitle is string = "File Link {NOQUOTE_RAD_LINKKEY_SOURCE}: "+DBConnection.DBConnectionID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	IF TableSelect(TABLE)>=1 THEN	
         		MDIOpen(WIN_Table_Project ,nAliasName,nWindowTitle,"DBConnectionID="+DBConnection.DBConnectionID)
         	END
         END
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
