 string_res :
  identifier : 0x0
  internal_properties : BgAAAAYAAAAnMYFQ1bL/vz9ehh7L22SNNSlIzGTOI8h5F/WtgDNP
  strings :
   -
     text :
      de-DE : Leider ist die Demozeit abgelaufen
      en-GB : Leider ist die Demozeit abgelaufen
     index : 0
   -
     text :
      de-DE : Leider ist die Demozeit (erweiterte Demo Lizenz 60 Tage) abgelaufen
      en-GB : Sorry the demo version (extended 60 days license) is over
     index : 1
   -
     text :
      de-DE : "Sie haben das Template: "
      en-GB : "You have the template: "
     index : 2
   -
     text :
      de-DE : " geändert, wollen Sie nun das Template hochladen für die Community?"
      en-GB : " changed, do you want to upload the template to the community now?"
     index : 3
   -
     text :
      de-DE : Sie haben 5x verweigert ein Template der Gemeinschaft zur Verfügung zu stellen!
      en-GB : You have declined to upload a template 5 times!
     index : 4
   -
     text :
      de-DE : Daher wird die Open-Source Lizenz ungültig!
      en-GB : The open-source license will be now invalid!
     index : 5
   -
     text :
      de-DE : Sie können nun eine andere Lizenz wählen!
      en-GB : You can now choose a other license type!
     index : 6
   -
     text :
      de-DE : "Sie haben noch "
      en-GB : "You have remaining "
     index : 7
   -
     text :
      de-DE : " Möglichkeiten das Template der Gemeinschaft zur Verfügung zu stellen!"
      en-GB : " times to upload the template to the community!"
     index : 8
   -
     text :
      de-DE : "Wenn Sie 5x ablehnen, dann wird die Open-Source Lizenz ungültig!"
      en-GB : "If you decline 5 times in a row to upload a template, the open-source license will expire!"
     index : 9
   -
     text :
      de-DE : Vielen Dank für Ihren Beitrag zur Community!
      en-GB : Thank you very much for your contribution to the scoriet community!
     index : 10
   -
     text :
      de-DE : Template konnte nicht hochgeladen werden!
      en-GB : The template could not be uploaded!
     index : 11
   -
     text :
      de-DE : Verbindung zum Scoriet Server war nicht erfolgreich
      en-GB : Could not connect to the scoriet server!
     index : 12
