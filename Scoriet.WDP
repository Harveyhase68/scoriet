 wb_style_sheet : .\ClassMax.wws
 rad_options :
  internal_properties : BgAAAAYAAADePF4WdmdDc9It93F39cB51P54DRQfTYOm1AqoWMTFmBTNWmgBMS9EHpU1PWFZf7jlB4y+y5vOOoPrxKQOtn+PODHGNohGOICfAqmhTV9pZt+GADVAz8KcyagS6TM8+ps3UGWESVl3WdMInI+Phzu3VmwMKLn/P/upHBNGeyhX3xubzEo6xcviuvfSrET8OEU96vCLySeA6pmG9wVLaA==
 code_elements :
  internal_properties : BgAAAAYAAACyo+AGPHs6tl+CMW8i1j+hisKclwORtfzp4tr+6B34gnEg+AegA2o6CeaiNwKFgQlNnqdA
  type_code : 0
  p_codes :
   -
     code : |1+
      
      global
      	gnLanguage is int
      	gsVersion is string
      	gnProjectID is int on 8 bytes
      	gsDataPath is string
      	gsExePath is string
      	gsIniFile is string
      	gsProjectPath is string
      	gsAnalysePath is string
      	gsDBPassword is string="" //Uncrypt("WvWtHBKEcXVWavLL",gsPassword,cryptRC516,encodeBASE64)
      	gsWampVerzeichnis is string
      	gsDocumentPath is string
      	gsTemplatePath is string
      	gsAgent is string
      	gsUserName is string
      	gsEmail is string
      	gsActualFile is string
      	garrWindowOpen is dynamic array of 0 string
      	gbLoading is boolean
      	gbOpenWizzard is boolean
      	gnTestProjectID is int=1
      	gnPageOffsetTop is int
      	gnPageOffsetleft is real on 8 bytes
      	gbEtiketteChanged is boolean
      	gnAktuelleHistoryNr is int
      	garrHistory is dynamic array of 0 stHistory
      	iFarbe is array of 27 int
      	sFarbeName is array of 27 string
      	gnInternalWindowWidth is int
      	gnInternalWindowHeight is int
       	gnZoom is int
       	gsTargetControl is string
      	gaaHistoryVorher is associative array (*, NULL) of variant
      	gaaHistoryNachher is associative array (*, NULL) of variant
      	CustomColor is array of 16 int
      	
      	stKeyWord is Structure
      		sKeyWord is string
      		sCodeWord is string
      		nType is int
      		nVaterId is int
      		bFinal is boolean
      		bNoCrLf is boolean
      	END
      	arrKeyWord is dynamic array of 0 STKeyWord
      	
      	RECT is structure
      		nLeft is int
      		nTop is int
      		nRight is int
      		nBottom is int
      	END
      	
      	stSourceTree is structure
      		sSource is string
      		nType is int
      		nID is int
      		nVaterID is int
      		bFinal is boolean
      		nIdent is int
      	END
      	
      	stHistory is structure
      		DataFileID is int on 8 bytes
      		nType is int //1 = Add, 2 = Modify, 3 = Delete
      		aaControlsVorher is associative array (*, NULL) of variant
      		aaControlsNachher is associative array (*, NULL) of variant
      	END
      
      	CONSTANT
      		ZIP_ARCHIVE = "Scoriet_template_zip"
      		SRCCOPY = 0xCC0020
      		DT_CALCRECT = 0x400
      		DEFAULT_CHARSET = 1
      		OUT_DEFAULT_PRECIS = 0
      		CLIP_DEFAULT_PRECIS = 0
      		PROOF_QUALITY = 2
      		DEFAULT_PITCH = 0
      		DT_SINGLELINE =0x20
      	END
      
      	POINTAPI is structure
      		x is int
      		y is int
      	END
      
      	//Nur für API WM_ Messages Zahl zu Text übersetzen...
      	wm_struc is structure
      		wm_pars is string
      		wm_value is int
      	END
      	wm_buf is array of 178 wm_struc
      
      	stArrIdent is Structure
      		sName	is string
      		bNoDot	is boolean
      	END
      
      EXTERN "WINCONST.WL"
      EXTERN "KeyConst.WL"
      
      IF In64bitMode() THEN
      	CallDLL32("kernel32","CreateMutexA", Null, Null, "Scoriet64")
      ELSE
      	CallDLL32("kernel32","CreateMutexA", Null, Null, "Scoriet32")
      END
      
      LOCAL
      	sProcList is string
      	sWampDir is string
      	sConfDir is string
      	sApacheConf is string
      	sLine is string
      	sSprache is string
      	m is int
      	
      iFarbe[1]=iWhite
      sFarbeName[1]="Weiss"
      iFarbe[2]=iBlack
      sFarbeName[2]="Schwarz"
      iFarbe[3]=iDarkGray
      sFarbeName[3]="Dunkelgrau"
      iFarbe[4]=iLightGray
      sFarbeName[4]="Hellgrau"
      iFarbe[5]=iDarkRed
      sFarbeName[5]="Dunkelrot"
      iFarbe[6]=iLightRed
      sFarbeName[6]="Hellrot"
      iFarbe[7]=iDarkYellow
      sFarbeName[7]="Dunkelgelb"
      iFarbe[8]=iLightYellow
      sFarbeName[8]="Hellgelb"
      iFarbe[9]=iYellowToolhelp
      sFarbeName[9]="Tooltip Gelb"
      iFarbe[10]=iDarkGreen
      sFarbeName[10]="Dunkelgrün"
      iFarbe[11]=iLightGreen
      sFarbeName[11]="Hellgrün"
      iFarbe[12]=iDarkBlue
      sFarbeName[12]="Dunkelblau"
      iFarbe[13]=iLightBlue
      sFarbeName[13]="Hellblau"
      iFarbe[14]=iDarkCyan
      sFarbeName[14]="Dunkeles Cyan"
      iFarbe[15]=iLightCyan
      sFarbeName[15]="Helles Cyan"
      iFarbe[16]=iLightMagenta
      sFarbeName[16]="Helles Mangenta"
      iFarbe[17]=iDarkMagenta
      sFarbeName[17]="Dunkles Mangenta"
      iFarbe[18]=RGB(255,150,150)
      sFarbeName[18]="Helles Rot"
      iFarbe[19]=RGB(255,150,190)
      sFarbeName[19]="Dunkles Rot"
      iFarbe[20]=RGB(255,170,150)
      sFarbeName[20]="Orange"
      iFarbe[21]=RGB(255,235,150)
      sFarbeName[21]="Gelb"
      iFarbe[22]=RGB(150,255,150)
      sFarbeName[22]="Grün"
      iFarbe[23]=RGB(200,255,150)
      sFarbeName[23]="Helles Grün"
      iFarbe[24]=RGB(150,255,200)
      sFarbeName[24]="Türkis"
      iFarbe[25]=RGB(150,235,255)
      sFarbeName[25]="Helles Blau"
      iFarbe[26]=RGB(150,170,255)
      sFarbeName[26]="Blau"
      iFarbe[27]=RGB(200,150,255)
      sFarbeName[27]="Violett"
      
      gbOpenWizzard=true
      
      //The path, where the executabe file is located
      gsExePath=CompleteDir(fExeDir())
      
      gsIniFile=gsExePath+"Scoriet.ini"
      
      gsTemplatePath=INIRead("Scoriet","TemplateRootPath","",gsIniFile)
      if gsTemplatePath="" then
      	gsTemplatePath=CompleteDir(SysDir(srMyDocuments))+"Scoriet\Templates\"
      	INIWrite("Scoriet","TemplateRootPath",gsTemplatePath,gsIniFile)
      END
      
      gsDataPath=INIRead("Scoriet","DatabasePath","#",gsIniFile)
      if gsDataPath="#" then
      	gsDataPath=CompleteDir(SysDir(srMyDocuments))+"Scoriet\Data"
      	INIWrite("Scoriet","DatabasePath",gsDataPath,gsIniFile)
      END
      
      //The path, where the project (WinDev sources) are located
      gsProjectPath=left(gsExePath,Position(gsExePath,"\scoriet")+8)
      
      //The path, where the analysis of the project is located
      if ontestmode() then
      	gsAnalysePath=CompleteDir(gsProjectPath+"Scoriet.ana")
      else
      	gsAnalysePath=CompleteDir(fExeDir())
      end
      
      gsDocumentPath=CompleteDir(CompleteDir(SysDir(srMyDocuments))+"Scoriet")
      
      gsAgent="Mozilla/5.0 (Windows NT 6.1; WOW64; rv:22.0) Gecko/20100101 Firefox/22.0"
      
      //Copy the analysis to the .exe directory, this is for testing of the upgrade and more
      if ontestmode() THEN
      	if not fCompare(gsExePath+"Scoriet.wdd",gsAnalysePath+"Scoriet.wdd")=0 then
      		fCopyFile(gsAnalysePath+"Scoriet.wdd",gsExePath)
      	END
      END
      
      if InTestMode() then
      	gsVersion=GetGUID(guidRough)
      else
      	gsVersion=ExeInfo(exeVersion)
      END
      	
      IF fFileExist(CompleteDir(gsExePath)+"language.txt") THEN
      	sSprache=fLoadText(CompleteDir(gsExePath)+"language.txt")
      	switch sSprache
      		case "en"
      			SaveParameter("Language","3")
      		case "de"
      			SaveParameter("Language","1")
      	END
      	fDelete(CompleteDir(gsExePath)+"language.txt")
      END
      
      gnLanguage=Val(LoadParameter("Language"))
      SWITCH gnLanguage
      	CASE 0
      		//Default
      		SaveParameter("Language",1)
      		Nation(1)
      	CASE 1
      		Nation(1)
      	OTHER CASE
      		Nation(3)
      END
      
      gsWampVerzeichnis=INIRead("Scoriet","wwwroot","",gsIniFile)
      if gsWampVerzeichnis="" then
      	sProcList=ExeListProcess(exePID, exeShortName)
      	if Position(sProcList,"httpd.exe")>0 then
      		//Nach Apache suchen!
      		sWampDir=fExtractPath(Win32_Process2(),fDirectory+fDrive)
      		sConfDir=Left(sWampDir,Length(sWampDir)-4)+"conf\httpd.conf"
      		sApacheConf=fLoadText(sConfDir,foAnsi)
      		m=stringcount(sApacheConf,Charact(10))+1
      		for i=1 to m
      			sLine=ExtractString(sApacheConf,i,Charact(10))
      			if left(sLine,12)="DocumentRoot" then
      				gsWampVerzeichnis=replace(replace(replace(Replace(middle(sLine,14),Charact(34),""),"/","\"),Charact(13),""),Charact(10),"")
      				INIWrite("Scoriet","wwwroot",gsWampVerzeichnis,gsIniFile)
      			END
      		END
      	else
      		//Nach IIS suchen...
      		gsWampVerzeichnis=RegistryQueryValue("HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\InetStp","PathWWWRoot")
      		INIWrite("Scoriet","wwwroot",gsWampVerzeichnis,gsIniFile)
      	END
      END
      
      ArrayKeyWord()
      
      Database_Classic(gsDataPath)
      
      gsUserName=LoadParameter("Username")
      gsEmail=LoadParameter("Email")
      
      if gsEmail="" and gsUserName="" then
      	open(WIN_Lizenz)
      END
     type : 196608
   -
     type : 196621
   -
     type : 196627
     enabled : false
