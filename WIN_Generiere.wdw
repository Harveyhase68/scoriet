         								IF n<>-1 THEN
         									vProjektVars.sAktFileDescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         								ELSE
         									vProjektVars.sAktFileDescription=arrFiles[nFileRun].sDescription
         								END
         								vProjektVars.sAktFileShort=arrFiles[nFileRun].sFileNameShort
         								vProjektVars.nAktFileID=arrFiles[nFileRun].nFileId
