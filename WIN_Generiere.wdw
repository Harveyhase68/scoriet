         								vProjektVars.sAktLanguageToken=Language.Token
         								vProjektVars.sAktLanguageSourceToken=Language.SourceToken
         								vProjektVars.sAktLanguageDescription=Language.Description
         								vProjektVars.nMaxLanguages=nMaxLanguages
         								vProjektVars.sAktSearchKeys=arrFiles[nFileRun].sSearchKeys
         								
         								sFileContent=""
         								sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         								IF fFileExist(sTemplateFile) THEN
         									sFileContent=fLoadText(sTemplateFile,foAnsi)
         									IF NOT ValidateSource(sTemplateFile,sFileContent) THEN
         										RETURN
         									END
         									HReadSeek(TemplateCache,TemplatePageID,TemplatePage.TemplatePageID,hIdentical)
         									IF NOT HFound(TemplateCache) THEN
         										//Generate WinDev code, update it
         										sSource=GetSourceCode(sFileContent)
         										IF sSource=0 THEN
         											RETURN
         										ELSE
         											TemplateCache.TemplatePageID=TemplatePage.TemplatePageID
         											TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         											TemplateCache.SourceCache=sSource
         											TemplateCache.Version=gsVersion
         											HAdd(TemplateCache)
         										END
         									ELSE
         										IF sComputeCrc32(sFileContent)=TemplateCache.SourceCRC AND gsVersion=TemplateCache.Version THEN
         											sSource=TemplateCache.SourceCache
         										ELSE
         											//Generate WinDev code, update it
         											sSource=GetSourceCode(sFileContent)
         											IF sSource=0 THEN
         												TemplateCache.Version=""
         												HModify(TemplateCache)
         												RETURN
         											ELSE
         												TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         												TemplateCache.SourceCache=sSource
         												TemplateCache.Version=gsVersion
         												HModify(TemplateCache)
         											END
         										END
         									END
         									
         									WHEN EXCEPTION IN
         										sFileContent=ExecuteCode(sSource)
         										IF Left(sFileContent,6)="Error:" THEN
         											Error(sFileContent)
         											RETURN
         										END
         									DO
         										Info(ExceptionInfo(errFullDetails))
         										RETURN
         									END
         									
         									IF NOT sFileContent="0" THEN
         										IF NOT fDirectoryExist(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder) THEN
         											fMakeDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)
         										END
         										
         										sOutputFile=CompleteDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)+TemplatePage.TemplatePageConstruct
         										IF NOT fDirectoryExist(fExtractPath(sOutputFile,fDirectory+fDrive)) THEN
         											fMakeDir(fExtractPath(sOutputFile,fDirectory+fDrive))
         										END
         										sOutputFile=Replace(sOutputFile,"%1",arrFiles[nFileRun].sFileName)
         										sOutputFile=Replace(sOutputFile,"%2",Language.Token)
         										sOutputFile=Replace(sOutputFile,"%3",Language.Description)
         										sOutputFile=Replace(sOutputFile,"%4",Language.SourceToken)
         										sOutputFile=Replace(sOutputFile,"%5",TemplatePage.TemplatePageName)
         										sOutputFile=Replace(sOutputFile,"%6",DateToString(DateSys(),"YYYY_MM_DD"))
         										sOutputFile=Replace(sOutputFile,"%7",TimeToString(TimeSys(),"HHMMSS"))
         										sOutputFile=Replace(sOutputFile,"%8",GetTimeStamp(DateSys(),TimeSys()))
         										sOutputFile=Replace(sOutputFile,"%9",NumToString(Project.LastVersionNo,"06d"))
         										fSaveText(sOutputFile,sFileContent)
         									END								
         								ELSE
         									Error(<§$003f§>+sTemplateFile)
         									RETURN
         								END
         							END
         						end
         					ELSE
         						Error(<§$0040§>+Language.Description+<§$0041§>+TemplatePage.TemplatePageName+<§$0042§>)
         					END
         				ELSE
         					Error(<§$0043§>+Project.ProjectName)
         					RETURN
         				END
         			OTHER CASE
         				Error(StringBuild(<§$0009§>,vTemplatePage.nGenerationTypeID,template.TemplateName))
         				RETURN
         		END
         	END
         END
         
         if CBOX_StartHomepage then
         	ShellExecute(Project.URL+"/"+Project.StartPage)
         END
         
         if CBOX_OpenDirectory then
         	ShellExecute(Project.Directory)
         END
         
         if CBOX_Upload then
         	if yesno("FTP Upload jetzt starten?")=yes then
         		if SiteDefinition.SecureFTP then
         			gnFTPConnection=FTPConnect(SiteDefinition.FTPAddress,SiteDefinition.Username,SiteDefinition.Password,990,True)
         			fListFile(Project.Directory+[“\”]+ “*”, FTPTransfer, fdInterruptible+fdFullInformation+frRecursive)
         			FTPDisconnect(gnFTPConnection)
         		else
         			gnFTPConnection=FTPConnect(SiteDefinition.FTPAddress,SiteDefinition.Username,SiteDefinition.Password,SiteDefinition.FTPPort,True)
         			fListFile(Project.Directory+[“\”]+ “*”, FTPTransfer, fdInterruptible+fdFullInformation+frRecursive)
         			FTPDisconnect(gnFTPConnection)
         		end
         	end
         END
         
