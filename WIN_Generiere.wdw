info :
 name : WIN_Generiere
 major_version : 26
 minor_version : 0
 type : 2
 description : ""
 subtype : 0
window :
 name : WIN_Generiere
 identifier : 0x2fbbeb2311d7f1ed
 internal_properties : 
 controls :
  -
    name : BTN_Start
    identifier : 0x2fbbeb3315142e70
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        internal_properties : 
        code : |1+
         
         local
         	nMaxDBVersion is int
         	nDBVersionRun is int
         	nMaxFiles is int
         	nFileRun is int
         	nMaxAllFiles is int
         	nAllFileRun is int
         	nMaxLanguages is int
         	nMaxAllLanguages is int
         	nLanguageRun is int
         	nCountLanguage is int
         	nMaxTemplates is int
         	nTemplateRun is int
         	nMaxTemplatePages is int
         	nTemplatePageRun is int
         	nMaxTemplateVars is int
         	nTemplateVarRun is int, useful
         	n is int
         	zz is int
         	nTemplatePageCount is int
         	sFileContent is string
         	sSource is string
         	sTemplateFile is string
         	sOutputFile is string
         	m is int
         	o is int
         	p is int
         	i is int
         	sSearchKey is string
         	stVarContent is structure
         		nLanguageID is int on 8 bytes
         		sDescription is string
         		sToken is string
         		sSourceToken is string
         		bGenerate is boolean
         		sContent is string
         	END
         	
         	stTemplateVars is structure
         		sVariable is string
         		sCaption is string
         		arrContent is dynamic array of 0 stVarContent
         		sContent is string
         	END
         		
         	strucProjektVars is Structure
         		nMaxVersions is int
         		nMaxTemplates is int
         		nMaxTemplatePages is int
         		nMaxFiles is int
         		nMaxAllFiles is int
         		nMaxKeys is int
         		nMaxItems is int
         		nMaxItemsNoKey is int
         		nMaxItemsNoKeyAll is int
         		nMaxItemsNoBlob is int
         		nMaxItemsBlob is int
         		nMaxItemsMasterDetail is int
         		nMaxItemsMasterDetailNoKey is int
         		nMaxForeignKeys is int
         		nMaxSearchKeys is int
         		nMaxLanguages is int
         		bGenerateMasterDetail is boolean
         		sDetailFileID is string
         		sDetailFileName is string
         		sDetailFileKey is string
         		sAktFile is string
         		sAktFileDescription is string
         		sAktFileShort is string
         		nAktFileID is int on 8 bytes
         		sAktKeyName is string
         		sAktPrimaryKey is string
         		sAktSearchKeys is string
         		nAktLanguageID is int on 8 bytes
         		sAktLanguageToken is string
         		sAktLanguageSourceToken is string
         		sAktLanguageDescription is string
         	END
         	
         	stLanguage is structure
         		nLanguageID is int on 8 bytes
         		sDescription is string
         		sToken is string
         		sSourceToken is string
         		bGenerate is boolean
         	END
         	
         	stDataItemsTranslation is structure
         		nDataItemsTranslationID is int on 8 bytes
         		nDataItemsID	is int on 8 bytes
         		nVersionID	is int on 8 bytes
         		nTemplatePageID	is int on 8 bytes
         		nLanguageID	is int on 8 bytes
         		sDescription is string
         		sToken is string
         		sSourceToken is string
         		sLanguageCaption is string
         		sCaption is string
         		sComboBoxContent is string
         	END
         
         	stItems is Structure
         		nDataItemsID is int on 8 bytes
         		nDataFileID is int on 8 bytes
         		nVersionID is int on 8 bytes
         		sFileName is string
         		sItemName is string
         		sItemNameRenamed is string
         		sCaption is string
         		nType is int
         		sTypeCast is string
         		sSize is string
         		nKeyType	is int
         		bNotNull is boolean
         		bAutoIncrement is boolean
         		sDefault is string
         		bUnsigned is boolean
         		nControlType is int
         		sWinDevType is string
         		sWinDevTypePlain is string
         		Data_Type is string
         		DB_Data_Type is string
         		sForeignTableAndItem is string
         		sForeignTable is string
         		nForeignTableID is int on 8 bytes
         		sForeignTableItem is string
         		nForeignTableItemID is int on 8 bytes
         		sForeignTableDisplayItem is string
         		nForeignTableDisplayItemID is int on 8 bytes
         		sForeignTableSortItem is string
         		nForeignTableSortItemID is int on 8 bytes
         		nForeignArrayID is int
         		nTemplatePageID is int on 8 bytes
         		sEditMask is string
         		nSortIndex is int
         		nX is int
         		nY is int
         		bItemVisible is boolean
         		nItemState is int
         		bItemGenerate is boolean
         		nMaxLanguage is int
         		nDataItemsTypeDetailsID is int on 8 bytes
         		arrCaption is dynamic array of 0 stDataItemsTranslation
         	END
         	
         	stKeySegment is Structure
         		nID is int
         		sFieldName is string
         		nType is int
         		nSegment is int
         		sTypeCast is string
         		Data_Type is string
         		DB_Data_Type is string
         	END
         	
         	stKey is Structure
         		sKeyName is string
         		nKeyType is int
         		arrFields is dynamic array of 0 stKeySegment
         		sPrimaryKeyList is string
         	END
         	
         	stForeignKey is Structure
         		nVersionID is int on 8 bytes
         		sTablePlusItem is string
         		sTableName is string
         		nTableID is int on 8 bytes
         		sItemName is string
         		nItemID is int on 8 bytes
         		sItemDisplay is string
         		nItemDisplayId is int on 8 bytes
         		sItemSort is string
         		nItemSortId is int on 8 bytes
         	END
         	
         	stDataFileTranslation is Structure
         		nDataFileTranslationID is int on 8 bytes
         		nDataFileID is int on 8 bytes
         		nVersionID is int on 8 bytes
         		nLanguageID is int on 8 bytes
         		nTemplatePageID is int on 8 bytes
         		sDescription	is string
         	END
         	
         	stFiles is Structure
         		nFileId is int on 8 bytes
         		nVersionID is int on 8 bytes
         		sFileName is string
         		sFileNameShort is string
         		sDescription is string
         		sKeyName is string
         		sPrimaryKey is string
         		bGenerateMasterDetail is boolean
         		sDetailFileID is string
         		sDetailFileName is string
         		sDetailFileKey is string
         		sSearchKeys is string
         		nMaxItems is int
         		nMaxItemsNoKey is int
         		nMaxItemsNoKeyAll is int
         		nMaxItemsNoBlob is int
         		nMaxItemsBlob is int
         		nMaxItemsMasterDetail is int
         		nMaxItemsMasterDetailNoKey is int
         		nMaxKeys is int
         		nMaxKeysForeign is int
         		nMaxKeysDetail is int
         		nMaxSearchKeys is int
         		arrDataFileTranslation is dynamic array of 0 stDataFileTranslation
         		arrItems is dynamic array of 0 stItems
         		arrItemsNoKey is dynamic array of 0 stItems
         		arrItemsNoKeyAll is dynamic array of 0 stItems
         		arrItemsNoBlob is dynamic array of 0 stItems
         		arrItemsBlob is dynamic array of 0 stItems
         		arrItemsMasterDetail is dynamic array of 0 stItems
         		arrItemsMasterDetailNoKey is dynamic array of 0 stItems
         		arrItemsSearchKeys is dynamic array of 0 stItems
         		arrKeys is dynamic array of 0 stKey
         		arrKeysDetail is dynamic array of 0 stKey
         		arrKeysForeign is dynamic array of 0 stForeignKey
         	END
         
         	stDBVersion is Structure
         		nVersionID is int on 8 bytes
         		nVersionNo is int
         		nProjectID is int on 8 bytes
         		sTitle is string
         		sDescription is string
         		nGenerateDateTime is DateTime
         		nLastZoom is int
         		nAnalyseHeight is int
         		nAnalyseWidth is int
         		arrFiles is dynamic array of 0 stFiles
         	END
         	
         	stTemplatePage is Structure
         		nTemplateID is int on 8 bytes
         		nTemplatePageID is int on 8 bytes
         		sTemplatePageName is string
         		nGenerationTypeID is int
         		sTemplatePageFilename is string
         		sTemplatePageFolder is string
         		sTemplatePageConstruct is string
         		bTemplatePageGenerate is boolean
         		sTemplateExecuteProgramAfter is string
         		bPersistentFile is boolean
         		nMaxFiles is int
         		arrFiles is dynamic array of 0 stFiles
         	END
         	
         	stTemplate is Structure
         		nTemplateID is int on 8 bytes
         		sTemplateName is string
         		sTemplateFolder	is string
         		sTemplateCommentChar is string
         		arrTemplatePages is dynamic array of 0 stTemplatePage
         		nMaxTemplatePages is int
         	END
         	
         	stProjectTranslation is structure
         		nDataProjectTranslationID is int on 8 bytes
         		nProjectID is int on 8 bytes
         		nLanguageID is int on 8 bytes
         		sDescription is string
         	END
         	
         	stProject is Structure
         		nProjectID is int on 8 bytes
         		nVersionID is int on 8 bytes
         		nVersionNo is int
         		sProjectName is string
         		sDatabase is string
         		nDBConnectionID is int on 8 bytes
         		sURL is string
         		sDirectory is string
         		sDBCDescription is string
         		sDBCPassword is string
         		sDBCServer is string
         		nDBCType is int
         		sDBCUsername is string
         		sTemplateFolder is string
         		sProjectTemplateRoot is string
         		sTemplateName is string
         		arrProjectTranslation is dynamic array of 0 stProjectTranslation
         	END
         	
         	vProject is stproject
         	vProjektVars is strucProjektVars
         	vTemplate is stTemplate
         	vTemplatePage is stTemplatePage
         	
         	arrLanguages is dynamic array of 0 stlanguage
         	arrAllLanguages is dynamic array of 0 stlanguage
         	arrTemplates is dynamic array of 0 stTemplate
         	arrTemplatePages is dynamic array of 0 stTemplatePage
         	arrFiles is dynamic array of 0 stFiles
         	arrItems is dynamic array of 0 stItems
         	arrItemsNoKey is dynamic array of 0 stItems
         	arrItemsNoKeyAll is dynamic array of 0 stItems
         	arrItemsNoBlob is dynamic array of 0 stItems
         	arrItemsBlob is dynamic array of 0 stItems
         	arrItemsMasterDetail is dynamic array of 0 stItems
         	arrItemsMasterDetailNoKey is dynamic array of 0 stItems
         	arrKeys is dynamic array of 0 stKey
         	arrKeysDetail is dynamic array of 0 stKey
         	arrForeignKeys is dynamic array of 0 stForeignKey
         	arrTemplateVars is dynamic array of stTemplateVars
         	arrItemsSearchKeys is dynamic array of 0 stItems
         	arrDBVersion is dynamic array of 0 stDBVersion
         	
         //if CBOX_CheckStructure then
         //	if not CheckTables() THEN
         //		if yesno(<§$0000§>)=yes then
         //			open(WIN_Import)
         //		end
         //	END
         //end
         
         message(<§$0037§>)
         Multitask(-1)
         
         nMaxLanguages=0
         HReadFirst(Language,LanguageID)
         WHILE NOT HOut(Language)
         	
         	//Only activated languages
         	IF Language.LanguageGenerate THEN
         		nMaxLanguages++
         		Dimension(arrLanguages,nMaxLanguages)
         		arrLanguages[nMaxLanguages].nLanguageID=Language.LanguageID
         		arrLanguages[nMaxLanguages].sDescription=Language.Description
         		arrLanguages[nMaxLanguages].sToken=Language.Token
         		arrLanguages[nMaxLanguages].sSourceToken=Language.SourceToken
         	END
         	
         	//All Languages
         	nMaxAllLanguages++
         	Dimension(arrAllLanguages,nMaxAllLanguages)
         	arrAllLanguages[nMaxAllLanguages].nLanguageID=Language.LanguageID
         	arrAllLanguages[nMaxAllLanguages].sDescription=Language.Description
         	arrAllLanguages[nMaxAllLanguages].sToken=Language.Token
         	arrAllLanguages[nMaxAllLanguages].sSourceToken=Language.SourceToken
         	HReadNext(Language,LanguageID)
         END
         
         hreadseek(Project,ProjectID,gnProjectID)
         
         nMaxDBVersion=0
         hfilter(Version,VersionKeyNo,[Project.ProjectID,hMinVal],[Project.ProjectID,hMaxVal])
         HReadFirst(Version,VersionKeyNo)
         while not hout(Version)
         	nMaxDBVersion++
         	Dimension(arrDBVersion,nMaxDBVersion)
         	arrDBVersion[nMaxDBVersion].nProjectID=Version.ProjectID
         	arrDBVersion[nMaxDBVersion].nVersionID=Version.VersionID
         	arrDBVersion[nMaxDBVersion].nVersionNo=Version.VersionNo
         	arrDBVersion[nMaxDBVersion].sDescription=Version.Description
         	arrDBVersion[nMaxDBVersion].sTitle=Version.Title
         	arrDBVersion[nMaxDBVersion].nGenerateDateTime=Version.GenerateDateTime
         	arrDBVersion[nMaxDBVersion].nLastZoom=Version.LastZoom
         	arrDBVersion[nMaxDBVersion].nAnalyseHeight=Version.AnalyseHeight
         	arrDBVersion[nMaxDBVersion].nAnalyseWidth=Version.AnalyseWidth
         	hreadnext(Version,VersionKeyNo)
         END
         HDeactivateFilter(Version)
         
         HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         IF NOT HFound(Version) THEN
         	Error("Version "+Project.LastVersionNo+<§$0025§>)
         	return
         END
         
         AddProjectList(Project.ProjectName)
         
         ////ProjectID+TemplateID
         //hfilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
         //HReadFirst(ProjectTemplates,ProjectTemplateKey)
         //WHILE NOT HOut(ProjectTemplates)
         //	hreadseek(Template,TemplateID,ProjectTemplates.TemplateID,hIdentical)
         //	if hfound(Template) then
         //		IF CheckTemplateXML(Project.ProjectID,Template.TemplateID)>0 THEN
         //			UploadTemplate(Project.ProjectID,Template.TemplateID)
         //		END
         //	end
         //	HReadNext(ProjectTemplates,ProjectTemplateKey)
         //END
         
         //Project structure
         vProject.nProjectID=Project.ProjectID
         vProject.nVersionID=version.VersionID
         vProject.nVersionNo=Version.VersionNo
         vProject.nDBConnectionID=Project.DBConnectionID
         HReadSeek(DBConnection,DBConnectionID,Project.DBConnectionID,hIdentical)
         IF HFound(DBConnection) THEN
         	vProject.nDBCType=DBConnection.Type
         	vProject.sDBCDescription=DBConnection.Description
         	vProject.sDBCPassword=DBConnection.Password
         	vProject.sDBCServer=DBConnection.Server
         	vProject.sDBCUsername=DBConnection.Username
         ELSE
         	Error(<§$0002§>)
         	RETURN
         END
         vProject.sDatabase=Project.Database
         vProject.sURL=Project.URL
         vProject.sProjectName=Project.ProjectName
         vProject.sDirectory=Project.Directory
         if gsTemplatePath="" then
         	vProject.sProjectTemplateRoot=CompleteDir("%USERDOCUMENTS%/Scoriet/Templates")
         	vProject.sProjectTemplateRoot=ReplaceCommon(vProject.sProjectTemplateRoot)
         else
         	vProject.sProjectTemplateRoot=CompleteDir(gsTemplatePath)
         	vProject.sProjectTemplateRoot=ReplaceCommon(vProject.sProjectTemplateRoot)
         end
         
         FOR nLanguageRun=1 TO nMaxLanguages
         	HReadSeek(ProjectTranslation,DataFileTranslationKey,HBuildKeyValue(ProjectTranslation,DataFileTranslationKey,Project.ProjectID,arrLanguages[nLanguageRun].nLanguageID),hIdentical)
         	IF HFound(ProjectTranslation) THEN
         		Dimension(vProject.arrProjectTranslation,Dimension(vProject.arrProjectTranslation)+1)
         		vProject.arrProjectTranslation[Dimension(vProject.arrProjectTranslation)].nDataProjectTranslationID=ProjectTranslation.DataProjectTranslationID
         		vProject.arrProjectTranslation[Dimension(vProject.arrProjectTranslation)].sDescription=ProjectTranslation.Description
         		vProject.arrProjectTranslation[Dimension(vProject.arrProjectTranslation)].nLanguageID=ProjectTranslation.LanguageID
         		vProject.arrProjectTranslation[Dimension(vProject.arrProjectTranslation)].nProjectID=ProjectTranslation.ProjectID
         	END
         END
         
         hfilter(DataFile,VersionID,version.VersionID,Version.VersionID)
         hreadfirst(DataFile,VersionID)
         while not hout(DataFile)
         	nMaxAllFiles++
         	IF DataFile.DataFileGenerate THEN
         		nMaxFiles++
         	end
         	hreadnext(DataFile,VersionID)
         END
         
         if nMaxFiles<=0 then
         	error(<§$0004§>+Version.VersionNo)
         	return
         END
         
         vProjektVars.nMaxFiles=nFileRun
         vProjektVars.nMaxAllFiles=nAllFileRun
         
         CheckProjectTemplates(Project.ProjectID)
         
         //Read all template files, proecess
         hfilter(ProjectTemplates,ProjectTemplateKey,HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMinVal),HBuildKeyValue(ProjectTemplates,ProjectTemplateKey,Project.ProjectID,hMaxVal))
         HReadFirst(ProjectTemplates,ProjectTemplateKey)
         while not hout(ProjectTemplates)
         	HReadSeek(Template,TemplateID,ProjectTemplates.TemplateID,hIdentical)
         	IF HFound(Template) THEN
         		nMaxTemplates++
         		Dimension(arrTemplates,nMaxTemplates)
         		arrTemplates[nMaxTemplates].nTemplateID=template.TemplateID
         		arrTemplates[nMaxTemplates].sTemplateCommentChar=Template.TemplateCommentChar
         		arrTemplates[nMaxTemplates].sTemplateFolder=Template.TemplateFolder
         		arrTemplates[nMaxTemplates].sTemplateName=Template.TemplateName
         		
         		hfilter(TemplateVars,TemplateID,template.TemplateID,template.TemplateID)
         		HReadFirst(TemplateVars,TemplateID)
         		while not hout(TemplateVars)
         			nMaxTemplateVars++
         			Dimension(arrTemplateVars,nMaxTemplateVars)
         			arrTemplateVars[nMaxTemplateVars].sVariable="{"+TemplateVars.VarName+"}"
         			arrTemplateVars[nMaxTemplateVars].sCaption=TemplateVars.Caption
         			for i=1 to nMaxLanguages
         				hreadseek(ProjectVars,ProjectVarsKey,HBuildKeyValue(ProjectVars,ProjectVarsKey,Project.ProjectID,TemplateVars.TemplateVarsID,arrLanguages[i].nLanguageID),hIdentical)
         				Dimension(arrTemplateVars[nMaxTemplateVars].arrContent,Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)+1)
         				if hfound(ProjectVars) then
         					arrTemplateVars[nMaxTemplateVars].arrContent[Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)].nLanguageID=arrLanguages[i].nLanguageID
         					arrTemplateVars[nMaxTemplateVars].arrContent[Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)].sDescription=arrLanguages[i].sDescription
         					arrTemplateVars[nMaxTemplateVars].arrContent[Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)].sToken=arrLanguages[i].sToken
         					arrTemplateVars[nMaxTemplateVars].arrContent[Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)].sSourceToken=arrLanguages[i].sSourceToken
         					arrTemplateVars[nMaxTemplateVars].arrContent[Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)].bGenerate=arrLanguages[i].bGenerate
         					arrTemplateVars[nMaxTemplateVars].arrContent[Dimension(arrTemplateVars[nMaxTemplateVars].arrContent)].sContent=StringToUTF8(ProjectVars.Text)
         				end
         			end
         			hreadnext(TemplateVars,TemplateID)
         		END
         		
         		HFilter(TemplatePage,TemplatePageID,hMinVal,hMaxVal,"TemplatePage.TemplateID="+Template.TemplateID)
         		HReadFirst(TemplatePage,TemplatePageID)
         		WHILE NOT HOut(TemplatePage)
         			if TemplatePage.TemplatePageGenerate then
         				nTemplatePageCount++
         				arrTemplates[nMaxTemplates].nMaxTemplatePages++
         				Dimension(arrTemplates[nMaxTemplates].arrTemplatePages,arrTemplates[nMaxTemplates].nMaxTemplatePages)
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].nTemplateID=Template.TemplateID
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].nGenerationTypeID=TemplatePage.GenerationType
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].nTemplatePageID=TemplatePage.TemplatePageID
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].sTemplatePageFilename=TemplatePage.TemplatePageFilename
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].sTemplatePageName=TemplatePage.TemplatePageName
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].sTemplatePageFolder=TemplatePage.TemplatePageFolder
         				arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages].sTemplatePageConstruct=TemplatePage.TemplatePageConstruct
         				FillTemplatePageFiles(gnProjectID,TemplatePage.TemplatePageID,version.VersionID,arrTemplates[nMaxTemplates].arrTemplatePages[arrTemplates[nMaxTemplates].nMaxTemplatePages])
         				Multitask(-1)
         			end
         			hreadnext(TemplatePage,TemplatePageID)
         		end
         	end
         	hreadnext(ProjectTemplates,ProjectTemplateKey)
         end
         HDeactivateFilter(ProjectTemplates)
         HDeactivateFilter(TemplatePage)
         
         for nTemplateRun=1 to nMaxTemplates
         	
         	HReadSeek(Template,TemplateID,arrTemplates[nTemplateRun].nTemplateID,hIdentical)
         	IF NOT HFound(Template) THEN
         		Info("Template not found!")
         		RETURN
         	END
         
         	//Template structure
         	vTemplate.nMaxTemplatePages=arrTemplates[nTemplateRun].nMaxTemplatePages
         	vTemplate.nTemplateID=arrTemplates[nTemplateRun].nTemplateID
         	vTemplate.sTemplateCommentChar=arrTemplates[nTemplateRun].sTemplateCommentChar
         	vTemplate.sTemplateFolder=arrTemplates[nTemplateRun].sTemplateFolder
         	vTemplate.sTemplateName=arrTemplates[nTemplateRun].sTemplateName
         	
         	nMaxTemplatePages=arrTemplates[nTemplateRun].nMaxTemplatePages
         	for nTemplatePageRun=1 to nMaxTemplatePages
         		zz++
         		gauge(zz,nTemplatePageCount,arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].sTemplatePageName)
         		Multitask(-1)
         		//Local copy of templatepages
         		ArrayCopy(arrTemplates[nTemplateRun].arrTemplatePages,arrTemplatePages)
         		
         		hreadseek(TemplatePage,TemplatePageID,arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].nTemplatePageID,hIdentical)
         		if not hfound(TemplatePage) THEN
         			Info("Template page not found!")
         			RETURN
         		END
         		
         		//Template page structure
         		vTemplatePage.sTemplatePageConstruct=TemplatePage.TemplatePageConstruct
         		vTemplatePage.sTemplatePageFilename=TemplatePage.TemplatePageFilename
         		vTemplatePage.sTemplatePageFolder=TemplatePage.TemplatePageFolder
         		vTemplatePage.nTemplatePageID=TemplatePage.TemplatePageID
         		vTemplatePage.sTemplatePageName=TemplatePage.TemplatePageName
         		vTemplatePage.nGenerationTypeID=TemplatePage.GenerationType
         		
         		SWITCH vTemplatePage.nGenerationTypeID
         			CASE 1
         				//Once per project, without processing, copy only!
         				sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         				IF NOT fCopyFile(sTemplateFile,CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder) THEN
         					Error(<§$000e§>+sTemplateFile+<§$000d§>+crlf+ErrorInfo(errFullDetails))
         					RETURN
         				END
         			CASE 2
         				//Folder per project, without processing, copy only!
         				sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         				IF fDirectoryExist(sTemplateFile) THEN
         					if not fCopyDir(sTemplateFile,CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder,frRecursive) then
         						Error(<§$002c§>+sTemplateFile+<§$002d§>+crlf+ErrorInfo(errFullDetails))
         						RETURN
         					END
         				ELSE
         					Error(<§$000f§>+sTemplateFile+<§$0010§>+crlf+ErrorInfo(errFullDetails))
         					RETURN
         				END		
         			CASE 3
         				//Project file, processing, generate only once. language default
         				HReadSeek(Language,LanguageID,Project.LanguageID,hIdentical)
         				IF HFound(Language) THEN
         					IF Language.LanguageGenerate THEN
         						
         						nCountLanguage=1
         						
         						n=ArraySeek(vProject.arrProjectTranslation,asLinear,"nLanguageID",Language.LanguageID)
         						if n<>-1 then
         							vProject.sProjectName=vProject.arrProjectTranslation[n].sDescription
         						END
         						
         						ArrayCopy(arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].arrFiles,arrFiles)
         
         						for i=1 to Dimension(arrFiles)
         							n=ArraySeek(arrFiles[i].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         							if n<>-1 then
         								arrFiles[i].sdescription=arrFiles[i].arrDataFileTranslation[n].sDescription
         							end
         						END
         						
         						n=0
         						LOOP
         							n++
         							IF n>Dimension(arrKeyWord) THEN BREAK
         							IF arrKeyWord[n].nType=3 THEN
         								ArrayDelete(arrKeyWord,n)
         								n=0
         							END
         						END
         						
         						FOR i=1 to Dimension(arrTemplateVars)
         							n=ArraySeek(arrTemplateVars[i].arrContent,asLinear,"nLanguageID",Language.LanguageID)
         							IF n<>-1 THEN
         								AddKeyWord(arrKeyWord,arrTemplateVars[i].sVariable,i,3)
         							END
         						END
         						
         						vProjektVars.nMaxFiles=nMaxFiles
         						vProjektVars.nAktLanguageID=Language.LanguageID
         						vProjektVars.sAktLanguageToken=Language.Token
         						vProjektVars.sAktLanguageSourceToken=Language.SourceToken
         						vProjektVars.sAktLanguageDescription=Language.Description
         						vProjektVars.nMaxLanguages=nMaxLanguages
         						
         						sFileContent=""
         						sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         						IF fFileExist(sTemplateFile) THEN
         							sFileContent=fLoadText(sTemplateFile,foAnsi)
         							ValidateSource(sTemplateFile,sFileContent)
         							HReadSeek(TemplateCache,TemplatePageID,TemplatePage.TemplatePageID,hIdentical)
         							IF NOT HFound(TemplateCache) THEN
         								//Generate WinDev code, update it
         								sSource=GetSourceCode(sFileContent)
         								TemplateCache.TemplatePageID=TemplatePage.TemplatePageID
         								TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         								TemplateCache.SourceCache=sSource
         								TemplateCache.Version=gsVersion
         								HAdd(TemplateCache)
         							ELSE
         								IF sComputeCrc32(sFileContent)=TemplateCache.SourceCRC AND gsVersion=TemplateCache.Version THEN
         									sSource=TemplateCache.SourceCache
         								ELSE
         									//Generate WinDev code, update it
         									sSource=GetSourceCode(sFileContent)
         									TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         									TemplateCache.SourceCache=sSource
         									TemplateCache.Version=gsVersion
         									HModify(TemplateCache)
         								END
         							END
         							
         							IF sSource=0 THEN BREAK
         							
         							sFileContent=ExecuteCode(sSource)
         							IF Left(sFileContent,6)="Error:" THEN
         								Error(sFileContent)
         								RETURN
         							END
         							
         							IF NOT fDirectoryExist(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder) THEN
         								fMakeDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)
         							END
         							
         							sOutputFile=CompleteDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)+TemplatePage.TemplatePageConstruct
         							IF NOT fDirectoryExist(fExtractPath(sOutputFile,fDirectory+fDrive)) THEN
         								fMakeDir(fExtractPath(sOutputFile,fDirectory+fDrive))
         							END
         							sOutputFile=Replace(sOutputFile,"%1",fExtractPath(TemplatePage.TemplatePageFilename,fFileName))
         							sOutputFile=Replace(sOutputFile,"%2",Language.Token)
         							sOutputFile=Replace(sOutputFile,"%3",Language.Description)
         							sOutputFile=Replace(sOutputFile,"%4",Language.SourceToken)
         							sOutputFile=Replace(sOutputFile,"%5",TemplatePage.TemplatePageName)
         							sOutputFile=Replace(sOutputFile,"%6",DateToString(DateSys(),"YYYY_MM_DD"))
         							sOutputFile=Replace(sOutputFile,"%7",TimeToString(TimeSys(),"HHMMSS"))
         							sOutputFile=Replace(sOutputFile,"%8",GetTimeStamp(DateSys(),TimeSys()))
         							sOutputFile=Replace(sOutputFile,"%9",NumToString(Project.LastVersionNo,"06d"))
         							fSaveText(sOutputFile,sFileContent)
         						else
         							error(<§$0031§>+sTemplateFile+<§$0032§>)
         							return
         						END
         					ELSE
         						Error(<§$0033§>+Language.Description+<§$0034§>+TemplatePage.TemplatePageName+<§$0035§>)
         					END
         				END
         			CASE 4
         				//Project file, processing, generate once per language
         				ArrayCopy(arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].arrFiles,arrFiles)
         				
         				FOR nCountLanguage=1 TO nMaxLanguages
         					HReadSeek(Language,LanguageID,arrLanguages[nCountLanguage].nLanguageID,hIdentical)
         					IF Language.LanguageGenerate THEN
         
         						n=ArraySeek(vProject.arrProjectTranslation,asLinear,"nLanguageID",Language.LanguageID)
         						IF n<>-1 THEN
         							vProject.sProjectName=vProject.arrProjectTranslation[n].sDescription
         						END
         						
         						n=0
         						LOOP
         							n++
         							IF n>Dimension(arrKeyWord) THEN BREAK
         							IF arrKeyWord[n].nType=3 THEN
         								ArrayDelete(arrKeyWord,n)
         								n=0
         							END
         						END
         						
         						FOR i=1 to Dimension(arrTemplateVars)
         							n=ArraySeek(arrTemplateVars[i].arrContent,asLinear,"nLanguageID",Language.LanguageID)
         							IF n<>-1 THEN
         								AddKeyWord(arrKeyWord,arrTemplateVars[i].sVariable,i,3)
         							END
         						END
         						
         						ArrayCopy(arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].arrFiles,arrFiles)
         						
         						FOR i=1 to Dimension(arrFiles)
         							n=ArraySeek(arrFiles[i].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         							IF n<>-1 THEN
         								arrFiles[i].sDescription=arrFiles[i].arrDataFileTranslation[n].sDescription
         							END
         						END
         					
         						vProjektVars.nMaxFiles=nMaxFiles
         						vProjektVars.nAktLanguageID=Language.LanguageID
         						vProjektVars.sAktLanguageToken=Language.Token
         						vProjektVars.sAktLanguageSourceToken=Language.SourceToken
         						vProjektVars.sAktLanguageDescription=Language.Description
         						vProjektVars.nMaxLanguages=nMaxLanguages
         						
         						sFileContent=""
         						sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         						IF fFileExist(sTemplateFile) THEN
         							sFileContent=fLoadText(sTemplateFile,foAnsi)
         							ValidateSource(sTemplateFile,sFileContent)
         							HReadSeek(TemplateCache,TemplatePageID,TemplatePage.TemplatePageID,hIdentical)
         							IF NOT HFound(TemplateCache) THEN
         								//Generate WinDev code, update it
         								sSource=GetSourceCode(sFileContent)
         								TemplateCache.TemplatePageID=TemplatePage.TemplatePageID
         								TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         								TemplateCache.SourceCache=sSource
         								TemplateCache.Version=gsVersion
         								HAdd(TemplateCache)
         							ELSE
         								IF sComputeCrc32(sFileContent)=TemplateCache.SourceCRC AND gsVersion=TemplateCache.Version THEN
         									sSource=TemplateCache.SourceCache
         								ELSE
         									//Generate WinDev code, update it
         									sSource=GetSourceCode(sFileContent)
         									TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         									TemplateCache.SourceCache=sSource
         									TemplateCache.Version=gsVersion
         									HModify(TemplateCache)
         								END
         							END
         							
         							IF sSource=0 THEN BREAK
         							
         							sFileContent=ExecuteCode(sSource)
         							IF Left(sFileContent,6)="Error:" THEN
         								n=Position(sFileContent,"Process of 'Code compiled dynamically' (Code compiled dynamically), line ")
         								if n>0 then
         									sFileContent=sFileContent+crlf+crlf+<§$0036§>+crlf+ExtractString(sSource,val(middle(sFileContent,n+73,Position(sFileContent,", thread",n+1)-(n+73))),crlf)
         								END
         								Error(sFileContent)
         								RETURN
         							END
         							
         							IF NOT fDirectoryExist(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder) THEN
         								fMakeDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)
         							END
         							
         							sOutputFile=CompleteDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)+TemplatePage.TemplatePageConstruct
         							IF NOT fDirectoryExist(fExtractPath(sOutputFile,fDirectory+fDrive)) THEN
         								fMakeDir(fExtractPath(sOutputFile,fDirectory+fDrive))
         							END
         							sOutputFile=Replace(sOutputFile,"%1",fExtractPath(TemplatePage.TemplatePageFilename,fFileName))
         							sOutputFile=Replace(sOutputFile,"%2",Language.Token)
         							sOutputFile=Replace(sOutputFile,"%3",Language.Description)
         							sOutputFile=Replace(sOutputFile,"%4",Language.SourceToken)
         							sOutputFile=Replace(sOutputFile,"%5",TemplatePage.TemplatePageName)
         							sOutputFile=Replace(sOutputFile,"%6",DateToString(DateSys(),"YYYY_MM_DD"))
         							sOutputFile=Replace(sOutputFile,"%7",TimeToString(TimeSys(),"HHMMSS"))
         							sOutputFile=Replace(sOutputFile,"%8",GetTimeStamp(DateSys(),TimeSys()))
         							sOutputFile=Replace(sOutputFile,"%9",NumToString(Project.LastVersionNo,"06d"))
         							fSaveText(sOutputFile,sFileContent)
         						ELSE
         							Error(<§$0031§>+sTemplateFile+<§$0032§>)
         							RETURN
         						END
         					END
         				END
         			CASE 5
         				//Data file, processing, generate only once
         				ArrayCopy(arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].arrFiles,arrFiles)
         				
         				HReadSeek(Language,LanguageID,Project.LanguageID,hIdentical)
         				IF HFound(Language) THEN
         					IF Language.LanguageGenerate THEN
         						
         						n=ArraySeek(vProject.arrProjectTranslation,asLinear,"nLanguageID",Language.LanguageID)
         						IF n<>-1 THEN
         							vProject.sProjectName=vProject.arrProjectTranslation[n].sDescription
         						END
         						
         						FOR nFileRun=1 TO nMaxFiles
         
         							WHEN EXCEPTION IN
         								n=ArraySeek(arrFiles[nFileRun].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         								IF n<>-1 THEN
         									arrFiles[nFileRun].sdescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         									vProjektVars.sAktFileDescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         								END
         							
         								ArrayCopy(arrFiles[nFileRun].arrItems,arrItems)
         								for i=1 to Dimension(arrItems)
         									n=arrayseek(arrItems[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         									if n<>-1 then
         										arrItems[i].sCaption=arrItems[i].arrCaption[n].sCaption
         									END
         								END
         
         								ArrayCopy(arrFiles[nFileRun].arrItemsNoKey,arrItemsNoKey)
         								FOR i=1 to Dimension(arrItemsNoKey)
         									n=ArraySeek(arrItemsNoKey[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         									IF n<>-1 THEN
         										arrItemsNoKey[i].sCaption=arrItemsNoKey[i].arrCaption[n].sCaption
         									END
         								END
         
         								ArrayCopy(arrFiles[nFileRun].arrItemsNoKeyAll,arrItemsNoKeyAll)
         								FOR i=1 to Dimension(arrItemsNoKeyAll)
         									n=ArraySeek(arrItemsNoKeyAll[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         									IF n<>-1 THEN
         										arrItemsNoKeyAll[i].sCaption=arrItemsNoKeyAll[i].arrCaption[n].sCaption
         									END
         								END
         
         								ArrayCopy(arrFiles[nFileRun].arrItemsNoBlob,arrItemsNoBlob)
         								FOR i=1 TO Dimension(arrItemsNoBlob)
         									n=ArraySeek(arrItemsNoBlob[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         									IF n<>-1 THEN
         										arrItemsNoBlob[i].sCaption=arrItemsNoBlob[i].arrCaption[n].sCaption
         									END
         								END
         								
         								ArrayCopy(arrFiles[nFileRun].arrItemsBlob,arrItemsBlob)
         								FOR i=1 TO Dimension(arrItemsBlob)
         									n=ArraySeek(arrItemsBlob[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         									IF n<>-1 THEN
         										arrItemsBlob[i].sCaption=arrItemsBlob[i].arrCaption[n].sCaption
         									END
         								END
         
         								ArrayDeleteAll(arrFiles[nFileRun].arrItemsSearchKeys)
         								if arrFiles[nFileRun].sSearchKeys="" then
         									p=ArraySeek(arrFiles[nFileRun].arrItems,asLinear,"sItemName",arrFiles[nFileRun].sKeyName)
         									IF p<>-1 THEN
         										o=ArrayAddLine(arrFiles[nFileRun].arrItemsSearchKeys)
         										arrFiles[nFileRun].arrItemsSearchKeys[o]=arrFiles[nFileRun].arrItems[p]
         									END
         								else
         									FOR i=1 TO StringCount(arrFiles[nFileRun].sSearchKeys,";")+1
         										sSearchKey=ExtractString(arrFiles[nFileRun].sSearchKeys,i,";")
         										IF sSearchKey<>"" THEN
         											p=ArraySeek(arrFiles[nFileRun].arrItems,asLinear,"sItemName",sSearchKey)
         											IF p<>-1 THEN
         												o=ArrayAddLine(arrFiles[nFileRun].arrItemsSearchKeys)
         												arrFiles[nFileRun].arrItemsSearchKeys[o]=arrFiles[nFileRun].arrItems[p]
         											END
         										END
         									END
         								end
         																
         								ArrayCopy(arrFiles[nFileRun].arrKeys,arrKeys)
         								ArrayCopy(arrFiles[nFileRun].arrKeysDetail,arrKeysDetail)
         								ArrayCopy(arrFiles[nFileRun].arrItemsMasterDetail,arrItemsMasterDetail)
         								ArrayCopy(arrFiles[nFileRun].arrItemsMasterDetailNoKey,arrItemsMasterDetailNoKey)
         								ArrayCopy(arrFiles[nFileRun].arrKeysForeign,arrForeignKeys)
         								ArrayCopy(arrFiles[nFileRun].arrItemsSearchKeys,arrItemsSearchKeys)
         								
         								arrFiles[nFileRun].sPrimaryKey=""
         								for i=1 to Dimension(arrKeys)
         									if arrKeys[i].nKeyType=4 or arrKeys[i].nKeyType=3 then
         										for n=1 to Dimension(arrKeys[i].arrFields)
         											arrKeys[i].sPrimaryKeyList+=arrKeys[i].arrFields[n].sFieldName
         											arrFiles[nFileRun].sPrimaryKey+=arrKeys[i].arrFields[n].sFieldName
         											If n<Dimension(arrKeys[i].arrFields) then
         												arrFiles[nFileRun].sPrimaryKey+=","
         												arrKeys[i].sPrimaryKeyList+=","
         											end
         										END
         										BREAK
         									END
         								END
         								
         								for i=1 to Dimension(arrFiles[nFileRun].arrItems)
         									for t=1 to Dimension(arrForeignKeys)
         										if arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItems[i].sItemName then
         											arrFiles[nFileRun].arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         											arrFiles[nFileRun].arrItems[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         											arrFiles[nFileRun].arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         											arrFiles[nFileRun].arrItems[i].nForeignTableID=arrForeignKeys[t].nTableID
         											arrFiles[nFileRun].arrItems[i].sForeignTableItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItems[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItems[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItems[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItems[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItems[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         											arrFiles[nFileRun].arrItems[i].nForeignArrayID=t
         										END
         									END
         								end
         								
         								FOR i=1 to Dimension(arrItems)
         									FOR t=1 to Dimension(arrForeignKeys)
         										IF arrForeignKeys[t].sItemName=arrItems[i].sItemName THEN
         											arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         											arrItems[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         											arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         											arrItems[i].nForeignTableID=arrForeignKeys[t].nTableID
         											arrItems[i].sForeignTableItem=arrForeignKeys[t].sItemName
         											arrItems[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         											arrItems[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItems[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItems[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItems[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         											arrItems[i].nForeignArrayID=t
         										END
         									END
         								END
         	
         								//if arrFiles[nFileRun].sFileName="artikel" then stop
         								FOR i=1 to Dimension(arrFiles[nFileRun].arrItemsNoKey)
         									FOR t=1 to Dimension(arrForeignKeys)
         										IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoKey[i].sItemName THEN
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTable		= arrForeignKeys[t].sTableName
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTable		= arrForeignKeys[t].sTableName
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableID		= arrForeignKeys[t].nTableID
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableItem	= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         											IF arrForeignKeys[t].sItemDisplay="" THEN
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         												arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         												arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemID
         											ELSE
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         												arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         												arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemSortId
         											END
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignArrayID=t
         										END
         									END
         								END
         								FOR i=1 to Dimension(arrFiles[nFileRun].arrItemsNoKeyAll)
         									FOR t=1 to Dimension(arrForeignKeys)
         										IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoKeyAll[i].sItemName THEN
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTable		= arrForeignKeys[t].sTableName
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTable		= arrForeignKeys[t].sTableName
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableID		= arrForeignKeys[t].nTableID
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableItem	= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         											IF arrForeignKeys[t].sItemDisplay="" THEN
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemID
         											ELSE
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         												arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemSortId
         											END
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignArrayID=t
         										END
         									END
         								END
         							do
         							end
         
         							//if arrFiles[nFileRun].sFileName="artikel" then stop
         							FOR i=1 TO Dimension(arrFiles[nFileRun].arrItemsNoBlob)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoBlob[i].sItemName THEN
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTable		= arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTable		= arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableID		= arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableItem	= arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemID
         										ELSE
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemSortId
         										END
         										arrFiles[nFileRun].arrItemsNoBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							//if arrFiles[nFileRun].sFileName="artikel" then stop
         							FOR i=1 TO Dimension(arrFiles[nFileRun].arrItemsBlob)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsBlob[i].sItemName THEN
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTable		= arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTable		= arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsBlob[i].nForeignTableID		= arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTableItem	= arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItemsBlob[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemID
         										ELSE
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemSortId
         										END
         										arrFiles[nFileRun].arrItemsBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							FOR i=1 to Dimension(arrItemsNoKey)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsNoKey[i].sItemName THEN
         										arrItemsNoKey[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoKey[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItemsNoKey[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoKey[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItemsNoKey[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItemsNoKey[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsNoKey[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrItemsNoKey[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrItemsNoKey[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrItemsNoKey[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsNoKey[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItemsNoKey[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItemsNoKey[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItemsNoKey[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										END
         										arrItemsNoKey[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							FOR i=1 to Dimension(arrItemsNoKeyAll)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsNoKeyAll[i].sItemName THEN
         										arrItemsNoKeyAll[i].sForeignTable			= arrForeignKeys[t].sTableName
         										arrItemsNoKeyAll[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         										arrItemsNoKeyAll[i].sForeignTable			= arrForeignKeys[t].sTableName
         										arrItemsNoKeyAll[i].nForeignTableID		= arrForeignKeys[t].nTableID
         										arrItemsNoKeyAll[i].sForeignTableItem		= arrForeignKeys[t].sItemName
         										arrItemsNoKeyAll[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         											arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         											arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         											arrItemsNoKeyAll[i].nForeignTableSortItemID	= arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         											arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         											arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         											arrItemsNoKeyAll[i].nForeignTableSortItemID	= arrForeignKeys[t].nItemSortId
         										END
         										arrItemsNoKeyAll[i].nForeignArrayID=t
         									END
         								END
         							END
         						
         							FOR i=1 TO Dimension(arrItemsNoBlob)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsNoBlob[i].sItemName THEN
         										arrItemsNoBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoBlob[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItemsNoBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoBlob[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItemsNoBlob[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItemsNoBlob[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsNoBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrItemsNoBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrItemsNoBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrItemsNoBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsNoBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItemsNoBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItemsNoBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItemsNoBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										END
         										arrItemsNoBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							FOR i=1 TO Dimension(arrItemsBlob)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsBlob[i].sItemName THEN
         										arrItemsBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsBlob[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItemsBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsBlob[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItemsBlob[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItemsBlob[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrItemsBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrItemsBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrItemsBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItemsBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItemsBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItemsBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										END
         										arrItemsBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							vProjektVars.nMaxFiles=nMaxFiles
         							vProjektVars.nMaxKeys=Dimension(arrFiles[nFileRun].arrKeys)
         							vProjektVars.nMaxItems=Dimension(arrFiles[nFileRun].arrItems)
         							vProjektVars.nMaxItemsNoKey=Dimension(arrFiles[nFileRun].arrItemsNoKey)
         							vProjektVars.nMaxItemsNoKeyAll=Dimension(arrFiles[nFileRun].arrItemsNoKeyAll)
         							vProjektVars.nMaxItemsNoBlob=Dimension(arrFiles[nFileRun].arrItemsNoBlob)
         							vProjektVars.nMaxItemsBlob=Dimension(arrFiles[nFileRun].arrItemsBlob)
         							vProjektVars.nMaxForeignKeys=Dimension(arrFiles[nFileRun].arrKeysForeign)
         							vProjektVars.nMaxItemsMasterDetail=Dimension(arrFiles[nFileRun].arrKeysDetail)
         							vProjektVars.nMaxItemsMasterDetailNoKey=Dimension(arrFiles[nFileRun].arrItemsMasterDetailNoKey)
         							vProjektVars.nMaxSearchKeys=Dimension(arrFiles[nFileRun].arrItemsSearchKeys)
         							vProjektVars.bGenerateMasterDetail=arrFiles[nFileRun].bGenerateMasterDetail
         							vProjektVars.sDetailFileID=arrFiles[nFileRun].sDetailFileID
         							vProjektVars.sDetailFileName=arrFiles[nFileRun].sDetailFileName
         							vProjektVars.sDetailFileKey=arrFiles[nFileRun].sDetailFileKey
         							vProjektVars.sAktFile=arrFiles[nFileRun].sFileName
         							vProjektVars.sAktKeyName=arrFiles[nFileRun].sKeyName
         							vProjektVars.sAktPrimaryKey=arrFiles[nFileRun].sPrimaryKey
         							n=ArraySeek(arrFiles[nFileRun].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         							IF n<>-1 THEN
         								vProjektVars.sAktFileDescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         							else
         								vProjektVars.sAktFileDescription=arrFiles[nFileRun].sDescription
         							END
         							vProjektVars.sAktFileShort=arrFiles[nFileRun].sFileNameShort
         							vProjektVars.nAktFileID=arrFiles[nFileRun].nFileId
         							vProjektVars.nAktLanguageID=Language.LanguageID
         							vProjektVars.sAktLanguageToken=Language.Token
         							vProjektVars.sAktLanguageSourceToken=Language.SourceToken
         							vProjektVars.sAktLanguageDescription=Language.Description
         							vProjektVars.nMaxLanguages=nMaxLanguages
         							vProjektVars.sAktSearchKeys=arrFiles[nFileRun].sSearchKeys
         								
         							sFileContent=""
         							sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         							IF fFileExist(sTemplateFile) THEN
         								sFileContent=fLoadText(sTemplateFile,foAnsi)
         								if not ValidateSource(sTemplateFile,sFileContent) then
         									return
         								END
         								HReadSeek(TemplateCache,TemplatePageID,TemplatePage.TemplatePageID,hIdentical)
         								IF NOT HFound(TemplateCache) THEN
         									//Generate WinDev code, update it
         									sSource=GetSourceCode(sFileContent)
         									IF sSource=0 THEN
         										RETURN
         									ELSE
         										TemplateCache.TemplatePageID=TemplatePage.TemplatePageID
         										TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         										TemplateCache.SourceCache=sSource
         										TemplateCache.Version=gsVersion
         										HAdd(TemplateCache)
         									END
         								ELSE
         									IF sComputeCrc32(sFileContent)=TemplateCache.SourceCRC AND gsVersion=TemplateCache.Version THEN
         										sSource=TemplateCache.SourceCache
         									ELSE
         										//Generate WinDev code, update it
         										sSource=GetSourceCode(sFileContent)
         										IF sSource=0 THEN
         											TemplateCache.Version=""
         											HModify(TemplateCache)
         											RETURN
         										ELSE
         											TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         											TemplateCache.SourceCache=sSource
         											TemplateCache.Version=gsVersion
         											HModify(TemplateCache)
         										END
         									END
         								END
         
         								WHEN EXCEPTION IN
         									sFileContent=ExecuteCode(sSource)
         									IF Left(sFileContent,6)="Error:" THEN
         										Error(sFileContent)
         										RETURN
         									END
         								DO
         									info(ExceptionInfo(errFullDetails))
         									return
         								END
         								
         								IF NOT sFileContent="0" THEN
         									IF NOT fDirectoryExist(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder) THEN
         										fMakeDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)
         									END
         									
         									sOutputFile=CompleteDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)+TemplatePage.TemplatePageConstruct
         									IF NOT fDirectoryExist(fExtractPath(sOutputFile,fDirectory+fDrive)) THEN
         										fMakeDir(fExtractPath(sOutputFile,fDirectory+fDrive))
         									END
         									sOutputFile=Replace(sOutputFile,"%1",arrFiles[nFileRun].sFileName)
         									sOutputFile=Replace(sOutputFile,"%2",Language.Token)
         									sOutputFile=Replace(sOutputFile,"%3",Language.Description)
         									sOutputFile=Replace(sOutputFile,"%4",Language.SourceToken)
         									sOutputFile=Replace(sOutputFile,"%5",TemplatePage.TemplatePageName)
         									sOutputFile=Replace(sOutputFile,"%6",DateToString(DateSys(),"YYYY_MM_DD"))
         									sOutputFile=Replace(sOutputFile,"%7",TimeToString(TimeSys(),"HHMMSS"))
         									sOutputFile=Replace(sOutputFile,"%8",GetTimeStamp(datesys(),TimeSys()))
         									sOutputFile=Replace(sOutputFile,"%9",NumToString(Project.LastVersionNo,"06d"))
         									fSaveText(sOutputFile,sFileContent)
         								END								
         							ELSE
         								Error(<§$0012§>+sTemplateFile)
         								RETURN
         							END
         						END
         					ELSE
         						Error(<§$0017§>+Language.Description+<§$0019§>+TemplatePage.TemplatePageName+<§$001a§>)
         					END
         				ELSE
         					Error(<§$0011§>+Project.ProjectName)
         					RETURN
         				END
         			CASE 6
         				//Data file, processing, generate once per language
         				FOR nCountLanguage=1 TO nMaxLanguages
         					HReadSeek(Language,LanguageID,arrLanguages[nCountLanguage].nLanguageID,hIdentical)
         					IF Language.LanguageGenerate THEN
         						
         						n=ArraySeek(vProject.arrProjectTranslation,asLinear,"nLanguageID",Language.LanguageID)
         						IF n<>-1 THEN
         							vProject.sProjectName=vProject.arrProjectTranslation[n].sDescription
         						END
         						
         						FOR nFileRun=1 TO nMaxFiles
         							
         							n=ArraySeek(arrFiles[nFileRun].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         							IF n<>-1 THEN
         								arrFiles[nFileRun].sdescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         								vProjektVars.sAktFileDescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         							END
         							
         							ArrayCopy(arrFiles[nFileRun].arrItems,arrItems)
         							FOR i=1 to Dimension(arrItems)
         								n=ArraySeek(arrItems[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         								IF n<>-1 THEN
         									arrItems[i].sCaption=arrItems[i].arrCaption[n].sCaption
         								END
         							END
         							
         							ArrayCopy(arrFiles[nFileRun].arrItemsNoKey,arrItemsNoKey)
         							FOR i=1 to Dimension(arrItemsNoKey)
         								n=ArraySeek(arrItemsNoKey[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         								IF n<>-1 THEN
         									arrItemsNoKey[i].sCaption=arrItemsNoKey[i].arrCaption[n].sCaption
         								END
         							END
         							
         							ArrayCopy(arrFiles[nFileRun].arrItemsNoKeyAll,arrItemsNoKeyAll)
         							FOR i=1 to Dimension(arrItemsNoKeyAll)
         								n=ArraySeek(arrItemsNoKeyAll[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         								IF n<>-1 THEN
         									arrItemsNoKeyAll[i].sCaption=arrItemsNoKeyAll[i].arrCaption[n].sCaption
         								END
         							END
         
         							ArrayCopy(arrFiles[nFileRun].arrItemsNoBlob,arrItemsNoBlob)
         							FOR i=1 TO Dimension(arrItemsNoBlob)
         								n=ArraySeek(arrItemsNoBlob[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         								IF n<>-1 THEN
         									arrItemsNoBlob[i].sCaption=arrItemsNoBlob[i].arrCaption[n].sCaption
         								END
         							END
         							
         							ArrayCopy(arrFiles[nFileRun].arrItemsBlob,arrItemsBlob)
         							FOR i=1 TO Dimension(arrItemsBlob)
         								n=ArraySeek(arrItemsBlob[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         								IF n<>-1 THEN
         									arrItemsBlob[i].sCaption=arrItemsBlob[i].arrCaption[n].sCaption
         								END
         							END
         
         							ArrayDeleteAll(arrFiles[nFileRun].arrItemsSearchKeys)
         							if arrFiles[nFileRun].sSearchKeys="" then
         								p=ArraySeek(arrFiles[nFileRun].arrItems,asLinear,"sItemName",arrFiles[nFileRun].sKeyName)
         								IF p<>-1 THEN
         									o=ArrayAddLine(arrFiles[nFileRun].arrItemsSearchKeys)
         									arrFiles[nFileRun].arrItemsSearchKeys[o]=arrFiles[nFileRun].arrItems[p]
         								END
         							else
         								FOR i=1 TO StringCount(arrFiles[nFileRun].sSearchKeys,";")+1
         									sSearchKey=ExtractString(arrFiles[nFileRun].sSearchKeys,i,";")
         									IF sSearchKey<>"" THEN
         										p=ArraySeek(arrFiles[nFileRun].arrItems,asLinear,"sItemName",sSearchKey)
         										IF p<>-1 THEN
         											o=ArrayAddLine(arrFiles[nFileRun].arrItemsSearchKeys)
         											arrFiles[nFileRun].arrItemsSearchKeys[o]=arrFiles[nFileRun].arrItems[p]
         										ENd
         									END
         								END
         							end
         														
         							ArrayCopy(arrFiles[nFileRun].arrKeys,arrKeys)
         							ArrayCopy(arrFiles[nFileRun].arrKeysDetail,arrKeysDetail)
         							ArrayCopy(arrFiles[nFileRun].arrItemsMasterDetail,arrItemsMasterDetail)
         							ArrayCopy(arrFiles[nFileRun].arrItemsMasterDetailNoKey,arrItemsMasterDetailNoKey)
         							ArrayCopy(arrFiles[nFileRun].arrItemsSearchKeys,arrItemsSearchKeys)
         							ArrayCopy(arrFiles[nFileRun].arrKeysForeign,arrForeignKeys)
         							
         							arrFiles[nFileRun].sPrimaryKey=""
         							FOR i=1 to Dimension(arrKeys)
         								IF arrKeys[i].nKeyType=4 OR arrKeys[i].nKeyType=3 THEN
         									FOR n=1 TO Dimension(arrKeys[i].arrFields)
         										arrKeys[i].sPrimaryKeyList+=arrKeys[i].arrFields[n].sFieldName
         										arrFiles[nFileRun].sPrimaryKey+=arrKeys[i].arrFields[n].sFieldName
         										IF n<Dimension(arrKeys[i].arrFields) THEN
         											arrFiles[nFileRun].sPrimaryKey+=","
         											arrKeys[i].sPrimaryKeyList+=","
         										END
         									END
         									BREAK
         								END
         							END
         							
         							FOR i=1 to Dimension(arrFiles[nFileRun].arrItems)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItems[i].sItemName THEN
         										arrFiles[nFileRun].arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItems[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItems[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItems[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItems[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										arrFiles[nFileRun].arrItems[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         										arrFiles[nFileRun].arrItems[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         										arrFiles[nFileRun].arrItems[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         										arrFiles[nFileRun].arrItems[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										arrFiles[nFileRun].arrItems[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							FOR i=1 to Dimension(arrItems)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItems[i].sItemName THEN
         										arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItems[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItems[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItems[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItems[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										arrItems[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         										arrItems[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         										arrItems[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         										arrItems[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										arrItems[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							m=Dimension(arrFiles[nFileRun].arrItemsNoKey)
         							FOR i=1 to m
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoKey[i].sItemName THEN
         										arrFiles[nFileRun].arrItemsNoKey[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItemsNoKey[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItemsNoKey[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         											
         										END
         										arrFiles[nFileRun].arrItemsNoKey[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							m=Dimension(arrFiles[nFileRun].arrItemsNoKeyAll)
         							FOR i=1 to m
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoKeyAll[i].sItemName THEN
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTable		= arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTable		= arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableID		= arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableItem	= arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemID
         										ELSE
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignTableSortItemID		= arrForeignKeys[t].nItemSortId
         											
         										END
         										arrFiles[nFileRun].arrItemsNoKeyAll[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							m=Dimension(arrFiles[nFileRun].arrItemsNoBlob)
         							FOR i=1 TO m
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoBlob[i].sItemName THEN
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItemsNoBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItemsNoBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         											
         										END
         										arrFiles[nFileRun].arrItemsNoBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							m=Dimension(arrFiles[nFileRun].arrItemsBlob)
         							FOR i=1 TO m
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsBlob[i].sItemName THEN
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrFiles[nFileRun].arrItemsBlob[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrFiles[nFileRun].arrItemsBlob[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrFiles[nFileRun].arrItemsBlob[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrFiles[nFileRun].arrItemsBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrFiles[nFileRun].arrItemsBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         											
         										END
         										arrFiles[nFileRun].arrItemsBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							FOR i=1 to Dimension(arrItemsNoKey)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsNoKey[i].sItemName THEN
         										arrItemsNoKey[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoKey[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItemsNoKey[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoKey[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItemsNoKey[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItemsNoKey[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsNoKey[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrItemsNoKey[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrItemsNoKey[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrItemsNoKey[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsNoKey[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItemsNoKey[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItemsNoKey[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItemsNoKey[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										END
         										arrItemsNoKey[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							FOR i=1 to Dimension(arrItemsNoKeyAll)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsNoKeyAll[i].sItemName THEN
         										arrItemsNoKeyAll[i].sForeignTable			= arrForeignKeys[t].sTableName
         										arrItemsNoKeyAll[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         										arrItemsNoKeyAll[i].sForeignTable			= arrForeignKeys[t].sTableName
         										arrItemsNoKeyAll[i].nForeignTableID		= arrForeignKeys[t].nTableID
         										arrItemsNoKeyAll[i].sForeignTableItem		= arrForeignKeys[t].sItemName
         										arrItemsNoKeyAll[i].nForeignTableItemID	= arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemName
         											arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemID
         											arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemName
         											arrItemsNoKeyAll[i].nForeignTableSortItemID	= arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsNoKeyAll[i].sForeignTableDisplayItem	= arrForeignKeys[t].sItemDisplay
         											arrItemsNoKeyAll[i].nForeignTableDisplayItemID	= arrForeignKeys[t].nItemDisplayId
         											arrItemsNoKeyAll[i].sForeignTableSortItem		= arrForeignKeys[t].sItemSort
         											arrItemsNoKeyAll[i].nForeignTableSortItemID	= arrForeignKeys[t].nItemSortId
         										END
         										arrItemsNoKeyAll[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							FOR i=1 TO Dimension(arrItemsNoBlob)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsNoBlob[i].sItemName THEN
         										arrItemsNoBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoBlob[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItemsNoBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsNoBlob[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItemsNoBlob[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItemsNoBlob[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsNoBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrItemsNoBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrItemsNoBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrItemsNoBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsNoBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItemsNoBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItemsNoBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItemsNoBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										END
         										arrItemsNoBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         							
         							FOR i=1 TO Dimension(arrItemsBlob)
         								FOR t=1 to Dimension(arrForeignKeys)
         									IF arrForeignKeys[t].sItemName=arrItemsBlob[i].sItemName THEN
         										arrItemsBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsBlob[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         										arrItemsBlob[i].sForeignTable=arrForeignKeys[t].sTableName
         										arrItemsBlob[i].nForeignTableID=arrForeignKeys[t].nTableID
         										arrItemsBlob[i].sForeignTableItem=arrForeignKeys[t].sItemName
         										arrItemsBlob[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         										IF arrForeignKeys[t].sItemDisplay="" THEN
         											arrItemsBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemName
         											arrItemsBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemID
         											arrItemsBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemName
         											arrItemsBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemID
         										ELSE
         											arrItemsBlob[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         											arrItemsBlob[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         											arrItemsBlob[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         											arrItemsBlob[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         										END
         										arrItemsBlob[i].nForeignArrayID=t
         									END
         								END
         							END
         
         							vProjektVars.nMaxFiles=nMaxFiles
         							vProjektVars.nMaxKeys=arrFiles[nFileRun].nMaxKeys
         							vProjektVars.nMaxItems=arrFiles[nFileRun].nMaxItems
         							vProjektVars.nMaxItemsNoKey=arrFiles[nFileRun].nMaxItemsNoKey
         							vProjektVars.nMaxItemsNoKeyAll=arrFiles[nFileRun].nMaxItemsNoKeyAll
         							vProjektVars.nMaxItemsNoBlob=arrFiles[nFileRun].nMaxItemsNoBlob
         							vProjektVars.nMaxItemsBlob=arrFiles[nFileRun].nMaxItemsBlob
         							vProjektVars.nMaxForeignKeys=arrFiles[nFileRun].nMaxKeysForeign
         							vProjektVars.nMaxItemsMasterDetail=arrFiles[nFileRun].nMaxItemsMasterDetail
         							vProjektVars.nMaxItemsMasterDetailNoKey=arrFiles[nFileRun].nMaxItemsMasterDetailNoKey
         							vProjektVars.nMaxSearchKeys=Dimension(arrFiles[nFileRun].arrItemsSearchKeys)
         							vProjektVars.bGenerateMasterDetail=arrFiles[nFileRun].bGenerateMasterDetail
         							vProjektVars.sDetailFileID=arrFiles[nFileRun].sDetailFileID
         							vProjektVars.sDetailFileName=arrFiles[nFileRun].sDetailFileName
         							vProjektVars.sDetailFileKey=arrFiles[nFileRun].sDetailFileKey
         							vProjektVars.sAktFile=arrFiles[nFileRun].sFileName
         							vProjektVars.sAktKeyName=arrFiles[nFileRun].sKeyName
         							vProjektVars.sAktPrimaryKey=arrFiles[nFileRun].sPrimaryKey
         							n=ArraySeek(arrFiles[nFileRun].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         							IF n<>-1 THEN
         								vProjektVars.sAktFileDescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         							ELSE
         								vProjektVars.sAktFileDescription=arrFiles[nFileRun].sDescription
         							END
         							vProjektVars.sAktFileShort=arrFiles[nFileRun].sFileNameShort
         							vProjektVars.nAktFileID=arrFiles[nFileRun].nFileId
         							vProjektVars.nAktLanguageID=Language.LanguageID
         							vProjektVars.sAktLanguageToken=Language.Token
         							vProjektVars.sAktLanguageSourceToken=Language.SourceToken
         							vProjektVars.sAktLanguageDescription=Language.Description
         							vProjektVars.nMaxLanguages=nMaxLanguages
         							vProjektVars.sAktSearchKeys=arrFiles[nFileRun].sSearchKeys
         							
         							sFileContent=""
         							sTemplateFile=CompleteDir(vProject.sProjectTemplateRoot+Template.TemplateFolder)+TemplatePage.TemplatePageFilename
         							
         							IF fFileExist(sTemplateFile) THEN
         								sFileContent=fLoadText(sTemplateFile,foAnsi)
         								ValidateSource(sTemplateFile,sFileContent)
         								HReadSeek(TemplateCache,TemplatePageID,TemplatePage.TemplatePageID,hIdentical)
         								IF NOT HFound(TemplateCache) THEN
         									//Generate WinDev code, update it
         									sSource=GetSourceCode(sFileContent)
         									IF sSource=0 THEN
         										RETURN
         									ELSE
         										TemplateCache.TemplatePageID=TemplatePage.TemplatePageID
         										TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         										TemplateCache.SourceCache=sSource
         										TemplateCache.Version=gsVersion
         										HAdd(TemplateCache)
         									END
         								ELSE
         									IF sComputeCrc32(sFileContent)=TemplateCache.SourceCRC AND gsVersion=TemplateCache.Version THEN
         										sSource=TemplateCache.SourceCache
         									ELSE
         										//Generate WinDev code, update it
         										sSource=GetSourceCode(sFileContent)
         										IF sSource=0 THEN
         											TemplateCache.Version=""
         											HModify(TemplateCache)
         											RETURN
         										ELSE
         											TemplateCache.SourceCRC=sComputeCrc32(sFileContent)
         											TemplateCache.SourceCache=sSource
         											TemplateCache.Version=gsVersion
         											HModify(TemplateCache)
         										END
         									END
         								END
         								
         								sFileContent=ExecuteCode(sSource)
         								IF Left(sFileContent,6)="Error:" THEN
         									Error(sFileContent)
         									RETURN
         								END
         								
         								IF NOT sFileContent="0" THEN
         									IF NOT fDirectoryExist(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder) THEN
         										fMakeDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)
         									END
         									
         									sOutputFile=CompleteDir(CompleteDir(Project.Directory)+TemplatePage.TemplatePageFolder)+TemplatePage.TemplatePageConstruct
         									IF NOT fDirectoryExist(fExtractPath(sOutputFile,fDirectory+fDrive)) THEN
         										fMakeDir(fExtractPath(sOutputFile,fDirectory+fDrive))
         									END
         									sOutputFile=Replace(sOutputFile,"%1",arrFiles[nFileRun].sFileName)
         									sOutputFile=Replace(sOutputFile,"%2",Language.Token)
         									sOutputFile=Replace(sOutputFile,"%3",Language.Description)
         									sOutputFile=Replace(sOutputFile,"%4",Language.SourceToken)
         									sOutputFile=Replace(sOutputFile,"%5",TemplatePage.TemplatePageName)
         									sOutputFile=Replace(sOutputFile,"%6",DateToString(DateSys(),"YYYY_MM_DD"))
         									sOutputFile=Replace(sOutputFile,"%7",TimeToString(TimeSys(),"HHMMSS"))
         									sOutputFile=Replace(sOutputFile,"%8",GetTimeStamp(DateSys(),TimeSys()))
         									sOutputFile=Replace(sOutputFile,"%9",NumToString(Project.LastVersionNo,"06d"))
         									fSaveText(sOutputFile,sFileContent)
         								END								
         							ELSE
         								Error(<§$0012§>+sTemplateFile)
         								RETURN
         							END
         						END
         					END
         				END
         			CASE 7
         				//DB Version
         				ArrayCopy(arrTemplates[nTemplateRun].arrTemplatePages[nTemplatePageRun].arrFiles,arrFiles)
         				
         				HReadSeek(Language,LanguageID,Project.LanguageID,hIdentical)
         				IF HFound(Language) THEN
         					IF Language.LanguageGenerate THEN
         						
         						n=ArraySeek(vProject.arrProjectTranslation,asLinear,"nLanguageID",Language.LanguageID)
         						IF n<>-1 THEN
         							vProject.sProjectName=vProject.arrProjectTranslation[n].sDescription
         						END
         						
         						for nDBVersionRun=1 to nMaxDBVersion
         							FOR nFileRun=1 TO nMaxFiles
         								
         								WHEN EXCEPTION IN
         									n=ArraySeek(arrFiles[nFileRun].arrDataFileTranslation,asLinear,"nLanguageID",Language.LanguageID)
         									IF n<>-1 THEN
         										arrFiles[nFileRun].sdescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         										vProjektVars.sAktFileDescription=arrFiles[nFileRun].arrDataFileTranslation[n].sDescription
         									END
         									
         									ArrayCopy(arrFiles[nFileRun].arrItems,arrItems)
         									FOR i=1 TO Dimension(arrItems)
         										n=ArraySeek(arrItems[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         										IF n<>-1 THEN
         											arrItems[i].sCaption=arrItems[i].arrCaption[n].sCaption
         										END
         									END
         									
         									ArrayCopy(arrFiles[nFileRun].arrItemsNoKey,arrItemsNoKey)
         									FOR i=1 TO Dimension(arrItemsNoKey)
         										n=ArraySeek(arrItemsNoKey[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         										IF n<>-1 THEN
         											arrItemsNoKey[i].sCaption=arrItemsNoKey[i].arrCaption[n].sCaption
         										END
         									END
         									
         									ArrayCopy(arrFiles[nFileRun].arrItemsNoKeyAll,arrItemsNoKeyAll)
         									FOR i=1 TO Dimension(arrItemsNoKeyAll)
         										n=ArraySeek(arrItemsNoKeyAll[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         										IF n<>-1 THEN
         											arrItemsNoKeyAll[i].sCaption=arrItemsNoKeyAll[i].arrCaption[n].sCaption
         										END
         									END
         									
         									ArrayCopy(arrFiles[nFileRun].arrItemsNoBlob,arrItemsNoBlob)
         									FOR i=1 TO Dimension(arrItemsNoBlob)
         										n=ArraySeek(arrItemsNoBlob[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         										IF n<>-1 THEN
         											arrItemsNoBlob[i].sCaption=arrItemsNoBlob[i].arrCaption[n].sCaption
         										END
         									END
         									
         									ArrayCopy(arrFiles[nFileRun].arrItemsBlob,arrItemsBlob)
         									FOR i=1 TO Dimension(arrItemsBlob)
         										n=ArraySeek(arrItemsBlob[i].arrCaption,asLinear,"nLanguageID",Language.LanguageID)
         										IF n<>-1 THEN
         											arrItemsBlob[i].sCaption=arrItemsBlob[i].arrCaption[n].sCaption
         										END
         									END
         									
         									ArrayDeleteAll(arrFiles[nFileRun].arrItemsSearchKeys)
         									IF arrFiles[nFileRun].sSearchKeys="" THEN
         										p=ArraySeek(arrFiles[nFileRun].arrItems,asLinear,"sItemName",arrFiles[nFileRun].sKeyName)
         										IF p<>-1 THEN
         											o=ArrayAddLine(arrFiles[nFileRun].arrItemsSearchKeys)
         											arrFiles[nFileRun].arrItemsSearchKeys[o]=arrFiles[nFileRun].arrItems[p]
         										END
         									ELSE
         										FOR i=1 TO StringCount(arrFiles[nFileRun].sSearchKeys,";")+1
         											sSearchKey=ExtractString(arrFiles[nFileRun].sSearchKeys,i,";")
         											IF sSearchKey<>"" THEN
         												p=ArraySeek(arrFiles[nFileRun].arrItems,asLinear,"sItemName",sSearchKey)
         												IF p<>-1 THEN
         													o=ArrayAddLine(arrFiles[nFileRun].arrItemsSearchKeys)
         													arrFiles[nFileRun].arrItemsSearchKeys[o]=arrFiles[nFileRun].arrItems[p]
         												END
         											END
         										END
         									END
         									
         									ArrayCopy(arrFiles[nFileRun].arrKeys,arrKeys)
         									ArrayCopy(arrFiles[nFileRun].arrKeysDetail,arrKeysDetail)
         									ArrayCopy(arrFiles[nFileRun].arrItemsMasterDetail,arrItemsMasterDetail)
         									ArrayCopy(arrFiles[nFileRun].arrItemsMasterDetailNoKey,arrItemsMasterDetailNoKey)
         									ArrayCopy(arrFiles[nFileRun].arrKeysForeign,arrForeignKeys)
         									ArrayCopy(arrFiles[nFileRun].arrItemsSearchKeys,arrItemsSearchKeys)
         									
         									arrFiles[nFileRun].sPrimaryKey=""
         									FOR i=1 TO Dimension(arrKeys)
         										IF arrKeys[i].nKeyType=4 OR arrKeys[i].nKeyType=3 THEN
         											FOR n=1 TO Dimension(arrKeys[i].arrFields)
         												arrKeys[i].sPrimaryKeyList+=arrKeys[i].arrFields[n].sFieldName
         												arrFiles[nFileRun].sPrimaryKey+=arrKeys[i].arrFields[n].sFieldName
         												IF n<Dimension(arrKeys[i].arrFields) THEN
         													arrFiles[nFileRun].sPrimaryKey+=","
         													arrKeys[i].sPrimaryKeyList+=","
         												END
         											END
         											BREAK
         										END
         									END
         									
         									FOR i=1 TO Dimension(arrFiles[nFileRun].arrItems)
         										FOR t=1 to Dimension(arrForeignKeys)
         											IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItems[i].sItemName THEN
         												arrFiles[nFileRun].arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         												arrFiles[nFileRun].arrItems[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         												arrFiles[nFileRun].arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         												arrFiles[nFileRun].arrItems[i].nForeignTableID=arrForeignKeys[t].nTableID
         												arrFiles[nFileRun].arrItems[i].sForeignTableItem=arrForeignKeys[t].sItemName
         												arrFiles[nFileRun].arrItems[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         												arrFiles[nFileRun].arrItems[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         												arrFiles[nFileRun].arrItems[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         												arrFiles[nFileRun].arrItems[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         												arrFiles[nFileRun].arrItems[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         												arrFiles[nFileRun].arrItems[i].nForeignArrayID=t
         											END
         										END
         									END
         									
         									FOR i=1 TO Dimension(arrItems)
         										FOR t=1 to Dimension(arrForeignKeys)
         											IF arrForeignKeys[t].sItemName=arrItems[i].sItemName THEN
         												arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         												arrItems[i].sForeignTableAndItem=arrForeignKeys[t].sTablePlusItem
         												arrItems[i].sForeignTable=arrForeignKeys[t].sTableName
         												arrItems[i].nForeignTableID=arrForeignKeys[t].nTableID
         												arrItems[i].sForeignTableItem=arrForeignKeys[t].sItemName
         												arrItems[i].nForeignTableItemID=arrForeignKeys[t].nItemID
         												arrItems[i].sForeignTableDisplayItem=arrForeignKeys[t].sItemDisplay
         												arrItems[i].nForeignTableDisplayItemID=arrForeignKeys[t].nItemDisplayId
         												arrItems[i].sForeignTableSortItem=arrForeignKeys[t].sItemSort
         												arrItems[i].nForeignTableSortItemID=arrForeignKeys[t].nItemSortId
         												arrItems[i].nForeignArrayID=t
         											END
         										END
         									END
         									
         									//if arrFiles[nFileRun].sFileName="artikel" then stop
         									FOR i=1 TO Dimension(arrFiles[nFileRun].arrItemsNoKey)
         										FOR t=1 to Dimension(arrForeignKeys)
         											IF arrForeignKeys[t].sItemName=arrFiles[nFileRun].arrItemsNoKey[i].sItemName THEN
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTable		= arrForeignKeys[t].sTableName
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTableAndItem	= arrForeignKeys[t].sTablePlusItem
         												arrFiles[nFileRun].arrItemsNoKey[i].sForeignTable		= arrForeignKeys[t].sTableName
