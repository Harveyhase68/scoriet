     type : 13
  procedures :
   -
     name : GetSourceCode
     internal_properties : 
     procedure_id : 1351110184912667150
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] GetSourceCode (<sTemplateSource> [, <bRecursive> is boolean])
      //
      // Parameters:
      //	sTemplateSource: <specify the role of sTemplateSource>
      //	bRecursive (boolean - default value=0): <specify the role of bRecursive>
      // Return Value:
      // 	Unspecified Type: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	sSource: <specify the role of sSource>
      //	arrFiles: <specify the role of arrFormItems>
      //	arrItems: <specify the role of arrFormItems>
      //	arrFormItems: <specify the role of arrTableItems>
      //	arrTableItems: <specify the role of arrTableItems>
      //	arrItemsNoKey: <specify the role of arrItemsNoKey>
      //	arrItemsNoKeyAll: <specify the role of arrItemsNoKeyAll>
      //	vTemplatePage: <specify the role of vTemplatePage>
      //	vProjektVars: <specify the role of vProjektVars>
      //	vTemplatePage: <specify the role of vProject>
      PROCEDURE GetSourceCode(sTemplateSource, bRecursive is boolean=false)
      
      LOCAL
      	i is int=1
      	n is int
      	zz is int
      	vz is int
      	nLoopIndex is int
      	nLoopEndPos is int
      	sCode is string
      	bAscOpen is boolean=False
      	arrIntend is dynamic array of 0 int
      	sCodeLine is string
      	r is int
      	sCodeNeu is string
      	sSource is string
      	cc is int
      	nCountType is int
      	bFound is boolean
      	sSwitchVariable is string
      	sIFVariable is string
      	sForVariable is string
      	sForLoopVariable is string
      	sVariable is string
      	arrLooperVariables is dynamic array of 0 string
      	sVariableList is string
      	sCodeVariable is string
      	sIncludeCode is string
      	garrSourceTree is dynamic array of 0 STSourceTree
      	m is int
      	
      ArrayDeleteAll(garrSourceTree)
      sCodeNeu=sTemplateSource
      
      //Alle LF's in CRLF umwandeln, sollte unser Problem lösen ^^
      sCodeNeu=Replace(sCodeNeu,Charact(13),"")
      sCodeNeu=replace(sCodeNeu,Charact(10),crlf)
      
      //Alle \{ und \} maskieren und nachher wieder herstellen!
      sCodeNeu=Replace(sCodeNeu,"~{","«²»")
      sCodeNeu=Replace(sCodeNeu,"~}","«³»")
      
      FOR i=1 TO StringCount(sCodeNeu,CRLF)+1
      	sCodeLine=ExtractString(sCodeNeu,i,CRLF)
      	IF GetTokenCount(sCodeLine)>0 THEN
      		
      		//Leerzeichen vorher rauslöschen
      		r=0
      		FOR n=1 to Length(sCodeLine)
      			IF Middle(sCodeLine,n,1)=Charact(32) OR Middle(sCodeLine,n,1)=Charact(9) THEN
      				r++
      			ELSE
      				//Anderes Zeichen gefunden, daher raus
      				BREAK
      			END
      		END
      		IF r>0 THEN
      			sCodeLine=Middle(sCodeLine,r+1)
      		END
      	END
      	
      	//Kommentare rauslöschen
      	if Template.TemplateCommentChar<>null and Template.TemplateCommentChar<>"" then
      		IF Left(sCodeLine,Length(Template.TemplateCommentChar))<>Template.TemplateCommentChar THEN
      			//Letztes CRLF verhindern
      			IF i<StringCount(sCodeNeu,CRLF)+1 THEN
      				sCode=sCode+sCodeLine+CRLF
      			ELSE
      				sCode=sCode+sCodeLine
      			END
      		end
      	else
      		//Letztes CRLF verhindern
      		IF i<StringCount(sCodeNeu,CRLF)+1 THEN
      			sCode=sCode+sCodeLine+CRLF
      		ELSE
      			sCode=sCode+sCodeLine
      		END
      	END
      END
      
      zz=1
      LOOP
      	IF FindKeyWord(zz,sCode,nLoopIndex, nLoopEndPos) THEN
      		bAscOpen=False
      		//if nLoopIndex=19 then stop
      		SWITCH arrKeyWord[nLoopIndex].nType
      			CASE 1
      				IF arrKeyWord[nLoopIndex].nVaterId=0 THEN
      					vz++
      					Dimension(garrSourceTree,vz)
      					garrSourceTree[vz].sSource=Middle(sCode,zz,nLoopEndPos)
      					garrSourceTree[vz].nID=Dimension(garrSourceTree)
      					garrSourceTree[vz].nVaterID=GetIntend(arrIntend)
      					garrSourceTree[vz].nType=nLoopIndex
      					garrSourceTree[vz].bFinal=arrKeyWord[nLoopIndex].bFinal
      					garrSourceTree[vz].nIdent=cc
      					Dimension(arrIntend,Dimension(arrIntend)+1)
      					arrIntend[Dimension(arrIntend)]=vz
      					cc++
      				ELSE
      					IF arrKeyWord[nLoopIndex].bFinal THEN
      						ArrayDelete(arrIntend,Dimension(arrIntend))
      						cc--
      					END
      					vz++
      					Dimension(garrSourceTree,vz)
      					garrSourceTree[vz].sSource=Middle(sCode,zz,nLoopEndPos)
      					garrSourceTree[vz].nID=Dimension(garrSourceTree)
      					garrSourceTree[vz].nVaterID=GetIntend(arrIntend)
      					garrSourceTree[vz].nType=nLoopIndex
      					garrSourceTree[vz].bFinal=arrKeyWord[nLoopIndex].bFinal
      					garrSourceTree[vz].nIdent=cc
      				END
      				//if left(garrSourceTree[vz].sSource,7)="{endif}" then stop
      				if arrKeyWord[nLoopIndex].bNoCrLf then
      					if Right(garrSourceTree[vz].sSource,2)=crlf then
      						garrSourceTree[vz].sSource=left(garrSourceTree[vz].sSource,Length(garrSourceTree[vz].sSource)-2)
      					END
      				end
      			CASE 2
      				vz++
      				Dimension(garrSourceTree,vz)
      				garrSourceTree[vz].sSource=Middle(sCode,zz,nLoopEndPos)
      				garrSourceTree[vz].nID=Dimension(garrSourceTree)
      				garrSourceTree[vz].nVaterID=GetIntend(arrIntend)
      				garrSourceTree[vz].nType=nLoopIndex
      				garrSourceTree[vz].bFinal=arrKeyWord[nLoopIndex].bFinal
      				garrSourceTree[vz].nIdent=cc
      				IF arrKeyWord[nLoopIndex].bNoCrLf THEN
      					IF Right(garrSourceTree[vz].sSource,2)=CRLF THEN
      						garrSourceTree[vz].sSource=Left(garrSourceTree[vz].sSource,Length(garrSourceTree[vz].sSource)-2)
      					END
      				end
      			CASE 3
      				vz++
      				Dimension(garrSourceTree,vz)
      				garrSourceTree[vz].sSource=Middle(sCode,zz,nLoopEndPos)
      				garrSourceTree[vz].nID=Dimension(garrSourceTree)
      				garrSourceTree[vz].nVaterID=GetIntend(arrIntend)
      				garrSourceTree[vz].nType=nLoopIndex
      				garrSourceTree[vz].bFinal=arrKeyWord[nLoopIndex].bFinal
      				garrSourceTree[vz].nIdent=cc
      				IF arrKeyWord[nLoopIndex].bNoCrLf THEN
      					IF Right(garrSourceTree[vz].sSource,2)=CRLF THEN
      						garrSourceTree[vz].sSource=Left(garrSourceTree[vz].sSource,Length(garrSourceTree[vz].sSource)-2)
      					END
      				end
      		END
      		zz=zz+nLoopEndPos
      	ELSE
      		IF NOT bAscOpen THEN
      			vz++
      			Dimension(garrSourceTree,vz)
      			garrSourceTree[vz].sSource=Middle(sCode,zz,1)
      			garrSourceTree[vz].nID=Dimension(garrSourceTree)
      			garrSourceTree[vz].nVaterID=GetIntend(arrIntend)
      			garrSourceTree[vz].nType=0
      			garrSourceTree[vz].bFinal=True
      			garrSourceTree[vz].nIdent=cc
      			bAscOpen=True
      		ELSE
      			garrSourceTree[vz].sSource=garrSourceTree[vz].sSource+Middle(sCode,zz,1)
      			IF Right(garrSourceTree[vz].sSource,2)=CRLF THEN
      				bAscOpen=False
      			END
      		END
      		zz=zz+1
      	END
      	IF zz>Length(sCode) THEN 
      		bAscOpen=False
      		ArrayDeleteAll(arrIntend)
      		BREAK
      	END
      END
      
      if not bRecursive then
      	sSource+="LOCAL"+CRLF
      	sSource+="    res is string"+CRLF
      	sSource+="    nCountItems is int, useful"+CRLF
      	sSource+="    nCountForeignCount is int, useful"+CRLF
      	sSource+="    nCountForeignItems is int, useful"+CRLF
      	sSource+="    nCountFileItems is int, useful"+CRLF
      	sSource+="    nCountItemsNoKey is int, useful"+crlf
      	sSource+="    nCountItemsNoKeyAll is int, useful"+CRLF
      	sSource+="    nCountItemsNoBlob is int, useful"+CRLF
      	sSource+="    nCountItemsBlob is int, useful"+CRLF
      	sSource+="    nCountKeys is int, useful"+CRLF
      	sSource+="    nCountKeysSecond is int, useful"+CRLF
      	sSource+="    nCountSegment is int, useful"+crlf
      	sSource+="    nCountItemDetails is int, useful"+CRLF
      	sSource+="    nCountItemDetailsNoKey is int, useful"+CRLF
      	sSource+="    nCountLanguages is int, useful"+crlf
      	sSource+="    nCountSearchKeys is int, useful"+CRLF
      	sSource+="    bFound is boolean, useful"+crlf+crlf
      	sSource+="WHEN EXCEPTION IN"+CRLF
      END
      sSource+="{VARPLACEHOLDER}"
      sSource+=CRLF
      
      m=Dimension(garrSourceTree)
      FOR i=1 TO m
      	IF garrSourceTree[i].nType>0 THEN
      		SWITCH arrKeyWord[garrSourceTree[i].nType].nType
      			CASE 1
      				SWITCH garrSourceTree[i].nType
      					CASE 1
      						//IF String
      						garrSourceTree[i].sSource="SWITCH "+GetArrayName(nCountType, sForLoopVariable)+".nType"+CRLF
      						garrSourceTree[i].sSource+=RepeatString("    ",garrSourceTree[i].nIdent+1)+"CASE CASE 13,14,16,18 to 38"+CRLF
      						garrSourceTree[i].sSource+=RepeatString("    ",1)
      					CASE 2
      						//End IF String
      						garrSourceTree[i].sSource="END"+CRLF
      					CASE 3
      						//AutoID
      						garrSourceTree[i].sSource="bFound=false"+crlf
      						garrSourceTree[i].sSource+="FOR nCountKeysSecond=1 TO vProjektVars.nMaxKeys"+crlf
      						garrSourceTree[i].sSource+="	IF arrKeys.arrFieldName[nCountKeysSecond]="+GetArrayName(nCountType, sForLoopVariable)+".sName THEN"+crlf
      						garrSourceTree[i].sSource+="		bFound=true"+crlf
      						garrSourceTree[i].sSource+="	END"+crlf
      						garrSourceTree[i].sSource+="END"+crlf
      						garrSourceTree[i].sSource+="IF bFound then"+crlf
      					CASE 4
      						//Ende AutoID
      						garrSourceTree[i].sSource="END"+CRLF
      					CASE 5
      						//NOT AutoID
      						garrSourceTree[i].sSource="bFound=false"+CRLF
      						garrSourceTree[i].sSource+="FOR nCountKeysSecond=1 TO vProjektVars.nMaxKeys"+CRLF
      						garrSourceTree[i].sSource+="	IF arrKeys.arrFieldName[nCountKeysSecond]="+GetArrayName(nCountType, sForLoopVariable)+".sName THEN"+CRLF
      						garrSourceTree[i].sSource+="		bFound=true"+CRLF
      						garrSourceTree[i].sSource+="	END"+CRLF
      						garrSourceTree[i].sSource+="END"+CRLF
      						garrSourceTree[i].sSource+="IF NOT bFound THEN"+CRLF
      					CASE 6
      						//Ende AutoID
      						garrSourceTree[i].sSource="END"+CRLF
      					CASE 7
      						//SWITCH
      						bFound=False
      						FOR n=1 to Dimension(arrKeyWord)
      							IF arrKeyWord[n].nType=2 THEN
      								IF Position(garrSourceTree[i].sSource,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      									sSwitchVariable=GetArrayType2(n ,nCountType, sForLoopVariable)
      									IF sSwitchVariable<>"" THEN
      										garrSourceTree[i].sSource="SWITCH "+sSwitchVariable+CRLF
      										bFound=True
      									END
      								END
      							END
      						END
      						IF NOT bFound THEN
      							//Nicht gefunden übernehmen
      							sSwitchVariable=Middle(garrSourceTree[i].sSource,9,Length(garrSourceTree[i].sSource)-9)
      							garrSourceTree[i].sSource="SWITCH "+sSwitchVariable+CRLF
      						END
      					CASE 8
      						//Case % lassen
      						sSwitchVariable=Middle(garrSourceTree[i].sSource,7,Length(garrSourceTree[i].sSource)-7)
      						garrSourceTree[i].sSource="CASE "+sSwitchVariable+CRLF
      					CASE 9
      						//OTHER CASE
      						garrSourceTree[i].sSource="OTHER CASE"+CRLF
      					CASE 10
      						//END CASE
      						garrSourceTree[i].sSource="END"+CRLF
      					CASE 11
      						//IF %
      						sSwitchVariable=Middle(garrSourceTree[i].sSource,4,Length(garrSourceTree[i].sSource)-4)
      						LOOP
      							bFound=False
      							FOR n=1 to Dimension(arrKeyWord)
      								IF arrKeyWord[n].nType=2 THEN
      									IF Position(sSwitchVariable,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      										sIFVariable=GetArrayType2(n ,nCountType, sForLoopVariable)
      										IF sIFVariable<>"" THEN
      											sIFVariable=sIFVariable
      											sSwitchVariable=Replace(sSwitchVariable,arrKeyWord[n].sKeyWord,sIFVariable)
      											bFound=True
      											BREAK
      										END
      									END
      								END
      							END
      							IF NOT bFound THEN
      								BREAK
      							END
      						END
      						garrSourceTree[i].sSource="IF "+sSwitchVariable+" THEN"+CRLF
      					CASE 12
      						//ELSE IF %
      						sSwitchVariable=Middle(garrSourceTree[i].sSource,9,Length(garrSourceTree[i].sSource)-9)
      						LOOP
      							bFound=False
      							FOR n=1 to Dimension(arrKeyWord)
      								IF arrKeyWord[n].nType=2 THEN
      									IF Position(sSwitchVariable,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      										sIFVariable=GetArrayType2(n ,nCountType, sForLoopVariable)
      										IF sIFVariable<>"" THEN
      											sIFVariable=sIFVariable
      											sSwitchVariable=Replace(sSwitchVariable,arrKeyWord[n].sKeyWord,sIFVariable)
      											bFound=True
      											BREAK
      										END
      									END
      								END
      							END
      							IF NOT bFound THEN
      								BREAK
      							END
      						END
      						garrSourceTree[i].sSource="ELSE IF "+sSwitchVariable+CRLF
      					CASE 13
      						//ELSE
      						garrSourceTree[i].sSource="ELSE"+CRLF
      					CASE 14
      						//END IF
      						garrSourceTree[i].sSource="END"+CRLF
      					CASE 15
      						//FOR
      						IF Position(garrSourceTree[i].sSource,"{nmaxitems}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountItems=1 TO vProjektVars.nMaxItems"+CRLF
      							nCountType=1
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxitemsnokey}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountItemsNoKey=1 TO vProjektVars.nMaxItemsNoKey"+CRLF
      							nCountType=2
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxitemsnokeyall}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource	= "FOR nCountItemsNoKeyAll=1 TO vProjektVars.nMaxItemsNoKeyAll"+CRLF
      							nCountType = 12
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxforeignkeys}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountForeignCount=1 TO vProjektVars.nMaxForeignKeys"+CRLF
      							nCountType=3
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxforeignitems}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountForeignItems=1 TO arrForeignKey[nCountForeignCount].nMaxForeignKeys"+CRLF
      							nCountType=4
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxitemsmasterdetail}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountItemDetails=1 TO vProjektVars.nMaxItemsMasterDetail"+CRLF
      							nCountType=5
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxitemsmasterdetailnokey}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountItemDetailsNoKey=1 TO vProjektVars.nMaxItemsMasterDetailNoKey"+CRLF
      							nCountType=6
      						else IF Position(garrSourceTree[i].sSource,"{nmaxfiles}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountFileItems=1 TO vProjektVars.nMaxFiles"+CRLF
      							nCountType=7
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxkeys}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountKeys=1 TO vProjektVars.nMaxKeys"+CRLF
      							nCountType=8
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxkeyssegment}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountSegment=1 TO dimension(arrKeys[nCountKeys].arrFields)"+CRLF
      							nCountType=9
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxlanguages}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountLanguages=1 TO vProjektVars.nMaxLanguages"+CRLF
      							nCountType=10
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxsearchkeys}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountSearchKeys=1 TO vProjektVars.nMaxSearchKeys"+CRLF
      							nCountType=13
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxitemsnoblob}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountItemsNoBlob=1 TO vProjektVars.nMaxItemsNoBlob"+CRLF
      							nCountType=14
      						ELSE IF Position(garrSourceTree[i].sSource,"{nmaxitemsblob}",1,IgnoreCase)>0 THEN
      							garrSourceTree[i].sSource="FOR nCountItemsBlob=1 TO vProjektVars.nMaxItemsBlob"+CRLF
      							nCountType=15
      						else
      							sForVariable=Middle(garrSourceTree[i].sSource,6,Length(garrSourceTree[i].sSource)-6)
      							garrSourceTree[i].sSource="FOR "+sForVariable+CRLF
      							nCountType=11
      							sForLoopVariable=ExtractString(sForVariable,1,"=")
      							switch sForLoopVariable
      								case "i"
      									//Diese Variable wird nicht deklariert, weil vorhanden!
      								OTHER CASE
      									//Suchen nach vorhandenen Variablen
      									if Position(sForLoopVariable,"{")>0 or Position(sForLoopVariable,"}")>0 then
      										error(<§$0014§>+sForLoopVariable)
      										result false
      									END
      									n=ArraySeek(arrLooperVariables,asLinearFirst,sForLoopVariable)
      									IF n=-1 THEN
      										Dimension(arrLooperVariables, Dimension(arrLooperVariables)+1)
      										arrLooperVariables[Dimension(arrLooperVariables)]=sForLoopVariable
      									END
      							END
      						END
      					CASE 16
      						//END FOR
      						garrSourceTree[i].sSource="END"+CRLF
      					CASE 17
      						//WHILE
      					CASE 18
      						//END WHILE
      					case 19
      						//{code: %}
      						sCodeVariable=Middle(garrSourceTree[i].sSource,7,Length(garrSourceTree[i].sSource)-7)
      						if right(sCodeVariable,1)=Charact(13) then
      							sCodeVariable=left(sCodeVariable,Length(sCodeVariable)-1)
      						END
      						IF Right(sCodeVariable,1)="}" THEN
      							sCodeVariable=Left(sCodeVariable,Length(sCodeVariable)-1)
      						END
      						LOOP
      							bFound=False
      							FOR n=1 TO Dimension(arrKeyWord)
      								IF arrKeyWord[n].nType=2 THEN
      									IF Position(sCodeVariable,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      										sIFVariable=GetArrayType2(n, nCountType, sForLoopVariable)
      										IF sIFVariable<>"" THEN
      											sCodeVariable=Replace(sCodeVariable,arrKeyWord[n].sKeyWord,sIFVariable)
      											bFound=True
      											BREAK
      										END
      									END
      								END
      							END
      							IF NOT bFound THEN
      								BREAK
      							END
      						END
      
      						LOOP
      							bFound=false
      
      							FOR n=1 TO Dimension(arrKeyWord)
      								IF arrKeyWord[n].nType=3 THEN
      									IF Position(sCodeVariable,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      										sSwitchVariable="arrTemplateVars[arrKeyWord["+NumToString(n,"d")+"].sCodeWord].arrContent[nCountLanguage].sContent"
      										IF sSwitchVariable<>"" THEN
      											sCodeVariable=Replace(sCodeVariable,arrKeyWord[n].sKeyWord,sSwitchVariable)
      											bFound=True
      											BREAK
      										END
      									END
      								END
      							END
      							
      							IF NOT bFound THEN
      								BREAK
      							END
      						END
      						garrSourceTree[i].sSource=sCodeVariable+CRLF
      					CASE 20
      						//{include: %}
      						n=Position(garrSourceTree[i].sSource,"}")
      						sCodeVariable=Middle(garrSourceTree[i].sSource,11,n-11)
      						sCodeVariable=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)+sCodeVariable
      						sIncludeCode=fLoadText(sCodeVariable)
      						sIncludeCode=GetSourceCode(sIncludeCode,true)
      						garrSourceTree[i].sSource=sIncludeCode+CRLF
      					OTHER CASE
      				END
      				sSource+=RepeatString("    ",garrSourceTree[i].nIdent)+AddSource(garrSourceTree[i].sSource, True)
      			CASE 2
      				bFound=false
      				FOR n=1 to Dimension(arrKeyWord)
      					IF arrKeyWord[n].nType=2 THEN
      						IF Position(garrSourceTree[i].sSource,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      							sSwitchVariable=GetArrayType2(n ,nCountType, sForLoopVariable)
      							IF sSwitchVariable<>"" THEN
      								garrSourceTree[i].sSource=sSwitchVariable
      								bFound=True
      								break
      							END
      						END
      					END
      				END
      				IF NOT bFound THEN
      					switch arrKeyWord[garrSourceTree[i].nType].sKeyWord
      						case "{var: %}"
      							sVariable=Middle(garrSourceTree[i].sSource,7,Length(garrSourceTree[i].sSource)-7)
      							garrSourceTree[i].sSource=sVariable
      							sSource+=RepeatString("    ",garrSourceTree[i].nIdent)+"res=res+"+AddSource(garrSourceTree[i].sSource)+CRLF
      						other case
      							info("Nicht gefunden: "+arrKeyWord[garrSourceTree[i].nType].sKeyWord)
      					END
      				else
      					sSource+=RepeatString("    ",garrSourceTree[i].nIdent)+"res=res+"+AddSource(garrSourceTree[i].sSource)+CRLF
      				END
      			CASE 3
      				bFound=False
      				FOR n=1 TO Dimension(arrKeyWord)
      					IF arrKeyWord[n].nType=3 THEN
      						IF Position(garrSourceTree[i].sSource,arrKeyWord[n].sKeyWord,1,IgnoreCase)>0 THEN
      							sSwitchVariable="arrTemplateVars[arrKeyWord["+NumToString(n,"d")+"].sCodeWord].arrContent[nCountLanguage].sContent"
      							IF sSwitchVariable<>"" THEN
      								garrSourceTree[i].sSource=sSwitchVariable
      								bFound=True
      								BREAK
      							END
      						END
      					END
      				END
      				sSource+=RepeatString("    ",garrSourceTree[i].nIdent)+"res=res+"+AddSource(garrSourceTree[i].sSource)+CRLF
      		END
      	ELSE
      		sSource+=RepeatString("    ",garrSourceTree[i].nIdent)+"res=res+"+Charact(34)+AddSource(garrSourceTree[i].sSource)+Charact(34)+CRLF
      	END
      END
      
      sVariableList=""
      for i=1 to Dimension(arrLooperVariables)
      	sVariableList=sVariableList+"    "+arrLooperVariables[i]+" is int"+crlf
      END
      
      sSource=replace(sSource,"{VARPLACEHOLDER}",sVariableList)
      
      if not bRecursive then
      	sSource+=CRLF+"RESULT res"+CRLF
      	sSource+="DO"+crlf
      	sSource+="    RESULT "+Charact(34)+"Error:"+Charact(34)+"+ExceptionInfo(errFullDetails)"+crlf
      	sSource+="END"+crlf
      end
      
      
      sSource=Replace(sSource,"+"+Charact(34)+Charact(34),"")
      
      //Alle \{ und \} maskieren und nachher wieder herstellen!
      sSource=Replace(sSource,"«²»","{")
      sSource=Replace(sSource,"«³»","}")
      
      RESULT sSource
      
      
     type : 458752
   -
     name : FillTemplatePageFiles
     procedure_id : 1533232251590020991
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] FillTemplatePageFiles (<nProjectID>, <nTemplatePage>, <nVersionID>, <arrTemplates>)
      //
      // Parameters:
      //	nProjectID: <specify the role of nProjectID>
      //	nTemplatePage: <specify the role of nTemplatePage>
      //	nVersionID: <specify the role of arrFiles>
      //	arrTemplates: <specify the role of arrFiles>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FillTemplatePageFiles(nProjectID, nTemplatePage, nVersionID, arrTemplates)
      
      local
      	nMaxFiles is int
      	n is int
      	
      hreadseek(Project,ProjectID,nProjectID,hIdentical)
      if not hfound(Project) then
      	error(<§$002e§>)
      	result false
      END
      
      hreadseek(TemplatePage,TemplatePageID,nTemplatePage,hIdentical)
      if not hfound(TemplatePage) then
      	error(<§$002f§>)
      	result false
      END
      
      hreadseek(Version,VersionID,nVersionID,hIdentical)
      IF NOT HFound(Version) THEN
      	Error(<§$0030§>)
      	RESULT False
      END
      
      hfilter(DataFile,DataFileSortKey,HBuildKeyValue(DataFile,DataFileSortKey,version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMaxVal))
      hreadfirst(DataFile,DataFileSortKey)
      while not hout(DataFile)
      	IF DataFile.DataFileGenerate THEN
      		HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TemplatePage.TemplatePageID),hIdentical)
      		if hfound(DataFileTypeDetails) then
      			if DataFileTypeDetails.FileGenerate then
      				nMaxFiles++
      				Dimension(arrTemplates.arrFiles,nMaxFiles)
      				arrTemplates.arrFiles[nMaxFiles].nFileId=DataFile.DataFileID
      				arrTemplates.arrFiles[nMaxFiles].sFileName=DataFile.FileName
      				arrTemplates.arrFiles[nMaxFiles].sFileNameShort=DataFile.FileNameShort
      				arrTemplates.arrFiles[nMaxFiles].bGenerateMasterDetail=DataFile.GenerateMasterDetail
      				arrTemplates.arrFiles[nMaxFiles].sDetailFileID=DataFile.DetailFileID
      				arrTemplates.arrFiles[nMaxFiles].sKeyName=DataFile.KeyName
      				arrTemplates.arrFiles[nMaxFiles].sSearchKeys=DataFile.AdditionalSearchFields
      				n=HSavePosition(DataFile)
      				HReadSeek(DataFile,DataFileID,DataFile.DetailFileID,hIdentical)
      				IF HFound(DataFile) THEN
      					arrTemplates.arrFiles[nMaxFiles].sDetailFileName=DataFile.FileName
      				END
      				HRestorePosition(n)
      				arrTemplates.arrFiles[nMaxFiles].sDetailFileKey=DataFile.DetailKeyName
      				FillItems(DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles],TemplatePage.TemplatePageID)
      				FillItemsNoKey(DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles],TemplatePage.TemplatePageID)
      				FillItemsNoKeyAll(DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles],TemplatePage.TemplatePageID)
      				FillItemsNoBlob(DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles],TemplatePage.TemplatePageID)
      				FillItemsBlob(DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles],TemplatePage.TemplatePageID)
      				FillKeys(DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles])
      				FillForeignKeys(nVersionID, DataFile.DataFileID, arrTemplates.arrFiles[nMaxFiles])
      				FillFileTranslation(DataFile.DataFileID, nTemplatePage, arrTemplates.arrFiles[nMaxFiles])
      			END
      		else
      			//Error!!!
      		end
      	END
      	hreadnext(DataFile,DataFileSortKey)
      END
      
      RESULT true
     type : 458752
   -
     name : FillItems
     procedure_id : 1534155536382318552
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //FillItems (<nDataFileID>, <arrFiles>, <nTemplatePageID>)
      //
      // Parameters:
      //	nDataFileID: <specify the role of nDataFileID>
      //	arrFiles: <specify the role of nTemplatePageID>
      //	nTemplatePageID: <specify the role of arrFiles>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	arrFiles: <specify the role of arrFiles>
      PROCEDURE FillItems(nDataFileID, arrFiles, nTemplatePageID)
      
      local
      	nMaxItems is int
      	nMaxLanguages is int
      	
      HFilter(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMinVal),HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMaxVal))
      HReadFirst(DataItems,DataItemsKey)
      WHILE NOT HOut(DataItems)
      	HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,nTemplatePageID),hIdentical)
      	IF HFound(DataItemsTypeDetails) THEN
      		IF DataItemsTypeDetails.ItemGenerate THEN
      			hreadseek(DataFile,DataFileID,DataItems.DataFileID,hIdentical)
      			nMaxItems++
      			Dimension(arrFiles.arrItems,nMaxItems)
      			arrFiles.arrItems[nMaxItems].nDataItemsID=DataItems.DataItemsID
      			arrFiles.arrItems[nMaxItems].nDataFileID=DataItems.DataFileID
      			arrFiles.arrItems[nMaxItems].nVersionID=DataItems.VersionID
      			arrFiles.arrItems[nMaxItems].sFileName=DataFile.FileName
      			arrFiles.arrItems[nMaxItems].sItemName=DataItems.ItemName
      			arrFiles.arrItems[nMaxItems].sItemNameRenamed=DataItems.sItemNameRenamed
      			arrFiles.arrItems[nMaxItems].nType=DataItems.Type
      			arrFiles.arrItems[nMaxItems].sTypeCast=DataItems.TypeCast
      			arrFiles.arrItems[nMaxItems].sSize=DataItems.Size
      			arrFiles.arrItems[nMaxItems].nKeyType=DataItems.KeyType
      			arrFiles.arrItems[nMaxItems].bNotNull=DataItems.bNotNull
      			arrFiles.arrItems[nMaxItems].bAutoIncrement=DataItems.AutoIncrement
      			arrFiles.arrItems[nMaxItems].sDefault=DataItems.sDefault
      			arrFiles.arrItems[nMaxItems].bUnsigned=DataItems.bUnsigned
      			arrFiles.arrItems[nMaxItems].nControlType=DataItems.ControlType
      			arrFiles.arrItems[nMaxItems].sWinDevType=DataItems.WinDevType
      			arrFiles.arrItems[nMaxItems].sWinDevTypePlain=DataItems.WinDevTypePlain
      			arrFiles.arrItems[nMaxItems].Data_Type=DataItems.Data_Type
      			arrFiles.arrItems[nMaxItems].DB_Data_Type=DataItems.DB_Data_Type
      			
      			arrFiles.arrItems[nMaxItems].nDataItemsTypeDetailsID=DataItemsTypeDetails.DataItemsTypeDetailsID
      			arrFiles.arrItems[nMaxItems].nTemplatePageID=DataItemsTypeDetails.TemplatePageID
      			arrFiles.arrItems[nMaxItems].sEditMask=DataItemsTypeDetails.EditMask
      			arrFiles.arrItems[nMaxItems].nSortIndex=DataItemsTypeDetails.SortIndex
      			arrFiles.arrItems[nMaxItems].nX=DataItemsTypeDetails.X
      			arrFiles.arrItems[nMaxItems].nY=DataItemsTypeDetails.Y
      			arrFiles.arrItems[nMaxItems].bItemVisible=DataItemsTypeDetails.ItemVisible
      			arrFiles.arrItems[nMaxItems].nItemState=DataItemsTypeDetails.ItemState
      			arrFiles.arrItems[nMaxItems].bItemGenerate=DataItemsTypeDetails.ItemGenerate
      
      			//DataItemsID+TemplatePageID+LanguageID
      			HFilter(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMinVal),HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMaxVal))
      			HReadFirst(DataItemsTranslation,DataItemsTranslationKey)
      			WHILE NOT HOut(DataItemsTranslation)
      				arrFiles.arrItems[nMaxItems].nMaxLanguage++
      				nMaxLanguages=arrFiles.arrItems[nMaxItems].nMaxLanguage
      				Dimension(arrFiles.arrItems[nMaxItems].arrCaption,nMaxLanguages)
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].nDataItemsTranslationID=DataItemsTranslation.DataItemsTranslationID
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].nDataItemsID=DataItemsTranslation.DataItemsID
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].nVersionID=DataItemsTranslation.VersionID
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].nTemplatePageID=DataItemsTranslation.TemplatePageID
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].nLanguageID=DataItemsTranslation.LanguageID
      				hreadseek(Language,LanguageID,DataItemsTranslation.LanguageID,hIdentical)
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].sDescription=Language.Description
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].sToken=Language.Token
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].sSourceToken=Language.SourceToken
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].sCaption=DataItemsTranslation.Caption
      				arrFiles.arrItems[nMaxItems].arrCaption[nMaxLanguages].sComboBoxContent=DataItemsTranslation.ComboBoxContent
      				HReadNext(DataItemsTranslation,DataItemsTranslationKey)
      			END
      			HDeactivateFilter(DataItemsTranslation)
      		END
      	END
      	HReadNext(DataItems,DataItemsKey)
      END
      HDeactivateFilter(DataItems)
      
      arraysort(arrFiles.arrItems,asMember,"+nSortIndex")
     type : 458752
   -
     name : FillItemsNoKey
     procedure_id : 1534176581724807051
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //FillItemsNoKey (<nDataFileID>, <arrFiles>, <nTemplatePageID>)
      //
      // Parameters:
      //	nDataFileID: <specify the role of nDataFileID>
      //	arrFiles: <specify the role of nTemplatePageID>
      //	nTemplatePageID: <specify the role of arrFiles>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	arrFiles: <specify the role of arrFiles>
      PROCEDURE FillItemsNoKey(nDataFileID, arrFiles, nTemplatePageID)
      
      local
      	nMaxItems is int
      	nMaxLanguages is int
      	
      HFilter(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMinVal),HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMaxVal))
      HReadFirst(DataItems,DataItemsKey)
      WHILE NOT HOut(DataItems)
      	HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,nTemplatePageID),hIdentical)
      	IF HFound(DataItemsTypeDetails) THEN
      		IF DataItemsTypeDetails.ItemGenerate THEN
      			if DataItems.KeyType<>4 then
      				nMaxItems++
      				Dimension(arrFiles.arrItemsNoKey,nMaxItems)
      				arrFiles.arrItemsNoKey[nMaxItems].nDataItemsID=DataItems.DataItemsID
      				arrFiles.arrItemsNoKey[nMaxItems].nDataFileID=DataItems.DataFileID
      				arrFiles.arrItemsNoKey[nMaxItems].sFileName=DataFile.FileName
      				arrFiles.arrItemsNoKey[nMaxItems].nVersionID=DataItems.VersionID
      				arrFiles.arrItemsNoKey[nMaxItems].sItemName=DataItems.ItemName
      				arrFiles.arrItemsNoKey[nMaxItems].sItemNameRenamed=DataItems.sItemNameRenamed
      				arrFiles.arrItemsNoKey[nMaxItems].nType=DataItems.Type
      				arrFiles.arrItemsNoKey[nMaxItems].sTypeCast=DataItems.TypeCast
      				arrFiles.arrItemsNoKey[nMaxItems].sSize=DataItems.Size
      				arrFiles.arrItemsNoKey[nMaxItems].nKeyType=DataItems.KeyType
      				arrFiles.arrItemsNoKey[nMaxItems].bNotNull=DataItems.bNotNull
      				arrFiles.arrItemsNoKey[nMaxItems].bAutoIncrement=DataItems.AutoIncrement
      				arrFiles.arrItemsNoKey[nMaxItems].sDefault=DataItems.sDefault
      				arrFiles.arrItemsNoKey[nMaxItems].bUnsigned=DataItems.bUnsigned
      				arrFiles.arrItemsNoKey[nMaxItems].nControlType=DataItems.ControlType
      				arrFiles.arrItemsNoKey[nMaxItems].sWinDevType=DataItems.WinDevType
      				arrFiles.arrItemsNoKey[nMaxItems].sWinDevTypePlain=DataItems.WinDevTypePlain
      				arrFiles.arrItemsNoKey[nMaxItems].Data_Type=DataItems.Data_Type
      				arrFiles.arrItemsNoKey[nMaxItems].DB_Data_Type=DataItems.DB_Data_Type
      				arrFiles.arrItemsNoKey[nMaxItems].nDataItemsTypeDetailsID=DataItemsTypeDetails.DataItemsTypeDetailsID
      				arrFiles.arrItemsNoKey[nMaxItems].nTemplatePageID=DataItemsTypeDetails.TemplatePageID
      				arrFiles.arrItemsNoKey[nMaxItems].sEditMask=DataItemsTypeDetails.EditMask
      				arrFiles.arrItemsNoKey[nMaxItems].nSortIndex=DataItemsTypeDetails.SortIndex
      				arrFiles.arrItemsNoKey[nMaxItems].nX=DataItemsTypeDetails.X
      				arrFiles.arrItemsNoKey[nMaxItems].nY=DataItemsTypeDetails.Y
      				arrFiles.arrItemsNoKey[nMaxItems].bItemVisible=DataItemsTypeDetails.ItemVisible
      				arrFiles.arrItemsNoKey[nMaxItems].nItemState=DataItemsTypeDetails.ItemState
      				arrFiles.arrItemsNoKey[nMaxItems].bItemGenerate=DataItemsTypeDetails.ItemGenerate
      				
      				HFilter(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMinVal),HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMaxVal))
      				HReadFirst(DataItemsTranslation,DataItemsTranslationKey)
      				WHILE NOT HOut(DataItemsTranslation)
      					arrFiles.arrItemsNoKey[nMaxItems].nMaxLanguage++
      					nMaxLanguages=arrFiles.arrItemsNoKey[nMaxItems].nMaxLanguage
      					Dimension(arrFiles.arrItemsNoKey[nMaxItems].arrCaption,nMaxLanguages)
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].nDataItemsTranslationID=DataItemsTranslation.DataItemsTranslationID
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].nDataItemsID=DataItemsTranslation.DataItemsID
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].nVersionID=DataItemsTranslation.VersionID
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].nTemplatePageID=DataItemsTranslation.TemplatePageID
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].nLanguageID=DataItemsTranslation.LanguageID
      					HReadSeek(Language,LanguageID,DataItemsTranslation.LanguageID,hIdentical)
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].sDescription=Language.Description
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].sToken=Language.Token
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].sSourceToken=Language.SourceToken
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].sCaption=DataItemsTranslation.Caption
      					arrFiles.arrItemsNoKey[nMaxItems].arrCaption[nMaxLanguages].sComboBoxContent=DataItemsTranslation.ComboBoxContent
      					HReadNext(DataItemsTranslation,DataItemsTranslationKey)
      				END
      			end
      		END
      	END
      	HReadNext(DataItems,DataItemsKey)
      END
      
      HDeactivateFilter(DataItems)
      
      ArraySort(arrFiles.arrItemsNoKey,asMember,"+nSortIndex")
     type : 458752
   -
     name : FillKeys
     procedure_id : 1534308450101887881
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] FillKeys (<nDataFileID>, <arrFiles>)
      //
      // Parameters:
      // 	nDataFileID: <specify the role of nDataFileID>
      // 	arrFiles: <specify the role of arrFiles>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FillKeys(nDataFileID,arrFiles)
      
      local
      	n is int
      	bFound is boolean
      	nMaxKeys is int
      		
      HFilter(DataKeys,DataKeysKey,HBuildKeyValue(DataKeys,DataKeysKey,nDataFileID,hMinVal,hMinVal),HBuildKeyValue(DataKeys,DataKeysKey,nDataFileID,hMaxVal,hMaxVal))
      HReadFirst(DataKeys,DataKeysKey)
      WHILE NOT HOut(DataKeys)
      	bFound=True
      	HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,nDataFileID,DataKeys.Field),hIdentical)
      	IF HFound(DataItems) THEN
      		n=ArraySeek(arrFiles.arrKeys,asLinear,"sKeyName",DataKeys.KeyName)
      		IF n=-1 THEN
      			nMaxKeys++
      			Dimension(arrFiles.arrKeys,nMaxKeys)
      			Dimension(arrFiles.arrKeys[nMaxKeys].arrFields,1)
      			arrFiles.arrKeys[nMaxKeys].sKeyName=DataKeys.KeyName
      			arrFiles.arrKeys[nMaxKeys].nKeyType=DataKeys.KeyType
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].nID=DataKeys.DataKeysID
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].sFieldName=DataKeys.Field
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].nType=DataKeys.KeyType
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].sTypeCast=DataItems.TypeCast
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].Data_Type=DataItems.Data_Type
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].DB_Data_Type=DataItems.DB_Data_Type
      			arrFiles.arrKeys[nMaxKeys].arrFields[1].nSegment=DataKeys.Segment
      		ELSE
      			Dimension(arrFiles.arrKeys[nMaxKeys].arrFields,Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)+1)
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].nID=DataKeys.DataKeysID
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].sFieldName=DataKeys.Field
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].nType=DataKeys.KeyType
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].sTypeCast=DataItems.TypeCast
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].Data_Type=DataItems.Data_Type
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].DB_Data_Type=DataItems.DB_Data_Type
      			arrFiles.arrKeys[nMaxKeys].arrFields[Dimension(arrFiles.arrKeys[nMaxKeys].arrFields)].nSegment=DataKeys.Segment
      		END
      	ELSE
      		Error("Key not found "+DataKeys.Field+" in file "+DataFile.FileName)
      		RESULT False
      	END
      	HReadNext(DataKeys,DataKeysKey)
      END
      
      arrFiles.nMaxKeys=nMaxKeys
      HDeactivateFilter(DataKeys)
      
      RESULT true
     type : 458752
   -
     name : FillForeignKeys
     procedure_id : 1534309455124404031
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //FillForeignKeys (<nVersionID>, <nDataFileID>, <arrFiles>)
      //
      // Parameters:
      //	nVersionID: <specify the role of nDataFileID>
      //	nDataFileID: <specify the role of arrFiles>
      // 	arrFiles: <specify the role of arrFiles>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FillForeignKeys(nVersionID, nDataFileID,arrFiles)
      
      local
      	nForeignCount is int
      	nMaxForeignKey is int
      	nParentID is int on 8 bytes
      	nSaveDataFile is int on 8 bytes
      
      hreadseek(DataFile,DataFileID,nDataFileID,hIdentical)
      if hfound(DataFile) then
      	
      	nForeignCount=0
      	ArrayDeleteAll(arrFiles.arrKeysForeign)
      	//VersionID+Parent_Table+Parent_Item
      	HFilter(ForeignKey,ForeignChildKey,HBuildKeyValue(ForeignKey,ForeignChildKey, nVersionID, DataFile.FileName,hMinVal),HBuildKeyValue(ForeignKey,ForeignChildKey, nVersionID, DataFile.FileName,hMaxVal))
      	HReadFirst(ForeignKey,ForeignChildKey)
      	WHILE NOT HOut(ForeignKey)
      		nMaxForeignKey++
      		HReadNext(ForeignKey,ForeignChildKey)
      	END
      	
      	Dimension(arrFiles.arrKeysForeign,nMaxForeignKey)
      	arrFiles.nMaxKeysForeign=nMaxForeignKey
      	
      	HReadFirst(ForeignKey,ForeignChildKey)
      	WHILE NOT HOut(ForeignKey)
      		nForeignCount++
      		
      		arrFiles.arrKeysForeign[nForeignCount].sTablePlusItem=ForeignKey.Parent_Table+"."+ForeignKey.Parent_Item
      		arrFiles.arrKeysForeign[nForeignCount].sTableName=ForeignKey.Parent_Table
      		
      		//VersionID+FileName
      		nSaveDataFile=HSavePosition(DataFile)
      		hreadseek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nVersionID,ForeignKey.Parent_Table),hIdentical)
      		if hfound(DataFile) then
      			arrFiles.arrKeysForeign[nForeignCount].nTableID=DataFile.DataFileID
      			nParentID=DataFile.DataFileID
      		END
      		arrFiles.arrKeysForeign[nForeignCount].sItemName=ForeignKey.Parent_Item
      		
      		//DataFileID+ItemName
      		hreadseek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,nParentID,ForeignKey.Parent_Item),hIdentical)
      		if hfound(DataItems) then
      			arrFiles.arrKeysForeign[nForeignCount].nItemID=DataItems.DataItemsID
      		end
      		arrFiles.arrKeysForeign[nForeignCount].nItemDisplayId=ForeignKey.DisplayItemID
      		
      		if ForeignKey.DisplayItemID>0 then
      			HReadSeek(DataItems,DataItemsID,ForeignKey.DisplayItemID,hIdentical)
      			IF HFound(DataItems) THEN
      				arrFiles.arrKeysForeign[nForeignCount].sItemDisplay=DataItems.ItemName
      			end
      		end
      
      		IF ForeignKey.DisplaySortItemID>0 THEN
      			HReadSeek(DataItems,DataItemsID,ForeignKey.DisplaySortItemID,hIdentical)
      			IF HFound(DataItems) THEN
      				arrFiles.arrKeysForeign[nForeignCount].sItemSort=DataItems.ItemName
      			END
      		END
      		
      		HRestorePosition(nSaveDataFile)
      		hreadnext(ForeignKey,ForeignChildKey)
      	END
      	
      	HDeactivateFilter(ForeignKey)
      	
      end
     type : 458752
   -
     name : FillFileTranslation
     procedure_id : 1535674730739976520
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //FillFileTranslation (<nDataFileID>, <nTemplatePageID>, <arrFiles>)
      //
      // Parameters:
      //	nDataFileID: <specify the role of nDataFileID>
      //	nTemplatePageID: <specify the role of arrFiles>
      // 	arrFiles: <specify the role of arrFiles>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FillFileTranslation(nDataFileID,nTemplatePageID,arrFiles)
      
      LOCAL
      	nLanguageCount is int
      	
      HReadSeek(DataFile,DataFileID,nDataFileID,hIdentical)
      IF HFound(DataFile) THEN
      	
      	HReadFirst(Language,LanguageID)
      	while not hout(Language)
      		nLanguageCount++
      		Dimension(arrFiles.arrDataFileTranslation,nLanguageCount)
      		if Language.LanguageGenerate then
      			//DataFileID+TemplatePageID+LanguageID
      			hreadseek(DataFileTranslation,DataFileTranslationKey,HBuildKeyValue(DataFileTranslation,DataFileTranslationKey,nDataFileID,nTemplatePageID,Language.LanguageID),hIdentical)
      			if hfound(DataFileTranslation) then
      				arrFiles.arrDataFileTranslation[nLanguageCount].nDataFileTranslationID=DataFileTranslation.DataFileTranslationID
      				arrFiles.arrDataFileTranslation[nLanguageCount].nDataFileID=nDataFileID
      				arrFiles.arrDataFileTranslation[nLanguageCount].nVersionID=DataFile.VersionID
      				arrFiles.arrDataFileTranslation[nLanguageCount].nLanguageID=Language.LanguageID
      				arrFiles.arrDataFileTranslation[nLanguageCount].nTemplatePageID=nTemplatePageID
      				arrFiles.arrDataFileTranslation[nLanguageCount].sDescription=DataFileTranslation.Description
      			END
      		END
      		hreadnext(Language,LanguageID)
      	END
      
      END
     type : 458752
   -
     name : ValidateSource
     procedure_id : 1536951173546135228
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] ValidateSource (<sFileName>, <sTemplateSource>)
      //
      // Parameters:
      //	sFileName: <specify the role of sTemplateSource>
      // 	sTemplateSource: <specify the role of sTemplateSource>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE ValidateSource(sFileName, sTemplateSource)
      
      local
      	sKeyWord is string
      	zz is int
      	pp is int
      	m is int
      	o is int
      	
      m=Dimension(arrKeyWord)
      for i=1 to m
      	if arrKeyWord[i].nType=1 then
      		if Position(arrKeyWord[i].sKeyWord,"%") then
      			sKeyWord=left(arrKeyWord[i].sKeyWord,Position(arrKeyWord[i].sKeyWord," %"))
      		else
      			sKeyWord=arrKeyWord[i].sKeyWord
      		END
      		zz=0
      		pp=0
      		if not arrKeyWord[i].bFinal and arrKeyWord[i].nVaterId=0 then
      			zz=StringCount(sTemplateSource,sKeyWord)
      			o=Dimension(arrKeyWord)
      			for t=1 to o
      				if arrKeyWord[t].nVaterId=i and arrKeyWord[t].bFinal then
      					pp=StringCount(sTemplateSource,arrKeyWord[t].sKeyWord)
      					break
      				END
      			END
      		END
      		if zz<>pp then
      			info(arrKeyWord[i].sKeyWord+<§$0038§>+sFileName)
      			result false
      		END
      	END
      END
      
      result true
     type : 458752
   -
     name : FTPTransfer
     procedure_id : 1560079237430510008
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] FTPTransfer (<sPath>, <sFileName>, <nChange>, <nPointer>)
      //
      // Parameters:
      //	sPath: <specify the role of sPath>
      //	sFileName: <specify the role of sFileName>
      //	nChange: <specify the role of nChange>
      //	nPointer: <specify the role of nPointer>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      Procedure PRIVATE FTPTransfer(sPath, sFileName, nChange <useful>, nPointer <useful>)
      
      PRIVATE
      	bResult is boolean
      	bFTPDirResult is boolean
      	
      Multitask(-1)
      IF gbInterupt THEN
      	RESULT False
      END
      
      gsActualFile=sFileName
      gsActualDirectory=Replace(sPath,project.Directory,"")
      gsActualDirectory=Replace(gsActualDirectory,"\","/")
      
      bFTPDirResult=FTPCurrentDir(gnFTPConnection , SiteDefinition.RootDirectory+gsActualDirectory)
      IF NOT bFTPDirResult THEN
      	IF NOT FTPMakeDir(gnFTPConnection,SiteDefinition.RootDirectory+gsActualDirectory) THEN
      		IF YesNo(<§$003c§>+SiteDefinition.RootDirectory+gsActualDirectory+<§$003d§>+CRLF+CRLF+<§$003e§>)=Yes THEN
      			RESULT False
      		END
      	END
      END
      
      bResult = FTPSend(gnFTPConnection, sPath+sFileName, SiteDefinition.RootDirectory+gsActualDirectory, FTPProgressBar, ftpBinaryMode)
      IF NOT bResult THEN
      	IF YesNo(<§$0039§>+sPath+sFileName+<§$003a§>+CRLF+CRLF+<§$003b§>)=Yes THEN
      		RESULT False
      	END
      END
      
      RESULT True
     type : 458752
   -
     name : FillItemsNoKeyAll
     procedure_id : 2249827805243095953
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //FillItemsNoKeyAll (<nDataFileID>, <arrFiles>, <nTemplatePageID>)
      //
      // Parameters:
      //	nDataFileID: <specify the role of nDataFileID>
      //	arrFiles: <specify the role of nTemplatePageID>
      //	nTemplatePageID: <specify the role of arrFiles>
      // Return value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      // 	arrFiles: <specify the role of arrFiles>
      PROCEDURE FillItemsNoKeyAll(nDataFileID, arrFiles, nTemplatePageID)
      
      local
      	nMaxItems is int
      	nMaxLanguages is int
      
      hreadseek(DataFile,DataFileID,nDataFileID,hIdentical)
      
      HFilter(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMinVal),HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMaxVal))
      HReadFirst(DataItems,DataItemsKey)
      WHILE NOT HOut(DataItems)
      	HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,nTemplatePageID),hIdentical)
      	IF HFound(DataItemsTypeDetails) THEN
      		IF DataItemsTypeDetails.ItemGenerate THEN
      			if DataItems.KeyType<>4 AND DataItems.ItemName<>DataFile.KeyName then
      				nMaxItems++
      				Dimension(arrFiles.arrItemsNoKeyAll,nMaxItems)
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nDataItemsID=DataItems.DataItemsID
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nDataFileID=DataItems.DataFileID
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sFileName=DataFile.FileName
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nVersionID=DataItems.VersionID
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sItemName=DataItems.ItemName
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sItemNameRenamed=DataItems.sItemNameRenamed
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nType=DataItems.Type
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sTypeCast=DataItems.TypeCast
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sSize=DataItems.Size
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nKeyType=DataItems.KeyType
      				arrFiles.arrItemsNoKeyAll[nMaxItems].bNotNull=DataItems.bNotNull
      				arrFiles.arrItemsNoKeyAll[nMaxItems].bAutoIncrement=DataItems.AutoIncrement
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sDefault=DataItems.sDefault
      				arrFiles.arrItemsNoKeyAll[nMaxItems].bUnsigned=DataItems.bUnsigned
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nControlType=DataItems.ControlType
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sWinDevType=DataItems.WinDevType
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sWinDevTypePlain=DataItems.WinDevTypePlain
      				arrFiles.arrItemsNoKeyAll[nMaxItems].Data_Type=DataItems.Data_Type
      				arrFiles.arrItemsNoKeyAll[nMaxItems].DB_Data_Type=DataItems.DB_Data_Type
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nDataItemsTypeDetailsID=DataItemsTypeDetails.DataItemsTypeDetailsID
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nTemplatePageID=DataItemsTypeDetails.TemplatePageID
      				arrFiles.arrItemsNoKeyAll[nMaxItems].sEditMask=DataItemsTypeDetails.EditMask
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nSortIndex=DataItemsTypeDetails.SortIndex
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nX=DataItemsTypeDetails.X
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nY=DataItemsTypeDetails.Y
      				arrFiles.arrItemsNoKeyAll[nMaxItems].bItemVisible=DataItemsTypeDetails.ItemVisible
      				arrFiles.arrItemsNoKeyAll[nMaxItems].nItemState=DataItemsTypeDetails.ItemState
      				arrFiles.arrItemsNoKeyAll[nMaxItems].bItemGenerate=DataItemsTypeDetails.ItemGenerate
      				
      				HFilter(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMinVal),HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMaxVal))
      				HReadFirst(DataItemsTranslation,DataItemsTranslationKey)
      				WHILE NOT HOut(DataItemsTranslation)
      					arrFiles.arrItemsNoKeyAll[nMaxItems].nMaxLanguage++
      					nMaxLanguages=arrFiles.arrItemsNoKeyAll[nMaxItems].nMaxLanguage
      					Dimension(arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption,nMaxLanguages)
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].nDataItemsTranslationID=DataItemsTranslation.DataItemsTranslationID
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].nDataItemsID=DataItemsTranslation.DataItemsID
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].nVersionID=DataItemsTranslation.VersionID
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].nTemplatePageID=DataItemsTranslation.TemplatePageID
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].nLanguageID=DataItemsTranslation.LanguageID
      					HReadSeek(Language,LanguageID,DataItemsTranslation.LanguageID,hIdentical)
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].sDescription=Language.Description
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].sToken=Language.Token
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].sSourceToken=Language.SourceToken
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].sCaption=DataItemsTranslation.Caption
      					arrFiles.arrItemsNoKeyAll[nMaxItems].arrCaption[nMaxLanguages].sComboBoxContent=DataItemsTranslation.ComboBoxContent
      					HReadNext(DataItemsTranslation,DataItemsTranslationKey)
      				END
      			end
      		END
      	END
      	HReadNext(DataItems,DataItemsKey)
      END
      
      HDeactivateFilter(DataItems)
      
      ArraySort(arrFiles.arrItemsNoKeyAll,asMember,"+nSortIndex")
     type : 458752
