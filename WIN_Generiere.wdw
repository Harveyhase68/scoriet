      						arrFiles.arrItemsBlob[nMaxItems].sEditMask=DataItemsTypeDetails.EditMask
      						arrFiles.arrItemsBlob[nMaxItems].nSortIndex=DataItemsTypeDetails.SortIndex
      						arrFiles.arrItemsBlob[nMaxItems].nX=DataItemsTypeDetails.X
      						arrFiles.arrItemsBlob[nMaxItems].nY=DataItemsTypeDetails.Y
      						arrFiles.arrItemsBlob[nMaxItems].bItemVisible=DataItemsTypeDetails.ItemVisible
      						arrFiles.arrItemsBlob[nMaxItems].nItemState=DataItemsTypeDetails.ItemState
      						arrFiles.arrItemsBlob[nMaxItems].bItemGenerate=DataItemsTypeDetails.ItemGenerate
      						
      						HFilter(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMinVal),HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMaxVal))
      						HReadFirst(DataItemsTranslation,DataItemsTranslationKey)
      						WHILE NOT HOut(DataItemsTranslation)
      							arrFiles.arrItemsBlob[nMaxItems].nMaxLanguage++
      							nMaxLanguages=arrFiles.arrItemsBlob[nMaxItems].nMaxLanguage
      							Dimension(arrFiles.arrItemsBlob[nMaxItems].arrCaption,nMaxLanguages)
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].nDataItemsTranslationID=DataItemsTranslation.DataItemsTranslationID
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].nDataItemsID=DataItemsTranslation.DataItemsID
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].nVersionID=DataItemsTranslation.VersionID
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].nTemplatePageID=DataItemsTranslation.TemplatePageID
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].nLanguageID=DataItemsTranslation.LanguageID
      							HReadSeek(Language,LanguageID,DataItemsTranslation.LanguageID,hIdentical)
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].sDescription=Language.Description
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].sToken=Language.Token
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].sSourceToken=Language.SourceToken
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].sCaption=DataItemsTranslation.Caption
      							arrFiles.arrItemsBlob[nMaxItems].arrCaption[nMaxLanguages].sComboBoxContent=DataItemsTranslation.ComboBoxContent
      						HReadNext(DataItemsTranslation,DataItemsTranslationKey)
      						END
      					other case
      				end
      			end
      		END
      	END
      	HReadNext(DataItems,DataItemsKey)
      END
      
      HDeactivateFilter(DataItems)
      
      ArraySort(arrFiles.arrItemsBlob,asMember,"+nSortIndex")
