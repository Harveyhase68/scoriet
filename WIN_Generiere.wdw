      //
      // For instance:
      // Indicate an example.
      //
      // 	arrFiles: <specify the role of arrFiles>
      PROCEDURE FillItemsNoBlob(nDataFileID, arrFiles, nTemplatePageID)
      
      local
      	nMaxItems is int
      	nMaxLanguages is int
      	
      HFilter(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMinVal),HBuildKeyValue(DataItems,DataItemsKey,nDataFileID,hMaxVal))
      HReadFirst(DataItems,DataItemsKey)
      WHILE NOT HOut(DataItems)
      	HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,nTemplatePageID),hIdentical)
      	IF HFound(DataItemsTypeDetails) THEN
      		IF DataItemsTypeDetails.ItemGenerate THEN
      			if DataItems.KeyType<>4 then
      				switch DataItems.Type
      					case 24,25,26,27,28,29
      						//Skip Blob types, Image, Text, Binary
      					other case
      						nMaxItems++
      						Dimension(arrFiles.arrItemsNoBlob,nMaxItems)
      						arrFiles.arrItemsNoBlob[nMaxItems].nDataItemsID=DataItems.DataItemsID
      						arrFiles.arrItemsNoBlob[nMaxItems].nDataFileID=DataItems.DataFileID
      						arrFiles.arrItemsNoBlob[nMaxItems].sFileName=DataFile.FileName
      						arrFiles.arrItemsNoBlob[nMaxItems].nVersionID=DataItems.VersionID
      						arrFiles.arrItemsNoBlob[nMaxItems].sItemName=DataItems.ItemName
      						arrFiles.arrItemsNoBlob[nMaxItems].sItemNameRenamed=DataItems.sItemNameRenamed
      						arrFiles.arrItemsNoBlob[nMaxItems].nType=DataItems.Type
      						arrFiles.arrItemsNoBlob[nMaxItems].sTypeCast=DataItems.TypeCast
      						arrFiles.arrItemsNoBlob[nMaxItems].sSize=DataItems.Size
      						arrFiles.arrItemsNoBlob[nMaxItems].nKeyType=DataItems.KeyType
      						arrFiles.arrItemsNoBlob[nMaxItems].bNotNull=DataItems.bNotNull
      						arrFiles.arrItemsNoBlob[nMaxItems].bAutoIncrement=DataItems.AutoIncrement
      						arrFiles.arrItemsNoBlob[nMaxItems].sDefault=DataItems.sDefault
      						arrFiles.arrItemsNoBlob[nMaxItems].bUnsigned=DataItems.bUnsigned
      						arrFiles.arrItemsNoBlob[nMaxItems].nControlType=DataItems.ControlType
      						arrFiles.arrItemsNoBlob[nMaxItems].sWinDevType=DataItems.WinDevType
      						arrFiles.arrItemsNoBlob[nMaxItems].sWinDevTypePlain=DataItems.WinDevTypePlain
      						arrFiles.arrItemsNoBlob[nMaxItems].Data_Type=DataItems.Data_Type
      						arrFiles.arrItemsNoBlob[nMaxItems].DB_Data_Type=DataItems.DB_Data_Type
      						arrFiles.arrItemsNoBlob[nMaxItems].nDataItemsTypeDetailsID=DataItemsTypeDetails.DataItemsTypeDetailsID
      						arrFiles.arrItemsNoBlob[nMaxItems].nTemplatePageID=DataItemsTypeDetails.TemplatePageID
      						arrFiles.arrItemsNoBlob[nMaxItems].sEditMask=DataItemsTypeDetails.EditMask
      						arrFiles.arrItemsNoBlob[nMaxItems].nSortIndex=DataItemsTypeDetails.SortIndex
      						arrFiles.arrItemsNoBlob[nMaxItems].nX=DataItemsTypeDetails.X
      						arrFiles.arrItemsNoBlob[nMaxItems].nY=DataItemsTypeDetails.Y
      						arrFiles.arrItemsNoBlob[nMaxItems].bItemVisible=DataItemsTypeDetails.ItemVisible
      						arrFiles.arrItemsNoBlob[nMaxItems].nItemState=DataItemsTypeDetails.ItemState
      						arrFiles.arrItemsNoBlob[nMaxItems].bItemGenerate=DataItemsTypeDetails.ItemGenerate
      						
      						HFilter(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMinVal),HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,nTemplatePageID,hMaxVal))
      						HReadFirst(DataItemsTranslation,DataItemsTranslationKey)
      						WHILE NOT HOut(DataItemsTranslation)
      							arrFiles.arrItemsNoBlob[nMaxItems].nMaxLanguage++
      							nMaxLanguages=arrFiles.arrItemsNoBlob[nMaxItems].nMaxLanguage
      							Dimension(arrFiles.arrItemsNoBlob[nMaxItems].arrCaption,nMaxLanguages)
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].nDataItemsTranslationID=DataItemsTranslation.DataItemsTranslationID
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].nDataItemsID=DataItemsTranslation.DataItemsID
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].nVersionID=DataItemsTranslation.VersionID
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].nTemplatePageID=DataItemsTranslation.TemplatePageID
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].nLanguageID=DataItemsTranslation.LanguageID
      							HReadSeek(Language,LanguageID,DataItemsTranslation.LanguageID,hIdentical)
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].sDescription=Language.Description
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].sToken=Language.Token
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].sSourceToken=Language.SourceToken
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].sCaption=DataItemsTranslation.Caption
      							arrFiles.arrItemsNoBlob[nMaxItems].arrCaption[nMaxLanguages].sComboBoxContent=DataItemsTranslation.ComboBoxContent
      						HReadNext(DataItemsTranslation,DataItemsTranslationKey)
      						END
      				end
      			end
      		END
      	END
      	HReadNext(DataItems,DataItemsKey)
      END
      
      HDeactivateFilter(DataItems)
      
      ArraySort(arrFiles.arrItemsNoBlob,asMember,"+nSortIndex")
     type : 458752
