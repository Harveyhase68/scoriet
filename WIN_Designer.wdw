  type_code : 1
  p_codes :
   -
     code : |1+
      
      Procedure WIN_Designer(nProjectID is int)
      
      GLOBAL
      	gnRecNum is int = 0					// current file record
      	gsModifiedWindow is boolean = False		// Was a record modified? 
      	nPageOffsetTop is real on 8 bytes=58
      	nPageOffsetleft is real on 8 bytes=9
      	gbFirstLoad is boolean
      	
      // Management of database access errors
      // Error messages returned by the database are displayed
      // Database error reviews can be processed here
      //WHEN EXCEPTION
      //	Error(<§$000d§>,ExceptionInfo(errMessage))
      ////	// Re-enable the exceptions
      //	ExceptionEnable()
      ////	// Resume the process
      //	ReturnToCapture()
      //END
   -
     code : |1-
      
      //Event("LocalEventTest", "*.*", null)
      //Event("MSG","IW_InternalWindow1",276)
      //Event("MSG","IW_InternalWindow1",277)
      gbFirstLoad=true
      gnPageOffsetTop=IW_InternalWindow1..y
      gnPageOffsetleft=IW_InternalWindow1..x
      
      if ontestmode() THEN
      	nProjectID=3
      	gnProjectID=3
      END
      
      HReadSeek(Project,ProjectID,nProjectID,hIdentical)
      if not hfound(Project) then
      	error(<§$000f§>)
      	close()
      END
      
      HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,project.LastVersionNo),hIdentical)
      if hfound(Version) then
      else
      	error(<§$0011§>)
      	close()
      END
      
      gnZoom=version.LastZoom
      
      FillFonts()
      COMBO_Schriftarten=""
      EDT_FontSize=""
      CalcZoom()
      CalcAnalyseWidthHeight()
      ResizeBlatt()
      DisplayObjects()
      gbFirstLoad=false
     type : 34
   -
     type : 230
     enabled : false
   -
     code : |1-
      
      IF gbEtiketteChanged THEN
      	SWITCH Dialog(<§?189751C802BB83DB§>)
      		CASE 1
      		CASE 2
      			IF gnAktuelleHistoryNr>0 THEN
      				while gnAktuelleHistoryNr>0
      					HistoryTakeBack()
      				end
      			END
      		CASE 3
      			ReturnToCapture(EDT_FONTSIZE)
      	END
      END
     type : 2
   -
     code : |1+
      
      
     type : 11
   -
     code : |1+
      
      
     type : 12
   -
     code : |1+
      
      
     type : 17
   -
     code : |1-
      
      //CalcZoom()
      //ResizeBlatt()
      //DisplayObjects()
      //MultitaskRedraw()
     type : 13
   -
     type : 65792
  procedures :
   -
     name : ResizeBlatt
     procedure_id : 1957367951438258275
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //ResizeBlatt ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE ResizeBlatt()
      
      LOCAL
      	rBreite is 8-byte real
      	rHoehe is 8-byte real
      	i is 8-byte real
      	n is int
      	
      CallDLL32("User32","LockWindowUpdate",Handle(MyWindow))
      
      ListDeleteAll(Combo_TextColor)
      
      n=Dimension(iFarbe)
      FOR i=1 TO n
      	ListAdd(Combo_TextColor,gBackground(iFarbe[i])+Left(sFarbeName[i]+RepeatString(" ",96),96)+TAB+NumToString(iFarbe[i],"06X"))
      END
      
      ListDeleteAll(Combo_BackgroundColor)
      ListAdd(Combo_BackgroundColor,Left("Transparent"+RepeatString(" ",96),96)+TAB+"-1")
      n=Dimension(iFarbe)
      FOR i=1 TO n
      	ListAdd(Combo_BackgroundColor,gBackground(iFarbe[i])+Left(sFarbeName[i]+RepeatString(" ",96),96)+TAB+NumToString(iFarbe[i],"06X"))
      END
      
      SetScrollValueH("WIN_Designer.IW_InternalWindow1",0)
      SetScrollValueV("WIN_Designer.IW_InternalWindow1",0)
      
      rBreite=Version.AnalyseWidth
      rHoehe=version.AnalyseHeight
      	
      WinUsefulSize(IW_InternalWindow1, rBreite+1, rHoehe+1)
      
      gnInternalWindowWidth=(rBreite+1)
      gnInternalWindowHeight=(rHoehe+1)
      
      IW_InternalWindow1.IMG_Blatt..Width=rBreite
      IW_InternalWindow1.IMG_Blatt..Height=rHoehe
      
      IW_InternalWindow1.IMG_Blatt..X=gnPageOffsetleft
      IW_InternalWindow1.IMG_Blatt..Y=gnPageOffsetTop
      
      IW_InternalWindow1.IMG_Blatt=""
      IW_InternalWindow1.IMG_Blatt..ZOrder=0
      
      CallDLL32("User32","LockWindowUpdate",Null)
     type : 458752
   -
     name : DisplayObjects
     procedure_id : 1968187055666005647
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] DisplayObjects ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE DisplayObjects()
      
      LOCAL
      	i is int
      	sControlName is string, useful
      	n is int
      	nID is dynamic array of 0 int on 8 bytes
      
      CallDLL32("User32","LockWindowUpdate",Handle(MyWindow))
      
      i=1
      sControlName = EnumControl(IW_InternalWindow1, i) 
      WHILE sControlName<>""
      	IF Left(sControlName,6)="OBJEKT" or left(sControlName,4)="WIRE" THEN
      		ControlDelete(sControlName)
      		i=1
      	END
      	i++
      	sControlName = EnumControl(IW_InternalWindow1, i)
      END
      
      HReadSeek(Project,ProjectID,nProjectID,hIdentical)
      IF HFound(Project) THEN
      	
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	IF HFound(Version) THEN
      	ELSE
      		Error(<§$0011§>)
      		Close()
      	END
      	
      	HFilter(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMaxVal))
      	HReadFirst(DataFile,DataFileKey)
      	WHILE NOT HOut(DataFile)
      
      		n++
      		Dimension(nID,n)
      		nID[n]=DataFile.DataFileID
      
      		HReadNext(DataFile,DataFileKey)
      	END
      	HDeactivateFilter(DataFile)
      	
      END
      
      for i=1 to n
      	Display(nID[i])
      END
      
      //VersionID+Child_Table+Child_Item
      hfilter(ForeignKey,ForeignChildKey,HBuildKeyValue(ForeignKey,ForeignChildKey,version.VersionID,hMinVal,hMinVal),HBuildKeyValue(ForeignKey,ForeignChildKey,Version.VersionID,hMaxVal,hMaxVal))
      HReadFirst(ForeignKey,ForeignChildKey)
      while not hout(ForeignKey)
      	//ControlClone("Win_Designer_Container.WIRE_NoName1","Win_Designer_Container.WIRE"+NumToString(ForeignKey.ForeignKeyID,"d"))
      	sControlName="Win_Designer_Container.WIRE"+NumToString(ForeignKey.ForeignKeyID,"d")
      	ControlCreate(sControlName,typWire)
      	HReadSeek(DataFile,datafilekey,HBuildKeyValue(DataFile,datafilekey,Version.VersionID,ForeignKey.Parent_Table),hIdentical)
      	if hfound(DataFile) then
      		WHEN EXCEPTION in
      			{sControlName,indControl}..StartControl="OBJEKT"+DataFile.DataFileID	
      		do
      			trace("Objekt "+"OBJEKT"+DataFile.DataFileID+" möglicherweise nicht gefunden?!")
      			stop
      		END
      	end
      	HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,ForeignKey.Child_Table),hIdentical)
      	IF HFound(DataFile) THEN
      		WHEN EXCEPTION IN
      			{sControlName,indControl}..EndControl="OBJEKT"+DataFile.DataFileID
      		do
      			Trace("Objekt "+"OBJEKT"+DataFile.DataFileID+" möglicherweise nicht gefunden?!")
      		end
      	end
      	{sControlName,indControl}..MaxNbSegment=25
      	{sControlName,indControl}..ZOrder=2
      	hreadnext(ForeignKey,ForeignChildKey)
      END
      HDeactivateFilter(ForeignKey)
      
      CallDLL32("User32","LockWindowUpdate",Null)
      
      result true
     type : 458752
   -
     name : LocalEventTest
     procedure_id : 1969889881349699208
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //LocalEventTest ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      Procedure LocalEventTest()
      
      switch _EVE.wMessage
      	case 32,512,160,132,133,1735,2035,2036,2037,15
      	
      	OTHER CASE
      		if _EVE.name="IW_InternalWindow1" THEN //_EVE.lParam<>0 or _EVE.wParam<>0 then
      			Trace(_EVE.wMessage+", "+_EVE.name+", "+_EVE.hWnd+", "+_EVE.lParam+"("+LoWord(_EVE.lParam)+"/"+HiWord(_EVE.lParam)+"), "+_EVE.wParam+"("+LoWord(_EVE.wParam)+"/"+HiWord(_EVE.wParam)+")")
      		end
      END
     type : 458752
   -
     name : CreateNewObject
     procedure_id : 2049033664617557481
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] CreateNewObject (<nFormular> is 8-byte int, <nObjectType> is int, <nObjectArt> is int [, <sValue> is string [, <sMask> is string]])
      //
      // Parameters:
      //	nFormular (8-byte int): <specify the role of nFormular>
      //	nObjectType (int): <specify the role of nObjectType>
      //	nObjectArt (int): <specify the role of nObjectArt>
      //	sValue (ANSI string - default value=""): <specify the role of sValue>
      //	sMask (ANSI string - default value=""): <specify the role of sMask>
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CreateNewObject(nFormular is int on 8 bytes, nObjectType is int, nObjectArt is int, sValue is string="", sMask is string="")
      
      gaaHistoryNachher["X"]=1
      gaaHistoryNachher["Y"]=1
      gaaHistoryNachher["Hoehe"]=6
      gaaHistoryNachher["Breite"]=50
      gaaHistoryNachher["FeldTyp"]=nObjectType
      gaaHistoryNachher["FeldArt"]=nObjectArt
      gaaHistoryNachher["EtikettID"]=nFormular
      gaaHistoryNachher["Schriftart"]="Arial"
      gaaHistoryNachher["SchriftPunkt"]=10
      gaaHistoryNachher["Fett"]=False
      gaaHistoryNachher["Kursiv"]=False
      gaaHistoryNachher["Unterstrichen"]=False
      gaaHistoryNachher["FeldName"]=DateSys()+TimeSys()+Random(1,1000)
      gaaHistoryNachher["Wert"]=sValue
      gaaHistoryNachher["EingabeMaske"]=sMask
      gaaHistoryNachher["HintergrundFarbe"]=-1
      gaaHistoryNachher["TextFarbe"]="000000"
      SWITCH nObjectType
      	CASE 6,7,8 //EAN
      		//Center
      		gaaHistoryNachher["OrientierungH"]=2
      		gaaHistoryNachher["OrientierungV"]=2
      	OTHER CASE
      		//TOP, Left
      		gaaHistoryNachher["OrientierungH"]=1
      		gaaHistoryNachher["OrientierungV"]=1
      END
      result HistoryAdd(1)
      
      result "OBJEKT"+NumToString(DataFile.DataFileID,"d")
     type : 458752
   -
     name : Display
     procedure_id : 2049473318940797503
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //Display (<gnObjektID>)
      //
      // Parameters:
      //	gnObjektID:<specify the role of gnObjektID>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE Display(gnObjektID)
      
      LOCAL
      	x is 8-byte real
      	y is 8-byte real
      	wd is 8-byte real
      	hg is 8-byte real
      	bFound is boolean
      	sControlName is string
      	i is int
      	nHdc is system int
      	nHdc2 is system int, useful
      	
      HReadSeek(DataFile,DataFileID,gnObjektID,hIdentical)
      if hfound(DataFile) then
      	if DataFile.VD_X=0 and DataFile.VD_Y=0 then
      		DataFile.VD_X=Random(0,800)
      		DataFile.VD_Y=Random(0,800)
      		HModify(DataFile)
      	END
      	IF DataFile.VD_W=0 AND DataFile.VD_H=0 THEN
      		DataFile.VD_X=100
      		DataFile.VD_Y=100
      		HModify(DataFile)
      	END
      end
      
      i=1
      bFound=False
      sControlName = EnumControl(IW_InternalWindow1, i) 
      WHILE sControlName<>""
      	IF sControlName="OBJEKT"+DataFile.DataFileID THEN
      		bFound=True
      		break
      	END
      	i++
      	sControlName = EnumControl(IW_InternalWindow1, i)
      END
      
      x=((DataFile.VD_X/100)*gnZoom)+gnPageOffsetleft
      y=((DataFile.VD_Y/100)*gnZoom)+gnPageOffsetTop
      
      wd=(DataFile.VD_W/100)*gnZoom
      hg=(DataFile.VD_H/100)*gnZoom
      if wd<=0 then
      	wd=50
      END
      if hg<=0 then
      	hg=50
      END
      
      if bFound then
      	ControlDelete(sControlName)
      	bFound=false
      END
      
      WHEN EXCEPTION IN
      	ControlClone(IW_InternalWindow1.CLONE_BILD,"OBJEKT"+DataFile.DataFileID,x,y)
      	{"OBJEKT"+DataFile.DataFileID,indControl}..Width=wd
      	{"OBJEKT"+DataFile.DataFileID,indControl}..Height=hg
      DO
      END
      
      WHEN EXCEPTION IN
      	nHdc=dStartDrawing({"OBJEKT"+DataFile.DataFileID,indControl},dErase)
      	{"OBJEKT"+DataFile.DataFileID,indControl}..ZOrder=9999
      	dRectangle(1,1,{"OBJEKT"+DataFile.DataFileID,indControl}..Width-1,{"OBJEKT"+DataFile.DataFileID,indControl}..Height-1,White,Black)
      	dRectangle(1,1,{"OBJEKT"+DataFile.DataFileID,indControl}..Width-1,22,DarkRed,DarkRed)
      	MaleText(nHdc,DataFile.FileName,IntegerPart(1),IntegerPart(1),IntegerPart(wd),IntegerPart(22),0,DataFile.VD_Font,IntegerPart(DataFile.VD_FontSize),"FFFFFF",Val(ExtractString(DataFile.VD_FontProperties,1,";")),Val(ExtractString(DataFile.VD_FontProperties,2,";")),Val(ExtractString(DataFile.VD_FontProperties,3,";")),Val(ExtractString(DataFile.VD_FontProperties,4,";")),2,2,0,gnZoom)
      DO
      	error("Fehler beim Zeichnen des Objektes: OBJEKT"+DataFile.DataFileID+crlf+crlf+ErrorInfo(errFullDetails))
      END
      
      MultitaskRedraw()
      
      WHEN EXCEPTION IN
      	{"OBJEKT"+DataFile.DataFileID,indControl}..Note=DataFile.DataFileID
      	{"OBJEKT"+DataFile.DataFileID,indControl}..Visible=True
      do
      end
     type : 458752
   -
     name : FillFonts
     procedure_id : 2049478717714831519
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //FillFonts ( [<bRefreshAll>])
      //
      // Parameters:
      // 	bRefreshAll (default value=0): <specify the role of bRefreshAll>
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE FillFonts(bRefreshAll=false)
      
      LOCAL
      	s is string
      	h is int
      	//sImage is string
      	sFontName is string
      	sFileName is string
      	w is int
      	sFontText is string
      	
      if not fDirectoryExist(CompleteDir(SysDir(srMyDocuments))+"Scoriet\Cache\") then
      	fMakeDir(CompleteDir(SysDir(srMyDocuments))+"Scoriet\Cache")
      END
      
      s=FontList(fontDefault)
      dStartDrawing(IMG_Image1,dErase)
      
      FOR i=1 TO StringCount(s,CR)+1
      	sFontName=replace(ExtractString(s,i,CR),"?","")
      	hreadseek(Fonts,FontName,sFontName)
      	if not hfound(Fonts) or bRefreshAll then
      		sFileName=CompleteDir(SysDir(srMyDocuments))+"Scoriet\Cache\"+sFontName+".png"
      		sFontText="öäüÖÄÜß ABC123"
      		//sFontText=sFontName
      		STC_Static1..FontName=sFontName
      		STC_Static1..FontSize=12
      		STC_Static1..FontBold=True
      		h=TextHeight(STC_Static1,sFontText)
      		if h=0 then
      			h=16
      		END
      		w=TextWidth(STC_Static1,sFontText)
      		if w=0 then
      			w=115
      		END
      		dFont(sFontName,12,iBold)
      		IMG_Image1..Height=h
      		IMG_Image1..Width=w
      		dRectangle(0,0,IMG_Image1..Width,IMG_Image1..Height,RGB(255,255,255))
      		dText(0,0,sFontText,RGB(0, 0, 0))
      		dSaveImagePNG(IMG_Image1,sFileName)
      		//sImage=dSaveImagePNG(IMG_Image1,inMemory)
      		IMG_Image1=sFileName
      		Fonts.FontName=sFontName
      		HAttacheMémo(Fonts,Picture,sFileName,hMemoImg)
      		if not hfound(Fonts) then
      			hadd(Fonts)
      		else
      			HModify(Fonts)
      		END
      	end
      END
      
      ListDisplay(COMBO_Schriftarten,taInit)
     type : 458752
