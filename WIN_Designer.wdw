             name : BTN_BackgroundColorSelect
             identifier : 0x29037d1f380aa9ec
             internal_properties : 
             type : 4
             code_elements :
              type_code : 4
              p_codes :
               -
                 code : |1+
                  LOCAL
                  	colorwert is int
                  	i is int
                  	bFound is boolean
                  
                  IF gsTargetControl<>"" THEN
                  	
                  	if Combo_BackgroundColor.Column2="-1" then
                  		colorwert=Val(Combo_BackgroundColor.Column2,"x")
                  	else
                  		colorwert=Val(Combo_BackgroundColor.Column2,"x")
                  	END
                  	
                  	IF SelectColor(colorwert,scInit+scPersoColor+scAnyColor,&CustomColor) THEN
                  		
                  		gaaHistoryNachher["HintergrundFarbe"]=colorwert
                  		gaaHistoryNachher["FeldID"]=Val(Middle(gsTargetControl,7))
                  		HistoryAdd(2)
                  	
                  		bFound=False
                  		FOR i=1 to ListCount(WIN_Designer.Combo_BackgroundColor)
                  			IF NumToString(WIN_Designer.Combo_BackgroundColor.Column2[i],"06X")=DataFile.VD_BackgroundColor THEN
                  				ListSelectPlus(WIN_Designer.Combo_BackgroundColor,i)
                  				bFound=True
                  				BREAK
                  			END
                  		END
                  		
                  		IF NOT bFound THEN
                  			ListDeleteAll(Combo_BackgroundColor)
                  			ListAdd(Combo_BackgroundColor,Left("Transparent"+RepeatString(" ",96),96)+TAB+"-1")
                  			FOR i=1 TO Dimension(iFarbe)
                  				ListAdd(Combo_BackgroundColor,gBackground(iFarbe[i])+Left(sFarbeName[i]+RepeatString(" ",96),96)+TAB+NumToString(iFarbe[i],"06X"))
                  			END
                  			ListAdd(WIN_Designer.Combo_BackgroundColor,gBackground(Val(DataFile.VD_BackgroundColor,"x"))+Left(<§$0000§>+RepeatString(" ",96),96)+TAB+DataFile.VD_BackgroundColor)
                  			ListSelectPlus(WIN_Designer.Combo_BackgroundColor,ListCount(WIN_Designer.Combo_BackgroundColor))
                  		END
                  
                  	END
                  
                  	Display(DataFile.DataFileID)
                  
                  END
                 type : 18
               -
                 type : 161
                 enabled : false
