     name : CalcZoom
     procedure_id : 1421168557579801389
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Description of in/out parameters for 'CalcZoom' :
      //
      // Syntax:
      //[ <Result> = ] CalcZoom ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CalcZoom()
      
      if gnZoom=0 then
      	gnZoom=100
      END
      
      COMBO_Zoom=NumToString(gnZoom,"d")+"%"
      
      result true
     type : 458752
   -
     name : Menu_Create
     procedure_id : 1421227969873291475
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Description of in/out parameters for 'Menu_Create' :
      //
      // Syntax:
      //[ <Result> = ] Menu_Create (<nEtikettID>, <nTyp>, <nArt> [, <sWert> is string [, <sFormat> is string [, <bDisplayObject> is boolean]]])
      //
      // Parameters:
      //	nEtikettID: <specify the role of nEtikettID>
      //	nTyp: <specify the role of nTyp>
      //	nArt: <specify the role of nArt>
      //	sWert (ANSI string - default value=""): <specify the role of sWert>
      //	sFormat (ANSI string - default value=""): <specify the role of sFormat>
      //	bDisplayObject (boolean - default value=1): <specify the role of bDisplayObject>
      // Return Value:
      // 	ANSI string: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE Menu_Create(nEtikettID, nTyp, nArt, sWert is string="", sFormat is string="", bDisplayObject is boolean=true)
      
      local
      	sObject is string
      	
      sObject=CreateNewObject(nEtikettID,nTyp,nArt,sWert,sFormat)
      WIN_Designer.IW_InternalWindow1.MoveActive=True
      gsTargetControl=sObject
      CursorPos(cpWindow,80,200)
      
      if bDisplayObject then
      	Display(Val(Middle(sObject,7)))
      	WIN_Designer.IW_InternalWindow1.AnzeigenControl(gsTargetControl)	
      	WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
      end
      
      result sObject
     type : 458752
   -
     name : CalcAnalyseWidthHeight
     procedure_id : 1802897227875842536
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //CalcAnalyseWidthHeight ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CalcAnalyseWidthHeight()
      
      local
      	nMaxWidth is int
      	nMaxHeight is int
      	
      HReadSeek(Project,ProjectID,nProjectID,hIdentical)
      IF HFound(Project) THEN
      	
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	IF HFound(Version) THEN
      	ELSE
      		Error(<§$0011§>)
      		Close()
      	END
      	
      	HFilter(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMaxVal))
      	HReadFirst(DataFile,DataFileKey)
      	WHILE NOT HOut(DataFile)
      		
      		if nMaxWidth<(((DataFile.VD_X+DataFile.VD_W)/100)*gnZoom)+gnPageOffsetleft then
      			nMaxWidth=(((DataFile.VD_X+DataFile.VD_W)/100)*gnZoom)+gnPageOffsetleft
      		END
      		if nMaxHeight<(((DataFile.VD_Y+DataFile.VD_H)/100)*gnZoom)+gnPageOffsetTop then
      			nMaxHeight=(((DataFile.VD_Y+DataFile.VD_H)/100)*gnZoom)+gnPageOffsetTop
      		END
      		HReadNext(DataFile,DataFileKey)
      	END
      	HDeactivateFilter(DataFile)
      	
      END
      
      HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      IF HFound(Version) THEN
      	Version.AnalyseWidth=nMaxWidth
      	Version.AnalyseHeight=nMaxHeight
      	Version.LastZoom=gnZoom
      	HModify(Version)
      ELSE
      	Error(<§$0011§>)
      	Close()
      END
     type : 458752
