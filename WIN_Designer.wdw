           -
             name : BTN_Delete
             identifier : 0x29037d1f3824a9ec
             internal_properties : 
             type : 4
             code_elements :
              type_code : 4
              p_codes :
               -
                 code : |1+
                  
                  local
                  	sTargetControl is string
                  	
                  sTargetControl=gsTargetControl
                  	
                  IF gsTargetControl<>"" THEN
                  	IF YesNo("Wollen Sie wirklich das Feld löschen?")=Yes THEN
                  		IF gsTargetControl="" THEN
                  			gsTargetControl=sTargetControl
                  		END
                  		WHEN EXCEPTION IN
                  			gaaHistoryNachher["FeldID"]=Val({gsTargetControl,indControl}..Note)	
                  		DO
                  			RETURN
                  		END
                  		HistoryAdd(3)
                  		DisplayObjects()
                  		gsTargetControl=""
                  		WHEN EXCEPTION IN
                  			WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
                  		DO
                  		END
                  	END
                  end
                 type : 18
               -
                 type : 161
                 enabled : false
           -
             name : BTN_Change
             identifier : 0x29037d1f3825a9ec
             internal_properties : 
             type : 4
             code_elements :
              type_code : 4
              p_codes :
               -
                 code : |1-
                  
                  LOCAL
                  	xmlRecord is string
                  	sXMLDoc is string="XML"
                  	
                  IF gsTargetControl<>"" THEN
                  	when exception in
                  		HReadSeek(DataFile,DataFileID,Val({gsTargetControl,indControl}..Note),hIdentical)
                  	do
                  		return
                  	end
                  
                  	IF HFound(DataFile) THEN
                  		xmlRecord=HRecordToXML(DataFile,"",charsetAnsi)
                  		xmlRecord=StringToUTF8(xmlRecord)
                  		XMLDocument("XMLDoc", xmlRecord)
                  		XMLFirst("XMLDoc")
                  		XMLChild("XMLDoc")
                  		XMLFirst("XMLDoc")
                  		WHILE NOT XMLOut("XMLDoc")
                  			gaaHistoryVorher[XMLElementName("XMLDoc")]=XMLData("XMLDoc")
                  			XMLNext("XMLDoc")
                  		END
                  		XMLClose("XMLDoc")
                  //		if open(WIN_Property,DataFile.DataFileID) then
                  //			xmlRecord=HRecordToXML(Felder,"",charsetAnsi)
                  //			xmlRecord=StringToUTF8(xmlRecord)
                  //			XMLDocument("XMLDoc", xmlRecord)
                  //			XMLFirst("XMLDoc")
                  //			XMLChild("XMLDoc")
                  //			XMLFirst("XMLDoc")
                  //			WHILE NOT XMLOut("XMLDoc")
                  //				gaaHistoryNachher[XMLElementName("XMLDoc")]=XMLData("XMLDoc")
                  //				XMLNext("XMLDoc")
                  //			END
                  //			XMLClose("XMLDoc")
                  //			HistoryAdd(2,True)
                  //			ResizeBlatt()
                  //			DisplayObjects()
                  //			WHEN EXCEPTION IN
                  //				WIN_Designer.IW_InternalWindow1.ResizeHandleEinstellen()
                  //			DO
                  //			END
                  //		end
                  	END		
                  END
                 type : 18
               -
                 type : 161
                 enabled : false
