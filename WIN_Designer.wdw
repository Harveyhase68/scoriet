             name : BTN_TextColorSelect
             identifier : 0x29037d1f3806a9ec
             internal_properties : 
             type : 4
             code_elements :
              type_code : 4
              p_codes :
               -
                 code : |1+
                  LOCAL
                  	colorwert is int
                  	i is int
                  	bFound is boolean
                  
                  IF gsTargetControl<>"" THEN
                  		
                  	colorwert=Val(Combo_TextColor.Column2,"x")
                  	
                  	IF SelectColor(colorwert,scInit+scPersoColor+scAnyColor,&CustomColor) THEN
                  	
                  		gaaHistoryNachher["TextFarbe"]=NumToString(colorwert,"06X")
                  		gaaHistoryNachher["FeldID"]=Val(Middle(gsTargetControl,7))
                  		HistoryAdd(2)
                  		
                  		bFound=False
                  		FOR i=1 to ListCount(WIN_Designer.Combo_TextColor)
                  			IF NumToString(WIN_Designer.Combo_TextColor.Column2[i],"06X")=DataFile.VD_FontColor THEN
                  				ListSelectPlus(WIN_Designer.Combo_TextColor,i)
                  				bFound=True
                  				BREAK
                  			END
                  		END
                  		
                  		IF NOT bFound THEN
                  			ListDeleteAll(Combo_TextColor)
                  			FOR i=1 TO Dimension(iFarbe)
                  				ListAdd(Combo_TextColor,gBackground(iFarbe[i])+Left(sFarbeName[i]+RepeatString(" ",96),96)+TAB+NumToString(iFarbe[i],"06X"))
                  			END
                  			ListAdd(WIN_Designer.Combo_TextColor,gBackground(Val(DataFile.VD_FontColor,"x"))+Left(<§$0000§>+RepeatString(" ",96),96)+TAB+DataFile.VD_FontColor)
                  			ListSelectPlus(WIN_Designer.Combo_TextColor,ListCount(WIN_Designer.Combo_TextColor))
                  		END
                  
                  	END
                  
                  	Display(DataFile.DataFileID)
                  
                  END
                 type : 18
               -
                 type : 161
                 enabled : false
