             name : BTN_BACK
             identifier : 0x29037d1f380fa9ec
             internal_properties : 
             type : 4
             code_elements :
              type_code : 4
              p_codes :
               -
                 code : |1+
                  
                  if gnAktuelleHistoryNr>0 then
                  	HistoryTakeBack()
                  end
                  DisplayObjects()
                  IW_InternalWindow1.ResizeHandleEinstellen()
                  WIN_Designer.BTN_BACK..State=Grayed
                  WIN_Designer.BTN_FORWARD..State=Grayed
                  IF gnAktuelleHistoryNr>0 THEN
                  	WIN_Designer.BTN_BACK..State=Active
                  	gbEtiketteChanged=true
                  else
                  	gbEtiketteChanged=false
                  END
                  IF Dimension(garrHistory)>gnAktuelleHistoryNr THEN
                  	WIN_Designer.BTN_FORWARD..State=Active
                  END
                  
                 type : 18
               -
                 type : 161
                 enabled : false
           -
             name : BTN_FORWARD
             identifier : 0x29037d1f3810a9ec
             internal_properties : 
             type : 4
             code_elements :
              type_code : 4
              p_codes :
               -
                 code : |1+
                  
                  IF gnAktuelleHistoryNr<Dimension(garrHistory) THEN
                  	HistoryTakeForward()
                  END
                  DisplayObjects()
                  IW_InternalWindow1.ResizeHandleEinstellen()
                  WIN_Designer.BTN_BACK..State=Grayed
                  WIN_Designer.BTN_FORWARD..State=Grayed
                  IF gnAktuelleHistoryNr>0 THEN
                  	WIN_Designer.BTN_BACK..State=Active
                  END
                  IF Dimension(garrHistory)>gnAktuelleHistoryNr THEN
                  	WIN_Designer.BTN_FORWARD..State=Active
                  END
                 type : 18
               -
                 type : 161
                 enabled : false
