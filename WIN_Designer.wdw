       ribbon_groups :
        -
          name : RIBGRP_Ansicht
          identifier : 0x29037d1f383da9ec
          internal_properties : 
          controls :
           -
             name : COMBO_Zoom
             identifier : 0x29037d1f383ea9ec
             internal_properties : 
             input :
              internal_properties : 
              type : 2
             dropdown :
              internal_properties : 
              type : 7
             type : 14
             code_elements :
              type_code : 23
              p_codes :
               -
                 type : 35
                 enabled : false
               -
                 code : |1+
                  
                  SWITCH COMBO_Zoom
                  	CASE "10%"
                  		gnZoom=10
                  	CASE "20%"
                  		gnZoom=20
                  	CASE "35%"
                  		gnZoom=35
                  	CASE "50%"
                  		gnZoom=50
                  	CASE "75%"
                  		gnZoom=75
                  	CASE "100%"
                  		gnZoom=100
                  	CASE "200%"
                  		gnZoom=200
                  	CASE "300%"
                  		gnZoom=300
                  	CASE "500%"
                  		gnZoom=500
                  	CASE "800%"
                  		gnZoom=800
                  	CASE "1000%"
                  		gnZoom=1000
                  	OTHER CASE
                  		switch ListSelect(COMBO_Zoom)
                  			case 12
                  				//Breite
                  				gnZoom=(WIN_Designer.IW_InternalWindow1..Width)/25.4
                  				COMBO_Zoom=NumToString(gnZoom,"d")+"%"
                  			case 13
                  				CalcZoom()
                  			other case
                  				gnZoom=val(COMBO_Zoom)
                  				if gnZoom<10 then
                  					gnZoom=10
                  				else if gnZoom>3000 then
                  					gnZoom=3000
                  				END
                  		END
                  END
                  CalcAnalyseWidthHeight()
                  ResizeBlatt()
                  DisplayObjects()
                 type : 33
               -
                 code : |1-
                  
                  if IsNumeric(COMBO_Zoom..Value) then
                  	if COMBO_Zoom..Value>=10 then
                  		gnZoom=val(COMBO_Zoom..Value)
                  		ResizeBlatt()
                  		DisplayObjects()
                  	END
                  end
                 type : 17
          type : 88
          code_elements :
           type_code : 123
           p_codes : []
       controls : []
