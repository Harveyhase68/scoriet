  -
    name : BTN_DeleteLine
    identifier : 0x200159ceca6ac9e1
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(No,"Do you want to delete the record?") THEN
         	// deletion
         	HDelete(DBConnection)
         	IF ErrorOccurred THEN
         		Error("Unable TO delete record."+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// Indicate that a record was modified (data refresh required)
         	gsModifiedWindow = True
         	
         	// reading the next record
         	HReadNext(DBConnection,DBConnectionID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(DBConnection,DBConnectionID)
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			RADClear()
         			// tell the user that the file is empty
         			Info("The file is empty")
         			// done
         			RETURN
         		END
         	END
         	
         	// transfer the file buffer to controls
         	RADDisplay()
         END
         	
         	
        type : 18
      -
        type : 161
        enabled : false
