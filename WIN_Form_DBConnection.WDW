    name : BTN_Test
    identifier : 0x2339287201eead20
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         LOCAL
         	ctCdn is connection
         	dsDATA is data Source
         	bRes is boolean
         	sSQL is string
         	
         SWITCH COMBO_Type
         	CASE 1,2
         		//MySQL,MariaDB
         		ctCdn..Server=Server
         		ctCdn..User=Username
         		ctCdn..Password=Password
         		ctCdn..Database=""
         		ctCdn..Provider = hNativeAccessMySQL
         		ctCdn..CursorOptions = hClientCursor
         		ctCdn..Access=hOReadWrite
         	CASE 3
         		//PostgreSQL
         		ctCdn..Server=Server
         		ctCdn..User=Username
         		ctCdn..Password=Password
         		ctCdn..Database=""
         		ctCdn..Provider = hNativeAccessPostgreSQL
         		ctCdn..CursorOptions = hClientCursor
         		ctCdn..Access=hOReadWrite
         END
         
         bRes=HOpenConnection(ctCdn)
         IF NOT bRes THEN
         	Username..BrushColor=iLightRed
         	Password..BrushColor=iLightRed
         	info(<§$0001§>+crlf+HErrorInfo(hErrFullDetails))
         	return
         ELSE
         	SWITCH COMBO_Type
         		// MySQL
         		CASE 1
         			sSQL="show databases;"
         			WHEN EXCEPTION IN
         				HExecuteSQLQuery(dsDATA,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
         				HReadFirst(dsDATA)
         				WHILE NOT HOut(dsDATA)
         					HReadNext(dsDATA)
         				END
         				HCloseConnection(ctCdn)
         			DO
         				Username..BrushColor=iLightRed
         				Password..BrushColor=iLightRed
         				Info(<§$0001§>+crlf+ErrorInfo(errFullDetails)+crlf+HErrorInfo(hErrFullDetails))
         				RETURN
         			END
         			Username..BrushColor=iWhite
         			Password..BrushColor=iWhite
         		// MS SQL Server
         		CASE 2
         			sSQL="sp_tables;"
         			WHEN EXCEPTION IN
         				HExecuteSQLQuery(dsDATA,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
         				HReadFirst(dsDATA)
         				WHILE NOT HOut(dsDATA)
         					HReadNext(dsDATA)
         				END
         				HCloseConnection(ctCdn)
         			DO
         				Username..BrushColor=iLightRed
         				Password..BrushColor=iLightRed
         				Info(<§$0001§>+crlf+ErrorInfo(errFullDetails)+crlf+HErrorInfo(hErrFullDetails))
         				RETURN
         			END
         			Username..BrushColor=iWhite
         			Password..BrushColor=iWhite
         	END
         END
         
         info(<§$0000§>)
        type : 18
      -
        type : 161
        enabled : false
