 message_bar :
  internal_properties : BgAAAAYAAAA67fgqjL+BlNW0l7RVb9QHekfVEUcR8SpB62EFBVueAPYoi1/j/aXUAO/gLLyCTVuQazFai314Ui0SG0rWW0oZm0BFICoRFAhcTeX8
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      PROCEDURE Window_View(RecID=Null)
      // Vision+ window on Project file
      // This window is used to select a record
      // in Project file.
      // When exiting the window, if the selection
      // was validated ('OK' button), the file is positioned on
      // the selected record. Otherwise, if the selection
      // was canceled, the file is positioned on the record found
      // when opening the window
      // The window returns 'True' if the selection was validated and
      // False if it was canceled
      GLOBAL
      	// saves the current record number
      	gnRecNum is int				// Initial Record Number 
      	gbLocalQuery is boolean = False		// has the query been run?
      	gnTimerNum is int			// Number of the refresh timer
      	gnNoRef is int = 1500		// Time between 2 refresh operations (100th/sec)
      	gbManageAutoRef is boolean = False		// Management of refresh 
      	gnFileVersionNum is int = HVersion(Project)	// File version (for refresh)
      
      // Management of database access errors
      // Error messages returned by the database are displayed
      // Database error reviews can be processed here
      WHEN EXCEPTION
      	Error("An error occured in the window",ExceptionInfo(errMessage))
      	// Re-enable the exceptions
      	ExceptionEnable()
      	// Resume the process
      	ReturnToCapture()
      END
   -
     code : |1-
      
      // The window return value is set to 'False'
      MyWindow..ReturnedValue=False
      
      gnRecNum = HRecNum(Project)
      
      // Go to current record?
      IF RecID<>Null THEN
      	// Search for the record
      	HReadSeekFirst(Project,ProjectID,RecID)
      	// The selection bar points to the current record
      	TableDisplay(Table,taCurrentFirst)
      END
      
      // Start the automatic refresh
      ManageRefresh(True)
      	
     type : 34
   -
     type : 230
     enabled : false
   -
     code : |1-
      // Stop the automatic window refresh
      ManageRefresh(False)									
     type : 2
   -
     code : |1+
      
      
     type : 11
   -
     code : |1+
      
      
     type : 12
   -
     code : |1+
      
      
     type : 17
   -
     code : |1+
      
      
     type : 13
  procedures :
   -
     name : Refresh
     procedure_id : 1153301836915225374
     type_code : 14
     code : |1+
      // Method called by the refresh timer
      PROCEDURE Refresh()
      // Stops the timer
      EndTimerSys(gnTimerNum)
      
      // If the user is not currently in edit
      IF TableInputInProgress(TABLE)=False THEN		
      	// Was the file modified?
      	IF gnFileVersionNum < HVersion(Project) THEN
      		// Store the file version number
      		gnFileVersionNum = HVersion(Project)
      		
      		// Refresh the table display
      		TableDisplay(TABLE,taCurrentSelection)
      		
      		// Other linked controls?
      		WHEN EXCEPTION IN 
      			ExecuteProcess("RADDisplay",trtProcedure)
      		DO
      			// Exception corresponding to an unknown procedure?
      			IF ExceptionInfo(errCode)<> 1027 THEN EXCEPTION
      		END
      	END
      END
      
      // Restart the timer
      gnTimerNum = TimerSys("Refresh",gnNoRef)		
      
     type : 458752
   -
     name : ManageRefresh
     procedure_id : 1153301836915290957
     type_code : 14
     code : |1-
      PROCEDURE ManageRefresh(bAutoRef=False)
      
      // Store whether refresh must be managed or not 
      gbManageAutoRef = bAutoRef
      
      // Is a timer enabled?
      IF gnTimerNum > 0 THEN
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	ELSE		
      		// Stops the timer
      		EndTimerSys(gnTimerNum)
      		gnTimerNum= 0
      	END
      ELSE
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	END
      END
     type : 458752
   -
     name : SuspendRefresh
     procedure_id : 1153301836915356509
     type_code : 14
     code : |1-
      PROCEDURE SuspendRefresh(bSuspend=True)
      
      // Suspend the refresh if this one is managed or restart it
      IF bSuspend = True THEN
      	IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer		
      	gnTimerNum = 0
      ELSE
      	// Reenable the timer (if managed)
      	IF gbManageAutoRef=True THEN
      		IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)
      	END
      END
     type : 458752
  procedure_templates : []
  property_templates : []
