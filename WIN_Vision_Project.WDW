  -
    name : BTN_Validate
    identifier : 0x200159e8d578315a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Stop the automatic window refresh
         SuspendRefresh(True)
         
         if TableSelect(Table)>0 then
         	hreadseek(Project,ProjectID,table.ProjectID)
         	if HFound(Project) then
         		
         		//Return Project ID
         		RecID=Project.ProjectID
         		
         		// The window return value is set to 'True'
         		MyWindow..ReturnedValue=True
         		
         		// close the window
         		Close()
         	else
         		info("I could not find this project!")
         	END
         else
         	info("Please select a project!")
         end
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Cancel
    identifier : 0x200159e8d57c316a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         
         
         // The window return value is set to 'False'
         MyWindow..ReturnedValue=False
         
         // if a record was selected during window opening
         // the window, go to this record
         IF gnRecNum<>-1 THEN
         	HRead(Project,gnRecNum)
         	// The context was freed
         	gnRecNum=0
         END
         
         // close the window
         Close()
         	
         	
        type : 18
      -
        type : 161
        enabled : false
