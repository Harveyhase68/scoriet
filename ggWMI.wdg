      // http://msdn2.microsoft.com/en-us/library/aa389273.aspx
      
      // format d'un champ DATETIME
      //	20070809103526.375000+120
      //  AAAAMMJJhhmmss.centièmes+Correction en minute/GMT ??
      //  103526 -> 12h35m26 375/100 +2h GMT ??
     type : 720896
