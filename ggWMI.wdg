     type : 458752
   -
     name : _CreateVbsLoop
     procedure_id : 1752573186275961622
     type_code : 15
     code : |1+
      FUNCTION _CreateVbsLoop(FieldList)
      VbsResult, FieldDefinition, FieldType, FieldName, vbsFieldName, InitialLastBlock, NewLastBlock are strings
      VbsResult =  ""
      
      FieldDefinition = ExtractString(FieldList,firstRank,";")
      WHILE FieldDefinition <> EOT
      	FieldDefinition = NoSpace(FieldDefinition)
      	WHILE Position(FieldDefinition,"  ") > 0
      		FieldDefinition = Replace(FieldDefinition,"  "," ")
      	END
      	FieldType = Upper(NoSpace(ExtractString(FieldDefinition,1," ")))
      	FieldName = ExtractString(FieldDefinition,2," ")
      	
      	SWITCH FieldType
      	
      		CASE "STRING", "STRING.", "BOOLEAN"
      			vbsFieldName = "objItem." + NoSpace(Replace(FieldName,"[]",""))
      			VbsResult += "if IsNull(" + vbsFieldName + ") then" + CRLF
      			VbsResult += "strResult =  strResult & ||  & chr(9)" + CRLF
      			VbsResult += "else" + CRLF
      			VbsResult += "strResult =  strResult & " + vbsFieldName + " & chr(9)" + CRLF
      			VbsResult += "end If" + CRLF
      						
      		CASE "SINT16", "SINT32", "SINT64", "UINT8", "UINT16", "UINT32", "UINT64", "REAL16", "REAL32", "REAL64", "DATETIME"
      			vbsFieldName = "objItem." + NoSpace(Replace(FieldName,"[]",""))
      			VbsResult += "if IsNull(" + vbsFieldName + ") then" + CRLF
      			VbsResult += "strResult =  strResult & ||  & chr(9)" + CRLF
      			VbsResult += "else" + CRLF
      			VbsResult += "strResult =  strResult & CStr(" + vbsFieldName + ") & chr(9)" + CRLF
      			VbsResult += "end If" + CRLF
      			
      		OTHER CASE
      			IF InTestMode() THEN Trace("type non référencé : " + FieldType)
      END
      	
      	FieldDefinition = ExtractString(FieldList,nextRank,";")
      END
      InitialLastBlock = ExtractString(VbsResult,lastRank,"if")
      NewLastBlock = Replace(InitialLastBlock,"chr(9)","chr(13) & chr(10)")
      VbsResult = Replace(VbsResult,InitialLastBlock,NewLastBlock)
      RESULT VbsResult
