 message_bar :
  internal_properties : BgAAAAYAAAA67fgqjL+BlNW0l7RVb9QHekfVEUcR8SpB62EFBVueAPYoi1/j/aXUAO/gLLyCTVuQazFai314Ui0SG0rWW0oZm0BFICoRFAhcTeX8
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1+
      // Open the Form window
      // In:CallMode=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      //				- "LinkedBrowse"	Browse the file in relation with the parent window
      //							(with deletion and creation)
      
      Procedure RADForm(OpeningMode="Browse")
      
      GLOBAL
      	gnRecNum is int = 0					// current file record
      	gsWindowMode is string					// Window Mode
      	gsModifiedWindow is boolean = False		// Was a record modified? 
      	gsCallMode is string = OpeningMode	//  Call mode of the window
      
      // Management of database access errors
      // Error messages returned by the database are displayed
      // Database error reviews can be processed here
      WHEN EXCEPTION
      	Error("An error occurred in the window",ExceptionInfo(errMessage))
      	// Re-enable the exceptions
      	ExceptionEnable()
      	// Resume the process
      	ReturnToCapture()
      END
      	
      
      
      
      
      
      
      
      
      
      
      
      
      
      
      
      
      
      
   -
     code : |1+
      	
      
      // If the form is opened in 'Browse' mode
      // but the file is empty
      // automatically switch to 'Creation' mode
      IF (OpeningMode="Browse" OR OpeningMode~="LinkedBrowse") AND HNbRec(DataItemsTypeDetails)=0 THEN
      	// opens a dialog box to inform the user
      	Info("No record found in file.","The form will switch to 'Creation' mode.")
      	// change the opening mode
      	OpeningMode="Creation"
      END
      
      // enable the controls according to the window mode
      ModifyWindowMode(OpeningMode)
     type : 34
   -
     code : |1+
      
      
