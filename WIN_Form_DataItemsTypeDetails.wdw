     type : 13
  procedures :
   -
     name : RADFindControl
     procedure_id : 1387068634675801664
     type_code : 14
     code : |1+
      Procedure RADFindControl(sItemName)
      
      WHEN EXCEPTION
      	RESULT ""
      END
      
      // Name of the control corresponding to the specified item
      sControlName is string
      nSubscript is int
      
      
      // Browse the window controls
      nSubscript = 1
      sControlName = EnumControl(WinInput(),nSubscript)
      WHILE NOT sControlName~="" 
      	// Is this control linked to the item specified in parameter
      	IF {sControlName,indControl}..FileLink<>"" THEN
      		IF {{sControlName,indControl}..FileLink}..InitialItem~=sItemName THEN
      			// Return the name of the control linked to the specified item		
      			RESULT sControlName
      		END
      	END
      	
      	// Continue to browse the window controls
      	nSubscript++
      	sControlName = EnumControl(WinInput(),nSubscript)
      END
      
      
      // Return an empty string if no control is linked to this item
      RESULT ""
     type : 458752
   -
     name : RADDisplay
     procedure_id : 1387068634675867216
     type_code : 14
     code : |1-
      	
      Procedure RADDisplay()
      // Called when displaying the form or when going to to the next form
      FileToScreen()
      	
      	
     type : 458752
   -
     name : RADClear
     procedure_id : 1387068634675932752
     type_code : 14
     code : |1-
      Procedure RADClear()
      // Called by the 'New' button or in form creation
      Reset
      
      	
      	
     type : 458752
   -
     name : RADSave
     procedure_id : 1387068634675998288
     type_code : 14
     code : |1-
      Procedure RADSave()
      // Function called when clicking the 'OK' button
      // Returns 'True' if the record is validated, 'False' otherwise
      // Transfer controls to file buffer
      ScreenToFile()
      
      // The record is valid
      RESULT True
      	
      	
     type : 458752
   -
     name : CheckModification
     procedure_id : 1387068634676063824
     type_code : 14
     code : |1-
      // check the form modifications
      // If the form was modified, ask the user
      // for confirmation
      // Modifies the record if user confirmation
      Procedure CheckModification()
      
      // if a control was modified in the form
      IF MyWindow..Modified THEN
      
      	IF YesNo("Form DataItemsTypeDetails modified. Do you want to save these modifications?") THEN
      		// Setup the record and save
      		IF RADSave() THEN
      
      			// Modify the record
      			HModify(DataItemsTypeDetails)
      			IF ErrorOccurred THEN
      				Info("Unable to modify record"+CR+HErrorInfo())
      				RETURN
      			END
      
      			// Indicate that a record was modified (data refresh required)
      			gsModifiedWindow = True
      
      			// indicates that the form is no longer modified
      			MyWindow..Modified=False
      
      
      			// Gray the controls for modification validation
      			IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Grayed
      		END
      	ELSE
      		// Modifications must not be taken into account
      		MyWindow..Modified = False
      
      		// Gray the controls for modification validation
      		IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Grayed
      		
      	END
      END
     type : 458752
   -
     name : ModifyWindowMode
     procedure_id : 1387068634676129360
     type_code : 14
     code : |1+
      // Modify the window mode
      // In:	ModeAppliedWindow=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      Procedure ModifyWindowMode(sModeAppliedWindow)
      
      // local variables
      sRelationKey is string
      sNameLinkedKey is string
      sValRelationKey is string
      
      // Saves the window mode
      gsWindowMode=sModeAppliedWindow
      
      // Link buttons (if any) are accessible by default
      IF ControlExist("GP_LINK") THEN {"GP_LINK"}..State=Active
      
      // Buttons for modification validation (if any) are invisible and grayed by default
      IF ControlExist("GP_APPLY") THEN 
      	GP_APPLY..Visible = False		
      	GP_APPLY..State = Grayed
      END
      
      // switch to 'Browse' mode
      IF sModeAppliedWindow="Browse" OR sModeAppliedWindow~="LinkedBrowse" THEN
      	// buttons of 'browse' mode are visible
      	GP_BROWSE..Visible=True
      	// Invisible mode modification buttons
      	GP_MODIF..Visible=False
      		// buttons for modification validation are visible
      	IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=True		
      
      		// In 'LinkedBrowse' mode, the current record is retained
      		IF gsWindowMode~="LinkedBrowse" THEN
      		gnRecNum = HRecNum(DataItemsTypeDetails)
      	END
      
      	// point to the current record
      	IF gnRecNum<>0 THEN
      		HRead(DataItemsTypeDetails,gnRecNum)
      		gnRecNum = 0
      	// or go to first record
      	ELSE
      		HReadFirst(DataItemsTypeDetails,DataItemsTypeDetailsID)
      	END
      
      	// transfer the file buffer to window controls
      	RADDisplay()
      
      // otherwise, switch to 'Creation' or 'Modif' mode
      ELSE
      	// Buttons of 'Browse' mode are invisible
      	GP_BROWSE..Visible=False
      	// buttons of 'modif' mode are visible
      	GP_MODIF..Visible=True
      	
      	// Management of parameter passing for relation links
      	sRelationKey = ExtractString(gsWindowMode,2,"=")
      	sNameLinkedKey = ExtractString(gsWindowMode,2,".")
      	IF NOT sNameLinkedKey~="" AND NOT sNameLinkedKey~=EOT THEN
      		// Store the value of the relation parameter
      		WHEN EXCEPTION IN
      			sValRelationKey = {sRelationKey}
      		DO
      			sValRelationKey = ""
      		END
      	END
      
      	// If switch to 'Creation' mode
      	IF Left(sModeAppliedWindow,8)~="Creation" THEN
      		IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=False	// buttons for modification validation are invisible
      			// clear the controls
      			HReset(DataItemsTypeDetails)
      			RADClear()
      			// In 'Creation' mode, link buttons (if any) are inaccessible
      			IF ControlExist("GP_LINK") THEN GP_LINK..State=Grayed
      		ELSE
      			// buttons for modification validation are visible
      			IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=True	
      			// stores the current record number
      				gnRecNum = HRecNum(DataItemsTypeDetails)
      		
      		END
      	// transfer the file buffer to window controls
      	RADDisplay()
      
      	// Check whether this is a link for forms on relation file 
      	// (parameter such as Creation=XXX or Modif=XXX)		
      	IF NOT sNameLinkedKey~~"" THEN
      		sControlName is string = RADFindControl(sNameLinkedKey)
      		IF NOT sControlName~="" THEN
      			{sControlName,indControl}..State = Grayed
      			// In 'Creation' mode, use the current value of the linked file
      			IF Left(sModeAppliedWindow,8)~="Creation" THEN {sControlName,indControl} = sValRelationKey
      	
      			// Is a Vision control associated with this control
      			IF ControlExist("Vision_"+sControlName) THEN
      				{"Vision_"+sControlName,indControl}..State = Grayed
      			END			
      		END	
      	END
      
      END
     type : 458752
