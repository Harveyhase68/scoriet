     enabled : false
   -
     code : |1-
      
      // check the form modifications
      CheckModification()
      Close("",gsModifiedWindow)
      	
     type : 2
   -
     code : |1+
      
      
     type : 11
   -
     code : |1+
      
      
     type : 12
