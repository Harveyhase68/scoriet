 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1+
      PROCEDURE WIN_Welcome()
   -
     code : |1+
      
      local
      	s is string
      	
      IF LoadParameter("wizardshow","")="NOSHOW" THEN
      	CBOX_NoShowStarterWindow=True
      ELSE
      	CBOX_NoShowStarterWindow=False
      END
      
      AddProjectList()
      
      FOR i=1 to 10
      	s=INIRead("Scoriet","LastProjectName"+NumToString(i,"d"),"",gsIniFile)
      	IF s<>"" THEN
      		LooperAdd(LOOP_Projects)
      		LOOP_Projects[LooperCount(LOOP_Projects)].BTN_Project=s
      	END
      END
     type : 34
   -
     code : |1+
      
      
