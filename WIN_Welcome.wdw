            if WinStatus(WIN_Main)<>NotFound then
            	hreadseek(Project,ProjectName,MySelf..Caption,hIdentical)
            	if hfound(Project) then
            		WIN_Main.COMBO_Project=Project.ProjectID
            		close()
            	else
            		info("Projekt nicht mehr gespeichert!")
            	END
            end
