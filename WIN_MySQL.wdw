  -
    name : BTN_NoName2
    identifier : 0x2f99aa898fb1290c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	ctCdn is connection
         	dsDATA is data Source
         	bRes is boolean
         	sSQL is string
         	
         ctCdn..Server=EDT_Server
         ctCdn..User=EDT_Username
         ctCdn..Password=EDT_Password
         ctCdn..Database=COMBO_Databases
         ctCdn..Provider = hNativeAccessMySQL
         ctCdn..CursorOptions = hClientCursor
         ctCdn..Access=hOReadWrite
         
         WHEN EXCEPTION IN
         	SocketConnect("mysql",3306,EDT_Server,1000)
         	SocketClose("mysql")
         DO
         	Error(<§$0000§>+crlf+HErrorInfo(hErrFullDetails)+crlf)
         	RESULT False
         END
         
         when exception in
         	bRes=HOpenConnection(ctCdn)
         	IF NOT bRes THEN
         		EDT_Username..BrushColor=iLightRed
         		EDT_Password..BrushColor=iLightRed
         		Error(<§$0000§>+crlf+HErrorInfo(hErrFullDetails)+crlf)
         		RESULT False
         	ELSE
         		sSQL="show databases;"
         		HExecuteSQLQuery(dsDATA,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
         		HReadFirst(dsDATA)
         		ListDeleteAll(COMBO_Databases)
         		WHILE NOT HOut(dsDATA)
         			ListAdd(COMBO_Databases,{"dsDATA.Database",indItem})
         			HReadNext(dsDATA)
         		END
         		HCloseConnection(ctCdn)
         		EDT_Username..BrushColor=LightGreen
         		EDT_Password..BrushColor=LightGreen
         	END
         do
         	Error(<§$0000§>+crlf+HErrorInfo(hErrFullDetails)+crlf)
         	RESULT False
         end
         
         HCloseConnection(ctCdn)
         info("Connection sucessful!")
         
         result true
        type : 18
      -
        type : 161
        enabled : false
