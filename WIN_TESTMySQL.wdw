  -
    name : BTN_Show
    identifier : 0x2f7da44eb7d41c6b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         
         LOCAL
         	ctCdn is connection
         	dsDATA is data Source
         	bRes is boolean
         	s is string
         	sSQL is string
         	
         ctCdn..Server=EDT_Server
         ctCdn..User=EDT_Username
         ctCdn..Password=EDT_Password
         ctCdn..Database=COMBO_Databases
         ctCdn..Provider = hNativeAccessMySQL
         ctCdn..CursorOptions = hClientCursor
         ctCdn..Access=hOReadWrite
         
         bRes=HOpenConnection(ctCdn)
         IF NOT bRes THEN
         	Error(<§$0000§>+crlf+HErrorInfo(hErrFullDetails)+crlf)
         	RESULT False
         ELSE
         	sSQL="SHOW FULL COLUMNS FROM " + TABLE_Tables.COL_TableName[TableSelect(TABLE_Tables)] + ";"
         	HExecuteSQLQuery(dsDATA,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
         	HReadFirst(dsDATA)
         	//TableDeleteAll(TABLE_Tables)
         	WHILE NOT HOut(dsDATA)
         		//IF {"dsDATA.Table_type",indItem}="BASE TABLE" THEN
         			s=s+{"dsDATA.Field",indItem}+","
         			s=s+{"dsDATA.Type",indItem}+","
         			s=s+{"dsDATA.Collation",indItem}+","
         			s=s+{"dsDATA.Null",indItem}+"," //YES, NO
         			s=s+{"dsDATA.Key",indItem}+"," //PRI = Primary, 	MUL = Multiple key (Index), UNI=unique key
         			s=s+{"dsDATA.Default",indItem}+","
         			s=s+{"dsDATA.Extra",indItem}+crlf
         		//END
         		HReadNext(dsDATA)
         	END
         	info(s)
         	HCloseConnection(ctCdn)
         END
         
         result true
        type : 18
      -
        type : 161
        enabled : false
