  type_code : 1
  p_codes :
   -
     code : |1+
      PROCEDURE WIN_Update_SQL()
   -
     code : |1-
      
      if ontestmode() then
      	if gnProjectID=0 then
      		gnProjectID=1
      	END
      end
      
      HReadSeek(Project,ProjectID,gnProjectID,hIdentical)
      HReadSeek(DBConnection,DBConnectionID,Project.DBConnectionID,hIdentical)
      ListSelectPlus(COMBO_Database,DBConnection.Type)
      
      ListDeleteAll(COMBO_Version_FROM)
      ListDeleteAll(COMBO_Version_TO)
      
      HFilter(Version,VersionKeyno,HBuildKeyValue(Version,VersionKeyNo,gnProjectID,hMinVal),HBuildKeyValue(Version,VersionKeyNo,gnProjectID,hMaxVal))
      HReadFirst(Version,VersionKeyno)
      while not hout(Version)
      	ListAdd(COMBO_Version_FROM,gLink(Version.VersionID)+version.Title)
      	ListAdd(COMBO_Version_TO,gLink(Version.VersionID)+Version.Title)
      	hreadnext(Version,VersionKeyNo)
      END
      HDeactivateFilter(Version)
      
      //if ontestmode() THEN
      //	ListSelectPlus(COMBO_Version_FROM,1)
      //	ListSelectPlus(COMBO_Version_TO,2)
      //	ListSelectPlus(COMBO_Database,1)
      //END
