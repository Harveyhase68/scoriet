info :
 name : WIN_Update_SQL
 major_version : 25
 minor_version : 0
 type : 2
 description : ""
 subtype : 0
window :
 name : WIN_Update_SQL
 identifier : 0x2f70c7f3015baa31
 internal_properties : 
 controls :
  -
    name : COMBO_Version_FROM
    identifier : 0x2f70c88d04a00528
    internal_properties : 
    dropdown :
     internal_properties : 
     type : 7
    type : 14
    code_elements :
     type_code : 23
     p_codes :
      -
        type : 35
        enabled : false
      -
        type : 17
        enabled : false
  -
    name : COMBO_Version_TO
    identifier : 0x2f70c8b304cd9989
    internal_properties : 
    dropdown :
     internal_properties : 
     type : 7
    type : 14
    code_elements :
     type_code : 23
     p_codes :
      -
        type : 35
        enabled : false
      -
        type : 17
        enabled : false
  -
    name : BTN_Start
    identifier : 0x2f70c8f107798c74
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         
         local
         	nVersionFrom is int on 8 bytes
         	nVersionTo is int on 8 bytes
         	
         	zz is int
         	xx is int
         	kk is int
         	ki is int
         	
         	stKeySegment is structure
         		sKeyItemName is string
         		nSegment is int
         		bExist is boolean
         		bNew is boolean
         	end
         	stKeys is structure
         		ID is int on 8 bytes
         		sKeyName is string
         		nKeyType is int
         		bPrimary is boolean
         		bUnique is boolean
         		bExist is boolean
         		bNew is boolean
         		bUpdate is boolean
         		arrKeyItems is dynamic array of 0 stKeySegment
         	end
         	stItems is structure
         		sItemName is string
         		bExist is boolean
         		bNew is boolean
         		bUpdate is boolean
         		sType is string
         		sSize is string
         		nKeyType is int
         		bNotNull is boolean
         		bAutoIncrement is boolean
         		sDefault is string
         	end
         	stFiles is structure
         		sFileName is string
         		bExist is boolean
         		bNew is boolean
         		bNewKey is boolean
         		bUpdate is boolean
         		bKeyUpdate is boolean
         		arrItems is dynamic array of 0 stItems
         		arrKeys is dynamic array of 0 stKeys
         	end
         	arrFiles is dynamic array of stfiles
         	sItem is string
         	
         nVersionFrom=val(COMBO_Version_FROM)
         nVersionTo=Val(COMBO_Version_To)
         
         HDeactivateFilter(Project)
         HReadSeek(Project,ProjectID,gnProjectID)
         IF NOT HFound(Project) THEN
         	Error("Projekt nicht gefunden!")
         	return
         END
         
         //Read all data old version
         zz=0
         HFilter(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nVersionFrom,hMinVal),HBuildKeyValue(DataFile,DataFileKey,nVersionFrom,hMaxVal))
         HReadFirst(DataFile,DataFileKey)
         WHILE NOT HOut(DataFile)
         	
         	zz=ArrayAddLine(arrFiles)
         	arrFiles[zz].sFileName=DataFile.FileName
         	
         	//Data items to array
         	xx=0
         	HFilter(DataItems,DataFileID,DataFile.DataFileID,DataFile.DataFileID)
         	HReadFirst(DataItems,DataFileID)
         	WHILE NOT HOut(DataItems)
         		
         		xx=ArrayAddLine(arrFiles[zz].arrItems)
         		arrFiles[zz].arrItems[xx].sItemName=DataItems.ItemName
         		arrFiles[zz].arrItems[xx].sType=DataItems.DB_Data_Type
         		arrFiles[zz].arrItems[xx].sSize=DataItems.Size
         		arrFiles[zz].arrItems[xx].nKeyType=DataItems.KeyType
         		arrFiles[zz].arrItems[xx].bNotNull=DataItems.bNotNull
         		arrFiles[zz].arrItems[xx].bAutoIncrement=DataItems.AutoIncrement
         		arrFiles[zz].arrItems[xx].sDefault=DataItems.sDefault
         		
         		hreadnext(DataItems,DataFileID)
         	end	
         	
         	kk=0
         	HFilter(DataKeys,DataKeysKey,[DataFile.DataFileID,hMinVal,hMinVal],[DataFile.DataFileID,hMaxVal,hMaxVal])
         	HReadFirst(DataKeys,DataKeysKey)
         	while not hout(DataKeys)
         		kk=ArraySeek(arrFiles[zz].arrKeys,asLinear,"sKeyName",DataKeys.KeyName)
         		if kk>0 then
         			ki														= ArrayAddLine(arrFiles[zz].arrKeys[kk].arrKeyItems)
         			arrFiles[zz].arrKeys[kk].ID								= DataKeys.DataKeysID
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].sKeyItemName	= DataKeys.Field
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].nSegment		= DataKeys.Segment
         		else
         			kk														= ArrayAddLine(arrFiles[zz].arrKeys)
         			arrFiles[zz].arrKeys[kk].ID								= DataKeys.DataKeysID
         			arrFiles[zz].arrKeys[kk].sKeyName						= DataKeys.KeyName
         			arrFiles[zz].arrKeys[kk].nKeyType						= DataKeys.KeyType
         			ki														= ArrayAddLine(arrFiles[zz].arrKeys[kk].arrKeyItems)
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].sKeyItemName	= DataKeys.Field
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].nSegment		= DataKeys.Segment
         		end
         		HReadNext(DataKeys,DataKeysKey)
         	END
         	HDeactivateFilter(DataKeys)
         	
         	HReadNext(DataFile,DataFileKey)
         	
         END
         HDeactivateFilter(DataFile)
         
         //Read all data new version
         HFilter(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,nVersionTo,hMinVal),HBuildKeyValue(DataFile,DataFileKey,nVersionTo,hMaxVal))
         HReadFirst(DataFile,DataFileKey)
         WHILE NOT HOut(DataFile)
         	
         	if DataFile.DataFileID=11 then stop
         	
         	zz = ArraySeek(arrFiles,asLinear,"sFileName",DataFile.FileName)
         	if zz<>-1 then
         		arrFiles[zz].bExist=true
         	else
         		zz=ArrayAddLine(arrFiles)
         		arrFiles[zz].bNew=True
         		arrFiles[zz].sFileName=DataFile.FileName
         	end
         	
         	HFilter(DataItems,DataFileID,DataFile.DataFileID,DataFile.DataFileID)
         	HReadFirst(DataItems,DataFileID)
         	WHILE NOT HOut(DataItems)
         		
         		xx = ArraySeek(arrFiles[zz].arrItems,asLinear,"sItemName",DataItems.ItemName)
         		if xx<>-1 then
         			arrFiles[zz].arrItems[xx].bExist=true
         			IF arrFiles[zz].arrItems[xx].sType<>DataItems.DB_Data_Type THEN
         				arrFiles[zz].bUpdate				= True
         				arrFiles[zz].arrItems[xx].bUpdate	= True
         				arrFiles[zz].arrItems[xx].sType		= DataItems.DB_Data_Type
         			END
         			IF arrFiles[zz].arrItems[xx].sSize<>DataItems.Size THEN
         				arrFiles[zz].bUpdate				= True
         				arrFiles[zz].arrItems[xx].bUpdate	= True
         				arrFiles[zz].arrItems[xx].sSize		= DataItems.Size
         			END
         			IF arrFiles[zz].arrItems[xx].nKeyType<> DataItems.KeyType THEN
         				arrFiles[zz].bUpdate					= True
         				arrFiles[zz].arrItems[xx].bUpdate		= True
         				arrFiles[zz].arrItems[xx].nKeyType		= DataItems.KeyType
         			END
         			IF arrFiles[zz].arrItems[xx].bNotNull<>DataItems.bNotNull THEN
         				arrFiles[zz].bUpdate					= True
         				arrFiles[zz].arrItems[xx].bUpdate		= True
         				arrFiles[zz].arrItems[xx].bNotNull		= DataItems.bNotNull
         			END
         			IF arrFiles[zz].arrItems[xx].bAutoIncrement<>DataItems.AutoIncrement THEN
         				arrFiles[zz].bUpdate						= True
         				arrFiles[zz].arrItems[xx].bUpdate			= True
         				arrFiles[zz].arrItems[xx].bAutoIncrement	= DataItems.AutoIncrement
         			END
         			IF arrFiles[zz].arrItems[xx].sDefault<>DataItems.sDefault THEN
         				arrFiles[zz].bUpdate					= True
         				arrFiles[zz].arrItems[xx].bUpdate		= True
         				arrFiles[zz].arrItems[xx].sDefault		= DataItems.sDefault
         			END
         		else
         			xx=arrayseek(arrFiles[zz].arrItems,asLinear,"sItemName",sItem)
         			if xx<>-1 then
         				xx++
         				ArrayInsertLine(arrFiles[zz].arrItems,xx)
         				arrFiles[zz].arrItems[xx].bNew				= True
         				arrFiles[zz].bUpdate						= True
         				arrFiles[zz].arrItems[xx].sItemName			= DataItems.ItemName
         				arrFiles[zz].arrItems[xx].sType				= DataItems.DB_Data_Type
         				arrFiles[zz].arrItems[xx].sSize				= DataItems.Size
         				arrFiles[zz].arrItems[xx].nKeyType			= DataItems.KeyType
         				arrFiles[zz].arrItems[xx].bNotNull			= DataItems.bNotNull
         				arrFiles[zz].arrItems[xx].bAutoIncrement	= DataItems.AutoIncrement
         				arrFiles[zz].arrItems[xx].sDefault			= DataItems.sDefault
         			else
         				xx=ArrayAddLine(arrFiles[zz].arrItems)
         				arrFiles[zz].arrItems[xx].bNew=True
         				arrFiles[zz].bUpdate=True
         				arrFiles[zz].arrItems[xx].sItemName			= DataItems.ItemName
         				arrFiles[zz].arrItems[xx].sType				= DataItems.DB_Data_Type
         				arrFiles[zz].arrItems[xx].sSize				= DataItems.Size
         				arrFiles[zz].arrItems[xx].nKeyType			= DataItems.KeyType
         				arrFiles[zz].arrItems[xx].bNotNull			= DataItems.bNotNull
         				arrFiles[zz].arrItems[xx].bAutoIncrement	= DataItems.AutoIncrement
         				arrFiles[zz].arrItems[xx].sDefault			= DataItems.sDefault
         			end
         		END
         		
         		sItem=DataItems.ItemName
         		
         		HReadNext(DataItems,DataFileID)
         	END
         	
         	kk=0
         	HFilter(DataKeys,DataKeysKey,[DataFile.DataFileID,hMinVal,hMinVal],[DataFile.DataFileID,hMaxVal,hMaxVal])
         	HReadFirst(DataKeys,DataKeysKey)
         	WHILE NOT HOut(DataKeys)
         		//if DataFile.FileName="vat" then stop
         		kk=ArraySeek(arrFiles[zz].arrKeys,asLinear,"sKeyName",DataKeys.KeyName)
         		IF kk>0 THEN
         			arrFiles[zz].arrKeys[kk].bExist=true
         			if arrFiles[zz].arrKeys[kk].nKeyType<>DataKeys.KeyType then
         				arrFiles[zz].arrKeys[kk].bUpdate=True
         			END
         		ELSE
         			kk														= ArrayAddLine(arrFiles[zz].arrKeys)
         			arrFiles[zz].arrKeys[kk].bExist=false
         			arrFiles[zz].arrKeys[kk].bNew=true
         			arrFiles[zz].arrKeys[kk].ID								= DataKeys.DataKeysID
         			arrFiles[zz].arrKeys[kk].sKeyName						= DataKeys.KeyName
         			arrFiles[zz].arrKeys[kk].nKeyType						= DataKeys.KeyType
         		END
         		ki=ArraySeek(arrFiles[zz].arrKeys[kk].arrKeyItems,asLinear,"sKeyItemName;nSegment",DataKeys.Field,DataKeys.Segment)
         		if ki>0 then
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].bExist=true
         		else
         			ki														= ArrayAddLine(arrFiles[zz].arrKeys[kk].arrKeyItems)
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].sKeyItemName	= DataKeys.Field
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].nSegment		= DataKeys.Segment
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].bExist=false
         			arrFiles[zz].arrKeys[kk].arrKeyItems[ki].bNew=True
         		end
         		HReadNext(DataKeys,DataKeysKey)
         	END
         	HDeactivateFilter(DataKeys)
         	
         	HReadNext(DataFile,DataFileKey)
         END
         HDeactivateFilter(DataFile)
         
         for f=1 to Dimension(arrFiles)
         	ArraySort(arrFiles[f].arrKeys,asMember,"+ID")
         	for k=1 to Dimension(arrFiles[f].arrKeys)
         		if arrFiles[f].arrKeys[k].bUpdate then
         			arrFiles[f].bKeyUpdate=True
         		END
         		for i=1 to Dimension(arrFiles[f].arrKeys[k].arrKeyItems)
         			IF arrFiles[f].arrKeys[k].arrKeyItems[i].bNew THEN
         				arrFiles[f].arrKeys[k].bUpdate=true
         				arrFiles[f].bKeyUpdate=True
         			END
         		END
         	end
         END
         
         switch COMBO_Database
         	case 1,2
         		//MySQL/MariaDB phpMySQL
         		EDT_SQL_Script+="-- phpMyAdmin Compatible SQL Script"+CRLF
         		EDT_SQL_Script+="--"+CRLF
         		EDT_SQL_Script+=<§$0001§>+DateToString(DateSys(),"DD.MM.YYYY")+" "+TimeToString(TimeSys(),"HH:MM:SS")+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+="SET SQL_MODE = ""NO_AUTO_VALUE_ON_ZERO"";"+CRLF
         		EDT_SQL_Script+="SET time_zone = ""+00:00"";"+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+="/*!40101 SET @OLD_CHARACTER_SET_CLIENT=@@CHARACTER_SET_CLIENT */;"+CRLF
         		EDT_SQL_Script+="/*!40101 SET @OLD_CHARACTER_SET_RESULTS=@@CHARACTER_SET_RESULTS */;"+CRLF
         		EDT_SQL_Script+="/*!40101 SET @OLD_COLLATION_CONNECTION=@@COLLATION_CONNECTION */;"+CRLF
         		EDT_SQL_Script+="/*!40101 SET NAMES utf8mb4 */;"+CRLF
         		EDT_SQL_Script+=""+CRLF
         	case 3
         		//MySQL Navicat
         		EDT_SQL_Script+="/*"+CRLF
         		EDT_SQL_Script+=" Navicat Premium Data Transfer Compatible SQL Script"+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+=" Source Server Type    : MySQL"+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+=" Target Server Type    : MySQL"+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+=" Date: "+DateToString(datesys(),"DD.MM.YYYY")+" "+TimeToString(timesys(),"HH:MM:SS")+CRLF
         		EDT_SQL_Script+="*/"+CRLF
         		EDT_SQL_Script+=""+CRLF
         		EDT_SQL_Script+="SET NAMES utf8mb4;"+CRLF
         		EDT_SQL_Script+="SET FOREIGN_KEY_CHECKS = 0;"+CRLF
         		EDT_SQL_Script+=""+CRLF
         	OTHER CASE
         		
         END
         
         for f=1 to Dimension(arrFiles)
         	if arrFiles[f].bNew=True then
         		EDT_SQL_Script+="CREATE TABLE IF NOT EXISTS `"+arrFiles[f].sFileName+"` ("+crlf
         		FOR i=1 to Dimension(arrFiles[f].arrItems)
         			if arrFiles[f].arrItems[i].bNew THEN
         				if arrFiles[f].arrItems[i].bNotNull then
         					EDT_SQL_Script+="  "+"`"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType+" NOT NULL"
         				else
         					EDT_SQL_Script+="  "+"`"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType
         				end
         				IF arrFiles[f].arrItems[i].sDefault<>"" THEN
         					switch arrFiles[f].arrItems[i].sDefault
         						case "NULL"
         							EDT_SQL_Script+=" DEFAULT "+arrFiles[f].arrItems[i].sDefault
         						case "CURRENT_TIMESTAMP"
         							if COMBO_Database=2 then
         								//Replace default CURRENT_TIMESTAMP to '0000-00-00 00:00:00', because MariaDB cannot handle CURRENT_TIMESTAMP!!!!
         								EDT_SQL_Script+=" DEFAULT '0000-00-00 00:00:00'"
         							else
         								EDT_SQL_Script+=" DEFAULT "+arrFiles[f].arrItems[i].sDefault
         							end
         						OTHER CASE
         							EDT_SQL_Script+=" DEFAULT '"+arrFiles[f].arrItems[i].sDefault+"'"
         					END
         				END
         				IF arrFiles[f].arrItems[i].bAutoIncrement THEN
         					EDT_SQL_Script+=" AUTO_INCREMENT"
         				END
         				IF Dimension(arrFiles[f].arrKeys)>0 THEN
         					EDT_SQL_Script+=","+CRLF
         				end
         			END
         		ENd
         		FOR k=1 to Dimension(arrFiles[f].arrKeys)
         			switch arrFiles[f].arrKeys[k].nKeyType
         				case 1,2,3
         					switch arrFiles[f].arrKeys[k].nKeyType
         						CASE 2
         							EDT_SQL_Script+="  KEY "
         						case 3
         							EDT_SQL_Script+="  UNIQUE KEY "
         						OTHER CASE
         					END
         					EDT_SQL_Script+="`"+arrFiles[f].arrKeys[k].sKeyName+"` ("
         					FOR ki=1 TO Dimension(arrFiles[f].arrKeys[k].arrKeyItems)
         						EDT_SQL_Script+="`"+arrFiles[f].arrKeys[k].arrKeyItems[ki].sKeyItemName+"`"
         						IF ki<Dimension(arrFiles[f].arrKeys[k].arrKeyItems) THEN
         							EDT_SQL_Script+=","
         						END
         					END
         					EDT_SQL_Script+=")"
         				case 4
         					EDT_SQL_Script+="  PRIMARY KEY ("
         					EDT_SQL_Script+="`"+arrFiles[f].arrKeys[k].arrKeyItems[1].sKeyItemName+"`"
         					EDT_SQL_Script+=")"
         				OTHER CASE
         			END
         			if k<Dimension(arrFiles[f].arrKeys) then
         				EDT_SQL_Script+=","+crlf
         			else
         				EDT_SQL_Script+=CRLF
         			END
         		END
         		EDT_SQL_Script+=") ENGINE="+DataFile.MySQL_Engine+" DEFAULT CHARSET="+DataFile.MySQL_CharSet+";"+CRLF+crlf
         	else if not arrFiles[f].bExist then
         		EDT_SQL_Script+="DROP TABLE IF EXISTS `"+arrFiles[f].sFileName+";"+crlf+crlf
         	else if arrFiles[f].bUpdate then
         		EDT_SQL_Script+="ALTER TABLE `"+arrFiles[f].sFileName+"`"+crlf
         	 	FOR i=1 to Dimension(arrFiles[f].arrItems)
         	 		IF arrFiles[f].arrItems[i].bNew THEN
         	 			sItem=""
         				for t=i-1 to 1 step -1
         					if arrFiles[f].arrItems[t].bExist OR arrFiles[f].arrItems[t].bNew then
         						sItem=arrFiles[f].arrItems[t].sItemName
         						break
         					END
         				END
         				if sItem<>"" then
         					IF arrFiles[f].arrItems[i].bNotNull THEN
         						EDT_SQL_Script+="  "+"ADD `"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType+" NOT NULL"
         					ELSE
         						EDT_SQL_Script+="  "+"ADD `"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType
         					END
         	 			else
         					IF arrFiles[f].arrItems[i].bNotNull THEN
         						EDT_SQL_Script+="  "+"ADD `"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType+" NOT NULL"
         					ELSE
         						EDT_SQL_Script+="  "+"ADD `"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType
         					END
         	 			end
         				IF arrFiles[f].arrItems[i].sDefault<>"" THEN
         					SWITCH arrFiles[f].arrItems[i].sDefault
         						CASE "NULL"
         							EDT_SQL_Script+=" DEFAULT "+arrFiles[f].arrItems[i].sDefault
         						CASE "CURRENT_TIMESTAMP"
         							IF COMBO_Database=2 THEN
         								//Replace default CURRENT_TIMESTAMP to '0000-00-00 00:00:00', because MariaDB cannot handle CURRENT_TIMESTAMP!!!!
         								EDT_SQL_Script+=" DEFAULT '0000-00-00 00:00:00'"
         							ELSE
         								EDT_SQL_Script+=" DEFAULT "+arrFiles[f].arrItems[i].sDefault
         							END
         						OTHER CASE
         							EDT_SQL_Script+=" DEFAULT '"+arrFiles[f].arrItems[i].sDefault+"'"
         					END
         				END
         				IF arrFiles[f].arrItems[i].bAutoIncrement THEN
         					EDT_SQL_Script+=" AUTO_INCREMENT"
         				END
         				EDT_SQL_Script+=" AFTER `"+sItem+"`"
         	 			IF i<Dimension(arrFiles[f].arrItems) THEN
         	 				EDT_SQL_Script+=","+CRLF
         	 			ELSE
         	 				EDT_SQL_Script+=";"+CRLF
         	 			END
         	 		else IF not arrFiles[f].arrItems[i].bExist THEN
         	 			EDT_SQL_Script+="  "+"DROP `"+arrFiles[f].arrItems[i].sItemName+"`"
         	 			IF i<Dimension(arrFiles[f].arrItems) THEN
         	 				EDT_SQL_Script+=","+CRLF
         	 			ELSE
         	 				EDT_SQL_Script+=";"+CRLF
         	 			END
         	 		else if arrFiles[f].arrItems[i].bUpdate then
         	 			if arrFiles[f].arrItems[i].bNotNull then
         	 				EDT_SQL_Script+="  "+"CHANGE `"+arrFiles[f].arrItems[i].sItemName+"` `"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType+" NOT NULL"+crlf
         	 			else
         	 				EDT_SQL_Script+="  "+"CHANGE `"+arrFiles[f].arrItems[i].sItemName+"` `"+arrFiles[f].arrItems[i].sItemName+"` "+arrFiles[f].arrItems[i].sType+""+CRLF
         	 			end
         				IF arrFiles[f].arrItems[i].sDefault<>"" THEN
         					SWITCH arrFiles[f].arrItems[i].sDefault
         						CASE "NULL"
         							EDT_SQL_Script+=" DEFAULT "+arrFiles[f].arrItems[i].sDefault
         						CASE "CURRENT_TIMESTAMP"
         							IF COMBO_Database=2 THEN
         								//Replace default CURRENT_TIMESTAMP to '0000-00-00 00:00:00', because MariaDB cannot handle CURRENT_TIMESTAMP!!!!
         								EDT_SQL_Script+=" DEFAULT '0000-00-00 00:00:00'"
         							ELSE
         								EDT_SQL_Script+=" DEFAULT "+arrFiles[f].arrItems[i].sDefault
         							END
         						OTHER CASE
         							EDT_SQL_Script+=" DEFAULT '"+arrFiles[f].arrItems[i].sDefault+"'"
         					END
         				END
         				IF arrFiles[f].arrItems[i].bAutoIncrement THEN
         					EDT_SQL_Script+=" AUTO_INCREMENT"
         				END
         				EDT_SQL_Script+=","+CRLF
         			END
         	 	END
         	 	EDT_SQL_Script=left(EDT_SQL_Script,Length(EDT_SQL_Script)-3)+";"+crlf
         	 	EDT_SQL_Script+=CRLF
         	else if arrFiles[f].bKeyUpdate OR arrFiles[f].bNewKey then
         		//if arrFiles[f].sFileName="vat" then stop
         		FOR k=1 to Dimension(arrFiles[f].arrKeys)
         			IF arrFiles[f].arrKeys[k].bUpdate THEN
         				//Delete it first!
         				EDT_SQL_Script+="ALTER TABLE `"+arrFiles[f].sFileName+"` DROP INDEX `"+arrFiles[f].arrKeys[k].sKeyName+"`;"+CRLF
         			END
         		end
         		EDT_SQL_Script+="ALTER TABLE `"+arrFiles[f].sFileName+"`"+CRLF
         		for k=1 to Dimension(arrFiles[f].arrKeys)
         			if arrFiles[f].arrKeys[k].bNew or arrFiles[f].arrKeys[k].bUpdate then
         				switch arrFiles[f].arrKeys[k].nKeyType
         					CASE 1,2,3,5,6
         						SWITCH arrFiles[f].arrKeys[k].nKeyType
         							CASE 2
         								EDT_SQL_Script+="  ADD INDEX "
         							CASE 3
         								EDT_SQL_Script+="  ADD UNIQUE KEY "
         							case 5
         								EDT_SQL_Script+="  ADD SPATIAL "
         							CASE 6
         								EDT_SQL_Script+="  ADD FULLTEXT "
         							OTHER CASE
         						END
         						EDT_SQL_Script+="`"+arrFiles[f].arrKeys[k].sKeyName+"` ("
         						FOR ki=1 TO Dimension(arrFiles[f].arrKeys[k].arrKeyItems)
         							EDT_SQL_Script+="`"+arrFiles[f].arrKeys[k].arrKeyItems[ki].sKeyItemName+"`"
         							IF ki<Dimension(arrFiles[f].arrKeys[k].arrKeyItems) THEN
         								EDT_SQL_Script+=","
         							END
         						END
         						EDT_SQL_Script+=")"
         					CASE 4
         						EDT_SQL_Script+="  ADD PRIMARY KEY ("
         						EDT_SQL_Script+="`"+arrFiles[f].arrKeys[k].arrKeyItems[1].sKeyItemName+"`"
         						EDT_SQL_Script+=")"
         					OTHER CASE
         				END
         				EDT_SQL_Script+=";"+crlf
         			END
         		END
         	END
         END
         
         switch COMBO_Database
         	case 1,2
         		EDT_SQL_Script+="/*!40101 SET CHARACTER_SET_CLIENT=@OLD_CHARACTER_SET_CLIENT */;"+CRLF
         		EDT_SQL_Script+="/*!40101 SET CHARACTER_SET_RESULTS=@OLD_CHARACTER_SET_RESULTS */;"+CRLF
         		EDT_SQL_Script+="/*!40101 SET COLLATION_CONNECTION=@OLD_COLLATION_CONNECTION */;"+CRLF
         		EDT_SQL_Script+=""+CRLF
         	case 3
         		EDT_SQL_Script+="SET FOREIGN_KEY_CHECKS = 1;"+crlf
         end
         
         Info("Fertig! Anzahl: "+zz)
        type : 18
      -
        type : 161
        enabled : false
