  -
    name : BTN_NoName3
    identifier : 0x2e10fc5f03aa9ed9
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         local
         	Checkpoint2 is Point
         
         if MyWindow..Modified then
         	SWITCH Dialog(<§?189751C802BB83DB§>)
         		// &Ja
         		CASE 1
         			info("Wir speichern!!!")
         			FOR i=1 to WIRE_WIRE..WayPoint..Count
         				Checkpoint2=WIRE_WIRE..WayPoint[i]
         				Trace(Checkpoint2..X+"/"+Checkpoint2..Y)
         			END
         			MyWindow..Modified=false
         		// &Nein
         		CASE 2
         			
         		// &Abbrechen
         		CASE 3
         			
         	END
         END
        type : 18
      -
        type : 161
        enabled : false
