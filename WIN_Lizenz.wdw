  -
    name : BTN_Register1
    identifier : 0x29f0dbd71b550a82
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         SaveParameter("Username",EDT_Username)
         SaveParameter("Email",EDT_Email)
         
         gsUserName=LoadParameter("Username")
         
         use(WIN_Main)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Register
    identifier : 0x29f0dbd71b560a82
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         local
         	sHeader is string
         	n is int
         	t is int
         	gsCookie is string
         	sResult is string
         	sPOST is string
         	sPassword is string
         	sHashPassword is string
         	m is int
         
         SaveParameter("Username",EDT_Username)
         SaveParameter("Email",EDT_Email)
         gsUserName=LoadParameter("Username")
         
         if EDT_Password<>EDT_Password1 then
         	info(<§$000a§>)
         	ReturnToCapture(EDT_Password1)
         END
         if Length(EDT_Password)<8 then
         	Info(<§$000b§>)
         	ReturnToCapture(EDT_Password)
         eND
         if emailCheckAddress(EDT_Email,emailValidateSyntax)<>emailAddressValid then
         	info(<§$0003§>)
         	ReturnToCapture(EDT_Email)
         END
         
         HTTPRequest("https://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         n=Position(sHeader,"Set-Cookie: ")
         IF n>0 THEN
         	t=Position(sHeader,";",n)
         	gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
         END
         
         //Check email
         HTTPRequest("https://www.scoriet.com/register/read_user.php",gsAgent,gsCookie,"email="+EDT_Email,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         sResult=HTTPGetResult(httpResult)
         
         if not IsNumeric(sResult) then
         	//Fehler ausgeben...
         	info(sResult)
         	return
         END
         
         if not val(sResult)=1 then
         	//Nicht für diese Email registriert, das machen wir jetzt!
         	sPassword=HashString(HA_MD5_128,EDT_Password)
         	m=Length(sPassword)
         	for i=1 to m
         		sHashPassword+=NumToString(asc(middle(sPassword,i,1)),"x")
         	END
         	sHashPassword=lower(sHashPassword)
         	sPOST+="&username="+EDT_Username
         	sPOST+="&password="+sHashPassword
         	sPOST+="&email="+EDT_Email
         	sPOST+="&language="+NumToString(nation(),"d")
         	HTTPRequest("https://www.scoriet.com/register/create_users.php",gsAgent,gsCookie,sPOST,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         	sResult=HTTPGetResult(httpResult)
         	if not sResult="OK" then
         		info(sResult)
         	else
         		info("Vielen Dank!")
         	END
         else
         	info("Vielen Dank!!")
         end
         
         close()
        type : 18
      -
        type : 161
        enabled : false
