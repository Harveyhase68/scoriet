      PROCEDURE WIN_Lizenz()
   -
     code : |1+
      
      local
      	sHeader is string
      	t is int
      	n is int
      	gsCookie is string
      	sLicense is string
      	
      EDT_Username=LoadParameter("Username")
      EDT_Email=LoadParameter("Email")
      
      IF OnTestMode() THEN
      	EDT_Password="prcode68"
      	EDT_Password1=EDT_Password
      END
      
      HTTPRequest("http://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
      sHeader=HTTPGetResult(httpHeader)
      n=Position(sHeader,"Set-Cookie: ")
      IF n>0 THEN
      	t=Position(sHeader,";",n)
      	gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
      END
      
