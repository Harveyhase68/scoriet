  procedures :
   -
     name : Display
     procedure_id : 1542885967968112812
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //Display ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE Display()
      
      local
      	nForeignCount is int
      	nMaxForeignKey is int
      	nSaveDataFile is int
      	nSaveDataFile2 is int
      	nParentID is int on 8 bytes
      	sContent is string
      	
      TableDeleteAll(TABLE_ForeignItems)
      
      if WinStatus(WIN_Main)<>NotFound then
      	gnProjectID=WIN_Main.COMBO_Project
      else
      	gnProjectID=3
      END
      
      HReadSeek(Project,ProjectID,gnProjectID)
      HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      IF NOT HFound(Version) THEN
      	Error("Version "+Project.LastVersionNo+<§$0000§>)
      	RETURN
      END
      
      HFilter(DataFile,DataFileSortKey,HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMaxVal))
      HReadFirst(DataFile,DataFileSortKey)
      WHILE NOT HOut(DataFile)
      	
      	if DataFile.DataFileGenerate then
      
      		nParentID=DataFile.DataFileID
      		
      		nForeignCount=0
      	
      		//VersionID+Parent_Table+Parent_Item
      		HFilter(ForeignKey,ForeignChildKey,HBuildKeyValue(ForeignKey,ForeignChildKey, Version.VersionID, DataFile.FileName,hMinVal),HBuildKeyValue(ForeignKey,ForeignChildKey, Version.VersionID, DataFile.FileName,hMaxVal))
      		HReadFirst(ForeignKey,ForeignChildKey)
      		WHILE NOT HOut(ForeignKey)
      			nMaxForeignKey++
      			HReadNext(ForeignKey,ForeignChildKey)
      		END
      		
      		HReadFirst(ForeignKey,ForeignChildKey)
      		WHILE NOT HOut(ForeignKey)
      			nForeignCount++
      			
      			TableAddLine(TABLE_ForeignItems)
      			
      			TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_ID=ForeignKey.ForeignKeyID
      			
      			//VersionID+FileName
      			sContent=""
      			nSaveDataFile=HSavePosition(DataFile)
      			HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,ForeignKey.Parent_Table),hIdentical)
      			IF HFound(DataFile) THEN
      				TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_SourceFileID=DataFile.DataFileID
      				nSaveDataFile2=HSavePosition(DataFile)
      				HFilter(DataItems,DataItemsKey,HBuildKeyValue(DataItems,DataItemsKey,DataFile.DataFileID,hMinVal),HBuildKeyValue(DataItems,DataItemsKey,DataFile.DataFileID,hMaxVal))
      				HReadFirst(DataItems,DataItemsKey)
      				WHILE NOT HOut(DataItems)
      					sContent+=DataItems.ItemName+gLink(DataItems.DataItemsID)+CR
      					HReadNext(DataItems,DataItemsKey)
      				END
      				HRestorePosition(nSaveDataFile2)
      				sContent=left(sContent,Length(sContent)-1)
      				TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_DisplayedRowID..Content=sContent
      				TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_SortItemID..Content=sContent
      			END
      			HRestorePosition(nSaveDataFile)
      			
      			//DataFileID+ItemName
      			HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,nParentID,ForeignKey.Parent_Item),hIdentical)
      			IF HFound(DataItems) THEN
      				TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_SourceItemID=DataItems.DataItemsID
      			END
      			
      			//VersionID+FileName
      			HReadSeek(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,ForeignKey.Child_Table),hIdentical)
      			IF HFound(DataFile) THEN
      				TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_LinkedFileID=DataFile.DataFileID
      			END
      		
      			//DataFileID+ItemName
      			HReadSeek(DataItems,DataItemsNameKey,HBuildKeyValue(DataItems,DataItemsNameKey,nParentID,ForeignKey.Child_Item),hIdentical)
      			IF HFound(DataItems) THEN
      				TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_LinkedItemID=DataItems.DataItemsID
      			END
      	
      			IF ForeignKey.DisplayItemID>0 THEN
      				HReadSeek(DataItems,DataItemsID,ForeignKey.DisplayItemID,hIdentical)
      				IF HFound(DataItems) THEN
      					TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_DisplayedRowID=DataItems.DataItemsID
      				END
      			END
      			
      			IF ForeignKey.DisplayItemID>0 THEN
      				HReadSeek(DataItems,DataItemsID,ForeignKey.DisplaySortItemID,hIdentical)
      				IF HFound(DataItems) THEN
      					TABLE_ForeignItems[TableCount(TABLE_ForeignItems)].COL_SortItemID=DataItems.DataItemsID
      				END
      			END
      	
      			HReadNext(ForeignKey,ForeignChildKey)
      		END
      	end
      		
      	HReadNext(DataFile,DataFileSortKey)
      	
      END
      
      HDeactivateFilter(ForeignKey)
     type : 458752
