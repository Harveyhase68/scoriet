     text :
      de-DE : Die Lizenz konnte nicht aktiviert werden!
      en-GB : The license could not be activated!
     index : 43
   -
     text :
      de-DE : Bitte wenden Sie sich an office@scoriet.com um eine Lizenz zu erhalten!
      en-GB : Please send a email to office@scoriet.com to get a license!
     index : 44
   -
     text :
      de-DE : "Diese Email wurde noch nicht bestätigt, öffnen Sie Ihr Email Programm und drücken Sie auf den Link!"
      en-GB : "This email was not activated, open your email program, click on the confirmation email to activate your email!"
     index : 45
