  -
    name : BTN_Next1
    identifier : 0x29f0dbc81963ccdd
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sHeader is string
         	sResult is string
         	n is int
         	t is int
         	gsCookie is string
         
         HTTPRequest("http://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         n=Position(sHeader,"Set-Cookie: ")
         IF n>0 THEN
         	t=Position(sHeader,";",n)
         	gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
         END
         
         //Check email
         HTTPRequest("http://www.scoriet.com/register/read_user.php",gsAgent,gsCookie,"email="+EDT_Email,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         sResult=HTTPGetResult(httpResult)
         
         IF NOT IsNumeric(sResult) THEN
         	//Fehler ausgeben...
         	Info(sResult)
         	RETURN
         END
         
         SWITCH Val(sResult)
         	CASE 0
         		//Nicht für diese Email registriert, Fehler
         		info(<§$000c§>)
         		MyWindow..Plane=2
         	CASE 1
         		if gnLicenseType=4 then
         			MyWindow..Plane=4
         		else
         			//Ist für diese Email registriert und bestätigt, wir lesen nun die Lizenz
         			HTTPRequest("http://www.scoriet.com/register/read_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         			sHeader=HTTPGetResult(httpHeader)
         			sResult=HTTPGetResult(httpResult)
         			IF Left(sResult,1)="1" THEN
         				IF ExtractString(sResult,3,";")="1" THEN
         					IF ExtractString(sResult,2,";")=gsLicenseNo THEN
         						EDT_License=ExtractString(sResult,2,";")
         					ELSE
         						//Erneuern!
         						HTTPRequest("http://www.scoriet.com/register/create_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d")+"&language="+NumToString(Nation(),"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         						sHeader=HTTPGetResult(httpHeader)
         						sResult=HTTPGetResult(httpResult)
         						IF Left(sResult,1)="1" OR Left(sResult,1)="2" THEN
         							EDT_License=ExtractString(sResult,2,";")
         						ELSE
         							//info(sResult)
         							Info("Die Lizenz konnte nicht erstellt werden!"+CRLF+CRLF+"Bitte wenden Sie sich an office@scoriet.com um eine Lizenz zu erhalten!")
         							RETURN
         						END
         					END
         				ELSE
         					EDT_License=ExtractString(sResult,2,";")
         				END
         			ELSE
         				HTTPRequest("http://www.scoriet.com/register/create_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d")+"&language="+NumToString(Nation(),"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         				sHeader=HTTPGetResult(httpHeader)
         				sResult=HTTPGetResult(httpResult)
         				IF Left(sResult,1)="1" OR Left(sResult,1)="2" THEN
         					EDT_License=ExtractString(sResult,2,";")
         				ELSE
         					Info("Die Lizenz konnte nicht erstellt werden!"+CRLF+CRLF+"Bitte wenden Sie sich an office@scoriet.com um eine Lizenz zu erhalten!")
         					RETURN
         				END
         			END
         			MyWindow..Plane=5
         		END
         	CASE 2
         		//Ist für diese Email registriert und NICHT bestätigt
         		info(<§$000d§>)
         		MyWindow..Plane=3
         end
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Buy
    identifier : 0x29f0dbc81964ccdd
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         LOCAL
         	sHeader is string
         	sResult is string
         	n is int
         	t is int
         	gsCookie is string
         	
         IF NOT CBOX_LicenseAgree THEN
         	Info(<§$002e§>)
         	RETURN
         END
         
         IF NOT CBOX_BuyNow THEN
         	Info("Bitte wählen Sie 'Ich möchte die Professionelle Lizenz für Scoriet kaufen'")
         	RETURN
         END
         
         HTTPRequest("http://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         n=Position(sHeader,"Set-Cookie: ")
         IF n>0 THEN
         	t=Position(sHeader,";",n)
         	gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
         END
         
         //Check email
         HTTPRequest("http://www.scoriet.com/register/read_user.php",gsAgent,gsCookie,"email="+EDT_Email,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         sResult=HTTPGetResult(httpResult)
         
         IF NOT IsNumeric(sResult) THEN
         	//Fehler ausgeben...
         	Info(sResult)
         	RETURN
         END
         
         SWITCH Val(sResult)
         	CASE 0
         		//Nicht für diese Email registriert, Fehler
         		Info("Diese Email ist noch nicht registriert, bitte versuchen Sie es erneut!")
         		MyWindow..Plane=2
         	CASE 1
         		//Ist für diese Email registriert und bestätigt, wir lesen nun die Lizenz
         		HTTPRequest("http://www.scoriet.com/register/read_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         		sHeader=HTTPGetResult(httpHeader)
         		sResult=HTTPGetResult(httpResult)
         		IF Left(sResult,1)="1" THEN
         			IF ExtractString(sResult,3,";")="1" THEN
         				IF ExtractString(sResult,2,";")=gsLicenseNo THEN
         					EDT_License=ExtractString(sResult,2,";")
         				ELSE
         					//Erneuern!
         					HTTPRequest("http://www.scoriet.com/register/create_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d")+"&language="+NumToString(Nation(),"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         					sHeader=HTTPGetResult(httpHeader)
         					sResult=HTTPGetResult(httpResult)
         					IF Left(sResult,1)="1" OR Left(sResult,1)="2" THEN
         						EDT_License=ExtractString(sResult,2,";")
         					ELSE
         						//info(sResult)
         						Info("Die Lizenz konnte nicht erstellt werden!"+CRLF+CRLF+"Bitte wenden Sie sich an office@scoriet.com um eine Lizenz zu erhalten!")
         						RETURN
         					END
         				END
         			ELSE
         				EDT_License=ExtractString(sResult,2,";")
         			END
         		ELSE
         			HTTPRequest("http://www.scoriet.com/register/create_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d")+"&language="+NumToString(Nation(),"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         			sHeader=HTTPGetResult(httpHeader)
         			sResult=HTTPGetResult(httpResult)
         			IF Left(sResult,1)="1" OR Left(sResult,1)="2" THEN
         				EDT_License=ExtractString(sResult,2,";")
         			ELSE
         				Info("Die Lizenz konnte nicht erstellt werden!"+CRLF+CRLF+"Bitte wenden Sie sich an office@scoriet.com um eine Lizenz zu erhalten!")
         				RETURN
         			END
         		END
         		MyWindow..Plane=5
         	CASE 2
         		//Ist für diese Email registriert und NICHT bestätigt
         		Info("Diese Email wurde noch nicht bestätigt, öffnen Sie Ihr Email Programm und drücken Sie auf den Link!")
         		MyWindow..Plane=3
         END
         
        type : 18
      -
