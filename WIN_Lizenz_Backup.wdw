   -
     code : |1+
      PROCEDURE WIN_Lizenz_Backup()
      
      global
      	gnLicenseType is int
   -
     code : |1+
      
      local
      	sHeader is string
      	t is int
      	n is int
      	gsCookie is string
      	sLicense is string
      	
      gnLicenseType=Val(LoadParameter("LicenseActive","1"))
      EDT_FirstName=LoadParameter("FirstName")
      EDT_Surname=LoadParameter("SurName")
      EDT_Company=LoadParameter("Company")
      EDT_UID=LoadParameter("UID")
      EDT_Street=LoadParameter("Street")
      EDT_PLZ=LoadParameter("PLZ")
      EDT_City=LoadParameter("City")
      COMBO_Country=LoadParameter("Country")
      EDT_Username=LoadParameter("Username")
      EDT_Email=LoadParameter("Email")
      EDT_Phone=LoadParameter("Phone")
      
      IF OnTestMode() THEN
      	EDT_Password="prcode68"
      	EDT_Password1=EDT_Password
      END
      
      HTTPRequest("http://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
      sHeader=HTTPGetResult(httpHeader)
      n=Position(sHeader,"Set-Cookie: ")
      IF n>0 THEN
      	t=Position(sHeader,";",n)
      	gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
      END
      
      
      //Free
      BTN_Free..Pushed=True
      BTN_Free..Image=IMG_Check
      
      switch nation()
      	case 1
