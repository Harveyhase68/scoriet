  -
    name : BTN_Register
    identifier : 0x29f0dbc81955ccdd
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sHeader is string
         	n is int
         	t is int
         	gsCookie is string
         	sResult is string
         	sPOST is string
         	sPassword is string
         	sHashPassword is string
         	m is int
         
         SaveParameter("FirstName",EDT_FirstName)
         SaveParameter("SurName",EDT_Surname)
         SaveParameter("Company",EDT_Company)
         SaveParameter("UID",EDT_UID)
         SaveParameter("Street",EDT_Street)
         SaveParameter("PLZ",EDT_PLZ)
         SaveParameter("City",EDT_City)
         SaveParameter("Country",COMBO_Country.COL_CountryISO)
         SaveParameter("Username",EDT_Username)
         SaveParameter("Email",EDT_Email)
         SaveParameter("Phone",EDT_Phone)
         gsUserName=LoadParameter("Username")
         
         if not BTN_Free..Pushed then
         	info(<§$0001§>)
         	MyWindow..Plane=1
         END
         if EDT_Password<>EDT_Password1 then
         	info(<§$000a§>)
         	ReturnToCapture(EDT_Password1)
         END
         if Length(EDT_Password)<8 then
         	Info(<§$000b§>)
         	ReturnToCapture(EDT_Password)
         END
         if NoSpace(EDT_FirstName)="" then
         	info(<§$0009§>)
         	ReturnToCapture(EDT_FirstName)
         END
         IF NoSpace(EDT_Surname)="" THEN
         	Info(<§$0008§>)
         	ReturnToCapture(EDT_Surname)
         END
         IF NoSpace(EDT_Street)="" THEN
         	Info(<§$0007§>)
         	ReturnToCapture(EDT_Street)
         END
         IF NoSpace(EDT_PLZ)="" THEN
         	Info(<§$0006§>)
         	ReturnToCapture(EDT_PLZ)
         END
         IF NoSpace(EDT_City)="" THEN
         	Info(<§$0005§>)
         	ReturnToCapture(EDT_City)
         END
         IF ListSelect(COMBO_Country)=0 THEN
         	Info(<§$0004§>)
         	ReturnToCapture(COMBO_Country)
         END
         
         if emailCheckAddress(EDT_Email,emailValidateSyntax)<>emailAddressValid then
         	info(<§$0003§>)
         	ReturnToCapture(EDT_Email)
         END
         
         HTTPRequest("http://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         n=Position(sHeader,"Set-Cookie: ")
         IF n>0 THEN
         	t=Position(sHeader,";",n)
         	gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
         END
         
         //Check email
         HTTPRequest("http://www.scoriet.com/register/read_user.php",gsAgent,gsCookie,"email="+EDT_Email,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         sHeader=HTTPGetResult(httpHeader)
         sResult=HTTPGetResult(httpResult)
         
         if not IsNumeric(sResult) then
         	//Fehler ausgeben...
         	info(sResult)
         	return
         END
         
         switch val(sResult)
         	case 0
         		//Nicht für diese Email registriert, das machen wir jetzt!
         		sPassword=HashString(HA_MD5_128,EDT_Password)
         		m=Length(sPassword)
         		for i=1 to m
         			sHashPassword+=NumToString(asc(middle(sPassword,i,1)),"x")
         		END
         		sHashPassword=lower(sHashPassword)
         		sPOST+="&username="+EDT_Username
         		sPOST+="&password="+sHashPassword
         		sPOST+="&email="+EDT_Email
         		sPOST+="&firstname="+EDT_FirstName
         		sPOST+="&surname="+EDT_Surname
         		sPOST+="&company="+EDT_Company
         		sPOST+="&UID="+EDT_UID
         		sPOST+="&street="+EDT_Street
         		sPOST+="&plz="+EDT_PLZ
         		sPOST+="&city="+EDT_City
         		sPOST+="&country="+COMBO_Country
         		sPOST+="&phone="+EDT_Phone
         		sPOST+="&language="+NumToString(nation(),"d")
         		HTTPRequest("http://www.scoriet.com/register/create_users.php",gsAgent,gsCookie,sPOST,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         		sResult=HTTPGetResult(httpResult)
         		if sResult="OK" then
         			//Registrierung abgeschlossen
         			MyWindow..Plane=3
         		else
         			info(sResult)
         		END
         	case 1
         		//Ist für diese Email registriert und bestätigt, wir lesen nun die Lizenz
         		MyWindow..Plane=3
         	case 2
         		//Ist für diese Email registriert und NICHT bestätigt
         		MyWindow..Plane=3
         END
        type : 18
      -
        type : 161
        enabled : false
