  -
    name : BTN_ActivateLicense
    identifier : 0x29f0dbc81975ccdd
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         LOCAL
         	sHeader is string
         	sResult is string
         	n is int
         	t is int
         	gsCookie is string
         
         if CBOX_LicenseAgreeFree then
         	HTTPRequest("http://www.scoriet.com/register/index.php",gsAgent,"","","application/x-www-form-urlencoded","scoriet","remove_this_password")
         	sHeader=HTTPGetResult(httpHeader)
         	n=Position(sHeader,"Set-Cookie: ")
         	IF n>0 THEN
         		t=Position(sHeader,";",n)
         		gsCookie="Cookie: "+Middle(sHeader,n+12,t-(n+12))
         	END
         	
         	//Check email
         	HTTPRequest("http://www.scoriet.com/register/read_user.php",gsAgent,gsCookie,"email="+EDT_Email,"application/x-www-form-urlencoded","scoriet","remove_this_password")
         	sHeader=HTTPGetResult(httpHeader)
         	sResult=HTTPGetResult(httpResult)
         	
         	IF NOT IsNumeric(sResult) THEN
         		//Fehler ausgeben...
         		Info(sResult)
         		RETURN
         	END
         	
         	SWITCH Val(sResult)
         		CASE 0
         			//Nicht für diese Email registriert, Fehler
         			Info(<§$0028§>)
         			MyWindow..Plane=2
         		CASE 1
         			//Ist für diese Email registriert und bestätigt, wir lesen nun die Lizenz
         			HTTPRequest("http://www.scoriet.com/register/read_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         			sHeader=HTTPGetResult(httpHeader)
         			sResult=HTTPGetResult(httpResult)
         			IF Left(sResult,1)="1" THEN
         				IF ExtractString(sResult,3,";")="0" THEN
         					//Aktivieren
         					HTTPRequest("http://www.scoriet.com/register/activate_license.php",gsAgent,gsCookie,"email="+EDT_Email+"&licensetype="+NumToString(gnLicenseType,"d")+"&license="+ExtractString(sResult,2,";"),"application/x-www-form-urlencoded","scoriet","remove_this_password")
         					sHeader=HTTPGetResult(httpHeader)
         					sResult=HTTPGetResult(httpResult)
         					IF Left(sResult,1)="1" then
         						SaveParameter("LicenseName",EDT_Email)
         						saveParameter("LicenseNo",ExtractString(sResult,2,";"))
         						saveParameter("LicenseActive",gnLicenseType)
         						gsUserName=LoadParameter("Username")
         						gsLicenseNo=LoadParameter("LicenseNo")
         						Info(<§$002a§>)
         						use(WIN_Main)
         					else if Left(sResult,1)="2" THEN
         						Info(<§$0029§>)
         						Use(WIN_Main)
         					ELSE
         						//info(sResult)
         						Info(<§$002b§>+CRLF+CRLF+<§$002c§>)
         						RETURN
         					END
         				ELSE
         					SaveParameter("LicenseName",EDT_Email)
         					SaveParameter("LicenseNo",ExtractString(sResult,2,";"))
         					SaveParameter("LicenseActive",gnLicenseType)
         					gsUserName=LoadParameter("Username")
         					gsLicenseNo=LoadParameter("LicenseNo")
         					Info("Ihre Lizenz wurde erfolgreich aktiviert, viel Erfolg mit Scoriet!")
         					Use(WIN_Main)
         				END
         			ELSE
         				Info(<§$002b§>+CRLF+CRLF+<§$002c§>)
         				RETURN
         			END
         			MyWindow..Plane=5
         		CASE 2
         			//Ist für diese Email registriert und NICHT bestätigt
         			Info(<§$002d§>)
         			MyWindow..Plane=3
         	END
         else
         	Info(<§$002e§>)
         end
        type : 18
      -
        type : 161
        enabled : false
