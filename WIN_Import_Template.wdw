 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      
      global
      	gnFileCount is int
      	gnMaxFiles is int
   -
     code : |1+
      
      LOCAL
      	nProjectID is int
      	
      IF WinStatus(WIN_Main)<>NotFound THEN
      	IF ListSelect(WIN_Main.COMBO_Project)>1 THEN
      		gnProjectID=WIN_Main.COMBO_Project
      	ELSE
      		Info("Bitte wählen Sie ein Projekt aus!")
      		Close()
      	END	
      ELSE
      	IF Open(WIN_Vision_Project,nProjectID) THEN
      		gnProjectID=nProjectID
      	ELSE
      		Close()
      	END
      END
      
      HReadSeek(Project,ProjectID,gnProjectID,hIdentical)
      IF NOT HFound(Project) THEN
      	Info(<§$0001§>)
      	Close()
      END
