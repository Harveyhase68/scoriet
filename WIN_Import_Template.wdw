  -
    name : BTN_Choose_ZIP
    identifier : 0x234287db00cf2bb4
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	sFile is string
         	sTemplateFile is string
         
         sFile = fSelect(fExtractPath(sTemplateFile,fDirectory+fDrive), sTemplateFile, "Select a file...", "*.zip" + TAB + "*.zip", "*.zip",fselExist)
         if fFileExist(sFile) then
         	EDT_ZIP=sFile
         end
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Import
    identifier : 0x234287db00d02bc4
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	xml is a xmlDocument, description="template.xml"
         	sTemplateName is string
         	sTemplateFolder is string
         	sTemplateCommentChar is string
         	sDirTemplate is string
         	sXMLFileName is string
         	sBuffer is string
         	nCRC is int on 8 bytes
         	sFileError is string
         	nError is int
         	
         HReadSeek(Project,ProjectID,gnProjectID,hIdentical)
         IF NOT HFound(Project) THEN
         	Info(<§$0001§>)
         	RETURN
         END
         
         sDirTemplate=CompleteDir(CompleteDir(gsTemplatePath)+Template.TemplateFolder)
         sXMLFileName=sDirTemplate+"template.xml"
         
         zipOpen("ZIP",EDT_ZIP,zipRead)
         zipExtractFile("ZIP","template.xml",sDirTemplate)
         xml=XMLOpen(sXMLFileName,fromFile)
         
         sTemplateName=xml.Template.Name
         sTemplateFolder=xml.Template.Folder
         sTemplateCommentChar=xml.Template.CommentChar
         
         zipExtractAll("ZIP",completedir(sDirTemplate)+sTemplateFolder,zipOverwrite)
         
         hreadseek(Template,TemplateName,sTemplateName,hIdentical)
         if hfound(Template) then
         	//Found!
         	Template.TemplateFolder=sTemplateFolder
         	HModify(Template)
         else
         	//Not found!
         	Template.TemplateFolder=sTemplateFolder
         	Template.TemplateName=sTemplateName
         	template.TemplateCommentChar=sTemplateCommentChar
         	hadd(Template)
         END
         
         FOR EACH ARootNode of xml.Template
         	SWITCH ARootNode..Name
         		CASE "TemplatePage"
         			hreadseek(TemplatePage,TemplatePageKey,HBuildKeyValue(TemplatePage,TemplatePageKey,template.TemplateID,ARootNode.Name),hIdentical)
         			if hfound(TemplatePage) then
         				TemplatePage.GenerationType=ARootNode.GenerationID
         				TemplatePage.PersistentFile=ARootNode.Persistent
         				TemplatePage.TemplateExecuteProgramAfter=ARootNode.Execute
         				TemplatePage.TemplatePageConstruct=ARootNode.Construct
         				TemplatePage.TemplatePageFilename=ARootNode.FileName
         				TemplatePage.TemplatePageFolder=ARootNode.Folder
         				TemplatePage.TemplatePageGenerate=ARootNode.Generate
         				TemplatePage.TemplatePageName=ARootNode.Name
         				HModify(TemplatePage)
         			else
         				TemplatePage.GenerationType=ARootNode.GenerationID
         				TemplatePage.PersistentFile=ARootNode.Persistent
         				TemplatePage.TemplateExecuteProgramAfter=ARootNode.Execute
         				TemplatePage.TemplateID=template.TemplateID
         				TemplatePage.TemplatePageConstruct=ARootNode.Construct
         				TemplatePage.TemplatePageFilename=ARootNode.FileName
         				TemplatePage.TemplatePageFolder=ARootNode.Folder
         				TemplatePage.TemplatePageGenerate=ARootNode.Generate
         				TemplatePage.TemplatePageName=ARootNode.Name
         				hadd(TemplatePage)
         			END
         			
         			switch ARootNode.GenerationID
         				case 2
         					//We have a directory...
         					for each aDirectory of ARootNode on TemplatePageFileName
         						//info(aDirectory.FileNameFull)
         						sBuffer=fLoadText(completedir(completedir(sDirTemplate)+sTemplateFolder)+aDirectory.FileNameFull,foAnsi)
         						nCRC=sComputeCrc32(sBuffer)
         						if aDirectory.CRC<>nCRC then
         							sFileError+=CompleteDir(CompleteDir(sDirTemplate)+sTemplateFolder)+aDirectory.FileNameFull+<§$0003§>+crlf
         							nError++
         						END
         					END
         				OTHER CASE
         					sBuffer=fLoadText(CompleteDir(CompleteDir(sDirTemplate)+sTemplateFolder)+ARootNode.FileName,foAnsi)
         					nCRC=sComputeCrc32(sBuffer)
         					IF ARootNode.CRC<>nCRC THEN
         						sFileError+=CompleteDir(CompleteDir(sDirTemplate)+sTemplateFolder)+ARootNode.FileName+<§$0003§>+crlf
         						nError++
         					END
         			END
         		case "TemplateVars"
         			//TemplateID+VarName
         			hreadseek(TemplateVars,TemplateVarsKey,HBuildKeyValue(TemplateVars,TemplateVarsKey,Template.TemplateID,ARootNode.VarName),hIdentical)
         			if hfound(TemplateVars) then
         				TemplateVars.Caption=ARootNode.Name
         				HModify(TemplateVars)
         			else
         				TemplateVars.TemplateID=template.TemplateID
         				TemplateVars.Caption=ARootNode.Name
         				TemplateVars.VarName=ARootNode.VarName
         				hadd(TemplateVars)
         			END
         	END
         END
         
         fDelete(sXMLFileName)
         zipClose("ZIP")
         
         if nError<>0 then
         	error(sFileError)
         else
         	Info(<§$0002§>)
         END
        type : 18
      -
        type : 161
        enabled : false
