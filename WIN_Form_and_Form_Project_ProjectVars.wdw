  -
    name : BTN_OK
    identifier : 0x253f7263036686c2
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         // indicates that control groups are no longer modified
         GP_CONTROL..Modified=False
         GP_LINKEDCONTROL..Modified=False
         
         // according to the window mode
         SWITCH gsWindowMode
         	// 'Creation' mode
         	CASE "Creation"
         		// Setup the record and save
         		ScreenToFile("",Project)
         
         		// Add the record
         		HAdd(Project)
         		IF ErrorOccurred THEN
         			Info("Unable to add record"+CR+HErrorInfo())
         			RETURN
         		END
         
         
         	// 'modif' mode
         	CASE "Modif"
         		// Setup the record and save
         		ScreenToFile("",Project)
         		// Modify the record
         		HModify(Project)
         		IF ErrorOccurred THEN
         			Info("Unable to modify record"+CR+HErrorInfo())
         			RETURN
         		END
         
         END
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" THEN
         	// the new record becomes the current record
         	HRead(Project,gnRecNum)
         
         	// back to source mode
         	ModifyWindowMode(OpeningMode)
         	// in other cases
         ELSE
         	// close the window
         	Close("")
         END
         
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Cancel
    identifier : 0x253f7263036a86c2
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // indicates that control groups are no longer modified
         GP_CONTROL..Modified=False
         GP_LINKEDCONTROL..Modified=False
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" THEN
         	// back to 'Browse' mode
         	ModifyWindowMode("Browse")
         	
         	// if there was a current record
         	IF gnRecNum<>0 THEN
         		// point to the modified record
         		HRead(Project,gnRecNum)
         
         		// and display items in controls
         		Refresh()
         	END
         	// otherwise, close the window
         ELSE
         	Close()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
