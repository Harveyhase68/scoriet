     type : 13
  procedures :
   -
     name : RADDisplay
     procedure_id : 1531068167863502592
     type_code : 14
     code : |1-
      
      Procedure RADDisplay()
      // Called when displaying the form or when going to to the next form
      FileToScreen()
     type : 458752
   -
     name : RADClear
     procedure_id : 1531068167863568128
     type_code : 14
     code : |1-
      
      Procedure RADClear()
      // Called by the 'New' button or in form creation
      Reset
     type : 458752
   -
     name : RADSave
     procedure_id : 1531068167863633664
     type_code : 14
     code : |1-
      
      Procedure RADSave()
      // Function called when clicking the 'OK' button
      // Returns 'True' if the record is validated, 'False' otherwise
      // Transfer controls to file buffer
      ScreenToFile()
      
      // The record is valid
      RESULT True
     type : 458752
   -
     name : ModifyWindowMode
     procedure_id : 1531068167863699200
     type_code : 14
     code : |1-
      
      // In:	ModeAppliedWindow=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      Procedure ModifyWindowMode(nModeAppliedWindow)
      
      // saves the window mode
      gsWindowMode=nModeAppliedWindow
      
      // switch to 'Browse' mode
      IF nModeAppliedWindow="Browse" THEN
      	// buttons of 'browse' mode are visible
      	GP_BROWSE..Visible=True
      	// Invisible mode modification buttons
      	GP_MODIF..Visible=False
      	// controls of linked file must be read-only
      	GP_LINKEDCONTROL..State=Active
      	
      	// point to the current record
      	IF gnRecNum<>0 THEN
      		HRead(Project,gnRecNum)
      
      	// or go to first record
      	ELSE
      		HReadFirst(Project,ProjectID)
      	END
      	
      // otherwise, switch to 'Creation' or 'Modif' mode
      ELSE
      	// buttons of 'browse' mode are invisible
      	GP_BROWSE..Visible=False
      	// buttons of 'modif' mode are visible
      	GP_MODIF..Visible=True
      	
      	IF nModeAppliedWindow="Modif" THEN
      	// controls of linked file are grayed
      		GP_LINKEDCONTROL..State=Active
      	else
      		GP_LINKEDCONTROL..State=Grayed
      	end
      	
      	// If switch to 'Creation' mode
      	IF nModeAppliedWindow="Creation" THEN
      		// clear the controls
      		HReset(Project)
      	ELSE
      		// stores the current record number
      		gnRecNum = HRecNum(Project)
      
      	END
      END
      
      // refresh the controls
      Refresh()
     type : 458752
   -
     name : CheckModification
     procedure_id : 1531068167863764736
     type_code : 14
     code : |1-
      // check the form modifications
      // If the form was modified, ask the user
      // for confirmation
      // Modifies the record if user confirmation
      Procedure CheckModification()
      
      // if a control of Project file was modified in the form
      IF GP_CONTROL..Modified THEN
      	// indicates that the form is no longer modified
      	GP_CONTROL..Modified=False
      	// validate the modification of ProjectVars file
      	ValidModif("Project")
      END
      
      // if a control of ProjectVars file was modified in the form
      IF GP_LINKEDCONTROL..Modified THEN
      	// indicates that the form is no longer modified
      	GP_LINKEDCONTROL..Modified=False
      	// validate the modification of ProjectVars file
      	ValidModif("ProjectVars")
      END
     type : 458752
   -
     name : ValidModif
     procedure_id : 1531068167863830272
     type_code : 14
     code : |1-
      // Validate the form modification
      // In: sFileName is the name of the file where the modification must be done
      Procedure ValidModif(sFileName)
      
      // Ask for confirmation
      IF YesNo("The form "+sFileName+" has been modified. Validate these modifications?") THEN
      	// transfer controls to file buffer
      	ScreenToFile("",sFileName)
      
      	// modify the record
      	HModify(sFileName)
      	IF ErrorOccurred THEN
      		Info("Unable to modify record"+CR+HErrorInfo())
      	END
      END
     type : 458752
   -
     name : Refresh
     procedure_id : 1531068167863895808
     type_code : 14
     code : |1+
      // Refresh the window
      // The form part is filled with the file buffer
      // and the table part is refreshed according to
      // the current record in the main file
      Procedure Refresh()
      
      // transfer the file buffer to controls
      
      FileToScreen("",Project)
      
      // filter
      HFilter(ProjectVars,ProjectID,Project.ProjectID)
      
      // read the first record in the linked form
      HReadFirst(ProjectVars,ProjectID)
      
      // clear the file variables if no record found
      IF HOut(ProjectVars) THEN HReset(ProjectVars)
      
      // transfer the file buffer to controls
      FileToScreen("",ProjectVars)
     type : 458752
  procedure_templates : []
  property_templates : []
