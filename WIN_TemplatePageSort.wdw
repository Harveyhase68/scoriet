    name : BTN_First
    identifier : 0x255b11b409c7fbc0
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         local
         	n is int
         	id is int
         	
         IF TableCount(TABLE_Datafields)>0 THEN
         	IF WinStatus(WIN_Main)<>NotFound THEN
         		HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
         	ELSE
         		HReadSeek(Project,ProjectID,1,hIdentical)
         	END
         	IF HFound(Project) THEN
         		HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         		IF HFound(Version) THEN
         			IF TABLE_Datafields.COL_Index>1 THEN
         				n=TABLE_Datafields.COL_Index
         				id=TABLE_Datafields.COL_ID
         				//DataItemsID+TemplatePageID
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,TABLE_Datafields.COL_ID,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					//Temporary replace with 999999
         					DataItemsTypeDetails.SortIndex=999999
         					HModify(DataItemsTypeDetails)
         				END	
         				FOR i=n-1 to 1 step -1
         					//TemplatePageID+VersionID+DataFileID+SortIndex
         					HReadSeek(DataItemsTypeDetails,DataItemsSortKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsSortKey,COMBO_TemplatePage,version.VersionID,COMBO_DataFile,i),hIdentical)
         					IF HFound(DataItemsTypeDetails) THEN
         						DataItemsTypeDetails.SortIndex=i+1
         						HModify(DataItemsTypeDetails)
         					END
         				END
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,TABLE_Datafields.COL_ID,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					//Temporary replace with 999999
         					DataItemsTypeDetails.SortIndex=1
         					HModify(DataItemsTypeDetails)
         				END
         				RefreshItems()
         				TableSelectPlus(TABLE_Datafields,1)
         			end
         		end
         	end	
         end
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Up
    identifier : 0x255b11f109d5eb9a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         
         LOCAL
         	n is int
         	id is int
         	Id2 is int
         	f is int
         	
         IF TableCount(TABLE_Datafields)>0 THEN
         	IF WinStatus(WIN_Main)<>NotFound THEN
         		HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
         	ELSE
         		HReadSeek(Project,ProjectID,1,hIdentical)
         	END
         	IF HFound(Project) THEN
         		HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         		IF HFound(Version) THEN
         			IF TABLE_Datafields.COL_Index>1 THEN
         				n=TABLE_Datafields.COL_Index
         				id=TABLE_Datafields.COL_ID
         				Id2=TABLE_Datafields[TableSelect(TABLE_Datafields)-1].COL_ID
         				//DataItemsID+TemplatePageID
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,id,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					//Temporary replace with 999999
         					DataItemsTypeDetails.SortIndex=999999
         					HModify(DataItemsTypeDetails)
         				END	
         				//TemplatePageID+VersionID+DataFileID+SortIndex
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,Id2,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					DataItemsTypeDetails.SortIndex=n
         					HModify(DataItemsTypeDetails)
         				END
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,id,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					//Temporary replace with 999999
         					DataItemsTypeDetails.SortIndex=n-1
         					HModify(DataItemsTypeDetails)
         				END
         				RefreshItems()
         				f=TableSeek(COL_ID,id,true)
         				TableSelectPlus(TABLE_Datafields,f)
         			END
         		END
         	END	
         END
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Last
    identifier : 0x255b11f309d7f3c5
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         
         LOCAL
         	n is int
         	id is int
         	m is int
         	
         IF TableCount(TABLE_Datafields)>0 THEN
         	IF WinStatus(WIN_Main)<>NotFound THEN
         		HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
         	ELSE
         		HReadSeek(Project,ProjectID,1,hIdentical)
         	END
         	IF HFound(Project) THEN
         		HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         		IF HFound(Version) THEN
         			IF TABLE_Datafields.COL_Index<TableCount(TABLE_Datafields) THEN
         				n=TABLE_Datafields.COL_Index
         				id=TABLE_Datafields.COL_ID
         				//DataItemsID+TemplatePageID
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,TABLE_Datafields.COL_ID,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					//Temporary replace with 999999
         					DataItemsTypeDetails.SortIndex=999999
         					HModify(DataItemsTypeDetails)
         				END
         				
         				m=TableCount(TABLE_Datafields)
         				FOR i=n to m
         					//TemplatePageID+VersionID+DataFileID+SortIndex
         					HReadSeek(DataItemsTypeDetails,DataItemsSortKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsSortKey,COMBO_TemplatePage,Version.VersionID,COMBO_DataFile,i),hIdentical)
         					IF HFound(DataItemsTypeDetails) THEN
         						DataItemsTypeDetails.SortIndex=i-1
         						HModify(DataItemsTypeDetails)
         					END
         				END
         				
         				HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,TABLE_Datafields.COL_ID,COMBO_TemplatePage),hIdentical)
         				IF HFound(DataItemsTypeDetails) THEN
         					//Temporary replace with 999999
         					DataItemsTypeDetails.SortIndex=TableCount(TABLE_Datafields)
         					HModify(DataItemsTypeDetails)
         				END
         				RefreshItems()
         				TableSelectPlus(TABLE_Datafields,1)
         			END
         		END
         	END	
         END
        type : 18
      -
        type : 161
        enabled : false
