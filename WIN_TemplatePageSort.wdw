  procedures :
   -
     name : RefreshData
     procedure_id : 1538492362438960291
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //RefreshData ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshData()
      
      local
      	id is int
      	n is int
      	
      id=COMBO_DataFile
      
      ListDeleteAll(COMBO_DataFile)
      if WinStatus(WIN_Main)<>NotFound then
      	hreadseek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
      else
      	HReadSeek(Project,ProjectID,1,hIdentical)
      end
      if hfound(Project) then
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	if hfound(Version) then
      		
      		//VersionID+DataFileSort
      		hfilter(DataFile,DataFileSortKey,HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMaxVal))
      		HReadFirst(DataFile)
      		while not hout(DataFile)
      			if DataFile.DataFileGenerate then
      		
      				//DataFileID+TemplatePageID
      				HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,COMBO_TemplatePage),hIdentical)
      				if hfound(DataFileTypeDetails) then
      					IF DataFileTypeDetails.FileGenerate THEN
      						ListAdd(COMBO_DataFile,DataFile.FileName+gLink(DataFileTypeDetails.DataFileID))
      					end
      				END
      			end
      			hreadnexT(DataFile,DataFileSortKey)
      		end
      		
      		HDeactivateFilter(DataFile)
      		
      		listsort(COMBO_DataFile)
      		
      		IF ListCount(COMBO_DataFile)>0 THEN
      			n=ListSeek(COMBO_DataFile,id,true)
      			if n<>-1 then
      				ListSelectPlus(COMBO_DataFile,n)	
      			else
      				ListSelectPlus(COMBO_DataFile,1)	
      			END
      			RefreshItems()
      		END
      		
      	end
      end
     type : 458752
   -
     name : RefreshItems
     procedure_id : 1538831694911126740
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //RefreshItems ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshItems()
      
      local
      	stItem is structure
      		nID is int on 8 bytes
      		nSortIndex is int
      	END
      	arrItems is dynamic array of 0 stItem
      	zz is int
      	n is int
      	id is int
      	
      id=COMBO_DataFile
      
      TableDeleteAll(TABLE_Datafields)
      IF WinStatus(WIN_Main)<>NotFound THEN
      	HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
      ELSE
      	HReadSeek(Project,ProjectID,1,hIdentical)
      END
      IF HFound(Project) THEN
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	IF HFound(Version) THEN
      		
      		hfilter(DataItems,DataFileID,COMBO_DataFile,COMBO_DataFile)
      		hreadfirst(DataItems,DataFileID)
      		while not hout(DataItems)
      			//DataItemsID+TemplatePageID
      			hreadseek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,COMBO_TemplatePage),hIdentical)
      			if hfound(DataItemsTypeDetails) then
      				zz++
      				Dimension(arrItems,zz)
      				arrItems[zz].nID=DataItems.DataItemsID
      				arrItems[zz].nSortIndex=DataItemsTypeDetails.SortIndex
      			END
      			hreadnext(DataItems,DataFileID)
      		END
      		HDeactivateFilter(DataItems)
      	end
      end
      
      arraysort(arrItems,asMember,"+nSortIndex")
      
      for i=1 to zz
      	hreadseek(DataItems,DataItemsID,arrItems[i].nID,hIdentical)
      	if hfound(DataItems) then
      		HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,DataItems.DataItemsID,COMBO_TemplatePage),hIdentical)
      		IF HFound(DataItemsTypeDetails) THEN
      			n=TableAddLine(TABLE_Datafields)
      			TABLE_Datafields[n].COL_ID=DataItems.DataItemsID
      			TABLE_Datafields[n].COL_Name=DataItems.ItemName
      			//DataItemsID+TemplatePageID+LanguageID
      			hreadseek(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,DataItems.DataItemsID,COMBO_TemplatePage,COMBO_Language),hIdentical)
      			if hfound(DataItemsTranslation) then
      				TABLE_Datafields[n].COL_Caption=DataItemsTranslation.Caption
      			else
      				TABLE_Datafields[n].COL_Caption=DataItems.ItemName
      				hreset(DataItemsTranslation)
      				DataItemsTranslation.Caption=FormatCaption(DataItems.ItemName)
      				DataItemsTranslation.DataItemsID=DataItems.DataItemsID
      				DataItemsTranslation.LanguageID=COMBO_Language
      				DataItemsTranslation.TemplatePageID=COMBO_TemplatePage
      				DataItemsTranslation.VersionID=version.VersionID
      				hadd(DataItemsTranslation)
      			end
      			TABLE_Datafields[n].COL_Index=DataItemsTypeDetails.SortIndex
      			TABLE_Datafields[n].COL_Generate=DataItemsTypeDetails.ItemGenerate
      		end
      	END
      END
      
      n=ListSeek(COMBO_DataFile,id,true)
      ListSelectPlus(COMBO_DataFile,n)
     type : 458752
