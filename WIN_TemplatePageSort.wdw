         for i=1 to n
         	HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,TABLE_Datafields[i].COL_ID,COMBO_TemplatePage),hIdentical)
         	IF HFound(DataItemsTypeDetails) THEN
         		DataItemsTypeDetails.ItemGenerate=false
         		HModify(DataItemsTypeDetails)
         	END
         END
         
         RefreshItems()
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_GenerateNone1
    identifier : 0x255c323e03678c0a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	id is int
         	t is int
         	nIndex is int
         	bGenerate is boolean
         	sCaption is string
         	m is int
         	n is int
         	
         t=COMBO_TemplatePage
         
         n=tablecount(TABLE_Datafields)
         for i=1 to n
         
         	//DataItemsID+TemplatePageID
         	HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,TABLE_Datafields[i].COL_ID,t),hIdentical)
         	IF HFound(DataItemsTypeDetails) THEN
         		
         		//DataItemsID+TemplatePageID+LanguageID
         		HReadSeek(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,TABLE_Datafields[i].COL_ID,t,COMBO_Language),hIdentical)
         		IF HFound(DataItemsTranslation) THEN
         			sCaption=DataItemsTranslation.Caption
         		else
         			hreadseek(DataItems,DataItemsID,DataItemsTypeDetails.DataItemsID,hIdentical)
         			if hfound(DataItems) then
         				sCaption=FormatCaption(DataItems.ItemName)
         			end
         		END
         		
         		id=DataItemsTypeDetails.DataItemsID
         		nIndex=DataItemsTypeDetails.SortIndex
         		bGenerate=DataItemsTypeDetails.ItemGenerate
         		
         		m=ListCount(COMBO_TemplatePage)
         		for f=1 to m
         			HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailsKey,HBuildKeyValue(DataItemsTypeDetails,DataItemsTypeDetailsKey,id,f),hIdentical)
         			if hfound(DataItemsTypeDetails) then
         				if f<>t then
         					DataItemsTypeDetails.ItemGenerate=bGenerate
         					DataItemsTypeDetails.SortIndex=nIndex
         					HModify(DataItemsTypeDetails)
         
         					//DataItemsID+TemplatePageID+LanguageID
         					HReadSeek(DataItemsTranslation,DataItemsTranslationKey,HBuildKeyValue(DataItemsTranslation,DataItemsTranslationKey,id,f,COMBO_Language),hIdentical)
         					IF HFound(DataItemsTranslation) THEN
         						DataItemsTranslation.Caption=sCaption
         						HModify(DataItemsTranslation)
         					END
         					
         				end
         			end
         		end
         
         	END
         end
         
         RefreshItems()
        type : 18
      -
        type : 161
        enabled : false
