      PROCEDURE WIN_TemplatePageSort()
   -
     code : |1-
      
      HDeactivateFilter(DataFile)
      
      IF WinStatus(WIN_Main)<>NotFound THEN
      	HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
      ELSE
      	HReadSeek(Project,ProjectID,1,hIdentical)
      END
      
      if ListCount(COMBO_Template)>0 then
      	listSelectPlus(COMBO_Template,1)
      end
      
      hreadseek(Language,LanguageID,Project.LanguageID,hIdentical)
      if hfound(Language) then
      	COMBO_Language=Language.LanguageID
      END
      
      //TemplateID+TemplatePageName
      hfilter(TemplatePage,TemplatePageKey,HBuildKeyValue(TemplatePage,TemplatePageKey,COMBO_Template,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKey,COMBO_Template,hMaxVal))
      ListDisplay(COMBO_TemplatePage,taInit)
      if ListCount(COMBO_TemplatePage)>0 then
      	ListSelectPlus(COMBO_TemplatePage,1)
      END
      //TemplatePageID+DataFileID
      RefreshData()
