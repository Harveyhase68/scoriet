  -
    name : BTN_DeleteLine
    identifier : 0x253d68dd19574995
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(No,<§$0009§>) THEN
         	// deletion
         	HDelete(TemplateVars)
         	IF ErrorOccurred THEN
         		Error(<§$000a§>+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// Indicate that a record was modified (data refresh required)
         	gsModifiedWindow = True
         	
         	// reading the next record
         	HReadNext(TemplateVars,TemplateVarsID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(TemplateVars,TemplateVarsID)
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			RADClear()
         			// tell the user that the file is empty
         			Info(<§$000b§>)
         			// done
         			RETURN
         		END
         	END
         	
         	// transfer the file buffer to controls
         	RADDisplay()
         END
         	
         	
        type : 18
