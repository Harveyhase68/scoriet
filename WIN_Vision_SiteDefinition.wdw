  procedures :
   -
     name : DeleteRow
     procedure_id : 1559343926146596168
     type_code : 14
     code : |1-
      Procedure DeleteRow()
     type : 458752
   -
     name : Refresh
     procedure_id : 1559343926146661704
     type_code : 14
     code : |1+
      // Method called by the refresh timer
      Procedure Refresh()
      // Stops the timer
      EndTimerSys(gnTimerNum)
      
      // If the user is not currently in edit
      IF TableInputInProgress(TABLE)=False THEN		
      	// Was the file modified?
      	IF gnFileVersionNum < HVersion(SiteDefinition) THEN
      		// Store the file version number
      		gnFileVersionNum = HVersion(SiteDefinition)
      		
      		// Refresh the table display
      		TableDisplay(TABLE,taCurrentSelection)
      		
      		// Other linked controls?
      		WHEN EXCEPTION IN 
      			ExecuteProcess("RADDisplay",trtProcedure)
      		DO
      			// Exception corresponding to an unknown procedure?
      			IF ExceptionInfo(errCode)<> 1027 THEN EXCEPTION
      		END
      	END
      END
      
      // Restart the timer
      gnTimerNum = TimerSys("Refresh",gnNoRef)		
      
     type : 458752
   -
     name : ManageRefresh
     procedure_id : 1559343926146727240
     type_code : 14
     code : |1-
      Procedure ManageRefresh(bAutoRef=False)
      
      // Store whether refresh must be managed or not 
      gbManageAutoRef = bAutoRef
      
      // Is a timer enabled?
      IF gnTimerNum > 0 THEN
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	ELSE		
      		// Stops the timer
      		EndTimerSys(gnTimerNum)
      		gnTimerNum= 0
      	END
      ELSE
      	// Is an automatic refresh required?
      	IF gbManageAutoRef = True THEN
      		// Start the timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)	
      	END
      END
     type : 458752
   -
     name : SuspendRefresh
     procedure_id : 1559343926146792776
     type_code : 14
     code : |1-
      PROCEDURE SuspendRefresh(bSuspend=True)
      
      // Suspend the refresh if this one is managed or restart it
      IF bSuspend = True THEN
      	IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer		
      	gnTimerNum = 0
      ELSE
      	// Reenable the timer (if managed)
      	IF gbManageAutoRef=True THEN
      		IF gnTimerNum<>0 THEN EndTimerSys(gnTimerNum)		// stop the current timer
      		gnTimerNum = TimerSys("Refresh",gnNoRef)
      	END
      END
     type : 458752
  procedure_templates : []
  property_templates : []
