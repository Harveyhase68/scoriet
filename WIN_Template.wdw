  -
    name : BTN_Vision_DBConnectionID1
    identifier : 0x233ea71d2cfb942b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         LOCAL
         	sDir is string
         	
         IF ListSelect(WIN_Main.COMBO_Project)>0 THEN
         	HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project,hIdentical)
         ELSE
         	Info(<§$0003§>)
         	RETURN
         END
         
         IF fDirectoryExist(CompleteDir(gsTemplatePath)+TemplateFolder) THEN
         	sDir=CompleteDir(gsTemplatePath)+TemplateFolder
         else
         	sDir=CompleteDir(gsTemplatePath)
         end
         
         sDir = fSelectDir("", <§$0011§>, sDir, CompleteDir(gsTemplatePath))
         
         TemplateFolder=Replace(sDir,CompleteDir(gsTemplatePath),"")
        type : 18
      -
        type : 161
        enabled : false
