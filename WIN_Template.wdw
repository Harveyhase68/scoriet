  -
    name : BTN_DeleteLine
    identifier : 0x200127d481ab940e
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(<§$000c§>) THEN
         	// delete the record	
         	HDelete(Template)
         	IF ErrorOccurred THEN
         		Error(<§$000d§>+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// reading the next record
         	HReadNext(Template,TemplateID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(Template,TemplateID)
         		
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			Reset
         			// tell the user that the file is empty
         			Info(<§$000e§>)
         			// done
         			RETURN
         		END
         	END
         	
         	// refresh the form and the linked table
         	Refresh()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
