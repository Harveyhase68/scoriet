  -
    name : BTN_OK
    identifier : 0x200127d4819d9363
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // indicates that the form is no longer modified
         MyWindow..Modified=False
         
         // according to the window mode
         SWITCH gsWindowMode
         	// 'Creation' mode
         	CASE "Creation"
         		// transfer controls to file buffer
         		ScreenToFile()
         		// Add the record
         		HAdd(Template)
         		IF ErrorOccurred THEN
         			Info(<§$0006§>+CR+HErrorInfo())
         			RETURN
         		END
         
         	// 'Modif' mode
         	CASE "Modif"
         		// transfer controls to file buffer
         		ScreenToFile()
         
         		// modify the record
         		HModify(Template)
         		IF ErrorOccurred THEN
         			Info(<§$0007§>+CR+HErrorInfo())
         			RETURN
         		END
         
         END
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" THEN
         	// the new record becomes the current record
         	gnRecNum = HRecNum(Template)
         
         	// Go to the added record
         	IF gnRecNum<>0 THEN
         		HReadSeekFirst(Template,TemplateID,Template.TemplateID)
         	ELSE
         		HReadFirst(Template,TemplateID)
         	END
         
         	// back to source mode
         	ModifyWindowMode(OpeningMode)
         	// in other cases
         ELSE
         	// close the window
         	Close()
         END
         
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Cancel
    identifier : 0x200127d4819f93a1
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // indicates that the form is no longer modified
         MyWindow..Modified=False
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" THEN
         	// back to 'Browse' mode
         	ModifyWindowMode("Browse")
         	
         	// if there was a current record
         	IF gnRecNum<>0 THEN
         		// point to the modified record
         		HRead(Template,gnRecNum)
         	
         		// and display items in controls
         		Refresh()
         	END
         	// otherwise, close the window
         ELSE
         	Close()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
