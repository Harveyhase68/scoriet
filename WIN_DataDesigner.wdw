 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1+
      PROCEDURE MyWindow()
   -
     code : |1+
      
      local
      	arrBilder is dynamic array of 0 control
      	
      gnProjectID=1
      
      //VersionID+FileName
      hreadseek(Project,ProjectID,gnProjectID,hIdentical)
      if hfound(Project) then
      
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	IF HFound(Version) THEN
      	ELSE
      		Error(<§$0000§>)
      		Close()
      	END
      	
      	hfilter(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMaxVal))
      	hreadfirst(DataFile,DataFileKey)
      	while not hout(DataFile)
      		Dimension(arrBilder,Dimension(arrBilder)+1)
      		if DataFile.VD_X<>0 and DataFile.VD_Y<>0 then
      			arrBilder[Dimension(arrBilder)] <- ControlCreate(DataFile.FileName,typImage,DataFile.VD_X,DataFile.VD_Y,DataFile.VD_W,DataFile.VD_H,True)
      		else
      			DataFile.VD_X=random(1,300)
      			DataFile.VD_Y=Random(1,300)
      			HModify(DataFile)
      			arrBilder[Dimension(arrBilder)] <- ControlCreate(DataFile.FileName,typImage,DataFile.VD_X,DataFile.VD_Y,DataFile.VD_W,DataFile.VD_H,True)
      		end
      		dStartDrawing(arrBilder[Dimension(arrBilder)])
      		dRectangle(1,1,100,100,White,Black)
      		
      		dtext(1,1,DataFile.FileName,Black,false)
      		hreadnext(DataFile,DataFileKey)
      	END
      	HDeactivateFilter(DataFile)
      
      end
      
      //Event("MOUSE_DOWN", ".*", WM_LBUTTONDOWN)
