  -
    name : BTN_ModifyTab
    identifier : 0x255c482509da171b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // empty table
         IF TableSelect(LINKEDTABLE)=-1 THEN RETURN
         
         // refresh the table before modification
         // in case modifications were made on another computer
         TableDisplay(LINKEDTABLE,taCurrentSelection)
         
         timersys(Refresh,500,1)
         
         // Open the form of DataItems file in 'Modif' mode
         nAliasName is string = "Modification_DataItems_"+DataItems.DataFileID
         nWindowName is string = "Modify the file DataItems: "+DataItems.DataFileID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_DataItems",nAliasName ,nWindowName ,"Modif")
         END
        type : 18
      -
        type : 161
        enabled : false
