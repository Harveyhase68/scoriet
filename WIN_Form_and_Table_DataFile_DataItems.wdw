    name : BTN_BTNewTab
    identifier : 0x255c482509d8170c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Open the form of DataItems file in 'Creation' mode
         nAliasName is string = "New_DataItems"
         nWindowTitle is string = "New Record: DataItems"
         
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_DataItems",nAliasName ,nWindowTitle ,"Creation")
         END
