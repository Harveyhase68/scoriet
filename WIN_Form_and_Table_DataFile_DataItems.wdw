 message_bar :
  internal_properties : BgAAAAYAAAA67fgqjL+BlNW0l7RVb9QHekfVEUcR8SpB62EFBVueAPYoi1/j/aXUAO/gLLyCTVuQazFai314Ui0SG0rWW0oZm0BFICoRFAhcTeX8
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      // Open the 'Form + Linked Table' window
      // In:CallMode=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      Procedure RADFormAndTable(OpeningMode="Browse",FilterValue="")
      
      GLOBAL
      	gnRecNum	is int = 0		// current file record
      	gsWindowMode is string		// Window Mode
      	
      	
      	// Management of database access errors
      	// Error messages returned by the database are displayed
      // Database error reviews can be processed here
      WHEN EXCEPTION
      	Error(<§$0000§>,ExceptionInfo(errMessage))
      	// Re-enable the exceptions
      	ExceptionEnable()
      	// Resume the process
      	ReturnToCapture()
      END
      
      IF OpeningMode="Browse" AND HNbRec(DataFile)=0 THEN
      	// opens a dialog box to inform the user
      	Info(<§$0001§>)
      	// change the opening mode
      	OpeningMode="Creation"
      END
      
      HReadSeek(Project,ProjectID,WIN_Main.COMBO_Project)
      IF HFound(Project) THEN
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
      	IF HFound(Version) THEN
      		FilterValue="VersionID="+Version.VersionID
      	ELSE
      		Info("Datenbank Version "+Project.LastVersionNo+" konnte nicht gefunden werden!")
      		close()
      	END
      ELSE
      	Info("Projekt "+WIN_Main.COMBO_Project[ListSelect(WIN_Main.COMBO_Project)]+" nicht gefunden!")
      	close()
      END
      
      // Specify the default initial filter
      InitialFilter(FilterValue)
      
      // enable the controls according to the window mode
      ModifyWindowMode(OpeningMode)	
      	
      	
   -
     code : |1-
      
     type : 34
