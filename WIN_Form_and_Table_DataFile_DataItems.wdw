    name : BTN_DeleteLineTab
    identifier : 0x255c482509de171b
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // empty table
         IF TableSelect(LINKEDTABLE)=-1 THEN RETURN
         
         // if the deletion is confirmed
         IF YesNo(No,<§$0006§>) THEN
         	// delete the table row and
         	// the matching record from DataItems file
         	TableDelete(LINKEDTABLE)
         	
         	// display an error if deletion failed
         	IF HError()<>0 THEN Info(<§$0007§>,HErrorInfo())
         END	
        type : 18
      -
