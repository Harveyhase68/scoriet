  -
    name : BTN_DeleteLine
    identifier : 0x255c482509c8170c
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(<§$0004§>) THEN
         	// delete the record	
         	HDelete(DataFile)
         	IF ErrorOccurred THEN
         		Error("Unable to delete record."+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// reading the next record
         	HReadNext(DataFile,DataFileID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(DataFile,DataFileID)
         		
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			Reset
         			// tell the user that the file is empty
         			Info(<§$0005§>)
         			// done
         			RETURN
         		END
         	END
         	
         	// refresh the form and the linked table
         	Refresh()
         END	
         	
         	
        type : 18
      -
        type : 161
        enabled : false
