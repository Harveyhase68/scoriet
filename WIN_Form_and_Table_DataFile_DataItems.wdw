     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // read the first record
         HReadFirst(DataFile,DataFileSortKey)
         
         // no record
         IF HOut() THEN
         	Info(<§$000b§>)
         ELSE
