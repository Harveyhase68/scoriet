 message_bar :
  internal_properties : BgAAAAYAAAA67fgqjL+BlNW0l7RVb9QHekfVEUcR8SpB62EFBVueAPYoi1/j/aXUAO/gLLyCTVuQazFai314Ui0SG0rWW0oZm0BFICoRFAhcTeX8
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1+
      // Open the Form window
      // In:CallMode=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      //				- "LinkedBrowse"	Browse the file in relation with the parent window
      //							(with deletion and creation)
      
      PROCEDURE RADForm(OpeningMode="Browse")
      
      GLOBAL
      	gnRecNum is int = 0					// current file record
      	gsWindowMode is string					// Window Mode
      	gsModifiedWindow is boolean = False		// Was a record modified? 
      	gsCallMode is string = OpeningMode	//  Call mode of the window
      
      // Management of database access errors
      // Error messages returned by the database are displayed
      // Database error reviews can be processed here
      
      WHEN EXCEPTION
      	Error(<§$0000§>,ExceptionInfo(errMessage))
      	// Re-enable the exceptions
      	ExceptionEnable()
      	// Resume the process
      	ReturnToCapture()
      END
   -
     code : |1+
      	
      
      // If the form is opened in 'Browse' mode
      // but the file is empty
      // automatically switch to 'Creation' mode
      IF (OpeningMode="Browse" OR OpeningMode~="LinkedBrowse") AND HNbRec(DataFile)=0 THEN
      	// opens a dialog box to inform the user
      	Info(<§$0001§>,<§$0002§>)
      	// change the opening mode
      	OpeningMode="Creation"
      END
      
      // enable the controls according to the window mode
      ModifyWindowMode(OpeningMode)
     type : 34
   -
     type : 230
     enabled : false
   -
     code : |1-
      
      // check the form modifications
      CheckModification()
      Close("",gsModifiedWindow)
      	
     type : 2
   -
     code : |1+
      
      
     type : 11
   -
     code : |1+
      
      
     type : 12
   -
     code : |1-
      // If a control was modified, activate the group for modification validation
      IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Active
      	
      	
     type : 17
   -
     code : |1+
      
      
     type : 13
  procedures :
   -
     name : RADFindControl
     procedure_id : 1153301798257299929
     type_code : 14
     code : |1+
      PROCEDURE RADFindControl(sItemName)
      
      WHEN EXCEPTION
      	RESULT ""
      END
      
      // Name of the control corresponding to the specified item
      sControlName is string
      nSubscript is int
      
      
      // Browse the window controls
      nSubscript = 1
      sControlName = EnumControl(WinInput(),nSubscript)
      WHILE NOT sControlName~="" 
      	// Is this control linked to the item specified in parameter
      	IF {sControlName,indControl}..FileLink<>"" THEN
      		IF {{sControlName,indControl}..FileLink}..InitialItem~=sItemName THEN
      			// Return the name of the control linked to the specified item		
      			RESULT sControlName
      		END
      	END
      	
      	// Continue to browse the window controls
      	nSubscript++
      	sControlName = EnumControl(WinInput(),nSubscript)
      END
      
      
      // Return an empty string if no control is linked to this item
      RESULT ""
     type : 458752
   -
     name : RADDisplay
     procedure_id : 1153301798257365465
     type_code : 14
     code : |1-
      	
      PROCEDURE RADDisplay()
      
      // Called when displaying the form or when going to to the next form
      FileToScreen()
      	
      IF WinStatus(WIN_Main)<>NotFound THEN
      	gnprojectID=WIN_Main.COMBO_Project
      ELSE
      	gnProjectID=1
      END
      
      HReadSeek(Project,ProjectID,gnProjectID,hIdentical)
      IF NOT HFound(Project) THEN
      	Info(<§$0009§>)
      	close()
      else
      	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,gnProjectID,Project.LastVersionNo),hIdentical)
      	if not hfound(Version) then
      		//1 : Yes
      		//2 : No
      		//3 : Cancel
      		SWITCH Dialog(<§?153D76D403F3D7A1§>)
      			// Yes
      			CASE 1
      				Project.LastVersionNo++
      				HModify(Project)
      				version.Description="Automatic version "+Project.LastVersionNo
      				version.GenerateDateTime=datesys()+timesys()
      				version.ProjectID=Project.ProjectID
      				version.Title="Version "+project.LastVersionNo
      				version.VersionNo=Project.LastVersionNo
      				ListDisplay(COMBO_Version,taInit)
      				hadd(Version)
      			// No
      			CASE 2
      				info(<§$0010§>)
      				close()
      			// Cancel
      			CASE 3
      				close()
      		END
      	else
      		IF gsWindowMode<>"Creation" THEN
      			if DataFile.VersionID<>Version.VersionID then
      				hreadseek(Version,VersionID,DataFile.VersionID,hIdentical)
      				if not HFound(Version) then
      					Info(<§$000d§>+DataFile.VersionID+<§$000c§>)
      					close()
      				end
      			END
      		end
      	END
      END
      
      IF gsWindowMode<>"Creation" THEN
      	TABLE_DataFileTypeDetails..State=Active
      	TABLE_Language..State=Active
      else
      	TABLE_DataFileTypeDetails..State=Grayed
      	TABLE_Language..State=Grayed
      END
      
      RADDisplayTables()
     type : 458752
   -
     name : RADClear
     procedure_id : 1153301798257431001
     type_code : 14
     code : |1+
      PROCEDURE RADClear()
      // Called by the 'New' button or in form creation
      Reset
     type : 458752
   -
     name : RADSave
     procedure_id : 1153301798257496537
     type_code : 14
     code : |1-
      PROCEDURE RADSave()
      // Function called when clicking the 'OK' button
      // Returns 'True' if the record is validated, 'False' otherwise
      // Transfer controls to file buffer
      ScreenToFile()
      
      DataFile.KeyName=COMBO_Keys..StoredValue
      DataFile.DetailKeyName=COMBO_DetailKey..StoredValue
      
      // The record is valid
      RESULT True
      	
     type : 458752
   -
     name : CheckModification
     procedure_id : 1153301798257562104
     type_code : 14
     code : |1-
      // check the form modifications
      // If the form was modified, ask the user
      // for confirmation
      // Modifies the record if user confirmation
      PROCEDURE CheckModification()
      
      // if a control was modified in the form
      IF MyWindow..Modified THEN
      
      	IF YesNo(<§$000e§>) THEN
      		// Setup the record and save
      		IF RADSave() THEN
      
      			// Modify the record
      			HModify(DataFile)
      			IF ErrorOccurred THEN
      				Info(<§$000f§>+CR+HErrorInfo())
      				RETURN
      			END
      			
      			RADUpdateTables()
      			
      			// Indicate that a record was modified (data refresh required)
      			gsModifiedWindow = True
      
      			// indicates that the form is no longer modified
      			MyWindow..Modified=False
      
      
      			// Gray the controls for modification validation
      			IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Grayed
      		END
      	ELSE
      		// Modifications must not be taken into account
      		MyWindow..Modified = False
      
      		// Gray the controls for modification validation
      		IF ControlExist("GP_APPLY") THEN GP_APPLY..State = Grayed
      		
      	END
      END
     type : 458752
   -
     name : ModifyWindowMode
     procedure_id : 1153301798257627656
     type_code : 14
     code : |1+
      // Modify the window mode
      // In:	ModeAppliedWindow=window opening mode:
      //				- "Browse"	Browse all records
      //								with navigation buttons
      //				- "Modif"		Modify the current record
      //				- "Creation"	Create a new record
      PROCEDURE ModifyWindowMode(sModeAppliedWindow)
      
      // local variables
      sRelationKey is string
      sNameLinkedKey is string
      sValRelationKey is string
      
      // Saves the window mode
      gsWindowMode=sModeAppliedWindow
      
      // Link buttons (if any) are accessible by default
      IF ControlExist("GP_LINK") THEN {"GP_LINK",indControl}..State=Active
      
      // Buttons for modification validation (if any) are invisible and grayed by default
      IF ControlExist("GP_APPLY") THEN 
      	GP_APPLY..Visible = False		
      	GP_APPLY..State = Grayed
      END
      
      // switch to 'Browse' mode
      IF sModeAppliedWindow="Browse" OR sModeAppliedWindow~="LinkedBrowse" THEN
      	// buttons of 'browse' mode are visible
      	GP_BROWSE..Visible=True
      	// Invisible mode modification buttons
      	GP_MODIF..Visible=False
      		// buttons for modification validation are visible
      	IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=True		
      
      		// In 'LinkedBrowse' mode, the current record is retained
      		IF gsWindowMode~="LinkedBrowse" THEN
      		gnRecNum = HRecNum(DataFile)
      	END
      
      	// point to the current record
      	IF gnRecNum<>0 THEN
      		HRead(DataFile,gnRecNum)
      		gnRecNum = 0
      	// or go to first record
      	ELSE
      		HReadFirst(DataFile,DataFileID)
      	END
      
      	// transfer the file buffer to window controls
      	RADDisplay()
      
      // otherwise, switch to 'Creation' or 'Modif' mode
      ELSE
      	// Buttons of 'Browse' mode are invisible
      	GP_BROWSE..Visible=False
      	// buttons of 'modif' mode are visible
      	GP_MODIF..Visible=True
      	
      	// Management of parameter passing for relation links
      	sRelationKey = ExtractString(gsWindowMode,2,"=")
      	sNameLinkedKey = ExtractString(gsWindowMode,2,".")
      	IF NOT sNameLinkedKey~="" AND NOT sNameLinkedKey~=EOT THEN
      		// Store the value of the relation parameter
      		WHEN EXCEPTION IN
      			sValRelationKey = {sRelationKey}
      		DO
      			sValRelationKey = ""
      		END
      	END
      
      	// If switch to 'Creation' mode
      	IF Left(sModeAppliedWindow,8)~="Creation" THEN
      		IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=False	// buttons for modification validation are invisible
      			// clear the controls
      			HReset(DataFile)
      			RADClear()
      			// In 'Creation' mode, link buttons (if any) are inaccessible
      			IF ControlExist("GP_LINK") THEN GP_LINK..State=Grayed
      		ELSE
      			// buttons for modification validation are visible
      			IF ControlExist("GP_APPLY") THEN GP_APPLY..Visible=True	
      			// stores the current record number
      				gnRecNum = HRecNum(DataFile)
      		
      		END
      	// transfer the file buffer to window controls
      	RADDisplay()
      
      	// Check whether this is a link for forms on relation file 
      	// (parameter such as Creation=XXX or Modif=XXX)		
      	IF NOT sNameLinkedKey~~"" THEN
      		sControlName is string = RADFindControl(sNameLinkedKey)
      		IF NOT sControlName~="" THEN
      			{sControlName,indControl}..State = Grayed
      			// In 'Creation' mode, use the current value of the linked file
      			IF Left(sModeAppliedWindow,8)~="Creation" THEN {sControlName,indControl} = sValRelationKey
      	
      			// Is a Vision control associated with this control
      			IF ControlExist("Vision_"+sControlName) THEN
      				{"Vision_"+sControlName,indControl}..State = Grayed
      			END			
      		END	
      	END
      
      END
     type : 458752
   -
     name : RADUpdateTables
     internal_properties : 
     procedure_id : 1530517385613522868
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //RADUpdateTables ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RADUpdateTables()
      
      FOR i=1 to TableCount(TABLE_Language)
      	HReadSeek(DataFileTranslation,DataFileTranslationID,TABLE_Language[i].COL_ID,hIdentical)
      	IF HFound(DataFileTranslation) THEN
      		DataFileTranslation.Description=TABLE_Language[i].COL_Description
      		HModify(DataFileTranslation)
      	END
      END
      
      FOR i=1 to TableCount(TABLE_DataFileTypeDetails)
      	HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TABLE_DataFileTypeDetails[i].COL_TemplatePageID),hIdentical)
      	IF HFound(DataFileTypeDetails) THEN
      		DataFileTypeDetails.FileGenerate=TABLE_DataFileTypeDetails[i].COL_FileGenerate
      		HModify(DataFileTypeDetails)
      	ELSE
      		DataFileTypeDetails.DataFileID=DataFile.DataFileID
      		DataFileTypeDetails.TemplatePageID=TABLE_DataFileTypeDetails[i].COL_TemplatePageID
      		DataFileTypeDetails.FileGenerate=True
      		HModify(DataFileTypeDetails)
      	END
      END
      
     type : 458752
   -
     name : RADDisplayTables
     procedure_id : 1530523604728795187
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //RADDisplayTables ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RADDisplayTables()
      
      local
      	arrKeys is array of 0 string
      	n is int
      	nRecord is int
      	nMasterFile is int
      	bGenerateThisTemplatePage is boolean
      
      TableDeleteAll(TABLE_DataFileTypeDetails)
      TableDeleteAll(TABLE_Language)
      
      ListDeleteAll(COMBO_Keys)
      
      IF gsWindowMode<>"Creation" THEN
      	ArrayDeleteAll(arrKeys)
      	
      	HFilter(DataKeys,DataKeysKey,HBuildKeyValue(DataKeys,DataKeysKey,DataFile.DataFileID,hMinVal,hMinVal),HBuildKeyValue(DataKeys,DataKeysKey,DataFile.DataFileID,hMaxVal,hMaxVal))
      	HReadFirst(DataKeys,DataKeysKey)
      	WHILE NOT HOut(DataKeys)
      		IF DataKeys.KeyType=4 or DataKeys.KeyType=3 THEN
      			n=ArraySeek(arrKeys,asLinear,DataKeys.Field)
      			IF n=-1 THEN
      				Dimension(arrKeys,Dimension(arrKeys)+1)
      				arrKeys[Dimension(arrKeys)]=DataKeys.Field
      			END
      		END
      		HReadNext(DataKeys,DataKeysKey)
      	END
      	HDeactivateFilter(DataKeys)
      	
      	FOR i=1 to Dimension(arrKeys)
      		ListAdd(COMBO_Keys,arrKeys[i])
      		IF DataFile.KeyName=arrKeys[i] THEN
      			ListSelectPlus(COMBO_Keys,i)
      		END
      	END
      
      	ListDeleteAll(COMBO_DetailKey)
      	IF DataFile.DetailFileID<>0 THEN
      		ListDeleteAll(COMBO_DetailKey)
      		ArrayDeleteAll(arrKeys)
      		HFilter(DataKeys,DataKeysKey,HBuildKeyValue(DataKeys,DataKeysKey,DataFile.DetailFileID,hMinVal,hMinVal),HBuildKeyValue(DataKeys,DataKeysKey,DataFile.DetailFileID,hMaxVal,hMaxVal))
      		HReadFirst(DataKeys,DataKeysKey)
      		WHILE NOT HOut(DataKeys)
      			IF DataKeys.KeyType=4 OR DataKeys.KeyType=3 THEN
      				n=ArraySeek(arrKeys,asLinear,DataKeys.KeyName)
      				IF n=-1 THEN
      					Dimension(arrKeys,Dimension(arrKeys)+1)
      					arrKeys[Dimension(arrKeys)]=DataKeys.KeyName
      				END
      			END
      			HReadNext(DataKeys,DataKeysKey)
      		END
      		HDeactivateFilter(DataKeys)
      		
      		FOR i=1 to Dimension(arrKeys)
      			ListAdd(COMBO_DetailKey,arrKeys[i])
      			IF DataFile.DetailKeyName=arrKeys[i] THEN
      				ListSelectPlus(COMBO_DetailKey,i)
      			END
      		END
      	END
      
      end
      
      HFilter(ProjectTemplates,ProjectID,gnProjectID,gnProjectID)
      HReadFirst(ProjectTemplates,ProjectID)
      WHILE NOT HOut(ProjectTemplates)
      	HFilter(TemplatePage,TemplatePageID,HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMinVal),HBuildKeyValue(TemplatePage,TemplatePageKeyID,ProjectTemplates.TemplateID,hMaxVal))
      	HReadFirst(TemplatePage,TemplatePageKeyID)
      	WHILE NOT HOut(TemplatePage)
      		
      		HReadSeek(DataFileTypeDetails,DataFileTypeDetailsKey,HBuildKeyValue(DataFileTypeDetails,DataFileTypeDetailsKey,DataFile.DataFileID,TemplatePage.TemplatePageID),hIdentical)
      		IF HFound(DataFileTypeDetails) THEN
      			TableAdd(TABLE_DataFileTypeDetails,TemplatePage.TemplatePageID+TAB+DataFileTypeDetails.FileGenerate)
      			bGenerateThisTemplatePage=DataFileTypeDetails.FileGenerate
      		ELSE
      			DataFileTypeDetails.DataFileID=DataFile.DataFileID
      			DataFileTypeDetails.TemplatePageID=TemplatePage.TemplatePageID
      			DataFileTypeDetails.FileGenerate=True
      			HAdd(DataFileTypeDetails)
      			TableAdd(TABLE_DataFileTypeDetails,TemplatePage.TemplatePageID+TAB+True)
      			bGenerateThisTemplatePage=true
      		END
      		
      		HReadFirst(Language,LanguageID)
      		WHILE NOT HOut(Language)
      			IF bGenerateThisTemplatePage THEN
      				HReadSeek(DataFileTranslation,DataFileTranslationKey,HBuildKeyValue(DataFileTranslation,DataFileTranslationKey,DataFile.DataFileID,TemplatePage.TemplatePageID,Language.LanguageID),hIdentical)
      				IF HFound(DataFileTranslation) THEN
      					if Language.LanguageGenerate then
      						TableAdd(TABLE_Language,DataFileTranslation.DataFileTranslationID+TAB+DataFileTranslation.TemplatePageID+TAB+DataFileTranslation.LanguageID+TAB+DataFileTranslation.Description)
      					end
      				ELSE
      					DataFileTranslation.DataFileID=DataFile.DataFileID
      					DataFileTranslation.VersionID=Version.VersionID
      					DataFileTranslation.LanguageID=Language.LanguageID
      					DataFileTranslation.TemplatePageID=TemplatePage.TemplatePageID
      					DataFileTranslation.Description=DataFile.FileName
      					HAdd(DataFileTranslation)
      					IF Language.LanguageGenerate THEN
      						TableAdd(TABLE_Language,TemplatePage.TemplatePageID+TAB+Language.LanguageID+TAB+DataFileTranslation.Description)			
      					end
      				END
      			END
      			HReadNext(Language,LanguageID)
      		END
      
      		HReadNext(TemplatePage,TemplatePageKeyID)
      	END
      	HDeactivateFilter(TemplatePage)
      	HReadNext(ProjectTemplates,ProjectID)
      END
      HDeactivateFilter(ProjectTemplates)
      
      nMasterFile=DataFile.DetailFileID
      ListDeleteAll(COMBO_DataFileMasterDetail)
      nRecord=HSavePosition(DataFile)
      HFilter(DataFile,DataFileKey,HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileKey,Version.VersionID,hMaxVal))
      HReadFirst(DataFile,DataFileKey)
      WHILE NOT HOut(DataFile)
      	ListAdd(COMBO_DataFileMasterDetail,DataFile.FileName+" ("+DataFile.DataFileID+")"+gLink(DataFile.DataFileID))
      	IF DataFile.DataFileID=nMasterFile THEN
      		ListSelectPlus(COMBO_DataFileMasterDetail,ListCount(COMBO_DataFileMasterDetail))
      	END
      	HReadNext(DataFile,DataFileKey)
      END
      HRestorePosition(nRecord)
