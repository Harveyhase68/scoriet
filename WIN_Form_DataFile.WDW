#To edit and compare internal_properties, use WINDEV integrated tools.
#Internal properties refer to the properties of controls in windows, reports, etc.
info :
 name : WIN_Form_DataFile
 major_version : 26
 minor_version : 0
 type : 2
 description : ""
 subtype : 0
window :
 name : WIN_Form_DataFile
 identifier : 0x200159ded1c0098f
 internal_properties : 
 controls :
  -
    name : BTN_OK
    identifier : 0x200159ded21209fc
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // According to the window mode
         SWITCH Left(ExtractString(gsWindowMode,1,"="),8)
         	// 'Creation' mode
         	CASE "Creation"
         		// Setup the record and save
         		IF RADSave() THEN
         			// Add the record
         			HAdd(DataFile)
         			IF ErrorOccurred THEN
         				Info(<§$0003§>+CR+HErrorInfo())
         				RETURN
         			END
         			
         			RADUpdateTables()
         			
         			// Indicates that the form is no longer modified
         			gsModifiedWindow = gsModifiedWindow OR MyWindow..Modified
         			MyWindow..Modified=False
         
         		END
         	// 'Modif' mode
         	CASE "Modif"
         		// Setup the record and save
         		IF RADSave() THEN
         			// modify the record
         			HModify(DataFile)
         			IF ErrorOccurred THEN
         				Info(<§$0004§>+CR+HErrorInfo())
         				RETURN
         			END
         			
         			RADUpdateTables()
         			
         			// Indicates that the form is no longer modified
         			gsModifiedWindow = gsModifiedWindow OR MyWindow..Modified
         			MyWindow..Modified=False
         
         		END
         END
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" OR OpeningMode~="LinkedBrowse" OR gsCallMode~="Browse" THEN
         	// the new record becomes the current record
         	gnRecNum = HRecNum(DataFile)
         
         	// Was the window opening mode changed?
         	IF gsCallMode ~= "Browse" THEN
         		// Go to the record in order to reinitialize the browse
         		IF gnRecNum<>0 THEN
         			HReadFirst(DataFile)
         		ELSE
         			HReadFirst(DataFile,DataFileID)
         		END
         
         		// Restore the expected opening mode
         		OpeningMode = gsCallMode
         	END
         
         	// back to source mode
         	ModifyWindowMode(OpeningMode)
         	// in other cases
         ELSE
         	// close the window
         	Close("",gsModifiedWindow)
         END
         
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Cancel
    identifier : 0x200159dfd2160cab
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // indicates that the form is no longer modified
         MyWindow..Modified=False
         
         // if the window was opened in 'Browse' mode
         IF OpeningMode="Browse" OR OpeningMode~="LinkedBrowse" THEN
         	
         	// back to 'Browse' or 'LinkedBrowse' mode
         	ModifyWindowMode(OpeningMode)
         	
         	// if there was a current record
         	IF gnRecNum<>0 THEN
         		// point to the modified record
         		HRead(DataFile,gnRecNum)
         
         		// and display items in controls
         		RADDisplay()
         	END
         	// otherwise, close the window
         ELSE
         	Close("",gsModifiedWindow)
         END
         	
         	
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_First
    identifier : 0x200159dfd21a0dc4
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // check the form modifications
         CheckModification()
         
         // read the first record
         HReadFirst(DataFile,DataFileID)
         
         // no record
         IF HOut() THEN
         	Info(<§$0011§>)
         	// otherwise, transfer the file buffer to controls
         ELSE
         	RADDisplay()
         END	
         	
        type : 18
      -
        type : 161
        enabled : false
