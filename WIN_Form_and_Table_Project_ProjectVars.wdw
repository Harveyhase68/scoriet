  -
    name : BTN_BTNewTab
    identifier : 0x253fc1ed02f4ae3a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         local
         	n is int on 8 bytes
         
         if WIN_Main.COMBO_Project=0 then
         	info("Bitte wählen Sie ein Projekt aus!")
         	return 
         END
         n=WIN_Main.COMBO_Project
         gnProjectID=WIN_Main.COMBO_Project
         
         if Open("WIN_Form_ProjectVars","Creation",n) then
         	Refresh()
         END
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_ModifyTab
    identifier : 0x253fc1ed02f6ae3a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // empty table
         IF TableSelect(LINKEDTABLE)=-1 THEN RETURN
         
         // refresh the table before modification
         // in case modifications were made on another computer
         TableDisplay(LINKEDTABLE,taCurrentSelection)
         
         // Open the form of ProjectVars file in 'Modif' mode
         nAliasName is string = "Modification_ProjectVars_"+ProjectVars.ProjectID
         nWindowName is string = "Modify the file ProjectVars: "+ProjectVars.ProjectID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_ProjectVars",nAliasName ,nWindowName ,"Modif")
         END
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLineTab
    identifier : 0x253fc1ed02faae4a
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // empty table
         IF TableSelect(LINKEDTABLE)=-1 THEN RETURN
         
         // if the deletion is confirmed
         IF YesNo(No,"Do you want to delete the row?") THEN
         	// delete the table row and
         	// the matching record from ProjectVars file
         	TableDelete(LINKEDTABLE)
         	
         	// display an error if deletion failed
         	IF HError()<>0 THEN Info("Deletion failed",HErrorInfo())
         END	
        type : 18
      -
        type : 161
        enabled : false
