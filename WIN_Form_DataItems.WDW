          code_elements :
           type_code : 4
           p_codes :
            -
              code : |1+
               
               // Open the Vision+ window
               IF Open(WIN_Vision_DataFile,(DataFileID)) THEN
               	// Refresh the combo box
               	ListDisplay(DataFileID,taCurrentFirst)
               	// Select the correct value in the combo box
               
               	DataFileID=DataFile.DataFileID
               
               	// The window was modified
               	MyWindow..Modified = True
               	GP_APPLY..State = Active
               END
              type : 18
