  -
    name : BTN_DeleteLine
    identifier : 0x200159d9cfe4f7e3
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Ask for confirmation
         IF YesNo(No,<§$000e§>) THEN
         	// deletion
         	HDelete(DataItems)
         	IF ErrorOccurred THEN
         		Error(<§$000f§>+CR+HErrorInfo())
         		RETURN
         	END
         	
         	// Indicate that a record was modified (data refresh required)
         	gsModifiedWindow = True
         	
         	// reading the next record
         	HReadNext(DataItems,DataItemsID)
         	
         	// if the deleted record was the last record
         	IF HOut() THEN
         		// read the last record
         		HReadLast(DataItems,DataItemsID)
         		// no other record found in file
         		IF HOut() THEN
         			// clear the controls
         			RADClear()
         			// tell the user that the file is empty
         			Info(<§$0010§>)
         			// done
         			RETURN
         		END
         	END
         	
         	// transfer the file buffer to controls
         	RADDisplay()
         END
         	
         	
        type : 18
      -
        type : 161
        enabled : false
