 message_bar :
  internal_properties : BgAAAAYAAACzhtfUFnfkcJ4VDyrQTV9UmHJpyofbsDyDQ8DayIvRHyTtpTqfyLYoG5tmoXOUcqHqBxbOTJnOlTSA5tT2NCIIxSvQM/u4StPc7Au+Jg==
 code_elements :
  type_code : 1
  p_codes :
   -
     code : |1-
      
      global
      	gnTimer is int
      	zz is int
      	gsControl is string
   -
     code : |1+
      
      gnTimer=timersys("AboutScroll",10,1)
      switch Nation()
      	case 1
      		//Deutsch
      		gsControl="IMG_About_De"
      	OTHER CASE
      		//Englisch
      		gsControl="IMG_About_En"
      END
      
      dStartDrawing(gsControl,dNoErase)
      dFont("Microsoft Sans Serif",11.5,iBold,0)
      dChangeMode(drawAntiAliasing)
      dText(72,15,ExeInfo(exeVersion),Black,false)
     type : 34
   -
     type : 230
     enabled : false
   -
     code : |1-
      
      EndTimerSys(gnTimer)
     type : 2
   -
     type : 11
   -
     type : 12
   -
     type : 17
   -
     type : 13
   -
     code : |1-
      
      close()
     type : 66049
  procedures :
   -
     name : AboutScroll
     procedure_id : 1571990362882483639
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //AboutScroll ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE AboutScroll()
      	
      CallDLL32("User32","LockWindowUpdate",Handle(MyWindow))
      
      // Copy of IMG_About_De in IMG_ABOUT
      dCopyBlt({gsControl,indControl}, IMG_ABOUT,copySrcCopy,0,zz,IMG_About..Height,IMG_About_De..Width,0,0)
      if zz-IMG_About_De..Height<0 then
      	dCopyBlt({gsControl,indControl}, IMG_ABOUT,copySrcCopy,0,zz-IMG_About_De..Height,IMG_About..Height,IMG_About_De..Width,0,0)
      end
      
      if zz>{gsControl+"..Height",indControl} then
      	zz=4
      else
      	zz=zz+4
      END
      
      CallDLL32("User32","LockWindowUpdate",Null)
     type : 458752
  procedure_templates : []
  property_templates : []
