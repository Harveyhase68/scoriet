  -
    name : BTN_Ready
    identifier : 0x25448c69227832a7
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         local
         	i is int
         	m is int
         	nType is int
         	sFolder is string
         	arrTemplates is dynamic array of 0 int on 8 bytes
         	nOldVersionId is int on 8 bytes
         	
         MySelf..State=Grayed	
         
         m=TableCount(TABLE_Template)
         FOR i=1 to m
         	IF TABLE_Template[i].COL_check THEN
         		sFolder=Replace(Replace(TABLE_Template[i].COL_TableName,EDT_TemplateBasis,""),"\","")
         		HReadSeek(Template,TemplateFolder,sFolder,hIdentical)
         		IF not HFound(Template) THEN
         			Info("Das Template "+sFolder+" wurde noch nicht importiert, bitte importieren Sie das Template und versuchen Sie erneut das Template für dieses Projekt zu verwenden!")
         			return
         		else
         			Dimension(arrTemplates,Dimension(arrTemplates)+1)
         			arrTemplates[Dimension(arrTemplates)]=template.TemplateID
         		END
         	END
         END
         
         m=TableCount(TABLE_TemplateVar)
         for i=1 to m
         	if TABLE_TemplateVar[i].COL_Text="" then
         		hreadseek(TemplateVars,TemplateVarsKey,HBuildKeyValue(TemplateVars,TemplateVarsKey,TABLE_TemplateVar[i].COL_TemplateID,TABLE_TemplateVar[i].COL_LanguageID),hIdentical)
         		if hfound(TemplateVars) then
         			TABLE_TemplateVar[i].COL_Text=TemplateVars.DefaultValue
         		END
         	END
         END
         
         FOR i=1 to 2
         	IF {"BTN_DB"+NumToString(i,"d"),indControl}..Pushed THEN
         		nType=i
         		BREAK
         	END
         END
         
         IF nType=0 THEN
         	Info(<§$0002§>)
         	MyWindow..Plane=2
         	return
         END
         
         if DBConnectionID=0 then
         	DBConnection.Description=Description
         	DBConnection.Server=server
         	DBConnection.Password=Password
         	DBConnection.Username=Username
         	DBConnection.Type=nType
         	hadd(DBConnection)
         else
         	hreadseek(DBConnection,DBConnectionID,DBConnectionID,hIdentical)
         	if not hfound(DBConnection) then
         		error("Datenbank Verbindung nicht gefunden!")
         		MyWindow..Plane=2
         		Close()
         	END
         end
         
         project.Database=Database
         project.DBConnectionID=DBConnection.DBConnectionID
         Project.Directory=EDT_OutputDir
         Project.FileNameShortLength=3
         Project.LanguageID=LanguageID
         Project.LastVersionNo=0
         Project.ProjectName=EDT_ProjektName
         Project.StartPage=""
         gsTemplatePath=EDT_TemplateBasis
         Project.URL=EDT_URL
         Project.WinDevAnalysis=""
         hadd(Project)
         
         gnProjectID=project.ProjectID
         WIN_Main.COMBO_Project=gnProjectID
         
         m=Dimension(arrTemplates)
         for i=1 to m
         	ProjectTemplates.ProjectID=Project.ProjectID
         	ProjectTemplates.TemplateID=arrTemplates[i]
         	hadd(ProjectTemplates)
         END
         
         IF Project.LastVersionNo>0 THEN
         	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         	IF NOT HFound(Version) THEN
         		Error("Datenbank Version " + Project.LastVersionNo+" nicht gefunden!")
         		Close()
         	ELSE
         		nOldVersionId=Version.VersionID
         	END
         END
         
         Project.LastVersionNo++
         HModify(Project)
         
         HReadSeek(Project,ProjectID,gnProjectID)
         
         m=TableCount(TABLE_TemplateVar)
         for i=1 to m
         	//ProjectID+TemplateVarsID+LanguageID
         	hreadseek(ProjectVars,ProjectVarsKey,HBuildKeyValue(ProjectVars,ProjectVarsKey,Project.ProjectID,TABLE_TemplateVar[i].COL_TemplateVarID,TABLE_TemplateVar[i].COL_LanguageID),hIdentical)
         	if not hfound(ProjectVars) then
         		ProjectVars.LanguageID=TABLE_TemplateVar[i].COL_LanguageID
         		ProjectVars.ProjectID=Project.ProjectID
         		ProjectVars.TemplateVarsID=TABLE_TemplateVar[i].COL_TemplateVarID
         		ProjectVars.Text=TABLE_TemplateVar[i].COL_Text
         		hadd(ProjectVars)
         	end
         END
         
         Version.Description="** Automatischer Import **"
         Version.GenerateDateTime=DateSys()+TimeSys()
         Version.ProjectID=Project.ProjectID
         Version.Title="Version: "+Project.LastVersionNo+" Import am "+DateToString(DateSys(),"DD.MM.YYYY")
         Version.VersionNo=Project.LastVersionNo
         HAdd(Version)
         
         HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         IF NOT HFound(Version) THEN
         	Error("Datenbank Version " + Project.LastVersionNo+" nicht gefunden!")
         	Close()
         END
         
         m=TableCount(TABLE_Tables)
         FOR i=1 to m
         	IF TABLE_Tables[i].COL_check THEN
         		IF NOT ImportTable(Version.VersionID, DBConnection.DBConnectionID,Database,TABLE_Tables[i].COL_TableName,i) THEN
         			Close()
         		END
         	END
         END
         
         m=TableCount(TABLE_Tables)
         FOR i=1 to m
         	IF TABLE_Tables[i].COL_check THEN
         		IF NOT ImportForeignKey(Version.VersionID, DBConnection.DBConnectionID,Database,TABLE_Tables[i].COL_TableName) THEN
         			close()
         		END
         	END
         END
         
         UpdateAll()
         
         listDisplay(WIN_Main.COMBO_Project,taCurrentSelection)
         
         AddProjectList(Project.ProjectName)
         
         info(<§$000e§>)
         Message(<§@1fb8c9cd011e86710007§>)
         
         close()
        type : 18
      -
        type : 161
        enabled : false
