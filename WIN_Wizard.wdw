        type : 5
       code_elements :
        internal_properties : BgAAAAYAAAD2Rkbx+OjeaV6cz3eLdX7jB0Jgs6WDDXWz15HdSBZm9oeZQ2BKnjRAOa1wH4EQ9d5x
        type_code : 5
        p_codes :
         -
           code : |1+
            
            local
            	n is int
            	v is int
            	
            v=TableCount(TABLE_Tables)
            FOR i=1 TO v
            	IF TABLE_Tables[i].COL_check THEN
            		n++
            	END
            END
            if n>10 then
            	v=TableCount(TABLE_Tables)
            	FOR i=1 to v
            		IF modulo(i,2)=0 THEN
            			TABLE_Tables[i].COL_check..BrushColor=RGB(229, 177, 170)
            			TABLE_Tables[i].COL_TableName..BrushColor=RGB(229, 177, 170)
            		else
            			TABLE_Tables[i].COL_check..BrushColor=RGB(245, 218, 218)
            			TABLE_Tables[i].COL_TableName..BrushColor=RGB(245, 218, 218)
            		end
            	END
            else
            	v=TableCount(TABLE_Tables)
            	FOR i=1 to v
            		IF modulo(i,2)=0 THEN
            			TABLE_Tables[i].COL_check..BrushColor=White
            			TABLE_Tables[i].COL_TableName..BrushColor=White
            		ELSE
            			TABLE_Tables[i].COL_check..BrushColor=0xF4F4F4
            			TABLE_Tables[i].COL_TableName..BrushColor=0xF4F4F4
            		END
            	END
            END
           type : 17
