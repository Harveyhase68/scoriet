      PROCEDURE WIN_Wizard()
      
      global
      	gsLastAskedDir is string
   -
     code : |1+
      
      BTN_Back..State=Grayed
      MyWindow..Plane=1
      if Nation()=1 then
      	hreadseek(Language,Token,"de",hIdentical)
      	if hfound(Language) then
      		LanguageID=Language.LanguageID
      	END
      else
      	HReadSeek(Language,Token,"en",hIdentical)
      	IF HFound(Language) THEN
      		LanguageID=Language.LanguageID
      	END
      END
      DBConnectionID=0
      EDT_TemplateBasis=CompleteDir(SysDir(srMyDocuments))+"Scoriet\Templates"
      
      for i=1 to 99
      	hreadseek(Project,ProjectName,"Project"+NumToString(i,"d"),hIdentical)
      	if not hfound(Project) then
      		EDT_ProjektName="Project"+NumToString(i,"d")
      		EDT_ProjektName..NoteTitle="Project"+NumToString(i,"d")
      		break
      	END
      END
      EDT_URL="http://localhost/"+Lower(EDT_ProjektName)
      EDT_OutputDir=CompleteDir(gsWampVerzeichnis)+EDT_ProjektName
      
      listadd(Database,<§$0009§>)
      ListSelectPlus(Database,1)
