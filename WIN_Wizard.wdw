  -
    name : BTN_Back
    identifier : 0x25413fc700e0af74
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         if MyWindow..Plane=2 then
         	BTN_Back..State=Grayed
         	BTN_Next..State=Active
         	MyWindow..Plane--
         else if MyWindow..Plane=3 then
         	BTN_Back..State=Active
         	BTN_Next..State=Active
         	MyWindow..Plane--
         ELSE IF MyWindow..Plane=4 THEN
         	BTN_Back..State=Active
         	BTN_Next..State=Active
         	MyWindow..Plane--
         ELSE IF MyWindow..Plane=5 THEN
         	BTN_Back..State=Active
         	BTN_Next..State=Active
         	BTN_Next..Visible=True
         	BTN_Ready..Visible=False
         	BTN_Ready..State=Grayed
         	MyWindow..Plane--
         end
        type : 18
      -
        type : 161
        enabled : false
  -
    name : EDT_ProjektName
    identifier : 0x2540f63954ae3867
    internal_properties : 
    type : 2
    code_elements :
     type_code : 3
     p_codes :
      -
        type : 276
        enabled : false
      -
        type : 277
        enabled : false
      -
        type : 278
        enabled : false
      -
        code : |1-
         
         local
         	sURL is string
         	sOutputDir is string
         
         hreadseek(Project,ProjectName,EDT_ProjektName,hIdentical)
         if hfound(Project) then
         	EDT_ProjektName..BrushColor=lightRed
         	EDT_ProjektName..ToolTip=<§$0003§>
         	BTN_Next..State=Grayed
         else
         	EDT_ProjektName..BrushColor=White
         	EDT_ProjektName..ToolTip=""
         	BTN_Next..State=Active
         	sOutputDir=CompleteDir(gsWampVerzeichnis)+EDT_ProjektName..NoteTitle
         	if EDT_OutputDir=sOutputDir then
         		EDT_OutputDir=CompleteDir(gsWampVerzeichnis)+EDT_ProjektName
         	end
         	sURL="http://localhost/"+Lower(EDT_ProjektName..NoteTitle)
         	if EDT_URL=sURL then
         		EDT_URL="http://localhost/"+Lower(EDT_ProjektName)
         	end
         END
         
         EDT_ProjektName..NoteTitle=EDT_ProjektName
        type : 17
