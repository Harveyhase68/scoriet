#To edit and compare internal_properties, use WINDEV integrated tools.
#Internal properties refer to the properties of controls in windows, reports, etc.
info :
 name : WIN_Wizard
 major_version : 26
 minor_version : 0
 type : 2
 description : ""
 subtype : 0
window :
 name : WIN_Wizard
 identifier : 0x2540f241505fb5ff
 internal_properties : 
 controls :
  -
    name : BTN_Next
    identifier : 0x2540f2c850f2c6c1
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        internal_properties : 
        code : |1+
         
         local
         	nAnzahl is int
         	s is string
         	n is int
         	sFolder is string
         	
         if MyWindow..Plane=1 then
         	HReadSeek(Project,ProjectName,EDT_ProjektName,hIdentical)
         	IF HFound(Project) THEN
         		EDT_ProjektName..BrushColor=LightRed
         		info("Projekt ist bereits vorhanden!")
         		EDT_ProjektName..ToolTip=<§$0003§>
         		BTN_Next..State=Grayed
         		ReturnToCapture(EDT_ProjektName)
         	end
         	if EDT_ProjektName="" then
         		NextTitle("Scoriet - Projektname")
         		info("Bitte geben Sie einen Projektnamen ein!")
         		ReturnToCapture(EDT_ProjektName)
         	END
         	if not fDirectoryExist(EDT_OutputDir) and gsLastAskedDir<>EDT_OutputDir then
         		if YesNo(<§$000d§>)=no THEN
         			return
         		else
         			gsLastAskedDir=EDT_OutputDir
         		END
         	END
         	BTN_Back..State=Active
         	BTN_Next..State=active
         	MyWindow..Plane++
         else if MyWindow..Plane=2 then
         	if Database="" then
         		info(<§$0006§>)
         		ReturnToCapture(Database)
         	END
         	if not RefreshDataList() then
         		return
         	END
         	BTN_Back..State=Active
         	BTN_Next..State=Active
         	MyWindow..Plane++
         ELSE IF MyWindow..Plane=3 THEN
         	for i=1 to TableCount(TABLE_Tables)
         		if TABLE_Tables[i].COL_check=1 then
         			nAnzahl++
         		END
         	END
         	if nAnzahl=0 then
         		info(<§$0007§>)
         		BTN_Next..State=Grayed
         		return
         	END
         	
         	IF fDirectoryExist(EDT_TemplateBasis) THEN
         		
         		TableDeleteAll(TABLE_Template)
         		
         		s=fListDirectory(EDT_TemplateBasis,frNotRecursive)
         		
         		FOR EACH STRING ADirectory OF s SEPARATED BY CR
         			// Add the directory into the TABLE_DirTable
         			TableAdd(TABLE_Template, ADirectory+TAB+True)
         		END
         		
         	END
         	BTN_Back..State=Active
         	BTN_Next..State=Active
         	MyWindow..Plane++
         else if MyWindow..Plane=4 THEN
         
         	TableDeleteAll(TABLE_TemplateVar)
         	FOR i=1 to TableCount(TABLE_Template)
         		IF TABLE_Template[i].COL_check THEN
         			sFolder=Replace(Replace(TABLE_Template[i].COL_TableName,EDT_TemplateBasis,""),"\","")
         			HReadSeek(Template,TemplateFolder,sFolder,hIdentical)
         			IF NOT HFound(Template) THEN
         				TABLE_Template[i].COL_check=false
         				Info(<§$000b§>+sFolder+<§$000c§>)
         				return
         			END
         			
         			HReadFirst(Language,LanguageID)
         			while not hout(Language)
         				hfilter(TemplateVars,TemplateID,template.TemplateID,Template.TemplateID)
         				hreadfirst(TemplateVars,TemplateID)
         				while not hout(TemplateVars)
         					n=TableAddLine(TABLE_TemplateVar)
         					TABLE_TemplateVar[n].COL_TemplateID=template.TemplateID
         					TABLE_TemplateVar[n].COL_TemplateVarID=TemplateVars.TemplateVarsID
         					TABLE_TemplateVar[n].COL_LanguageID=Language.LanguageID
         					TABLE_TemplateVar[n].COL_Text=TemplateVars.DefaultValue
         					HReadnext(TemplateVars,TemplateID)
         				END
         				HReadNext(Language,LanguageID)
         			END
         		END
         	END
         
         	BTN_Back..State=Active
         	BTN_Next..State=Grayed
         	BTN_Ready..State=Active
         	BTN_Ready..Visible=True
         	BTN_Next..Visible=False
         	MyWindow..Plane++
         end
        type : 18
      -
        type : 161
        enabled : false
