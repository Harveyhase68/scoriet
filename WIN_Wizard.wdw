   -
     name : RefreshDBConnection
     procedure_id : 1532469095996958192
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //RefreshDBConnection ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshDBConnection()
      
      local
      	bFound is boolean
      
      IF DBConnectionID=0 THEN
      	FOR i=1 to 6
      		if {"BTN_DB"+NumToString(i,"d"),indControl}..Pushed then
      			bFound=true
      		END
      	END
      	if not bFound then
      		Description..State=Grayed
      		Server..State=Grayed
      		Username..State=Grayed
      		Password..State=Grayed
      		Database..State=Grayed
      		Description=""
      		Server=""
      		Username=""
      		Password=""
      		Database=""
      	else
      		Description..State=Active
      		Server..State=Active
      		Username..State=Active
      		Password..State=Active
      		Database..State=Active
      		Description=""
      		Server=""
      		Username=""
      		Password=""
      		Database=""
      	END
      ELSE
      	HReadSeek(DBConnection,DBConnectionID,DBConnectionID,hIdentical)
      	IF HFound(DBConnection) THEN
      		Description..State=Active
      		Server..State=Active
      		Username..State=Active
      		Password..State=Active
      		Database..State=Active
      		Description=DBConnection.Description
      		Server=DBConnection.Server
      		Username=DBConnection.Username
      		Password=DBConnection.Password
      		FOR i=1 to 2
      			IF NumToString(i,"d")<>Middle(MySelf..Name,7) THEN
      				{"BTN_DB"+NumToString(i,"d"),indControl}..Pushed=False
      			END
      		END
      		IF DBConnection.Type=1 OR DBConnection.Type=2 THEN
      			BTN_DB1..Pushed=True
      		ELSE IF DBConnection.Type=3 THEN
      			BTN_DB2..Pushed=True
      		END
      	END
      END
      
     type : 458752
   -
     name : RefreshDatabaseList
     procedure_id : 1532472974354050388
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] RefreshDatabaseList ( [<bSilent>])
      //
      // Parameters:
      // 	bSilent (default value=0): <specify the role of bSilent>
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshDatabaseList(bSilent=false)
      
      
      LOCAL
      	ctCdn is connection
      	dsDATA is data Source
      	bRes is boolean
      	sSQL is string
      	nType is int
      
      ListDeleteAll(Database)
      	
      FOR i=1 to 2
      	IF {"BTN_DB"+NumToString(i,"d"),indControl}..Pushed THEN
      		nType=i
      		BREAK
      	END
      END
      
      IF nType=0 THEN
      	if not bSilent then
      		Info(<§$0002§>)
      	end
      	result false
      END
      
      SWITCH nType
      	CASE 1,2
      		//MySQL,MariaDB
      		ctCdn..Server=Server
      		ctCdn..User=Username
      		ctCdn..Password=Password
      		ctCdn..Database=""
      		ctCdn..Provider = hNativeAccessMySQL
      		ctCdn..CursorOptions = hClientCursor
      		ctCdn..Access=hOReadWrite
      	CASE 3
      		//PostgreSQL
      		ctCdn..Server=Server
      		ctCdn..User=Username
      		ctCdn..Password=Password
      		ctCdn..Database=""
      		ctCdn..Provider = hOledbSQLServer
      		ctCdn..CursorOptions = hClientCursor
      		ctCdn..Access=hOReadWrite
      END
      
      bRes=HOpenConnection(ctCdn)
      IF NOT bRes THEN
      	Username..BrushColor=iLightRed
      	Password..BrushColor=iLightRed
      	IF NOT bSilent THEN
      		Info(<§$0001§>+crlf+ErrorInfo(errFullDetails)+crlf+HErrorInfo(hErrFullDetails))
      	end
      	result false
      ELSE
      	SWITCH nType
      		// MySQL
      		CASE 1
      			sSQL="show databases;"
      			WHEN EXCEPTION IN
      				HExecuteSQLQuery(dsDATA,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
      				HReadFirst(dsDATA)
      				WHILE NOT HOut(dsDATA)
      					ListAdd(Database,dsDATA.Database)
      					HReadNext(dsDATA)
      				END
      				HCloseConnection(ctCdn)
      			DO
      				Username..BrushColor=iLightRed
      				Password..BrushColor=iLightRed
      				IF NOT bSilent THEN
      					Info(<§$0001§>+crlf+ErrorInfo(errFullDetails)+crlf+HErrorInfo(hErrFullDetails))
      				end
      				REsult false
      			END
      			Username..BrushColor=iWhite
      			Password..BrushColor=iWhite
      		// MS SQL Server
      		CASE 2
      			sSQL="sp_databases;"
      			WHEN EXCEPTION IN
      				HExecuteSQLQuery(dsDATA,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
      				HReadFirst(dsDATA)
      				WHILE NOT HOut(dsDATA)
      					ListAdd(Database,dsDATA.DATABASE_NAME)
      					HReadNext(dsDATA)
      				END
      				HCloseConnection(ctCdn)
      			DO
      				Username..BrushColor=iLightRed
      				Password..BrushColor=iLightRed
      				IF NOT bSilent THEN
      					Info(<§$0001§>+crlf+ErrorInfo(errFullDetails)+crlf+HErrorInfo(hErrFullDetails))
      				end
      				result false
      			END
      			Username..BrushColor=iWhite
      			Password..BrushColor=iWhite
      	END
      END
      
      result true
      
     type : 458752
   -
     name : RefreshDataList
     procedure_id : 1532477514136128834
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] RefreshDataList ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshDataList()
      
      LOCAL
      	sSQL is string
      	dsData is data source
      	bRes is boolean
      	nType is int
      	ctCdn is connection
      	
      FOR i=1 to 2
      	IF {"BTN_DB"+NumToString(i,"d"),indControl}..Pushed THEN
      		nType=i
      		BREAK
      	END
      END
      
      IF nType=0 THEN
      	Info(<§$0002§>)
      	RESULT False
      END
      
      SWITCH nType
      	CASE 1
      		//MySQL
      		ctCdn..Server=Server
      		ctCdn..User=Username
      		ctCdn..Password=Password
      		ctCdn..Database=Database
      		ctCdn..Provider = hNativeAccessMySQL
      		ctCdn..CursorOptions = hClientCursor
      		ctCdn..Access=hOReadWrite
      	CASE 2
      		//MsSQL
      		ctCdn..Server=Server
      		ctCdn..User=Username
      		ctCdn..Password=Password
      		ctCdn..Database=Database
      		ctCdn..Provider = hOledbSQLServer
      		ctCdn..CursorOptions = hClientCursor
      		ctCdn..Access=hOReadWrite
      END
      
      bRes=HOpenConnection(ctCdn)
      IF bRes THEN
      	SWITCH nType
      		CASE 1,2
      			//MySQL,MariaDB
      			sSQL="show full tables from " + Database + ";"
      			HExecuteSQLQuery(dsData,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
      			HReadFirst(dsData)
      			TableDeleteAll(TABLE_Tables)
      			WHILE NOT HOut(dsData)
      				IF {"dsDATA.Table_type"}="BASE TABLE" THEN
      					TableAdd(TABLE_Tables,{"dsDATA.tables_in_"+Database}+TAB+True)
      				END
      				HReadNext(dsData)
      			END
      			HFreeQuery(dsData)
      			HCloseConnection(ctCdn)
      		CASE 3
      			//PostgreSQL
      			sSQL="sp_tables @table_name = '%';"
      			HExecuteSQLQuery(dsData,ctCdn,hQueryWithoutCorrection+hNoBind,sSQL)
      			HReadFirst(dsData)
      			TableDeleteAll(TABLE_Tables)
      			WHILE NOT HOut(dsData)
      				IF dsData.TABLE_OWNER="dbo" THEN
      					TableAdd(TABLE_Tables,dsData.TABLE_NAME+TAB+True)
      				END
      				HReadNext(dsData)
      			END
      			HFreeQuery(dsData)
      			HCloseConnection(ctCdn)
      		OTHER CASE
      	END
      END
      
      result true
     type : 458752
   -
     name : CheckAllButtons
     procedure_id : 1560552285198901151
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //CheckAllButtons ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE CheckAllButtons()
      
      LOCAL
      	bFound is boolean
      	
      FOR i=1 to 6
      	IF NumToString(i,"d")<>Middle(MySelf..Name,7) THEN
      		{"BTN_DB"+NumToString(i,"d"),indControl}..Pushed=False
      	ELSE
      		IF {"BTN_DB"+NumToString(i,"d"),indControl}..Pushed THEN
      			bFound=True
      		END
      	END
      	IF bFound THEN
      		Description..State=Active
      		Server..State=Active
      		Username..State=Active
      		Password..State=Active
      		Database..State=Active
      	ELSE
      		Description..State=Grayed
      		Server..State=Grayed
      		Username..State=Grayed
      		Password..State=Grayed
      		Database..State=Grayed
      	END
      END
     type : 458752
