  -
    name : BTN_NewLine
    identifier : 0x233fe19b32457b72
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         // Open the form of Language file in 'Creation' mode
         nAliasName is string = "New_Language"
         nWindowTitle is string = "New record: Language"
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_Language",nAliasName,nWindowTitle ,"Creation")
         END	
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Modify
    identifier : 0x233fe19b32477b72
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         	
         IF TableSelect(TABLE)=-1 THEN RETURN
         
         // The input/selection row cannot be deleted
         IF TableSelect(TABLE)>TableCount(TABLE) THEN 
         	Info("The selected row is used for direct input in the table","This row cannot be modified")
         	RETURN
         END
         
         // refresh the table before modification
         // in case modifications were made on another computer
         TableDisplay(TABLE,taCurrentSelection)
         
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         // open the form of Language file in 'Modif' mode
         nAliasName is string = "Modification_Language_"+Language.LanguageID
         nWindowTitle is string = "Modification of Language file: "+Language.LanguageID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	MDIOpen("WIN_Form_Language",nAliasName ,nWindowTitle , "Modif")
         END
         
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_DeleteLine
    identifier : 0x233fe19b32497b82
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // no action if no record is selected in the table
         IF TableSelect(TABLE)=-1 THEN RETURN
         
         // The input/selection row cannot be deleted
         IF TableSelect(TABLE)>TableCount(TABLE) THEN 
         	Info("The selected row is used for direct input in the table","This row cannot be deleted")
         	RETURN
         END
         	
         // Stop the automatic window refresh
         SuspendRefresh(True)									
         
         // if the deletion is confirmed, delete the table row and
         // the matching record from Language file
         IF YesNo("Do you want to delete the row?") THEN 
         	// Delete the record from the table
         	TableDelete(TABLE)
         	
         	// Check integrity
         	IF HErrorIntegrity() THEN
         		Error("The selected row has not been deleted: ",HErrorInfo())		
         	END
         END
         
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Close
    identifier : 0x233fe19b324d7b82
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         // close the window (no action)
         Close()
         	
         	
        type : 18
      -
        type : 161
        enabled : false
