  procedures :
   -
     name : RefreshDBList
     procedure_id : 2282792022817686710
     type_code : 14
     code : |1-
      // Summary: <specify the procedure action>
      // Syntax:
      //[ <Result> = ] RefreshDBList ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	boolean: // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshDBList()
      
      LOCAL
      	n is int
      	bRes is boolean
      	dsData is data source
      	
      IF ListSelect(Combo_DBConnection)>0 THEN
      	
      	LOCAL
      		sSQL is string
      		
      	ListDeleteAll(COMBO_Databases)
      	
      	HReadSeek(DBConnection,DBConnectionID,Combo_DBConnection)
      	
      	SWITCH DBConnection.Type
      		CASE 1,2
      			//MySQL,MariaDB
      			clConnect..Server=DBConnection.Server
      			clConnect..User=DBConnection.Username
      			clConnect..Password=DBConnection.Password
      			clConnect..Database=""
      			clConnect..Provider = hNativeAccessMySQL
      			clConnect..CursorOptions = hClientCursor
      			clConnect..Access=hOReadWrite
      		CASE 3
      			//PostgreSQL
      			clConnect..Server=DBConnection.Server
      			clConnect..User=DBConnection.Username
      			clConnect..Password=DBConnection.Password
      			clConnect..Database=""
      			clConnect..Provider = hOledbSQLServer
      			clConnect..CursorOptions = hClientCursor
      			clConnect..Access=hOReadWrite
      		other case
      			error("Datenbank Verbindung: "+DBConnection.Type+" ist noch nicht aktiv!")
      			result false
      	END
      	
      	bRes=HOpenConnection(clConnect)
      	IF bRes THEN
      		SWITCH DBConnection.Type
      			CASE 1,2
      				//MySQL,MariaDB
      				sSQL="show databases;"
      				IF HExecuteSQLQuery(dsData,clConnect,hQueryWithoutCorrection+hNoBind,sSQL) THEN
      					//if Connector.cnExecute(sSQL) then
      					HReadFirst(dsData)
      					ListDeleteAll(COMBO_Databases)
      					WHILE NOT HOut(dsData)
      						ListAdd(COMBO_Databases,dsData.Database)
      						HReadNext(dsData)
      					END
      					HFreeQuery(dsData)
      					
      					Combo_DBConnection..BrushColor=iWhite
      					
      					HReadSeek(Project,ProjectID,gnProjectID)
      					n=ListCount(COMBO_Databases)
      					FOR i=1 to n
      						IF Lower(COMBO_Databases[i]..DisplayedValue)=Lower(NoSpace(Project.Database)) THEN
      							ListSelectPlus(COMBO_Databases,i)
      							BREAK
      						END
      					END
      					
      					RESULT True
      				ELSE
      					Info(HErrorInfo(hErrFullDetails))
      					RESULT False
      				END
      			CASE 3
      				//PostgreSQL
      				sSQL="sp_databases;"
      				IF HExecuteSQLQuery(dsData,clConnect,hQueryWithoutCorrection+hNoBind,sSQL) THEN
      					//if Connector.cnExecute(sSQL) then
      					HReadFirst(dsData)
      					ListDeleteAll(COMBO_Databases)
      					WHILE NOT HOut(dsData)
      						ListAdd(COMBO_Databases,dsData.DATABASE_NAME)
      						HReadNext(dsData)
      					END
      					HFreeQuery(dsData)
      					
      					Combo_DBConnection..BrushColor=iWhite
      					
      					HReadSeek(Project,ProjectID,gnProjectID)
      					n=ListCount(COMBO_Databases)
      					FOR i=1 to n
      						IF Lower(COMBO_Databases[i]..DisplayedValue)=Lower(NoSpace(Project.Database)) THEN
      							ListSelectPlus(COMBO_Databases,i)
      							BREAK
      						END
      					END
      					
      					RESULT True
      				ELSE
      					Info(HErrorInfo(hErrFullDetails))
      					RESULT False
      				END
      			OTHER CASE
      		END
      	ELSE
      		Info(HErrorInfo(hErrFullDetails))
      		Combo_DBConnection..BrushColor=iLightRed
      		RESULT False
      	END
      ELSE
      	RESULT False
      END
      
      RESULT False
     type : 458752
   -
     name : RefreshDataList
     procedure_id : 2285776398045499412
     type_code : 14
     code : |1+
      // Summary: <specify the procedure action>
      // Syntax:
      //RefreshDataList ()
      //
      // Parameters:
      //	None
      // Return Value:
      // 	None
      //
      // For instance:
      // Indicate an example.
      //
      PROCEDURE RefreshDataList()
      
      LOCAL
      	sSQL is string
      	dsData is data source
      	bRes is boolean
      	
      IF ListSelect(Combo_DBConnection)>0 AND ListSelect(COMBO_Databases)>0 THEN		
      	HReadSeek(DBConnection,DBConnectionID,Combo_DBConnection)
      	SWITCH DBConnection.Type
      		CASE 1,2
      			//MySQL,MariaDB
      			clConnect..Server=DBConnection.Server
      			clConnect..User=DBConnection.Username
      			clConnect..Password=DBConnection.Password
      			clConnect..Database=""
      			clConnect..Provider = hNativeAccessMySQL
      			clConnect..CursorOptions = hClientCursor
      			clConnect..Access=hOReadWrite
      		CASE 3
      			//PostgreSQL
      			clConnect..Server=DBConnection.Server
      			clConnect..User=DBConnection.Username
      			clConnect..Password=DBConnection.Password
      			clConnect..Database=COMBO_Databases..DisplayedValue
      			clConnect..Provider = hOledbSQLServer
      			clConnect..CursorOptions = hClientCursor
      			clConnect..Access=hOReadWrite
      	END
      	
      	bRes=HOpenConnection(clConnect)
      	IF bRes THEN
      		
      		SWITCH DBConnection.Type
      			CASE 1,2
      				//MySQL,MariaDB
      				sSQL="USE `" + COMBO_Databases..DisplayedValue + "`; SHOW FULL TABLES FROM `" + COMBO_Databases..DisplayedValue + "`;"
      				HExecuteSQLQuery(dsData,clConnect,hQueryWithoutCorrection,sSQL)
      				HReadFirst(dsData)
      				TableDeleteAll(TABLE_Tables)
      				WHILE NOT HOut(dsData)
      					IF {"dsDATA.Table_type"}="BASE TABLE" THEN
      						TableAdd(TABLE_Tables,{"dsDATA.tables_in_"+COMBO_Databases..DisplayedValue}+TAB+True)
      					END
      					HReadNext(dsData)
      				END
      				HCloseConnection(clConnect)
      				HFreeQuery(dsData)
      			CASE 3
      				//PostgreSQL
      				sSQL="sp_tables @table_name = '%';"
      				HExecuteSQLQuery(dsData,clConnect,hQueryWithoutCorrection+hNoBind,sSQL)
      				HReadFirst(dsData)
      				TableDeleteAll(TABLE_Tables)
      				WHILE NOT HOut(dsData)
      					IF dsData.TABLE_OWNER="dbo" THEN
      						TableAdd(TABLE_Tables,dsData.TABLE_NAME+TAB+True)
      					END
      					HReadNext(dsData)
      				END
      				HCloseConnection(clConnect)
      				HFreeQuery(dsData)
      			OTHER CASE
      		END
      	END
      END
     type : 458752
