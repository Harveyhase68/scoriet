  -
    name : BTN_CheckAllNone
    identifier : 0x2fb8b4ec181bf4db
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         local
         	n is int
         	
         if BTN_CheckAllNone..Pushed then
         	BTN_CheckAllNone..Caption=<§$0001§>
         	n=TableCount(TABLE_Tables)
         	for i=1 to n
         		TABLE_Tables[i].COL_check=true
         	END
         else
         	BTN_CheckAllNone..Caption=<§$0002§>
         	n=TableCount(TABLE_Tables)
         	FOR i=1 to n
         		TABLE_Tables[i].COL_check=false
         	END
         END
        type : 18
