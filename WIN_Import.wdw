  -
    name : BTN_Vision_DBConnectionID
    identifier : 0x2fae19cc16c7161f
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         
         // Open the Vision+ window
         IF Open(WIN_Vision_DBConnection,(Combo_DBConnection)) THEN
         	// Refresh the combo box
         	ListDisplay(Combo_DBConnection,taCurrentFirst)
         	// Select the correct value in the combo box
         
         	Combo_DBConnection=DBConnection.DBConnectionID
         	
         	RefreshDBList()
         	RefreshDataList()
         	
         	// The window was modified
         	MyWindow..Modified = True
         END
