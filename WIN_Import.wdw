  -
    name : BTN_Import
    identifier : 0x2fae19711abbb28d
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        internal_properties : 
        code : |1-
         
         local
         	nOldVersionId is int on 8 bytes
         	zz is int
         	stDataFileTranslation is structure
         		nTemplatePageID is int
         		nLanguageID is int
         		sDescription is int
         	end
         	stDataItemsTranslation is structure
         		nDataItemsID is int
         		nTemplatePageID is int
         		nLanguageID is int
         		sCaption is string
         		sComboBoxContent is string
         	end
         	stDataItemsTypeDetails is structure
         		nTemplateID is int
         		sEditMask is string
         		bGenerate is boolean
         		bVisible is boolean
         		nSortIndex is int
         		nItemState is int
         		x is int
         		y is int
         	end
         	stDataItems is structure
         		sItemName is string
         		arrDataItemsTypeDetails is dynamic array of 0 stDataItemsTypeDetails
         		arrDataItemsTranslation is dynamic array of 0 stDataItemsTranslation
         	end
         	stDataFile is structure
         		sTableName is string
         		sPrimaryKey is string
         		nSort is int
         		bGenerate is boolean
         		bGenerateMasterDetail is boolean
         		nDetail is int
         		sDetailKey is string
         		sSearchKeys is string
         		arrDataFileTranslation is dynamic array of 0 stDataFileTranslation
         		arrDataItems is dynamic array of 0 stdataitems
         	end
         	arrDataFile is dynamic array of 0 stdatafile
         	f is int
         	i is int
         	t is int
         	r is int
         	
         HDeactivateFilter(Project)
         HReadSeek(Project,ProjectID,gnProjectID)
         IF NOT HFound(Project) THEN
         	Error("Projekt nicht gefunden!")
         	return
         END
         
         //ProjectID+VersionNo conversion
         HReadSeek(Version,VersionKeyNo,[Project.ProjectID,Project.LastVersionNo],hIdentical)
         
         //Store all user settings in memory
         hfilter(DataFile, VersionID, Version.VersionID, Version.VersionID)
         HReadFirst(DataFile,VersionID)
         while not hout(DataFile)
         	f=ArrayAddLine(arrDataFile)
         	arrDataFile[f].sTableName=DataFile.FileName
         	arrDataFile[f].sPrimaryKey=DataFile.KeyName
         	arrDataFile[f].bGenerate=DataFile.DataFileGenerate
         	arrDataFile[f].bGenerateMasterDetail=DataFile.GenerateMasterDetail
         	arrDataFile[f].nDetail=DataFile.DetailFileID
         	arrDataFile[f].sDetailKey=DataFile.DetailKeyName
         	arrDataFile[f].nSort=DataFile.DataFileSort
         	arrDataFile[f].sSearchKeys=DataFile.AdditionalSearchFields
         	
         	hfilter(DataFileTranslation,DataFileID,DataFile.DetailFileID,DataFile.DetailFileID)
         	HReadFirst(DataFileTranslation,DataFileID)
         	while not hout(DataFileTranslation)
         		i=ArrayAddLine(arrDataFile[f].arrDataFileTranslation)
         		arrDataFile[f].arrDataFileTranslation[i].nTemplatePageID=DataFileTranslation.TemplatePageID
         		arrDataFile[f].arrDataFileTranslation[i].nLanguageID=DataFileTranslation.LanguageID
         		arrDataFile[f].arrDataFileTranslation[i].sDescription=DataFileTranslation.Description
         		hreadnext(DataFileTranslation,DataFileID)
         	END
         	
         	//DataFileID+DataItemsID
         	hfilter(DataItems,DataItemsKey,[DataFile.DataFileID,hMinVal],[DataFile.DataFileID,hMaxVal])
         	HReadFirst(DataItems,DataItemsKey)
         	while not hout(DataItems)
         		i=ArrayAddLine(arrDataFile[f].arrDataItems)
         		arrDataFile[f].arrDataItems[i].sItemName=DataItems.ItemName
         
         		hfilter(DataItemsTypeDetails,DataItemsID,DataItems.DataItemsID,DataItems.DataItemsID)
         		HReadFirst(DataItemsTypeDetails,DataItemsID)
         		while not hout(DataItemsTypeDetails)
         
         			t = ArrayAddLine(arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails)
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].nTemplateID	= DataItemsTypeDetails.TemplatePageID
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].bGenerate		= DataItemsTypeDetails.ItemGenerate
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].bVisible		= DataItemsTypeDetails.ItemVisible
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].sEditMask		= DataItemsTypeDetails.EditMask
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].nSortIndex	= DataItemsTypeDetails.SortIndex
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].X				= DataItemsTypeDetails.X
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].Y				= DataItemsTypeDetails.Y
         			arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].nItemState	= DataItemsTypeDetails.ItemState
         
         			hreadnext(DataItemsTypeDetails,DataItemsID)
         		END
         		HReadNext(DataItems,DataItemsKey)
         		
         		//DataItemsID+TemplatePageID+LanguageID
         		hfilter(DataItemsTranslation,DataItemsTranslationKey,[DataItems.DataItemsID,hMinVal,hMinVal],[DataItems.DataItemsID,hMaxVal,hMaxVal])
         		HReadFirst(DataItemsTranslation,DataItemsTranslationKey)
         		while not hout(DataItemsTranslation)
         			r = arrayAddLine(arrDataFile[f].arrDataItems[i].arrDataItemsTranslation)
         			arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[r].nDataItemsID		= DataItemsTranslation.DataItemsID
         			arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[r].nTemplatePageID	= DataItemsTranslation.TemplatePageID
         			arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[r].nLanguageID		= DataItemsTranslation.LanguageID
         			arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[r].sCaption			= DataItemsTranslation.Caption
         			arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[r].sComboBoxContent	= DataItemsTranslation.ComboBoxContent
         			hreadnext(DataItemsTranslation,DataItemsTranslationKey)
         		end		
         	END
         	hreadnext(DataFile,VersionID)
         END
         
         //Release filter
         HDeactivateFilter(DataFile)
         HDeactivateFilter(DataItems)
         HDeactivateFilter(DataItemsTypeDetails)
         HDeactivateFilter(DataFileTranslation)
         
         IF Project.LastVersionNo>0 THEN
         	HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         	IF NOT HFound(Version) THEN
         		Error("Datenbank Version " + Project.LastVersionNo+" nicht gefunden!")
         		return
         	ELSE
         		nOldVersionId=Version.VersionID
         	END
         END
         
         Project.LastVersionNo++
         HModify(Project)
         
         HReadSeek(Project,ProjectID,gnProjectID)
         
         Version.Description="** Automatischer Import **"
         Version.GenerateDateTime=DateSys()+TimeSys()
         Version.ProjectID=Project.ProjectID
         Version.Title="Version: "+Project.LastVersionNo+" Import am "+DateToString(DateSys(),"DD.MM.YYYY")
         Version.VersionNo=Project.LastVersionNo
         HAdd(Version)
         
         HReadSeek(Version,VersionKeyNo,HBuildKeyValue(Version,VersionKeyNo,Project.ProjectID,Project.LastVersionNo),hIdentical)
         IF NOT HFound(Version) THEN
         	Error("Datenbank Version " + Project.LastVersionNo+" nicht gefunden!")
         	return
         END
         
         //Delete all Data with new version (for safty)
         HFilter(DataFile,DataFileSortKey,HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMinVal),HBuildKeyValue(DataFile,DataFileSortKey,Version.VersionID,hMaxVal))
         HReadFirst(DataFile,DataFileSortKey)
         WHILE NOT HOut(DataFile)
         	
         	//Delete all information in all datafiles about the project
         	HFilter(DataKeys,DataFileID,DataFile.DataFileID,DataFile.DataFileID)
         	HReadFirst(DataKeys,DataFileID)
         	WHILE NOT HOut(DataKeys)
         		HDelete(DataKeys)
         		HReadNext(DataKeys,DataFileID)
         	END
         	HDeactivateFilter(DataKeys)
         	
         	HFilter(DataFileTranslation,DataFileID,DataFile.DataFileID,DataFile.DataFileID)
         	HReadFirst(DataFileTranslation,DataFileID)
         	WHILE NOT HOut(DataFileTranslation)
         		HDelete(DataFileTranslation)
         		HReadNext(DataFileTranslation,DataFileID)
         	END
         	HDeactivateFilter(DataFileTranslation)
         	
         	HFilter(DataItems,DataFileID,DataFile.DataFileID,DataFile.DataFileID)
         	HReadFirst(DataItems,DataFileID)
         	WHILE NOT HOut(DataItems)
         		
         		HFilter(ForeignKey,DataItemsID,DataItems.DataItemsID,DataItems.DataItemsID)
         		HReadFirst(ForeignKey,DataItemsID)
         		WHILE NOT HOut(ForeignKey)
         			HDelete(ForeignKey)
         			HReadNext(ForeignKey,DataItemsID)
         		END
         		HDeactivateFilter(ForeignKey)
         		
         		HFilter(DataItemsTypeDetails,DataItemsID,DataItems.DataItemsID,DataItems.DataItemsID)
         		HReadFirst(DataItemsTypeDetails,DataItemsID)
         		WHILE NOT HOut(DataItemsTypeDetails)
         			HReadNext(DataItemsTypeDetails,DataItemsID)
         		END
         		HDeactivateFilter(DataItemsTypeDetails)
         		
         		HFilter(DataItemsTranslation,DataItemsID,DataFile.DataFileID,DataFile.DataFileID)
         		HReadFirst(DataItemsTranslation,DataItemsID)
         		WHILE NOT HOut(DataItemsTranslation)
         			HDelete(DataItemsTranslation)
         			HReadNext(DataItemsTranslation,DataItemsID)
         		END
         		HDeactivateFilter(DataItemsTranslation)
         		
         		HDelete(DataItems)
         		HReadNext(DataItems,DataFileID)
         	END
         	HDeactivateFilter(DataItems)
         	
         	HDelete(DataFile)
         	
         	HReadNext(DataFile,DataFileSortKey)
         END
         HDeactivateFilter(DataFile)
         
         for i=1 to TableCount(TABLE_Tables)
         	if TABLE_Tables[i].COL_check then
         		if not ImportTable(version.VersionID, Combo_DBConnection,COMBO_Databases[ListSelect(COMBO_Databases)],TABLE_Tables[i].COL_TableName,i, Project.FileNameShortLength) then
         			return
         		END
         		zz++
         	END
         END
         
         FOR i=1 to TableCount(TABLE_Tables)
         	IF TABLE_Tables[i].COL_check THEN
         		IF NOT ImportForeignKey(Version.VersionID, Combo_DBConnection,COMBO_Databases[ListSelect(COMBO_Databases)],TABLE_Tables[i].COL_TableName) THEN
         			RETURN
         		END
         	END
         END
         
         //ProjectID+VersionNo conversion
         HReadSeek(Version,VersionKeyNo,[Project.ProjectID,Project.LastVersionNo],hIdentical)
         
         //Restore all user settings...
         HFilter(DataFile, VersionID, Version.VersionID, Version.VersionID)
         HReadFirst(DataFile,VersionID)
         WHILE NOT HOut(DataFile)
         
         	f = ArraySeek(arrDataFile,asLinear,"sTableName",DataFile.FileName)
         	if f<>-1 then
         	
         		if arrDataFile[f].sPrimaryKey<>"" then
         			DataFile.KeyName=arrDataFile[f].sPrimaryKey
         		end
         		DataFile.DataFileSort=arrDataFile[f].nSort
         		DataFile.DataFileGenerate=arrDataFile[f].bGenerate
         		DataFile.GenerateMasterDetail=arrDataFile[f].bGenerateMasterDetail
         		DataFile.DetailFileID=arrDataFile[f].nDetail
         		DataFile.DetailKeyName=arrDataFile[f].sDetailKey
         		DataFile.AdditionalSearchFields=arrDataFile[f].sSearchKeys
         		HModify(DataFile)
         		
         		for i=1 to Dimension(arrDataFile[f].arrDataFileTranslation)
         			//DataFileID+TemplatePageID+LanguageID
         			HReadSeek(DataFileTranslation,DataFileTranslationKey,[DataFile.DataFileID,arrDataFile[f].arrDataFileTranslation[i].nTemplatePageID,arrDataFile[f].arrDataFileTranslation[i].nLanguageID],hIdentical)
         			if HFound(DataFileTranslation) THEN
         				DataFileTranslation.Description=arrDataFile[f].arrDataFileTranslation[i].sDescription
         				HModify(DataFileTranslation)
         			END
         		END
         		
         		for i=1 to Dimension(arrDataFile[f].arrDataItems)
         			
         			//DataFileID+ItemName, we seek for the name, if it not exist, so we don't need to copy
         			hreadseek(DataItems,DataItemsNameKey,[DataFile.DataFileID,arrDataFile[f].arrDataItems[i].sItemName],hIdentical)
         			
         			if hfound(DataItems) THEN
         				//In items are no user settings...
         				
         				//But in templates type details
         				FOR t=1 TO Dimension(arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails)
         					//TemplatePageID, DataItemsID, we are on the right file, so we can take DataItemsID
         					HReadSeek(DataItemsTypeDetails,DataItemsTypeDetailTemplateKey,[arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].nTemplateID,DataItems.DataItemsID],hIdentical)
         					if hfound(DataItemsTypeDetails) THEN
         						DataItemsTypeDetails.EditMask=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].sEditMask	
         						DataItemsTypeDetails.ItemGenerate=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].bGenerate	
         						DataItemsTypeDetails.ItemVisible=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].bVisible	
         						DataItemsTypeDetails.SortIndex=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].nSortIndex 
         						DataItemsTypeDetails.ItemState=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].nItemState 
         						DataItemsTypeDetails.x=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].x
         						DataItemsTypeDetails.y=arrDataFile[f].arrDataItems[i].arrDataItemsTypeDetails[t].y
         						HModify(DataItemsTypeDetails)
         					END
         				END
         				
         				FOR t=1 TO Dimension(arrDataFile[f].arrDataItems[i].arrDataItemsTranslation)
         					//DataItemsID+TemplatePageID+LanguageID
         					HReadSeek(DataFileTranslation,DataFileTranslationKey,[DataItems.DataItemsID,arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].nTemplatePageID,arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].nLanguageID],hIdentical)
         					if hfound(DataFileTranslation) then
         						DataItemsTranslation.DataItemsID = arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].nDataItemsID	
         						DataItemsTranslation.TemplatePageID = arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].nTemplatePageID
         						DataItemsTranslation.LanguageID = arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].nLanguageID	
         						DataItemsTranslation.Caption = arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].sCaption		
         						DataItemsTranslation.ComboBoxContent = arrDataFile[f].arrDataItems[i].arrDataItemsTranslation[t].sComboBoxContent
         						HModify(DataFileTranslation)
         					END
         				END
         				
         			END
         		END
         		
         	end
         	HReadNext(DataFile,VersionID)
         END
         HDeactivateFilter(DataFile)
         
         Info("Fertig! Anzahl: "+zz)
        type : 18
      -
        type : 161
        enabled : false
