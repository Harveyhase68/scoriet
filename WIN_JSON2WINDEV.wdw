window :
 name : WIN_JSON2WINDEV
 identifier : 0x2f818529020e24b7
 internal_properties : 
 controls :
  -
    name : SPLIT_NoName1
    identifier : 0x2f818529020f24b7
    internal_properties : 
    type : 28
    code_elements :
     type_code : 61
     p_codes : []
  -
    name : EDT_JSON
    identifier : 0x2f818529021024b7
    internal_properties : 
    type : 2
    code_elements :
     type_code : 3
     p_codes :
      -
        type : 276
        enabled : false
      -
        type : 277
        enabled : false
      -
        type : 278
        enabled : false
      -
        code : |1+
         
         local
         	vContent is variant
         	sResult is string
         	arrEmpty is dynamic array of 0 stArrIdent
         	n is int
         	
         WHEN EXCEPTION in
         	vContent=JSONToVariant(EDT_JSON)
         do
         	EDT_PHP="//error"
         	return
         END
         
         sResult="data is Variant"+crlf
         sResult+=MakePHPAssociative(vContent, arrEmpty)	
         
         EDT_PHP=sResult
         
         INTERNAL PROCEDURE MakePHPAssociative(LOCAL vData, arrIdent is array of stArrIdent)
         	
         	sOutput is string
         	
         	if vData..Count>0 then
         		for i=1 to vData..occurrence
         			n					= ArrayAddLine(arrIdent)
         			arrIdent[n].sName	= "["+NumToString(i,"d")+"]"
         			arrIdent[n].bNoDot	= True
         			sOutput+=MakePHPAssociative(vData[i], arrIdent)
         			ArrayDelete(arrIdent,Dimension(arrIdent))
         		end
         	else
         		sOutput+=MakePHPAssociativeArray(vData, arrEmpty)
         	END
         	
         	result sOutput
         	
         END
         
         internal procedure MakePHPAssociativeArray(LOCAL vData is variantMember, arrIdent is array of stArrIdent)
         
         private
         	sBuffer is string
         	vSub is variantmember
         	zz is int
         	
         	zz=0
         	for EACH vSub OF vData..Member
         		zz++
         		//if vSub..Name="TransactionId" then stop
         		switch vSub..Type
         			case wlVariantArray //142
         				//array
         				n=ArrayAddLine(arrIdent)
         				arrIdent[n].sName=""""+vSub..Name+""""
         				FOR i=1 TO vSub..Occurrence
         					n=ArrayAddLine(arrIdent)
         					arrIdent[n].sName="["+NumToString(i,"d")+"]"
         					arrIdent[n].bNoDot=true
         					sBuffer+=MakePHPAssociativeArray(vSub[i], arrIdent)
         					ArrayDelete(arrIdent,Dimension(arrIdent))
         				END
         				ArrayDelete(arrIdent,Dimension(arrIdent))
         			case wlVariantObject //143
         				//Object
         				n					= ArrayAddLine(arrIdent)
         				arrIdent[n].sName	= """"+vSub..Name+""""
         				sBuffer+=MakePHPAssociativeArray(vSub, arrIdent)
         				ArrayDelete(arrIdent,Dimension(arrIdent))
         			case wlBoolean //Boolean
         				//Simple type
         				sBuffer+="data"
         				FOR i=1 TO Dimension(arrIdent)
         					IF arrIdent[i].bNoDot THEN
         						sBuffer+=arrIdent[i].sName
         					ELSE
         						sBuffer+="."+arrIdent[i].sName
         					END
         				END
         				if vSub..Value then
         					sBuffer+="."+""""+vSub..Name+""""+"=true"+CRLF
         				else
         					sBuffer+="."+""""+vSub..Name+""""+"=false"+CRLF
         				end
         			case wlInt,wlInt_1,wlInt_2,wlInt_4,wlInt_8,wlReal,wlCurrency,wlNumeric //Integer
         				//Simple type
         				sBuffer+="data"
         				FOR i=1 TO Dimension(arrIdent)
         					if arrIdent[i].bNoDot THEN
         						sBuffer+=arrIdent[i].sName
         					else
         						sBuffer+="."+arrIdent[i].sName
         					END
         				END
         				sBuffer+="."+""""+vSub..Name+""""+"="+vSub..Value+CRLF
         			case 16,19,wlCharacter,wlDate,wlDateTime,wlTime,wlSQLQuery,wlUUID,wlUUID_128,wlUUID_256 //String = wlString but be careful!!
         				//Simple type
         				sBuffer+="data"
         				FOR i=1 TO Dimension(arrIdent)
         					IF arrIdent[i].bNoDot THEN
         						sBuffer+=arrIdent[i].sName
         					ELSE
         						sBuffer+="."+arrIdent[i].sName
         					END
         				END
         				sBuffer+="."+""""+vSub..Name+""""+"="""+vSub..Value+""""+CRLF
         			case wlEmpty
         				sBuffer+="data"
         				FOR i=1 TO Dimension(arrIdent)
         					IF arrIdent[i].bNoDot THEN
         						sBuffer+=arrIdent[i].sName
         					ELSE
         						sBuffer+="."+arrIdent[i].sName
         					END
         				END
         				sBuffer+="."+""""+vSub..Name+""""+"=NULL"+CRLF
         			OTHER CASE
         				info("ERROR SUB TYPE " + vSub..Type)
         		end
         	end
         	
         	result sBuffer
         end
        type : 17
