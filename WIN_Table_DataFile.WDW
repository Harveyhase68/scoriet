  -
    name : BTN_TableLink_WIN_Table_DataItems
    identifier : 0x200159e2d2f417c2
    internal_properties : 
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1-
         
         // Stop the automatic window refresh
         SuspendRefresh(True)
         // open the window "WIN_Table_DataItems"
         nAliasName is string = "Link_DataFileID_"+DataFile.DataFileID
         nWindowTitle is string = "File Link {NOQUOTE_RAD_LINKKEY_SOURCE}: "+DataFile.DataFileID
         IF WinStatus(nAliasName)<>NotFound THEN
         	WinStatus(nAliasName,TopActive)
         ELSE
         	IF TableSelect(TABLE)>=1 THEN	
         		MDIOpen(WIN_Table_DataItems ,nAliasName,nWindowTitle,"DataFileID="+DataFile.DataFileID)
         	END
         END
         // Restart the automatic window refresh
         SuspendRefresh(False)
        type : 18
      -
        type : 161
        enabled : false
